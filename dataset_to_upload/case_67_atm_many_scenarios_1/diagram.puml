@startuml
title ATM Cash Withdrawal Scenario

[*] --> Idle

state Idle
state "Waiting for PIN" as WaitingForPIN
state "Validating PIN" as ValidatingPIN
state "Waiting for Customer Choice" as WaitingForChoice
state "Processing Withdrawal" as ProcessingWithdrawal
state Dispensing
state Printing
state Ejecting
state Terminating

Idle --> WaitingForPIN : Card Inserted
WaitingForPIN --> ValidatingPIN : PIN Entered
ValidatingPIN --> WaitingForChoice : Valid PIN
WaitingForChoice --> ProcessingWithdrawal : Withdrawal Selected
ProcessingWithdrawal --> Dispensing : Withdrawal Approved
Dispensing --> Printing : Cash Dispensed
Printing --> Ejecting : Receipt Printed
Ejecting --> Terminating : Card Ejected
Terminating --> Idle : After (Elapsed Time)

@enduml