@startuml
title UML state machine diagram

state "Authentication Login" as Auth
Auth : entry/User opens the application
Auth : do/User enters username and password
Auth : exit/Login Successful
Auth : exit/Application close

state "Final State" as FinalState
FinalState : entry/User clicks on close application
FinalState : do/Close all current sessions
FinalState : exit/End application

state "Dashboard" as Dashboard {

  state "Add Goods" as AddGoods
  AddGoods : entry/User adds goods
  AddGoods : do/Add goods details to database
  AddGoods : exit/User successfully adds

  state "Expired Goods" as ExpiredGoods
  ExpiredGoods : entry/User does on expired goods
  ExpiredGoods : do/Displays expired goods from database
  ExpiredGoods : exit/Item removed from database

  state "Edit Goods" as EditGoods
  EditGoods : entry/User edits goods
  EditGoods : do/Update goods in database
  EditGoods : exit/Successfully updated

  state "Search Item" as SearchItem
  SearchItem : entry/User searches item
  SearchItem : do/Retrieve item from database
  SearchItem : exit/Item successfully retrieved

  state "Place Order" as PlaceOrder
  PlaceOrder : entry/User places order
  PlaceOrder : do/Enter order details
  PlaceOrder : exit/Order placed to supplier

  state "Customer Request" as CustomerRequest
  CustomerRequest : entry/User handles request
  CustomerRequest : do/Obtain input from customer
  CustomerRequest : exit/Request sent to supplier

  state "Remove Goods" as RemoveGoods
  RemoveGoods : entry/User removes goods
  RemoveGoods : do/Delete goods from database
  RemoveGoods : exit/Successfully removed

  state "Receipt Generation" as Receipt
  Receipt : entry/User generates receipt
  Receipt : do/Create receipt
  Receipt : exit/Receipt added to database

  state "Invoice Generation" as Invoice
  Invoice : entry/User places order
  Invoice : do/Generate bill and add to database
  Invoice : exit/Bill added

  state "View Summary Report" as Report
  Report : entry/User views report
  Report : do/Generate monthly comparison
  Report : exit/Report generated

  state "Tax Generation" as Tax
  Tax : entry/User generates tax
  Tax : do/Calculate tax
  Tax : exit/Tax added to receipt

  state "Replace Item" as Replace
  Replace : entry/User replaces item
  Replace : do/Edit receipt contents
  Replace : exit/Item replaced

  state "Cancel Receipt" as Cancel
  Cancel : entry/User cancels receipt
  Cancel : do/Remove from database
  Cancel : exit/Receipt removed

  SearchItem --> PlaceOrder
  PlaceOrder --> Invoice
  Invoice --> Receipt

  Receipt --> Tax
  Receipt --> Replace
  Receipt --> Cancel

  ExpiredGoods --> RemoveGoods
  Invoice --> Report

}

[*] --> Auth
Auth --> Dashboard : login successful
Auth --> FinalState : application close

Dashboard --> FinalState

@enduml