@startuml
title UML State Machine Diagram (Search Users)

state "Search users" as SearchUsers {

    [*] --> Choice1

    ' Entry / do / exit
    SearchUsers : entry / To search users
    SearchUsers : do / Choosing users based on category
    SearchUsers : exit / After displaying

    ' First decision
    state Choice1 <<choice>>

    Choice1 --> ChooseCategory : [category]
    Choice1 --> ChooseRate : [rate]

    state "Choose category" as ChooseCategory
    state "Choose rate range" as ChooseRate

    ' Merge point
    state Merge1 <<choice>>

    ChooseCategory --> Merge1
    ChooseRate --> Merge1

    ' Final action
    state "search and display" as SearchDisplay

    Merge1 --> SearchDisplay

    SearchDisplay --> [*]
}

@enduml