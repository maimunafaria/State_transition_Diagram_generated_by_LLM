@startuml
title A sample state machine for legal sequence of use case operations

[*] --> WaitingForSale

state WaitingForSale
state EnteringItems
state WaitingForPayment
state AuthorizingPayment

WaitingForSale --> EnteringItems : makeNewSale
EnteringItems --> EnteringItems : enterItem
EnteringItems --> WaitingForPayment : endSale

WaitingForPayment --> WaitingForSale : makeCashPayment
WaitingForPayment --> AuthorizingPayment : makeCreditPayment
WaitingForPayment --> AuthorizingPayment : makeCheckPayment

AuthorizingPayment --> WaitingForSale : authorized

@enduml