@startuml
title UML State Chart Diagram

[*] --> FromTo

state "from and to" as FromTo
FromTo : entry / login and about to start journey
FromTo : do / select source and destination
FromTo : exit / get details and convey to user

state details
details : entry / select source and destination
details : do / fetch details
details : exit / NIL

state "drive mode" as DriveMode
DriveMode : entry / select source and destination
DriveMode : do / enable drive mode
DriveMode : exit / notify

state order
order : entry / select from menu
order : do / collect order
order : exit / confirm order

state menu
menu : entry / select hotel
menu : do / shows menu
menu : exit / select from menu

state accident
accident : entry / accident had taken place
accident : do / inform health admin
accident : exit / notify

state notify
notify : entry / either accident or blowing horn or about drive mode
notify : do / notify users
notify : exit / NIL

state feedback
feedback : entry / complete journey
feedback : do / collect feedback
feedback : exit / exit

state Choice1 <<choice>>

FromTo --> details
details --> FromTo
FromTo --> DriveMode
FromTo --> Choice1
FromTo --> feedback : [complete journey and provide feedback]

Choice1 --> order : [if hungry]
Choice1 --> accident : [if accident occur]

menu --> order
accident --> notify
DriveMode --> notify

feedback --> [*]

@enduml