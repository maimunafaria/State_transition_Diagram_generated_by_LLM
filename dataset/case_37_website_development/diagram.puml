@startuml
title UML State Chart Diagram

[*] --> Homepage

state Homepage
Homepage : entry / To Action
Homepage : do / Remain Same
Homepage : exit / Navbar

state NavChoice <<choice>>
Homepage --> NavChoice

state "Display Projects" as DisplayProjects
DisplayProjects : entry / Navbar
DisplayProjects : do / Remain same
DisplayProjects : exit / photos/videos

state Photos
Photos : entry / Display Projects
Photos : do / display photos
Photos : exit / Updates

state "Walk-through" as WalkThrough
WalkThrough : entry / Display projects
WalkThrough : do / display videos
WalkThrough : exit / update

state "Available departments" as Departments
Departments : entry / Navbar
Departments : do / Display available departments
Departments : exit / Updates

state "History of the firm" as HistoryFirm
HistoryFirm : entry / Navbar
HistoryFirm : do / display the history of the firm
HistoryFirm : exit / Updates

state "News/blog" as NewsBlog
NewsBlog : entry / Navbar
NewsBlog : do / Display news
NewsBlog : exit / Updates

state "Career opportunities" as CareerOpportunities
CareerOpportunities : entry / Navbar
CareerOpportunities : do / Display career opportunities
CareerOpportunities : exit / Updates / Application form

state "Employment/Internship application form" as ApplicationForm
ApplicationForm : entry / Career opportunities
ApplicationForm : do / Display application form
ApplicationForm : exit / Verification

state Verification
Verification : entry / Employment/Internship application form
Verification : do / Verify application
Verification : exit / Updates

state Updates
Updates : entry / All
Updates : do / Update the application
Updates : exit / End

state ProjectChoice <<choice>>
state MergeUpdates <<choice>>

NavChoice --> DisplayProjects
NavChoice --> Departments
NavChoice --> HistoryFirm
NavChoice --> NewsBlog
NavChoice --> CareerOpportunities

DisplayProjects --> ProjectChoice
ProjectChoice --> Photos
ProjectChoice --> WalkThrough

Photos --> MergeUpdates
WalkThrough --> MergeUpdates
Departments --> MergeUpdates
HistoryFirm --> MergeUpdates
NewsBlog --> MergeUpdates
CareerOpportunities --> ApplicationForm
CareerOpportunities --> MergeUpdates : [Updates]
ApplicationForm --> Verification
Verification --> MergeUpdates

MergeUpdates --> Updates
Updates --> [*]

@enduml