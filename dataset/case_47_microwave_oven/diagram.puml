@startuml
title State diagram of a microwave oven

[*] --> Waiting

state Waiting
Waiting : do / Display Time

state "Full Power" as FullPower
FullPower : do / Set Power = 600

state "Half Power" as HalfPower
HalfPower : do / Set Power = 300

state "Set Time" as SetTime
SetTime : do / Get Number
SetTime : exit / Set Time

state Enabled
Enabled : do / Display "Ready"

state Disabled
Disabled : do / Display "Waiting"

state Operation
Operation : do / Operate Oven

Waiting --> FullPower : Full Power
Waiting --> HalfPower : Half Power

FullPower --> HalfPower : Half Power
HalfPower --> FullPower : Full Power

FullPower --> SetTime : Timer
HalfPower --> SetTime : Timer

SetTime --> SetTime : Number
SetTime --> Enabled : Door Closed
SetTime --> Disabled : Door Open

Enabled --> Operation : Start
Enabled --> Disabled : Door Open

Disabled --> Enabled : Door Closed

Operation --> Disabled : Door Open
Operation --> Waiting : Cancel
Operation --> Waiting

Waiting --> [*]

@enduml