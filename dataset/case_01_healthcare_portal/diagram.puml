@startuml
title UML State Machine Diagram

state CheckUser <<choice>>
state EntryJoin <<choice>>
state FacilityChoice <<choice>>
state HealthChoice <<choice>>
state FinanceChoice <<choice>>
state ResourceChoice <<choice>>
state PaymentTypeChoice <<choice>>
state FeedbackChoice <<choice>>
state ExitJoin <<choice>>
state ExitJoinFinal <<choice>>
state LastJoin <<choice>>
state ResourceChoiceFinal <<choice>>

[*] --> CheckUser : [ check user ]

state Register
Register : entry / when the user is a new user
Register : do / registration process
Register : exit / successfully registered
Register : exit / invalid registration

state "Login" as Login {
  Login : entry / registered user
  Login : do / permitted to use facilities
  Login : exit / required resources have been accessed

  state CheckStart <<choice>>

  state Facilities
  Facilities : entry / user must be logged in
  Facilities : do / selection and usage of desired facilities
  Facilities : exit / selected facility can be accessed

  state "News and Experts" as NewsExperts
  NewsExperts : entry / when the user has chosen news and experts
  NewsExperts : do / select options
  NewsExperts : exit / provide information

  state "Symptoms checker" as SymptomsChecker
  SymptomsChecker : entry / when the user has chosen symptoms checker
  SymptomsChecker : do / get symptoms and fetch the disease
  SymptomsChecker : exit / display result

  state "Check fitness" as CheckFitness
  CheckFitness : entry / when the user has chosen check fitness
  CheckFitness : do / get details and calculate fitness
  CheckFitness : exit / display result

  state Finance
  Finance : entry / user has insurance
  Finance : do / processing
  Finance : exit / insurance is validated

  state Apply
  Apply : entry / user doesn't have insurance
  Apply : do / process and validate details
  Apply : exit / insurance provided

  state Cash
  Cash : entry / when the user is delivered with drugs
  Cash : do / calculate amount, return date
  Cash : exit / user is prompted to pay during delivery

  state Payment
  Payment : entry / when the doctor is consulted or the drugs are purchased
  Payment : do / check insurance details and make payment
  Payment : exit / payment process completed

  state Feedback
  Feedback : entry / user has opted to give the feedback
  Feedback : do / collect feedback for the service
  Feedback : exit / feedback completed

  [*] --> CheckStart
  CheckStart --> Facilities : [ new location ]

  Facilities --> FacilityChoice

  FacilityChoice --> NewsExperts : [ choice="News and experts" ]
  FacilityChoice --> HealthChoice : [ choice="Health A-Z" ]
  FacilityChoice --> FinanceChoice : [ choice="Finance" ]

  HealthChoice --> SymptomsChecker : [ option="Symptoms checker" ]
  HealthChoice --> CheckFitness : [ option="fitness checker" ]

  SymptomsChecker --> ExitJoin
  CheckFitness --> ExitJoin
  NewsExperts --> ExitJoin
  ExitJoin --> ExitJoinFinal
  ExitJoinFinal --> CheckStart
  ExitJoinFinal --> LastJoin
  FinanceChoice --> Finance : [ insurance="available" ]
  FinanceChoice --> Apply : [ insurance="not available" ]

  Finance --> ResourceChoice : [ when resource is utilized ]
  Apply --> ResourceChoice

  ResourceChoice --> ResourceChoiceFinal
  ResourceChoiceFinal --> Payment : [ resource="doctor consulted" ]
  ResourceChoiceFinal --> PaymentTypeChoice : [ resource="Drugs and supplements" ]

  PaymentTypeChoice --> Cash : [ payment type="cash" ]
  PaymentTypeChoice --> Payment : [ payment type="through insurance" ]

  Payment --> FeedbackChoice

  FeedbackChoice --> Feedback : [ user wishes to give feedback ]
  FeedbackChoice --> [*] : [ user isn't willing to give feedback ]

  Feedback --> LastJoin

  LastJoin --> [*] : [ user needs to logout the system ]
}

state Logout
Logout : entry / when the user opts to logout
Logout : do / update the details
Logout : exit / user will be logged out

CheckUser --> Register : [ New user="yes" ]
CheckUser --> EntryJoin : [ New user="no" ]

Register --> EntryJoin : [ successfully registered ]
Register --> [*] : [ invalid registration ]

EntryJoin --> Login
Login --> Logout
Logout --> [*]

@enduml