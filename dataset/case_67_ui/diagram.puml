@startuml
title Check Budget Window State Machine

[*] --> NoClientSelected

state "Check Budget Window" as CBW {

  state NoClientSelected as "1 No Client Selected"
  state NoCampaignSelected as "2 No Campaign Selected"
  state Blank as "3 Blank"
  state DisplayResult as "4 Display Result"

  NoClientSelected --> NoCampaignSelected : clientSelected()
  NoCampaignSelected --> Blank : campaignSelected()
  Blank --> DisplayResult : checkButtonClicked()
  DisplayResult --> DisplayResult : checkButtonClicked()

}

@enduml