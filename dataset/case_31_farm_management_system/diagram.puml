@startuml
title UML State Machine Diagram

[*] --> UserLogin

state "user login" as UserLogin
UserLogin : entry / Not logged in
UserLogin : do / Authenticate
UserLogin : exit / Successfully logged in

state "user home" as UserHome
UserHome : entry / user logged in
UserHome : do / display available options
UserHome : exit / pest control techniques
UserHome : exit / soil condition
UserHome : exit / weather insights
UserHome : exit / labour availability
UserHome : exit / market conditions
UserHome : exit / logout

state "logout" as Logout
Logout : entry / to logout
Logout : do / logout user
Logout : exit / user logged out

state "market conditions" as MarketConditions
MarketConditions : entry / to market conditions
MarketConditions : do / gather all market conditions reports
MarketConditions : exit / market conditions report

state "market conditions report" as MarketReport
MarketReport : entry / to market conditions report
MarketReport : do / display market details
MarketReport : exit / return to home

state "pestcontrol" as PestControl
PestControl : entry / to pestcontrol
PestControl : do / ask for photo
PestControl : exit / pest control techniques

state "pest control techniques" as PestTechniques
PestTechniques : entry / to pest control techniques
PestTechniques : do / best control techniques
PestTechniques : exit / return to home

state "soil condition" as SoilCondition
SoilCondition : entry / to soil condition
SoilCondition : do / ask for soil info
SoilCondition : exit / display soil condition report

state "soil condition view" as SoilView
SoilView : entry / to soil condition view
SoilView : do / display crops suitable for soil condition
SoilView : exit / return to home

state "weather insights" as WeatherInsights
WeatherInsights : entry / to weather insights
WeatherInsights : do / ask for location
WeatherInsights : exit / display weather analysis view

state "weather insights view" as WeatherView
WeatherView : entry / to weather insights view
WeatherView : do / display weather analysis
WeatherView : exit / return to home

state "labour availability" as LabourAvailability
LabourAvailability : entry / to labour availability
LabourAvailability : do / ask for location
LabourAvailability : exit / labour availability view

state "labour availability view" as LabourView
LabourView : entry / to labour availability view
LabourView : do / display labour availability
LabourView : exit / return to home

state HomeOptions <<choice>>
state ReturnJoin <<choice>>
state SoilChoice <<choice>>
state WeatherChoice <<choice>>
state PestChoice <<choice>>

UserLogin --> ReturnJoin
ReturnJoin --> UserHome  : [go to home]

UserHome --> HomeOptions : [available options]

HomeOptions --> Logout : [logout]
HomeOptions --> MarketConditions : [market conditions]
HomeOptions --> LabourAvailability : [labour availability]
HomeOptions --> WeatherInsights : [weather insights]
HomeOptions --> SoilCondition : [crops suitable based on soil]
HomeOptions --> PestControl : [pest control]

PestControl --> PestChoice
PestChoice --> PestTechniques : [valid soil details]

SoilCondition --> SoilChoice
SoilChoice --> SoilView : [valid soil details]

WeatherInsights --> WeatherChoice
WeatherChoice --> WeatherView : [location details]

LabourAvailability --> WeatherChoice
WeatherChoice --> LabourView : [location details]

MarketConditions --> MarketReport

PestTechniques --> ReturnJoin
SoilView --> ReturnJoin
WeatherView --> ReturnJoin
LabourView --> ReturnJoin
MarketReport --> ReturnJoin
SoilChoice --> ReturnJoin
PestChoice --> ReturnJoin
WeatherChoice --> ReturnJoin
Logout --> [*]

@enduml