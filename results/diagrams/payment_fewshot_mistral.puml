@startuml
[*] --> PaymentPending

PaymentPending --> OnlinePayment : online payment
PaymentPending --> OfflinePayment : offline payment
OfflinePayment --> CashOnDelivery : cash on delivery
OfflinePayment --> OnSpotTransaction : on-spot transaction
OnlinePayment --> DigitalPayment : digital payment

DigitalPayment --> PaymentSuccess : success
CashOnDelivery --> PaymentSuccess : payment received
OnSpotTransaction --> PaymentSuccess : transaction completed

PaymentSuccess --> MemoGenerated : generate memo
PaymentSuccess --> NotificationSent : send notification

PaymentPending --> PaymentFailed : failed payment
PaymentFailed --> RetryPayment : retry payment
RetryPayment --> PaymentFailed : exceed retries

@enduml
