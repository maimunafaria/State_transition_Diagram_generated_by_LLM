@startuml
[*] --> Idle

Idle --> SalesHistory : new sale
SalesHistory --> Calculation : sales history available
Calculation --> SubtotalCalculation : calculate subtotal
SubtotalCalculation --> ProfitCalculation : calculate profit
ProfitCalculation --> Reporting : report generated

Reporting --> HandlingDuePayments : due payments pending
HandlingDuePayments --> PaymentProcessing : payment processed
PaymentProcessing --> EmployeeSalaries : salaries and bonuses to process

EmployeeSalaries --> BonusCalculation : bonuses available
BonusCalculation --> SalaryReport : salary report generated

@enduml
