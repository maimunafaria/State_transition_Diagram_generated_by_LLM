@startuml
[*] --> Initial

Initial --> OnlineOrder : online order
OnlineOrder --> PaymentMethodSelection : select method
PaymentMethodSelection --> CashOnDelivery : cash on delivery selected
CashOnDelivery --> Paid : payment successful, memo generated

CashOnDelivery --> Failed : payment failed
Failed --> Initial : reset

PaymentMethodSelection --> DigitalPayment : digital payment selected
DigitalPayment --> Paid : payment successful, memo generated

DigitalPayment --> Failed : payment failed
Failed --> Initial : reset

Initial --> OfflineOrder : offline order
OfflineOrder --> PaymentMethodSelection : select method

@enduml
