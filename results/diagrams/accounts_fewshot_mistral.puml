@startuml
[*] --> Idle

Idle --> Sales : start sale
Sales --> SalesDetails : add product details
Sales --> Payments : collect customer payment

Payments --> DuePayments : if due, update due payments
Payments --> EmployeeSalary : if employee salary, payout

SalesDetails --> SubtotalCalculation : calculate subtotal
SubtotalCalculation --> SalesHistory : record sale history

Idle --> SalesReportsGeneration : generate reports
SalesReportsGeneration --> FinancialReporting : display profit/income report

@enduml
