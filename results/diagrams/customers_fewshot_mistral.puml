@startuml
[*] --> Idle

Idle --> OrderReceived : receive order
OrderReceived --> OrderProcessing : process order
OrderProcessing --> InvoiceGenerated : generate invoice
InvoiceGenerated --> SMSSent : send SMS with invoice
SMSSent --> RecommendationsGenerated : generate recommendations
RecommendationsGenerated --> Idle : store recommendations for future use

Idle --> CustomerDetailsUpdated : update customer details
CustomerDetailsUpdated --> Idle : save updated customer data

@enduml
