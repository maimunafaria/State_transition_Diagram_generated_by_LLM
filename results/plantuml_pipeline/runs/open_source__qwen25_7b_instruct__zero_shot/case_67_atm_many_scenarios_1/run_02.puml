@startuml
title ATM State Transition Diagram

initial : Insert Card
state "Waiting for PIN" as WFPIN
state "PIN Verified" as PV
state "Options Available" as OA
state "Withdrawal Requested" as WR
state "Cash Dispensed" as CD
state "Receipt Printed" as RP
state "Card Returned" as CR
state "System Reset" as SR

WFPIN --> PV : Enter PIN
PV --> OA : Verify PIN
OA --> WR : Approve Options
WR --> CD : Process Withdrawal
CD --> RP : Dispense Cash
RP --> CR : Print Receipt
CR --> SR : Return Card
SR --> WFPIN : Reset System

@enduml
