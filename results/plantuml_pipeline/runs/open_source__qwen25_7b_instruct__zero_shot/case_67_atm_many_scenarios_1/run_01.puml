@startuml
title ATM State Transition Diagram

initial : Initial State

state "Card Inserted" as CardInserted {
    state "PIN Entry" as PINEntry {
        state "PIN Verified" as PINVerified {
            state "Options Menu" as OptionsMenu {
                state "Withdrawal Request Approved" as WithdrawalApproved {
                    state "Cash Dispensed" as CashDispensed {
                        state "Receipt Printed" as ReceiptPrinted {
                            state "Card Returned" as CardReturned {
                                state "System Reset" as SystemReset
                            }
                        }
                    }
                }
            }
        }
    }
}

CardInserted --> PINEntry : Insert Card
PINEntry --> PINVerified : Enter PIN
PINVerified --> OptionsMenu : Verify PIN
OptionsMenu --> WithdrawalApproved : Approve Withdrawal Request
WithdrawalApproved --> CashDispensed : Dispense Cash
CashDispensed --> ReceiptPrinted : Print Receipt
ReceiptPrinted --> CardReturned : Return Card
CardReturned --> SystemReset : Reset System

@enduml
