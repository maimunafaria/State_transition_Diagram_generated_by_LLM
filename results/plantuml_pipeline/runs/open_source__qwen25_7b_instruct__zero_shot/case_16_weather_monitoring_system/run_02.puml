@startuml
title Weather Monitoring System State Transition Diagram

initial : Initial State

state "User Registration" as Register {
    state "Not Successful" as RegFail
}

state "Login" as Login {
    state "Successful" as LogIn
}

state "Location Check" as LocationCheck {
    state "Invalid Location" as LocFail
}

state "Weather Information Selection" as InfoSelect

state "Session Active" as SessionActive

state "Logout" as Logout

Register --> RegFail : Registration Failure
Login --> RegFail : Registration Failure
Login --> LogIn : Login Success
LogIn --> LocationCheck : Check Weather for Location
LocationCheck --> LocFail : Invalid Location Entered
LocationCheck --> InfoSelect : Valid Location Entered
InfoSelect --> SessionActive : Select Weather Information
SessionActive --> Logout : User Logs Out

@enduml
