@startuml

title Weather Monitoring System State Transition Diagram

initial : Initial State

state "User Not Logged In" {
    state "Create Account" as CA
    state "Login" as L
}

state "Logged In" as LI

state "Session Ended" as SE

CA --> L : Attempt Login
L --> LI : Successful Login
LI --> SE : Logout

state "Location Check Failed" as LC_F
LI --> LC_F : Invalid Location Entered
LC_F --> SE : End Process

LI --> "Check Weather Info" as CWI
CWI --> LI : Valid Location, Choose Info Type
CWI --> SE : End Process

CWI --> "Show Selected Info" as SSI
SSI --> LI : Show Weather Information

state "View Additional Details" as VAD
LI --> VAD : View Additional Details
VAD --> SE : End Session

@enduml
