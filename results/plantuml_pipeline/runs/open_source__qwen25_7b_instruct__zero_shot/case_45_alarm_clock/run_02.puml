@startuml
initial state : Off

state Off {
    initial Off
    : Initial State;
}

state ActiveAlarm {
    : Alarm Activated;
}

state RingingAlarm {
    : Alarm is Ringing;
}

state Off {
    --> ActiveAlarm : Set Alarm Time
}

ActiveAlarm {
    --> RingingAlarm : Current Time Matches Alarm Time
}

RingingAlarm {
    --> Off : Stop Alarm
    --> ActiveAlarm : Next Scheduled Alarm Time
}

@enduml
