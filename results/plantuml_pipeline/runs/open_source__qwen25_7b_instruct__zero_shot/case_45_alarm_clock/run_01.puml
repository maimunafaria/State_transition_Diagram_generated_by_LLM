@startuml
title Alarm Clock State Transition Diagram

initial : Off

state "Off" as off {
    activate : [Set Alarm Time] -> "Activate"
}

state "Activated" as activated {
    ring : [Current Time Matches Set Alarm Time] -> "Start Ringing"
    stop : [Stop Alarm] -> "Stop Ringing"
}

state "Ringing" as ringing {
    stop : [Stop Alarm] -> "Stop Ringing"
}

state "Active" as active

off --> activated : [Activate]
ring --> ringing : [Current Time Matches Set Alarm Time]
stop --> off : [Stop Alarm]
stop --> active : [Stop Alarm]

@enduml
