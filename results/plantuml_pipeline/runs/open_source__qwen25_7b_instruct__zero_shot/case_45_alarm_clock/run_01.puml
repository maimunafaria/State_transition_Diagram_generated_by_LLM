@startuml
initial state : Off

state Off {
    initial : Initial State;
    activateAlarm : Activate Alarm;
}

state Active {
    ringAlarm : Ringing;
    stopRinging : Stop Ringing;
}

state Stopped {}

activateAlarm --> ringAlarm : Set Alarm Time
ringAlarm --> stopRinging : Current Time Matches Alarm Time
stopRinging --> Off : Turn Off Alarm
ringAlarm --> Active : Current Time Matches Alarm Time

final state : Off
@enduml
