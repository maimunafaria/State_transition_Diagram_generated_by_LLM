@startuml
initial state : Off

state Off {
    initial Off
    : Initial State;
}

state ActiveAlarm {
    : Alarm Activated;
}

state RingingAlarm {
    : Alarm is Ringing;
}

state StoppedAlarm {
    : Alarm Stopped;
}

: Current Time Matches Set Alarm;

Off --> ActiveAlarm : "User sets an alarm time"
ActiveAlarm --> RingingAlarm : "Current time matches set alarm time"
RingingAlarm --> StoppedAlarm : "User stops the alarm"
StoppedAlarm --> Off : "Next scheduled alarm time"

final state : Off
@enduml
