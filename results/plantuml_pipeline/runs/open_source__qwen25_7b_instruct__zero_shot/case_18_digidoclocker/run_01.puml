@startuml
title Digidoclocker State Transition Diagram

initial : Citizen Registration;
state "Citizen" as Citizen {
    initial : Registered;
    state "Logged In" as LoggedIn {
        state "Document Upload" as DocumentUpload {
            state "Profile View" as ProfileView {
                state "Certificate Application" as CertificateApplication
            }
        }
    }
    state "Registrar Request" as RegistrarRequest {
        state "Multiple Certificates" as MultipleCertificates {
            state "Continue Requesting" as ContinueRequesting
        }
    }
}

state "Session Ended" as SessionEnded

Citizen --> Registered : User enters details
Registered --> LoggedIn : Citizen registers and logs in
LoggedIn --> DocumentUpload : Upload documents
DocumentUpload --> ProfileView : View profile
ProfileView --> CertificateApplication : Apply for certificate
CertificateApplication --> DocumentUpload : Continue uploading documents
CertificateApplication --> ProfileView : View profile again
CertificateApplication --> SessionEnded : Done with actions

RegistrarRequest --> MultipleCertificates : Request certificates
MultipleCertificates --> ContinueRequesting : Continue requesting more
ContinueRequesting --> RegistrarRequest : Re-request after receiving one

@enduml
