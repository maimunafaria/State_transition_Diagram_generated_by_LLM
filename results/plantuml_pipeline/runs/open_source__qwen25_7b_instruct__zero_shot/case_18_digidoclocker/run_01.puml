@startuml

title Digidoclocker State Transition Diagram

initial : Citizen Registration;
state "Citizen" as Citizen {
    initial : Registered;
    state "Logged In" as LoggedIn {
        state "Uploading Documents" as UploadingDocuments {
            state "Viewing Profile" as ViewingProfile {
                state "Applying for Certificate" as ApplyingForCertificate
            }
        }
    }
    state "Session Ended" as SessionEnded

    Citizen --> Registered : Enter Details
    Registered --> LoggedIn : Register
    LoggedIn --> UploadingDocuments : Upload Documents
    LoggedIn --> ViewingProfile : View Profile
    LoggedIn --> ApplyingForCertificate : Apply for Certificate
    ApplyingForCertificate --> UploadingDocuments : Continue Uploading
    ApplyingForCertificate --> SessionEnded : Done

    state "Registrar" as Registrar {
        initial : Registered;
        state "Requesting Certificates" as RequestingCertificates {
            state "Multiple Requests" as MultipleRequests
        }
    }

    Registrar --> Registered : Enter Details
    Registered --> RequestingCertificates : Register
    RequestingCertificates --> MultipleRequests : Continue Requesting

@enduml
