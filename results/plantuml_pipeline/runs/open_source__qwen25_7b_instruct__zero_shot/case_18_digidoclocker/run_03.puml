@startuml

title Digidoclocker State Transition Diagram

initial : Citizen Registration;
state "Citizen" as Citizen {
    initial : Registered;
    state "Logged In" as LoggedIn {
        state "Uploading Documents" as UploadingDocuments {
            state "Viewing Profile" as ViewingProfile {
                state "Applying for Certificate" as ApplyingForCertificate
            }
        }
    }
    state "Registrar Requesting Certificates" as RegistrarRequestingCertificates

    : Citizen Registration -> Registered;
    : Registered -> LoggedIn;
    : LoggedIn -> UploadingDocuments;
    : LoggedIn -> ViewingProfile;
    : LoggedIn -> ApplyingForCertificate;
    : ApplyingForCertificate -> LoggedIn;
    : UploadingDocuments -> LoggedIn;

    : LoggedIn -> RegistrarRequestingCertificates;
    : RegistrarRequestingCertificates -> LoggedIn;

    : LoggedIn -> "End Session";
}

@enduml
