@startuml
initial state as WaitingForNewSale

state WaitingForNewSale {}
state EnteringItems {}
state PaymentSelection {}
state CardPaymentVerification {}
state CheckPaymentVerification {}
state SaleCompleted {}

WaitingForNewSale --> EnteringItems : New sale received
EnteringItems --> PaymentSelection : All items added
PaymentSelection --> SaleCompleted : Cash payment
PaymentSelection --> CardPaymentVerification : Card or check selected

CardPaymentVerification --> SaleCompleted : Payment approved
CheckPaymentVerification --> SaleCompleted : Payment approved

SaleCompleted --> WaitingForNewSale : Next customer

@enduml
