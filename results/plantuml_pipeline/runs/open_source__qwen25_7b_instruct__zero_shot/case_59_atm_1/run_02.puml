@startuml
title ATM Withdrawal Scenario 1

initial : Initial State

state "Withdrawal Amount Selection" {
    state "Select Predefined Amount" as s1
    state "Enter Custom Amount" as s2
    state "Transaction Cancelled" as s3
    state "Transaction Completed" as s4
    
    initial --> s1 : User selects predefined amount
    s1 --> s4 : User cancels transaction
    s1 --> s2 : User chooses to enter custom amount
    s2 --> s4 : User cancels transaction
    s2 --> s3 : Transaction completed
}

s3 --> s3 : Loop (Transaction Cancelled)
s4 --> s3 : Transaction cancelled

final : Final State
@enduml
