@startuml
title ATM Withdrawal Scenario 1

initial : Initial State

state "Withdrawal Amount Selection" {
    state "Select Predefined Amount" as predefinedAmount
    state "Enter Custom Amount" as customAmount
}

state "Transaction Cancelled" as cancelled
state "Transaction Completed" as completed
state "Transaction Stopped" as stopped

initial --> predefinedAmount : Choose Predefined Amount
predefinedAmount --> customAmount : Enter Custom Amount
customAmount --> predefinedAmount : Select Another Predefined Amount
customAmount --> cancelled : Cancel Transaction
predefinedAmount --> cancelled : Cancel Transaction
cancelled --> stopped : Stop Transaction
stopped --> initial : Return to Initial State

state completed {
    completed --> initial : End of Transaction
}

@enduml
