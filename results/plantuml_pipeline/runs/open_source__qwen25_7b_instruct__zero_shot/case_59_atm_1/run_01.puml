@startuml
title ATM Withdrawal Scenario 1

initial : Start

state "Idle" as idle
state "Select Amount" as selectAmount
state "Custom Input" as customInput
state "Cancel Transaction" as cancelTransaction
state "Transaction Complete" as transactionComplete
state "Card Returned" as cardReturned

idle --> selectAmount : User selects predefined amount
idle --> customInput : User inputs custom amount
selectAmount --> idle : User cancels transaction
customInput --> idle : User cancels transaction
cancelTransaction --> cardReturned : System stops transaction and returns card

@enduml
