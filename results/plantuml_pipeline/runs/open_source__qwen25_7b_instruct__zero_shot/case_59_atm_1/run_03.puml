@startuml
title ATM Withdrawal Scenario 1

initial : Initial State

state "Withdrawal Amount Selection" {
    state "Select Predefined Amounts" as predefinedAmounts
    state "Enter Custom Amount" as customAmount
}

state "Transaction Cancelled" as cancelled
state "Transaction Completed" as completed
state "Card Returned" as cardReturned

initial --> predefinedAmounts : User selects predefined amount
predefinedAmounts --> customAmount : User chooses to enter custom amount
customAmount --> predefinedAmounts : User changes mind and selects predefined amount
customAmount --> cancelled : User cancels transaction
cancelled --> cardReturned : System returns the card
predefinedAmounts --> cancelled : User cancels transaction

state "Card Returned" as finalState
@enduml
