@startuml
title Digital Watch State Transition Diagram

initial : Initial State

state "Idle" as idle
state "Time Setting - Hour" as timeHour
state "Time Setting - Minutes" as timeMin
state "Alarm Setting - On" as alarmOn
state "Alarm Setting - Off" as alarmOff
state "Alarm Ringing" as alarmRinging
state "Light On" as lightOn
state "Light Off" as lightOff

idle --> timeHour : Press Button to Change Hour
timeHour --> idle : Press Button to Change Minute or Alarm
timeHour --> timeMin : Press Button to Change Minute
timeMin --> idle : Press Button to Change Hour or Alarm
timeMin --> timeHour : Press Button to Change Hour
timeMin --> alarmOn : Press Button to Set Alarm
alarmOn --> idle : Press Button to Stop Alarm
alarmOn --> alarmRinging : Current Time Matches Alarm Time
alarmOff --> idle : Press Button to Turn On Light
lightOn --> lightOff : Release Button

@enduml
