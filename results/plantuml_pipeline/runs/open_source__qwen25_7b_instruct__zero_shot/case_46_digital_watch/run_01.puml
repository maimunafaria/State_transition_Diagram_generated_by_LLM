@startuml
title Digital Watch State Transition Diagram

initial : Initial State

state "Idle" {}
state "TimeAdjustingHour" as HA {}
state "TimeAdjustingMinute" as MA {}
state "AlarmAdjustingHour" as AA {}
state "AlarmAdjustingMinute" as AM {}
state "AlarmOn" {}
state "LightOn" {}

:View Time; -> Idle : View or Adjust Time
:Switch to Hour; -> Idle : Press Button
:Switch to Minute; -> HA : Press Button
:Switch to Alarm Hour; -> MA : Press Button
:Switch to Alarm Minute; -> AA : Press Button

:Increase Value; -> HA, MA, AA, AM : Press Button

:Turn On Alarm; -> Idle : Set Alarm
:Alarm Time Matches Current Time; -> AlarmOn : Current Time = Set Alarm Time

:Stop Alarm; -> AlarmOn : Press Stop Button
:Light Button Pressed; -> LightOn : Press Button
:Light Button Released; -> Idle : Release Button

@enduml
