@startuml
title Digital Watch State Transition Diagram

initial : Initial State

state "Idle" as idle
state "Time Adjustment" as timeAdj
state "Alarm Setting" as alarmSet
state "Alarm On" as alarmOn
state "Light On" as lightOn

idle --> timeAdj : Press Button to Adjust Time
timeAdj --> idle : Press Button to Exit
timeAdj --> alarmSet : Press Button to Set Alarm
alarmSet --> idle : Press Button to Exit
alarmSet --> alarmOn : Turn On Alarm
alarmOn --> idle : Stop Alarm by Pressing Button

lightOn --> idle : Release Button

@enduml
