@startuml
title Digital Watch State Transition Diagram

initial : Initial State

state "Idle" as idle
state "TimeAdjustingHour" as timeAdjHour
state "TimeAdjustingMinute" as timeAdjMin
state "AlarmAdjustingHour" as alarmAdjHour
state "AlarmAdjustingMinute" as alarmAdjMin
state "AlarmOn" as alarmOn
state "AlarmOff" as alarmOff

idle --> idle : Button Pressed (Light On)
idle --> timeAdjHour : Button Pressed (Time Adjusting Hour)
timeAdjHour --> timeAdjMin : Button Pressed (Next Field)
timeAdjMin --> timeAdjHour : Button Pressed (Previous Field)
timeAdjMin --> idle : Button Released
alarmAdjHour --> alarmAdjMin : Button Pressed (Next Field)
alarmAdjMin --> alarmAdjHour : Button Pressed (Previous Field)
alarmAdjMin --> idle : Button Released
idle --> alarmOn : Alarm On Button Pressed
alarmOn --> alarmOff : Alarm Off Button Pressed

alarmOff --> alarmOn : Alarm Time Matches Current Time
alarmOn --> alarmOff : Stop Alarm Button Pressed

@enduml
