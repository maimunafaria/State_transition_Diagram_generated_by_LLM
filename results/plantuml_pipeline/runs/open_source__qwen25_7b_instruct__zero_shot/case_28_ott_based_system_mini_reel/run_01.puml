@startuml
title Ott Based System Mini Reel - State Transition Diagram

initial : Initial State

state "Logged Out" {
    state "Create Account" as CA
    state "Watch Videos" as WV
}

state "Logged In" {
    state "Upload Video" as UV
    state "Save Video in Likes List" as SVLL
    state "View Saved Videos from Likes List" as VSVLL
    state "Enter Discussion Option" as EDO
}

CA -[Create Account]-> WV
WV -[Watch Videos]-> SVLL
SVLL -[Save Video]-> WV
UV -[Upload Video]-> WV
EDO -[Enter Discussion]-> WV

initial --> CA : Start
WV --> VSVLL : View Saved Videos from Likes List
WV --> EDO : Enter Discussion Option

@enduml
