@startuml
title Ott Based System Mini Reel - State Transition Diagram

initial : Initial State

state "Logged Out" {
    state "Create Account" {
        initial : Create Account
        "Create Account" -> "Account Created"
    }
    "Account Created" -> "Watch Videos" : Login
}

state "Logged In" {
    state "Watching Videos" {
        "Watching Videos" -> "Save Video to Likes List" : Like Video
        "Watching Videos" -> "View Saved Videos" : View Likes List
        "Watching Videos" -> "Enter Discussion" : Enter Discussion
    }
    state "Uploading Videos" {
        initial : Upload Video
        "Upload Video" -> "Video Uploaded"
    }
}

state "Discussion" {
    initial : Enter Discussion
    "Enter Discussion" -> "View Comments" : View Comments
    "Enter Discussion" -> "Post Comment" : Post Comment
}

"Account Created" -> "Uploading Videos" : Upload Video

"Watch Videos" -> "Watching Videos"
"Save Video to Likes List" -> "Watching Videos"

"Video Uploaded" -> "Logged In"

"View Saved Videos" -> "Watching Videos"

"Post Comment" -> "Discussion"

@enduml
