@startuml
title Ott Based System Mini Reel - State Transition Diagram

initial : Initial State

state "Logged Out" {
    state "Create Account"
    state "Watch Videos"
}

state "Logged In" {
    state "Upload Videos"
    state "Save Videos in Likes List"
    state "View Saved Videos"
    state "Enter Discussion"
}

:User creates an account; -> Create Account
:User watches videos; -> Watch Videos
:User uploads videos; -> Upload Videos
:User saves videos in likes list; -> Save Videos in Likes List
:User views saved videos; -> View Saved Videos
:User enters discussion; -> Enter Discussion

Logged Out --> Create Account : "Start"
Create Account --> Watch Videos : "Watch after account creation"
Watch Videos --> Logged In : "Login required to watch"
Logged In --> Upload Videos : "Upload video"
Logged In --> Save Videos in Likes List : "Save video"
Save Videos in Likes List --> View Saved Videos : "View saved videos"
View Saved Videos --> Logged In : "Return to logged-in state"
Logged In --> Enter Discussion : "Enter discussion"

@enduml
