@startuml

title Campaign State Transition Diagram

initial : Start;
state "Initial" as Initial;
state "Assigned" as Assigned;
state "Approved & Signed" as ApprovedAndSigned;
state "Preparing Adverts" as PreparingAdverts;
state "Scheduled Adverts" as ScheduledAdverts;
state "Running Adverts" as RunningAdverts;
state "Extending/Adjusting" as ExtendingAdjusting;
state "Completed" as Completed;
state "Paid" as Paid;
state "Archived" as Archived;

Initial --> Assigned : Manager and Staff Assigned
Assigned --> ApprovedAndSigned : Everything Approved, Contract Signed
ApprovedAndSigned --> PreparingAdverts : Prepare Adverts
PreparingAdverts --> ScheduledAdverts : Approve & Schedule Adverts
ScheduledAdverts --> RunningAdverts : Run Adverts
RunningAdverts --> ExtendingAdjusting : Extension or Adjustment
ExtendingAdjusting --> RunningAdverts : Continue Running
RunningAdverts --> Completed : All Adverts Finished
Completed --> Paid : Final Statement Generated, Payment Due
Paid --> Archived : Full Amount Paid

@enduml
