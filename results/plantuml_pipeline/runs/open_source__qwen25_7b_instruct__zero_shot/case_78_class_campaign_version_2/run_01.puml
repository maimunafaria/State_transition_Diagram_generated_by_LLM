@startuml

title Campaign State Transition Diagram

initial : Start
rectangle "Initial" as InitialState

state "Campaign Not Started" as NotStarted
state "Campaign Assigned" as Assigned
state "Campaign Approved & Signed" as ApprovedSigned
state "Adverts Preparing" as AdvertsPreparing
state "Adverts Scheduled" as AdvertsScheduled
state "Adverts Running" as AdvertsRunning
state "Campaign Extending/Adjusting" as ExtendingAdjusting
state "Campaign Completed" as CampaignCompleted
state "Payment Handling" as PaymentHandling
state "Paid" as Paid
state "Archived" as Archived

InitialState --> NotStarted : Start

NotStarted --> Assigned : Manager and Staff Assigned
Assigned --> ApprovedSigned : Everything Approved, Contract Signed
ApprovedSigned --> AdvertsPreparing : Prepare Adverts
AdvertsPreparing --> AdvertsScheduled : Approve & Schedule Adverts
AdvertsScheduled --> AdvertsRunning : Run Adverts
AdvertsRunning --> ExtendingAdjusting : Extension or Adjustment
ExtendingAdjusting --> CampaignCompleted : All Adverts Finished
CampaignCompleted --> PaymentHandling : Final Statement Prepared
PaymentHandling --> Paid : Full Amount Paid
Paid --> Archived : Archive Campaign

@enduml
