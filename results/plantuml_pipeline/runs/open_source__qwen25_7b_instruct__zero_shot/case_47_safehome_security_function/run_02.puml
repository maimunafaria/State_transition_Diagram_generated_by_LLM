@startuml
title Safehome Security Function State Transition Diagram

initialstate as i0
:Power-on;
i0 --> s1 : Check Startup

state s1 as "Startup"
s1 --> s2 : Everything is fine
s1 --> s3 : Problem during startup

state s2 as "Ready to use"
s2 --> s7 : Activate
s2 --> s6 : Reset
s2 --> s6 : Turn off

state s3 as "Not Ready"
s3 --> s2 : Reset

state s4 as "Monitoring"
s4 --> s8 : Sensor triggered
s4 --> s9 : False alarm or time ends

state s5 as "Alarm"
s5 --> s4 : Stop and return to normal

state s6 as "Stopped"
s6 --> s2 : Enter password

@enduml
