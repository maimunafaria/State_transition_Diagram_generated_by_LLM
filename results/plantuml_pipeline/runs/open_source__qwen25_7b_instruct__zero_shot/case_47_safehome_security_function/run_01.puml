@startuml

title Safehome Security Function State Transition Diagram

initial : Power-on;
state "Power-on" as P {
    initial : true;
}
state "Startup Problem" as S1;
state "Ready to Use" as R;

transition P to S1: Startup Problem
transition P to R: Everything is Fine

state "Activated" as A;
state "Monitoring" as M;
state "Alarm Activated" as Al;
state "False Alarm" as F;

transition R to A: User Activates
transition A to M: Start Monitoring
transition M to Al: Sensor Triggered
transition M to F: False Alarm or Time Ends

transition Al to R: Stop and Return to Normal
transition F to R: Stop and Return to Normal

@enduml
