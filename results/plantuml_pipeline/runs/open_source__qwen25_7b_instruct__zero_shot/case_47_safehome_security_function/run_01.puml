@startuml

title Safehome Security Function State Transition Diagram

initial : Power-on;
state "Power-on" as P {
    initial
}
state "Startup Problem" as SP {
    "System stops if there is a problem"
}
state "Ready to Use" as R {
    "System becomes ready after successful startup"
}
state "Monitoring" as M {
    "System monitors when activated"
}
state "Alarm Active" as A {
    "System triggers alarm and sends alerts on sensor trigger"
}
state "False Alarm/Timeout" as FA {
    "System continues monitoring if it's a false alarm or time ends"
}
state "Off" as O {
    "System turns off when user enters password"
}

P --> SP : Problem during startup
SP --> R : Everything is fine

R --> M : User activates system
M --> A : Sensor triggered
A --> FA : False alarm or timeout
FA --> M : Continue monitoring

R --> O : User enters password at any time

@enduml
