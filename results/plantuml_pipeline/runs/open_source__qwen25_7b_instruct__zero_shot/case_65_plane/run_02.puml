@startuml
title Plane State Transition Diagram

initial : New;
state New {
    * Order
}

state Order {
    -> Arrival : Arrival
}

state Arrival {
    * Preparation
}

state Preparation {
    * Operations : Scheduled Flights
    * Maintenance : No More Scheduled Flights or Maintenance Required
}

state Operations {
    * Maintenance : No More Scheduled Flights or Maintenance Required
}

state Maintenance {
    * Preparation : Checked and Serviced
}

state 'Not Available' {
    * Withdrawn : Permanently Withdrawn from Service
}

@enduml
