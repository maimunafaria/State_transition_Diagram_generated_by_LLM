@startuml

initial state : Order

state Order {
    : Plane acquired;
}

state Arrival {
    : Plane arrives;
    -> Preparation : Arrival
}

state Preparation {
    : Plane prepared;
    -> Operations : Assigned to Operations
    -> Maintenance : Assigned to Maintenance
}

state Operations {
    : Scheduled flights remaining;
    -> Maintenance : No more scheduled flights or maintenance required
}

state Maintenance {
    : Plane serviced and checked;
    -> Preparation : Ready for operations
}

state OutOfService {
    : Plane is no longer available;
    -> FinalState : Permanently withdrawn from service
}

final state : FinalState

@enduml
