@startuml
title Plane State Transition Diagram

initial : New;
state New {
    * Order
}

state Order {
    --> Arrival : Arrival
}

state Arrival {
    --> Preparation : Arrival
}

state Preparation {
    --> Operations : Prepare for operations
    --> Maintenance : Maintenance required
}

state Operations {
    * Operations
    --> Maintenance : No more scheduled flights or maintenance required
}

state Maintenance {
    --> Preparation : Serviced and ready for operations
}

state "Not Available" {
    * Not Available
    --> Withdrawn : Plane withdrawn from service
}

state Withdrawn {
    * Withdrawn
}

@enduml
