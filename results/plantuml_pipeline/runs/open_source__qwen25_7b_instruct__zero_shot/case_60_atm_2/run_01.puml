@startuml
title ATM Withdrawal Scenario 2 State Transition Diagram

initial state as start
:Start;

state "Select Amount" as selectAmount
state "Enter Custom Value" as enterCustomValue
state "Transaction Verification" as verifyTransaction
state "Re-enter Amount" as reEnterAmount
state "Final State" as finalState

start --> selectAmount : User selects an amount from the list
selectAmount --> verifyTransaction : Transaction is verified
verifyTransaction : Transaction rejected ? --> reEnterAmount : Yes
verifyTransaction --> finalState : Transaction approved

reEnterAmount --> selectAmount : Re-enter amount after rejection

@enduml
