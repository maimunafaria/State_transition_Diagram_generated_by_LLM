@startuml
title ATM Withdrawal State Transition Diagram

initial : Initial State

state "Withdrawal Menu" {
    state "Select Amount" as SA
    state "Enter Custom Value" as ECV
    state "Transaction Verification" as TV
    state "Re-enter Amount" as RA
    state "Transaction Success" as TS
    state "Transaction Failed" as TF

    SA -[Verify]-> TV : Verify Transaction
    TV -[Reject]-> RA : Rejected
    RA -[Retry]-> SA : Retry
    TV -[Accept]-> TS : Accepted
}

initial --> SA : Select Amount
SA --> ECV : Enter Custom Value
ECV --> TV : Verify Transaction

@enduml
