@startuml
title ATM Withdrawal State Transition Diagram

initial : Start

state "Idle" as idle
state "Select Amount" as selectAmount
state "Enter Custom Value" as enterCustomValue
state "Verify Transaction" as verifyTransaction
state "Re-enter Amount" as reEnterAmount
state "Transaction Complete" as transactionComplete
state "Error" as error

idle --> selectAmount : User selects an amount from the list
selectAmount --> verifyTransaction : User confirms selection
verifyTransaction : Transaction is verified
verifyTransaction --> transactionComplete : Transaction is approved
verifyTransaction --> reEnterAmount : Transaction is rejected
reEnterAmount --> selectAmount : User re-enters amount

idle --> enterCustomValue : User enters a custom value
enterCustomValue --> verifyTransaction : User confirms entry

error --> idle : Error handling

@enduml
