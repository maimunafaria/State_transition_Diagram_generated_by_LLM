@startuml
title ATM Withdrawal Scenario

initial : Initial State

state "Select Amount" {
    state "List Options" {}
    state "Custom Value" {}
}

state "Verify Transaction" {}

state "Re-enter Amount" {}

final : Final State

initial --> "Select Amount" : User selects amount from list or enters custom value
"Select Amount" --> "Verify Transaction" : Verify transaction
"Verify Transaction" -down: "Transaction Rejected" --> "Re-enter Amount"
"Verify Transaction" -right: "Transaction Approved" --> final

@enduml
