@startuml
title Website Development - State Transition Diagram

initial : Homepage

state "Homepage" as homepage {
    activate homepage
}

state "Projects Page" as projectsPage {
    activate projectsPage
}

state "Career Opportunities Page" as careerOpportunitiesPage {
    activate careerOpportunitiesPage
}

transition homepage to projectsPage: Select Projects
transition homepage to careerOpportunitiesPage: Select Career Opportunities

state "Project Details" as projectDetails {
    activate projectDetails
}

transition projectsPage to projectDetails: View Project Photos or Videos

state "Career Update Page" as careerUpdatePage {
    activate careerUpdatePage
}

state "Application Form Page" as applicationFormPage {
    activate applicationFormPage
}

transition careerOpportunitiesPage to careerUpdatePage: View Updates
transition careerOpportunitiesPage to applicationFormPage: Open Application Form

final : Application Form Submission

@enduml
