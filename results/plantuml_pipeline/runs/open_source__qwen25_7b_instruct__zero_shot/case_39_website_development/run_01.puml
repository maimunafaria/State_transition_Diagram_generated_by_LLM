@startuml
title Website Development - State Transition Diagram

initial : Homepage

state "Homepage" as homepage {
    activate homepage
}

state "Projects Page" as projectsPage {
    activate projectsPage
}

state "Project Details" as projectDetails {
    activate projectDetails
}

state "Career Opportunities Page" as careerOpportunitiesPage {
    activate careerOpportunitiesPage
}

state "Job Application Form" as jobApplicationForm {
    activate jobApplicationForm
}

state "Job Application Submitted" as jobApplicationSubmitted {
    activate jobApplicationSubmitted
}

homepage --> projectsPage : Select Projects
projectsPage --> projectDetails : View Project Details
projectDetails --> projectsPage : Back to Projects

homepage --> careerOpportunitiesPage : Select Career Opportunities
careerOpportunitiesPage --> jobApplicationForm : Apply for Job
jobApplicationForm --> jobApplicationSubmitted : Submit Application

@enduml
