@startuml
title Website State Transition Diagram

initial : Homepage

state "Homepage" as h {
    state "Projects" as p
    state "Career Opportunities" as c
}

h --> p : Select Projects
p --> h : Back to Homepage
p --> c : View Career Opportunities from Projects
c --> h : Back to Homepage

state "Project Details" as pd {
    state "View Photos" as vph
    state "Watch Videos" as wv
}
p --> pd : Choose View Mode
pd --> vph : Select Photos
pd --> wv : Select Videos
vph --> p : Back to Project Details
wv --> p : Back to Project Details

state "Career Opportunity Details" as cod {
    state "View Updates" as vu
    state "Apply for Job" as aj
}
c --> cod : Choose View Mode
cod --> vu : Select Updates
cod --> aj : Apply for Job
vu --> c : Back to Career Opportunities
aj --> h : Submit Application, Back to Homepage

@enduml
