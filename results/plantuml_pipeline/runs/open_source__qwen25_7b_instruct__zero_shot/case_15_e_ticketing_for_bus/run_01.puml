@startuml
title E Ticketing For Bus - State Transition Diagram

initial : Initial State

state "User Not Registered" {
    state "Not Logged In" {
        initial : Initial State
        : Create New Account;
        --> "Registered"
    }
    
    state "Registered" {
        : Validate Registration;
        --> "Validated"
    }
    
    state "Validated" {
        : Log In;
        --> "Logged In"
    }
}

state "User Registered" {
    state "Logged In" {
        initial : Initial State
        : Check Ticket Status;
        --> "Ticket Status Checked"
        
        : Book Ticket;
        --> "Booking Confirmed"
        
        : Make Payment;
        --> "Payment Made"
        
        : Edit Account Details;
        --> "Account Edited"
        
        : Delete Account;
        --> "Account Deleted"
    }
    
    state "Logged Out" {
        : Log Out;
        --> Final State
    }
}

: Final State

@enduml
