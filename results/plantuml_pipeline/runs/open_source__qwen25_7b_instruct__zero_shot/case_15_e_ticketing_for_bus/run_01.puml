@startuml
title E Ticketing For Bus - State Transition Diagram

initial : Initial State

state "User Not Registered" {
    state "Not Logged In"
    state "Logged In"
}

state "Registered User"

transition "Register New Account" from initial to "User Not Registered.Not Logged In"

transition "Validate Registration" from "User Not Registered.Not Logged In" to "User Not Registered.Logged In"

transition "Login" from "User Not Registered.Logged In" to "Logged In"

transition "Check Ticket Status" from "Logged In" to "Logged In"

transition "Book and Confirm Ticket, Pay" from "Logged In" to "Logged In"

transition "Manage Account Details (Edit/Delete)" from "Logged In" to "Logged In"

transition "Logout" from "Logged In" to initial

@enduml
