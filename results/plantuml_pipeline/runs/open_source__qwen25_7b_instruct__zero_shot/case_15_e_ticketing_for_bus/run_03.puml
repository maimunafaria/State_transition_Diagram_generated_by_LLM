@startuml
title E Ticketing For Bus - State Transition Diagram

initial : Initial State

state "Registered" {
    state "Logged In"
    
    state "Account Management" {
        state "Edit Account"
        state "Delete Account"
    }
}

state "Not Registered"

transition "Register" from Not Registered to Registered
transition "Login" from Not Registered to "Logged In"
transition "Logout" from "Logged In" to Not Registered

transition "Check Ticket Status" from "Logged In" to "Logged In"
transition "Book Ticket & Confirm Payment" from "Logged In" to "Logged In"

transition "Edit Account" from "Account Management" to "Logged In"
transition "Delete Account" from "Account Management" to "Logged In"

@enduml
