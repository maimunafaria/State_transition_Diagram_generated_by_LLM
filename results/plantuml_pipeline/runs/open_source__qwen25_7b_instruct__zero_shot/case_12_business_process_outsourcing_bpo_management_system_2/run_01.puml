@startuml
title BPO Management System - Search State Transition Diagram

initial : Initial State

state "Search Not Initiated" {}

state "Filter Category Selected" {}
state "Price Range Filtered" {}
state "Results Displayed" {}

:User initiates search;

"Search Not Initiated" -> "Filter Category Selected" : Select filter category
"Filter Category Selected" -> "Price Range Filtered" : Select price range
"Price Range Filtered" -> "Results Displayed" : Apply filters

state "Final State" {}
"Results Displayed" --> "Final State" : Search completed

@enduml
