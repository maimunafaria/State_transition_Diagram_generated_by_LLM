@startuml
title BPO Management System - Search State Transition Diagram

initial : Initial State

state "Search Not Started" {
    initial : Initial State
    state "Select Filter Category"
    state "Select Price Range"
    state "Display Matching Users"
}

transition "Select Filter Category" to "Select Price Range" : Next
transition "Select Price Range" to "Display Matching Users" : Apply Filters

state "Search Completed" {
    final : Final State
}

@enduml
