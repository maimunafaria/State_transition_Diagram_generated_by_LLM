@startuml
title Video Suggestion System State Transition Diagram

initial : User makes a video suggestion request;
state "User Idle" as idle {
    initial : true;
}
state "Request Received" as received {
    transition to received from idle : Receive Request
}
state "Identifying User" as identifying {
    transition to identifying from received : Identify User
}
state "Gathering Videos" as gathering {
    transition to gathering from identifying : Gather Videos
}
state "Adding Details" as adding {
    transition to adding from gathering : Add Details
}
state "Sending Suggestions" as sending {
    transition to sending from adding : Send Suggestions
}
state "Final State" as final {
    transition to final from sending : Finalize
}

@enduml
