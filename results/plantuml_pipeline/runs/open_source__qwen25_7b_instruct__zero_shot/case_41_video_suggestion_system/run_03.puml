@startuml

initial state : "Initial State"

state UserRequestReceived {
    :Receive video suggestion request from user;
}

state UserIdentified {
    :Identify user who made the request;
}

state VideosGathered {
    :Gather different types of videos based on user's profile or preferences, trending videos, similar tags, genres, and promoted videos;
}

state DetailsAdded {
    :Add additional details such as thumbnails and view counts to suggested videos;
}

state SuggestionsSent {
    :Send suggested videos to the user;
}

state FinalState {
    :Final State
}

UserRequestReceived --> UserIdentified : "User request received"
UserIdentified --> VideosGathered : "User identified"
VideosGathered --> DetailsAdded : "Videos gathered"
DetailsAdded --> SuggestionsSent : "Details added"
SuggestionsSent --> FinalState : "Suggestions sent"

@enduml
