@startuml
title Video Suggestion System State Transition Diagram

initial : User makes video suggestion request

state "User Makes Request" as A {
    state "Identify User" as B {}
    state "Gather Videos" as C {}
    state "Add Details" as D {}
    state "Send Suggestions" as E {}
}

A --> B : Receive request
B --> C : Identify user
C --> D : Gather videos
D --> E : Add details
E --> A : Send suggestions

state "Final State" as F {}

E --> F : Final state

@enduml
