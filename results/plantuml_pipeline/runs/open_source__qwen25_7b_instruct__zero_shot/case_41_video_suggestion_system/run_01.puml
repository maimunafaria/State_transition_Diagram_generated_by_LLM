@startuml

title Video Suggestion System State Transition Diagram

initial : Initial State

state "User Makes Request" {
    state "Identify User" {
        initial : Yes
        state "Gather Videos"
        state "Add Details"
        state "Send Suggestions"
        final : Final State
    }
}

"Identify User" --> "Gather Videos" : Video Suggestion Request Received

"Gather Videos" --> "Add Details" : Videos Identified

"Add Details" --> "Send Suggestions" : Details Added

"Send Suggestions" --> Final State : Suggestions Sent

@enduml
