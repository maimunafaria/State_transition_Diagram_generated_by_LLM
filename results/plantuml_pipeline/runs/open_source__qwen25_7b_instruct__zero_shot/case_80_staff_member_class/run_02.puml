@startuml
title Staff Member State Transition Diagram

initial : Unassigned

state Unassigned {}
state AssignedToClient {}
state AssignedToCampaign {}
state SwitchingAssignments {}
state Unemployed {}

Unassigned --> AssignedToClient : Assign to Client
Unassigned --> AssignedToCampaign : Add to Campaign
AssignedToClient --> Unassigned : Remove Assignment
AssignedToCampaign --> Unassigned : Remove Assignment
AssignedToClient --> SwitchingAssignments : Switch Assignments
AssignedToCampaign --> SwitchingAssignments : Switch Assignments
SwitchingAssignments --> Unassigned : Complete Switch
Unemployed --> #lightgray : Archive Record

@enduml
