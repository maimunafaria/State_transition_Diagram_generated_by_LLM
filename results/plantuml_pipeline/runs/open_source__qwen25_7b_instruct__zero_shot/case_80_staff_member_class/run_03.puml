@startuml
title Staff Member State Transition Diagram

initial : Unassigned
rectangle "Unassigned" {
    : Unassigned;
}

state "Assigned to Client" as AssignedClient {
    : Assigned to Client;
}

state "Assigned to Campaign" as AssignedCampaign {
    : Assigned to Campaign;
}

state "Switching Assignments" as SwitchingAssignments {
    : Switching Assignments;
}

state "Unemployed" as Unemployed {
    : Unemployed;
}

state "Archived" as Archived {
    : Archived;
}

initial --> AssignedClient : Assign to Client
AssignedClient --> AssignedCampaign : Add to Campaign
AssignedClient --> SwitchingAssignments : Switch Assignment
AssignedCampaign --> AssignedClient : Remove from Campaign
SwitchingAssignments --> AssignedClient : Complete Switch
Unassigned --> Unemployed : Leave Job
Unemployed --> Archived : Archive Record

@enduml
