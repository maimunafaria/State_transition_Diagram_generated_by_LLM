@startuml
title Staff Member State Transition Diagram

initial : Unassigned

rectangle "Unassigned" {
    state "Unassigned" {}
}

state "Assigned to Client" {}
state "Assigned to Campaign" {}

state "Switching Assignments" {}

transition "Assign to Client" from Unassigned to "Assigned to Client"
transition "Assign to Campaign" from Unassigned to "Assigned to Campaign"

transition "Remove Assignment" from "Assigned to Client" to Unassigned
transition "Remove Assignment" from "Assigned to Campaign" to Unassigned

state "Unemployed" {}

transition "Leave Job" from "Assigned to Client" to "Unemployed"
transition "Leave Job" from "Assigned to Campaign" to "Unemployed"

state "Archived" {}
transition "Archive Record" from "Unemployed" to "Archived"

@enduml
