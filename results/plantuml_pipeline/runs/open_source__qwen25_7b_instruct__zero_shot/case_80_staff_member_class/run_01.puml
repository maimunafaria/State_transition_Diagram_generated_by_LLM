@startuml
title Staff Member State Transition Diagram

initial : Unassigned

state "Unassigned" {}
state "Assigned to Client" {}
state "Assigned to Campaign" {}
state "Switching Assignments" {}
state "Unemployed" {}
state "Archived" {}

"Unassigned" --> "Assigned to Client" : Assign to Client
"Unassigned" --> "Assigned to Campaign" : Add to Campaign

"Assigned to Client" --> "Switching Assignments" : Switch Assignment
"Assigned to Campaign" --> "Switching Assignments" : Switch Assignment

"Switching Assignments" --> "Assigned to Client" : Switch to Client
"Switching Assignments" --> "Assigned to Campaign" : Switch to Campaign

"Unassigned" --> "Unemployed" : Leave Job
"Unemployed" --> "Archived" : After some time

@enduml
