@startuml
title Farm Management System State Transition Diagram

initial : Initial State

state "Logged Out" {}
state "Main Area" as MA {}
state "Market Conditions" as MC {}
state "Pest Control Help" as PCH {}
state "Soil Suggestions" as SS {}
state "Weather Insights" as WI {}
state "Labour Availability" as LA {}
state "Logged In" {}

initial --> Logged In : Login

Logged In --> MA : Sign in
MA --> MA : Continue

MA --> MC : Select Market Condition
MC --> MC : Continue

MC --> PCH : Select Pest Control Help
PCH --> PCH : Provide Photo
PCH --> PCH : Continue

PCH --> SS : Continue
SS --> SS : Continue

SS --> WI : Provide Location
WI --> WI : Continue

WI --> LA : Provide Location
LA --> LA : Continue

MA, MC, PCH, SS, WI, LA --> Logged Out : Logout

@enduml
