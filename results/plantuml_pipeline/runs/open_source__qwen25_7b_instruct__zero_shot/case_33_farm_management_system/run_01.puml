@startuml
title Farm Management System State Transition Diagram

initial : User is not logged in

state "Logged Out" as LOGGED_OUT {
    state "Main Area" as MAIN_AREA {
        initial : Initial State
        state "Market Conditions"
        state "Pest Control Help"
        state "Soil Suggestions"
        state "Weather Insights"
        state "Labour Availability"
    }
}

transition LOGGED_OUT to MAIN_AREA: User logs in

transition MAIN_AREA to "Market Conditions": User selects market condition
transition MAIN_AREA to "Pest Control Help": User selects pest control help
transition MAIN_AREA to "Soil Suggestions": User provides soil information
transition MAIN_AREA to "Weather Insights": User provides location
transition MAIN_AREA to "Labour Availability": User provides location

state "Logged In" as LOGGED_IN {
    state "Market Conditions"
    state "Pest Control Help"
    state "Soil Suggestions"
    state "Weather Insights"
    state "Labour Availability"
}

transition "Market Conditions" to LOGGED_IN: Continue using service
transition "Pest Control Help" to LOGGED_IN: Continue using service
transition "Soil Suggestions" to LOGGED_IN: Continue using service
transition "Weather Insights" to LOGGED_IN: Continue using service
transition "Labour Availability" to LOGGED_IN: Continue using service

final : User logs out

@enduml
