@startuml
title Farm Management System State Transition Diagram

initial : User Login
state "Logged Out" as loggedOut
state "Main Area" as mainArea
state "Market Conditions" as marketConditions
state "Pest Control Help" as pestControlHelp
state "Soil Suggestions" as soilSuggestions
state "Weather Insights" as weatherInsights
state "Labour Availability" as labourAvailability
state "Logged In" as loggedIn

loggedOut --> loggedIn : Login
loggedIn --> mainArea : Sign In
mainArea --> marketConditions : Select Market Condition
marketConditions --> mainArea : Continue
mainArea --> pestControlHelp : Select Pest Control Help
pestControlHelp --> mainArea : Provide Photo -> Continue
pestControlHelp --> pestControlHelpTechniques : Select Pest Control Techniques
pestControlHelpTechniques --> mainArea : Continue
mainArea --> soilSuggestions : Provide Soil Information
soilSuggestions --> mainArea : Continue
mainArea --> weatherInsights : Provide Location
weatherInsights --> mainArea : Continue
mainArea --> labourAvailability : Provide Location
labourAvailability --> mainArea : Continue
loggedIn --> loggedOut : Logout

@enduml
