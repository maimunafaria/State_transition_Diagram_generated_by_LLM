@startuml
title Farm Management System State Transition Diagram

initial : Initial State

state "Logged Out" {}
state "Main Area" as MA {}
state "Market Conditions" as MC {}
state "Pest Control Help" as PCH {}
state "Soil Suggestions" as SS {}
state "Weather Insights" as WI {}
state "Labour Availability" as LA {}
state "Viewing Results" as VR {}
state "Logged In" {}

initial --> Logged Out : Start

Logged Out --> MA : Log in
MA --> MC : Select Market Condition
MC --> MC : Stay
MC --> PCH : Select Pest Control Help
PCH --> PCH : Stay
PCH --> SS : Provide Photo
SS --> SS : Stay
SS --> WI : Provide Location
WI --> WI : Stay
WI --> LA : Provide Location
LA --> LA : Stay
LA --> VR : Continue Using Service
VR --> VR : Stay

MA --> VR : Continue Using Service
MC --> VR : Continue Using Service
PCH --> VR : Continue Using Service
SS --> VR : Continue Using Service
WI --> VR : Continue Using Service
LA --> VR : Continue Using Service

VR --> MA : Log in
VR --> MC : Select Market Condition
VR --> PCH : Select Pest Control Help
VR --> SS : Provide Photo
VR --> WI : Provide Location
VR --> LA : Provide Location

MA --> Logged Out : Logout
MC --> Logged Out : Logout
PCH --> Logged Out : Logout
SS --> Logged Out : Logout
WI --> Logged Out : Logout
LA --> Logged Out : Logout
VR --> Logged Out : Logout

@enduml
