@startuml
title Healthcare Portal State Transition Diagram

initial : Initial State

state "New User" {
    state "Registering" as r
    state "Registered"
}

state "User" {
    state "Signed In" as s
    state "Viewing Facilities"
    state "Reading News/Content"
    state "Checking Symptoms/Fitness"
    state "Using Finance Services"
    state "Payment Process"
    state "Logging Out"
}

r --> r : Registration Fails
r --> s : Registration Succeeds

s --> s : Continue Using System
s --> Viewing Facilities : Access Available Facilities
Viewing Facilities --> Reading News/Content : Read News and Content
Reading News/Content --> Checking Symptoms/Fitness : Check Symptoms or Fitness
Checking Symptoms/Fitness --> Using Finance Services : Use Health-Related Information
Using Finance Services --> Payment Process : Process and Validate Insurance
Payment Process --> s : Finish Session

s --> s : Continue Using System
s --> Logging Out : End of Session

@enduml
