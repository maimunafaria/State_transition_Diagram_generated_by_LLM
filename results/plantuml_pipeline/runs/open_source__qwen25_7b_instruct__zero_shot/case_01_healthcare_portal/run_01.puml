@startuml
title Healthcare Portal State Transition Diagram

initial : Initial State

state "New User" {
    state "Registering" as registering
    state "Registration Failed" as registrationFailed
}

state "Registered User" {
    state "Signed In" as signedIn
    state "Accessing Facilities" as accessingFacilities
    state "Reading Content" as readingContent
    state "Checking Symptoms/Fitness" as checkingSymptomsFitness
    state "Viewing Result" as viewingResult
    state "Payment Processing" as paymentProcessing
    state "Cash Payment Details" as cashPaymentDetails
    state "Insurance Payment Completed" as insurancePaymentCompleted
}

state "Session Ended" as sessionEnded

transition "Start Registration" from initial to registering
transition "Registration Failed" from registering to registrationFailed
transition "Sign In" from initial to signedIn
transition "Access Facilities" from signedIn to accessingFacilities
transition "Read Content" from accessingFacilities to readingContent
transition "Check Symptoms/Fitness" from readingContent to checkingSymptomsFitness
transition "View Result" from checkingSymptomsFitness to viewingResult
transition "Continue Using System" from viewingResult to accessingFacilities
transition "Finish Session" from viewingResult to sessionEnded

state "Payment Processing - Insurance" as paymentProcessingInsurance
transition "Process Payment with Insurance" from signedIn to paymentProcessingInsurance
transition "Complete Insurance Payment" from paymentProcessingInsurance to insurancePaymentCompleted

state "Payment Processing - Cash" as paymentProcessingCash
transition "Choose Cash Payment Method" from signedIn to paymentProcessingCash
transition "Show Cash Details" from paymentProcessingCash to cashPaymentDetails
transition "Proceed with Cash Payment" from cashPaymentDetails to sessionEnded

transition "Submit Feedback" from viewingResult to sessionEnded
transition "Log Out" from accessingFacilities to sessionEnded

@enduml
