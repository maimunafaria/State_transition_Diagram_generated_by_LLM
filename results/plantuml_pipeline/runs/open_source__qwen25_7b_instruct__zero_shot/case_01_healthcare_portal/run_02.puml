@startuml

title Healthcare Portal State Transition Diagram

initial : Initial State

state "New User" {
    state "Registering" as R
    state "Registered"
}

state "User" {
    state "Signed In" as S
    state "Accessing Facilities"
    state "Reading Content"
    state "Checking Symptoms/Fitness"
    state "Viewing Result" as V
    state "Finishing Session" as F
}

state "Session End" as E

R --> R : Registration Failure
R --> Registered : Registration Success
Registered --> S : Sign In

S --> Accessing Facilities : Access Facilities
Accessing Facilities --> S : Continue Using System
S --> Reading Content : Read News/Content
Reading Content --> V : View Result
V --> F : Finish Session
F --> E : Log Out

state "Payment" {
    state "Insurance Payment"
    state "Cash Payment"
}

S --> Insurance Payment : Select Insurance Payment
Insurance Payment --> E : Complete Payment Process

S --> Cash Payment : Select Cash Payment
Cash Payment --> E : Inform About Cash Details

E --> E : Final State

@enduml
