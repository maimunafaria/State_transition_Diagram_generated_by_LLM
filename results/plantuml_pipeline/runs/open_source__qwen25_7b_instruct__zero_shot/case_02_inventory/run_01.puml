@startuml

title Inventory System State Transition Diagram

initial : Initial State

state "Idle" {
    state "Add Goods"
    state "Update Price"
    state "Remove Goods"
    state "Identify Expired Goods"
    state "Place Order"
    state "Generate Invoice"
    state "Search Items"
    state "Calculate Discount and Tax"
    state "Generate Receipt"
    state "Replace Item or Cancel Receipt"
    state "Record Customer Requests"
    state "View Summary Report"

    initial --> Idle : Start

    Idle --> Add Goods : Add New Goods
    Idle --> Update Price : Update Price
    Idle --> Remove Goods : Remove Goods
    Idle --> Identify Expired Goods : Identify Expired Goods
    Idle --> Place Order : Place Order
    Idle --> Generate Invoice : Generate Invoice
    Idle --> Search Items : Search Items
    Idle --> Calculate Discount and Tax : Calculate Discount and Tax
    Idle --> Generate Receipt : Generate Receipt
    Idle --> Replace Item or Cancel Receipt : Replace Item/Cancel Receipt
    Idle --> Record Customer Requests : Record Customer Requests
    Idle --> View Summary Report : View Summary Report

    Add Goods --> Idle : Complete
    Update Price --> Idle : Complete
    Remove Goods --> Idle : Complete
    Identify Expired Goods --> Idle : Complete
    Place Order --> Generate Invoice : Place Order
    Generate Invoice --> Idle : Complete
    Search Items --> Idle : Complete
    Calculate Discount and Tax --> Generate Receipt : Calculate Discount and Tax
    Generate Receipt --> Idle : Complete
    Replace Item or Cancel Receipt --> Idle : Complete
    Record Customer Requests --> Idle : Complete
    View Summary Report --> Idle : Complete

}

@enduml
