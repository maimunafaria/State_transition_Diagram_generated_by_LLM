@startuml

title Inventory System State Transition Diagram

initial : Initial State

state "Inventory Idle" {
    state "Add New Goods"
    state "Update Price"
    state "Remove Goods"
    state "Identify Expired Goods"
    state "Place Order"
    state "Generate Invoice"
    state "Search Items"
    state "Calculate Discount and Tax"
    state "Generate Receipt"
    state "Replace Item or Cancel Receipt"
    state "Record Customer Requests"
    state "View Summary Report"

    initial --> "Inventory Idle" : Start

    "Inventory Idle" --> "Add New Goods" : Add new goods
    "Inventory Idle" --> "Update Price" : Update price
    "Inventory Idle" --> "Remove Goods" : Remove goods
    "Inventory Idle" --> "Identify Expired Goods" : Identify expired goods
    "Inventory Idle" --> "Place Order" : Place order

    "Add New Goods" --> "Inventory Idle" : Done adding
    "Update Price" --> "Inventory Idle" : Done updating
    "Remove Goods" --> "Inventory Idle" : Done removing
    "Identify Expired Goods" --> "Generate Invoice" : Notify removal
    "Place Order" --> "Generate Invoice" : Place order

    "Generate Invoice" --> "Inventory Idle" : Invoice generated
    "Search Items" --> "Select for Purchase" : Search items
    "Calculate Discount and Tax" --> "Generate Receipt" : Calculate tax
    "Generate Receipt" --> "Replace Item or Cancel Receipt" : Replace item/cancel receipt
    "Record Customer Requests" --> "Inventory Idle" : Record request
    "View Summary Report" --> "Inventory Idle" : View report

@enduml
