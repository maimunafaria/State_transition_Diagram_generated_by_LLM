@startuml

title Inventory System State Transition Diagram

initial : Initial State

state "Idle" as Idle {
}

state "Adding Goods" as AddingGoods {
}

state "Updating Prices" as UpdatingPrices {
}

state "Removing Goods" as RemovingGoods {
}

state "Identifying Expired Goods" as IdentifyingExpiredGoods {
}

state "Placing Order" as PlacingOrder {
}

state "Generating Invoice" as GeneratingInvoice {
}

state "Searching Items" as SearchingItems {
}

state "Calculating Discount and Tax" as CalculatingDiscountTax {
}

state "Generating Receipt" as GeneratingReceipt {
}

state "Replacing Item or Cancelling Receipt" as ReplacingItemCancellingReceipt {
}

state "Viewing Summary Report" as ViewingSummaryReport {
}

state "Final State" as FinalState {
}

Idle --> AddingGoods : Add New Goods
AddingGoods --> Idle : Done

Idle --> UpdatingPrices : Update Prices
UpdatingPrices --> Idle : Done

Idle --> RemovingGoods : Remove Goods
RemovingGoods --> Idle : Done

Idle --> IdentifyingExpiredGoods : Identify Expired Goods
IdentifyingExpiredGoods --> Idle : Done

Idle --> PlacingOrder : Place Order
PlacingOrder --> GeneratingInvoice : Generate Invoice
GeneratingInvoice --> Idle : Done

Idle --> SearchingItems : Search Items
SearchingItems --> CalculatingDiscountTax : Calculate Discount and Tax
CalculatingDiscountTax --> GeneratingReceipt : Generate Receipt
GeneratingReceipt --> Idle : Done

Idle --> ReplacingItemCancellingReceipt : Replace Item or Cancel Receipt
ReplacingItemCancellingReceipt --> Idle : Done

Idle --> ViewingSummaryReport : View Summary Report
ViewingSummaryReport --> Idle : Done

@enduml
