@startuml
title Green Rides - State Transition Diagram

initial : User Logged In

state "Journey Details Displayed" as JD {
    state "Driving Mode Activated" as DM
    state "Other Options Chosen" as OO
}

state "Place to Eat Selected" as PE
state "Order Placed" as OP
state "Accident Occurred" as AO
state "Feedback Provided" as FP

JD --> JD : View Journey Details
JD --> DM : Activate Driving Mode
JD --> OO : Choose Other Options
JD --> PE : Select Place to Eat
PE --> OP : View Menu and Place Order
AO --> AO : Inform Authorities
JD --> AO : Accident Occurred
DM --> DM : Send Driving Notifications
OO --> OO : Send Other Option Notifications
OP --> OP : Send Order Confirmation
AO --> FP : Provide Feedback

@enduml
