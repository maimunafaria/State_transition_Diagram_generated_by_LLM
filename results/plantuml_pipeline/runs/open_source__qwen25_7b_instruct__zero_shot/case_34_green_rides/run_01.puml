@startuml
title Green Rides - State Transition Diagram

initial : User Not Logged In

state "User Not Logged In" {}
state "Logged In, Journey Details Viewed" as JDetailsViewed {}
state "Driving Mode Activated" as DrivingMode {}
state "Eating Mode Activated" as EatingMode {}
state "Feedback Provided" as FeedbackProvided {}
state "Final State" {}

transition "Login & Select Destination" : -> JDetailsViewed
transition "Activate Driving Mode" : -> DrivingMode
transition "Select Place to Eat" : -> EatingMode
transition "Place Order" : -> EatingMode
transition "Accident Occurs" : -> FeedbackProvided
transition "End Journey" : -> FeedbackProvided

state "Logged In, Journey Details Viewed" as JDetailsViewed {}
state "Driving Mode Activated" as DrivingMode {}
state "Eating Mode Activated" as EatingMode {}
state "Feedback Provided" as FeedbackProvided {}

@enduml
