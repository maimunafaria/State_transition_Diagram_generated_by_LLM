@startuml
title Green Rides - State Transition Diagram

initial : User Not Logged In

state "User Not Logged In" {}
state "Logged In and Viewing Journey Details" as JD {}
state "Driving Mode Activated" as DM {}
state "Selecting Place to Eat" as E {}
state "Order Placed" as O {}
state "Accident Occurred" as A {}
state "Feedback Provided" as F {}

JD --> JD : Login
JD --> DM : Activate Driving Mode
JD --> E : Select Place to Eat
DM --> DM : Drive
DM --> A : Accident
DM --> F : Feedback
E --> O : Place Order
O --> JD : Done Ordering
A --> JD : Inform Authorities

@enduml
