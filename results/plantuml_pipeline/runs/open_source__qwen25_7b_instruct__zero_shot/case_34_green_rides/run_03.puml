@startuml
title Green Rides - State Transition Diagram

initial : Initial State

state "Login and Destination Selected" {}
state "Driving Mode Activated" as DrivingMode {}
state "Other Options Chosen" as OtherOptions {}
state "Eating Place Selection" as EatingPlace {}
state "Feedback Provided" as Feedback {}
state "Final State" {}

initial --> "Login and Destination Selected" : User Logs In and Selects Destination

"Login and Destination Selected" --> "Driving Mode Activated" : Activate Driving Mode
"Login and Destination Selected" --> "Other Options Chosen" : Choose Other Options

"Eating Place Selection" --> "Feedback Provided" : Finish Eating and Provide Feedback

"Driving Mode Activated" --> "Sending Notifications" : During Driving or Accident
"Driving Mode Activated" --> "Inform Authorities" : In Case of an Accident

"Other Options Chosen" --> "Eating Place Selection" : Select a Place to Eat

"Feedback Provided" --> "Final State" : Journey Completed

"Sending Notifications" --> "Final State" 
"Inform Authorities" --> "Final State"

@enduml
