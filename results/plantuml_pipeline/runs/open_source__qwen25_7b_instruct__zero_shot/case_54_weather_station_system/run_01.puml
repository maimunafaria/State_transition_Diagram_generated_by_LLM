@startuml
title Weather Station System State Transition Diagram

initial : [Initial State]
state Running {
    state Configuring
    state DataCollection
    state SummaryPreparation
    state StatusChecking
    state ControlledMode
    state Shutdown
}

initial --> Running : Restart and Begin Running

Running --> Configuring : Configuration Mode Requested
Configuring --> Running : Configuration Completed

Running --> DataCollection : Clock Trigger
DataCollection --> Running : Activity Finished

Running --> SummaryPreparation : Summary Preparation Requested
SummaryPreparation --> Running : Activity Finished

Running --> StatusChecking : Status Checking Requested
StatusChecking --> Running : Activity Finished

Running --> ControlledMode : Remote Control Command
ControlledMode --> Running : Exit Controlled Mode

Running --> Shutdown : Shutdown Command Given

state Shutdown {
    final : [Final State]
}

@enduml
