@startuml
title Weather Station System State Transition Diagram

initial : [Initial State]
state Running {
    state ConfigMode
    state Shutdown
    state ControlledMode
    
    * -> Running : Restart and begin running from a shut down condition
    Running --> Running : Clock triggers data collection
    Running --> Running : Prepare and send out weather summary upon request
    Running --> Running : Check own status and transmit result upon request
    Running --> ConfigMode : Changes or power-saving settings required
    ConfigMode --> Running : Configuration completed
    Running --> Shutdown : Shutdown command given while running
    Running --> ControlledMode : Remote control
    ControlledMode --> Running : Control ends
}
state Shutdown {
    * -> Running : Restart and begin running from a shut down condition
}

@enduml
