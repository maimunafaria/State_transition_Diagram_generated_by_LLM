@startuml
title Microwave Oven State Transition Diagram

initial : WaitingForInput
state WaitingForInput {}
state FullPowerCooking {}
state HalfPowerCooking {}
state DoorOpen {}
state Stopped {}

WaitingForInput --> FullPowerCooking : SelectFullPower
WaitingForInput --> HalfPowerCooking : SelectHalfPower
FullPowerCooking --> DoorOpen : OpenDoor
HalfPowerCooking --> DoorOpen : OpenDoor
Stopped --> WaitingForInput : CancelCooking
FullPowerCooking --> Stopped : StopButtonPressed
HalfPowerCooking --> Stopped : StopButtonPressed

state WaitingForInput final
state Stopped final

@enduml
