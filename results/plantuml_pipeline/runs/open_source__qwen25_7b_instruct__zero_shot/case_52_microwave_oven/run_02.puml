@startuml
title Microwave Oven State Transition Diagram

initial : WaitingForInput

state WaitingForInput {
    -> DisplayTime { "Display Current Time" }
}

state FullPowerCooking {
    [DoorOpen] --> StoppedOrCancelled { "Stop Immediately" }
    [UserCancel] --> StoppedOrCancelled { "User Cancels Cooking" }
    [TimeElapsed] --> WaitingForInput { "Time Ends" }
}

state HalfPowerCooking {
    [DoorOpen] --> StoppedOrCancelled { "Stop Immediately" }
    [UserCancel] --> StoppedOrCancelled { "User Cancels Cooking" }
    [TimeElapsed] --> WaitingForInput { "Time Ends" }
}

state StoppedOrCancelled {
    -> WaitingForInput { "Return to Display Time" }
}

@enduml
