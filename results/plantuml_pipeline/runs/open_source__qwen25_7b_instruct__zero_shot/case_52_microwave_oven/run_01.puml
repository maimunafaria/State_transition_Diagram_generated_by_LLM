@startuml
title Microwave Oven State Transition Diagram

initial : WaitingForInput

state WaitingForInput {
    -> DisplayTime { "Display Current Time" }
}

state FullPowerCooking {
    [DoorOpen] --> Stopped { "Stop Immediately" }
    -> CancelCooking { "User Cancels Cooking" } --> Stopped
    -> WaitingForInput { "End of Cooking or Cancellation" }
}

state HalfPowerCooking {
    [DoorOpen] --> Stopped { "Stop Immediately" }
    -> CancelCooking { "User Cancels Cooking" } --> Stopped
    -> WaitingForInput { "End of Cooking or Cancellation" }
}

state Stopped {
    <|-- WaitingForInput { "After Stopping/Cancelling" }
    <|-- FullPowerCooking { "Start Full Power Cooking" }
    <|-- HalfPowerCooking { "Start Half Power Cooking" }
}

@enduml
