@startuml

title ATM State Transition Diagram

initial : Initial State

state "Card Inserted" {
    state "Greeting User" {
        initial : Initial; -> "User Arrives"
        : Greet User;
    }
    
    state "PIN Check" {
        : Check PIN; -[Correct]-> "Display Options"
        : Check PIN; -[Incorrect]-> "Try Again"
    }

    state "Try Again" {
        : Try Again; -[Correct]-> "Display Options"
        : Try Again; -[Incorrect]-> "Keep Card Securely"
    }
    
    state "Display Options" {
        : Display Options;
        : Process Request; -[User Chooses]-> "Process Request"
    }

    state "Keep Card Securely" {
        : Keep Card Securely
    }

    state "Return Card" {
        : Return Card
    }
}

state "Card Not Inserted" {
    initial : Initial; -> "Card Inserted"
}

: Final State

@enduml
