@startuml
title ATM State Transition Diagram

initial : Initial State

state "Card Inserted" {
    state "Greeting User" {
        initial : Yes
        state "PIN Check"
        state "Try Again"
        state "Card Kept for Security"
        state "Return Card"
        state "Options Displayed"
        state "Request Processed"
    }
}

state "Cancelled Operation" {}

:User Arrives;
-> "Card Inserted" : Card Inserted

"Card Inserted" --> "Greeting User" : Greeting
"Greeting User" --> "PIN Check" : PIN Entered

"PIN Check" --> "Try Again" : Incorrect PIN
"PIN Check" --> "Options Displayed" : Correct PIN

"Try Again" --> "PIN Check" : Try Again

"Card Inserted" --> "Cancelled Operation" : Cancelled

"Options Displayed" --> "Request Processed" : Request Selected

"PIN Check" --> "Card Kept for Security" : Invalid Card
"PIN Check" --> "Return Card" : Too Many Incorrect PIN Attempts

"Card Kept for Security" : Final State
"Return Card" : Final State
"Options Displayed" : Final State
"Request Processed" : Final State

@enduml
