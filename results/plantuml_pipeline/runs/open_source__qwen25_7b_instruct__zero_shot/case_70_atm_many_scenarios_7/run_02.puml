@startuml
title ATM State Transition Diagram

initial : Initial State

state "Card Inserted" {
    state "Greeting User" {
        initial : Initial; -> "User Arrives"
    }
    state "PIN Check" {
        "PIN Correct" --> "Display Options"
        "PIN Incorrect" --> "Try Again"
    }
    state "Try Again" {
        "Attempt 1" --> "PIN Incorrect (2)" : "Incorrect PIN"
        "Attempt 2" --> "Card Kept for Security" : "Incorrect PIN"
        "Cancel Operation" --> "Return Card"
    }
    state "Card Kept for Security" {}
    state "Return Card" {
        "User Cancels" --> "Initial State"
    }
}

state "Display Options" {
    initial : Initial; -> "PIN Correct"
    "Withdraw Money" --> "Process Request"
    "Check Information" --> "Process Request"
    "Make Transfer" --> "Process Request"
}

state "Process Request" {}

final : Final State
@enduml
