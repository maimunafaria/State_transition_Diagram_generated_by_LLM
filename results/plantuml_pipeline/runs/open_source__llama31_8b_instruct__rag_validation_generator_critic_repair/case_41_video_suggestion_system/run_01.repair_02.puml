@startuml
title Video Suggestion System State Machine

[*] --> Idle
state Idle {
  Idle --> ReceiveRequest
  ReceiveRequest --> Processing : receive request
  Processing --> GatherVideos : gather videos
  GatherVideos --> AddDetails : add details
  AddDetails --> SendVideos : send videos
  SendVideos --> Idle : idle
  Idle --> [*]
}

state ReceiveRequest {
  ReceiveRequest --> Processing
}

state Processing {
  Processing --> Idle
}

state GatherVideos {
  GatherVideos --> AddDetails
}

state AddDetails {
  AddDetails --> SendVideos
}

state SendVideos {
  SendVideos --> Idle
}

@enduml
