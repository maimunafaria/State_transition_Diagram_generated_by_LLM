@startuml
title Video Suggestion System State Machine

[*] --> Idle
state Idle {
  Idle --> ReceiveRequest : receive request
  ReceiveRequest --> Processing : gather videos
  Processing --> GatherVideos : gather videos
  GatherVideos --> AddDetails : add details
  AddDetails --> SendVideos : send videos
  SendVideos --> Idle : idle
}

state ReceiveRequest {
  ReceiveRequest --> Idle : idle
}

state Processing {
  Processing --> GatherVideos : gather videos
}

state GatherVideos {
  GatherVideos --> AddDetails : add details
}

state AddDetails {
  AddDetails --> SendVideos : send videos
}

state SendVideos {
  SendVideos --> Idle : idle
  SendVideos --> [*] : idle
}

@enduml
