@startuml
title Farm Management System

[*] --> Login

state Login
Login : entry / getInfo
Login : do / verifyData
Login : exit / verified

state LoginDecision <<choice>>
Login --> LoginDecision

state "Valid Login" as ValidLogin
ValidLogin : entry / contain Info
ValidLogin : do / allow Access to system
ValidLogin : exit / gallery Entry
ValidLogin --> LoggedOut

state "Invalid Login" as InvalidLogin
InvalidLogin : entry / wrong Info
InvalidLogin : do / display Error message
InvalidLogin : exit / return To Start
InvalidLogin --> LoggedOut

LoginDecision --> ValidLogin [valid]
LoginDecision --> InvalidLogin [invalid]

state NavChoice <<choice>>
ValidLogin --> NavChoice

state Dashboard
Dashboard : entry / show Products
Dashboard : do / allow to select Products
Dashboard : exit / save Products

state MarketConditions
MarketConditions : entry / show Market Conditions
MarketConditions : do / allow to select Market Conditions
MarketConditions : exit / save Market Conditions

state MarketReport
MarketReport : entry / show Market Report
MarketReport : do / allow to select Market Report
MarketReport : exit / save Market Report

state PestControl
PestControl : entry / show Pest Control
PestControl : do / allow to select Pest Control
PestControl : exit / save Pest Control

state SoilSuggestions
SoilSuggestions : entry / show Soil Suggestions
SoilSuggestions : do / allow to select Soil Suggestions
SoilSuggestions : exit / save Soil Suggestions

state WeatherInsights
WeatherInsights : entry / show Weather Insights
WeatherInsights : do / allow to select Weather Insights
WeatherInsights : exit / save Weather Insights

state LabourAvailability
LabourAvailability : entry / show Labour Availability
LabourAvailability : do / allow to select Labour Availability
LabourAvailability : exit / save LabourAvailability

NavChoice --> Dashboard
NavChoice --> MarketConditions
NavChoice --> MarketReport
NavChoice --> PestControl
NavChoice --> SoilSuggestions
NavChoice --> WeatherInsights
NavChoice --> LabourAvailability

PestControl --> PhotoRequired
PhotoRequired : entry / require Photo
PhotoRequired : do / allow to upload Photo
PhotoRequired : exit / save Photo

SoilSuggestions --> SoilInfo
SoilInfo : entry / get Soil Info
SoilInfo : do / provide Soil Suggestions
SoilInfo : exit / save Soil Suggestions

WeatherInsights --> Location
Location : entry / get Location
Location : do / provide Weather Insights
Location : exit / save Weather Insights

LabourAvailability --> Location
Location --> LabourAvailability

state Logout
Logout : entry / exit System
Logout : do / end Session
Logout : exit / end
Logout --> [*]

Dashboard --> Logout
MarketConditions --> Logout
MarketReport --> Logout
PestControl --> Logout
SoilSuggestions --> Logout
WeatherInsights --> Logout
LabourAvailability --> Logout

@enduml
