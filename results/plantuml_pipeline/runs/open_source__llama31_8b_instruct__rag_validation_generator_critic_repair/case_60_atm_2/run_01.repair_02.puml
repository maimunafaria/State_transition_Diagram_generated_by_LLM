@startuml
title ATM Control - Withdraw Funds

[*] --> WaitingForAmount

state WaitingForAmount
state VerifyingTransaction
state ReleasingCard

WaitingForAmount --> VerifyingTransaction : enterAmount
VerifyingTransaction --> WaitingForAmount : invalidAmount
VerifyingTransaction --> ReleasingCard : validAmount
ReleasingCard --> [*] : end

@enduml
