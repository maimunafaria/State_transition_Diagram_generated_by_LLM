@startuml
title Inventory Management System

[*] --> AddGoods
state "Add Goods" as AddGoods
state "Update Price" as UpdatePrice
state "Remove Goods" as RemoveGoods
state "Expired Goods" as ExpiredGoods
state "Place Order" as PlaceOrder
state "Generate Invoice" as GenerateInvoice
state "Search Items" as SearchItems
state "Calculate Discount" as CalculateDiscount
state "Generate Receipt" as GenerateReceipt
state "Replace Item" as ReplaceItem
state "Cancel Receipt" as CancelReceipt
state "Record Requests" as RecordRequests
state "View Transactions" as ViewTransactions

AddGoods --> UpdatePrice
UpdatePrice --> RemoveGoods
RemoveGoods --> ExpiredGoods
ExpiredGoods --> PlaceOrder
PlaceOrder --> GenerateInvoice
GenerateInvoice --> SearchItems
SearchItems --> CalculateDiscount
CalculateDiscount --> GenerateReceipt
GenerateReceipt --> ReplaceItem
ReplaceItem --> CancelReceipt
CancelReceipt --> RecordRequests
RecordRequests --> ViewTransactions
[*] --> AddGoods
AddGoods --> PlaceOrder
PlaceOrder --> GenerateInvoice
GenerateInvoice --> SearchItems
SearchItems --> CalculateDiscount
CalculateDiscount --> GenerateReceipt
GenerateReceipt --> ReplaceItem
ReplaceItem --> CancelReceipt
CancelReceipt --> RecordRequests
RecordRequests --> ViewTransactions
ViewTransactions --> [*]

@enduml
