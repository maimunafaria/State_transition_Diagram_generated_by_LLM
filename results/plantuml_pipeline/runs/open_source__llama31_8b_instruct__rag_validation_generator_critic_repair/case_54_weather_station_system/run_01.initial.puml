@startuml
[*] --> Idle
Idle --> [*]

state Idle {
  [*] --> Restarting
  Restarting --> Running : restartComplete
}

state Running {
  [*] --> Configuring
  Configuring --> Running : configComplete
  Running --> CollectingData : collectDataTriggered
  CollectingData --> Running : dataCollectionComplete
  Running --> PreparingSummary : prepareSummaryTriggered
  PreparingSummary --> Running : summaryPrepared
  Running --> CheckingStatus : checkStatusTriggered
  CheckingStatus --> Running : statusChecked
}

state Configuring {
  [*] --> SavingSettings
  SavingSettings --> Configuring : settingsSaved
}

state Controlled {
  [*] --> Running
  Running --> Controlled : remoteControlCommand
}

state ShuttingDown {
  [*] --> Idle
  Idle --> ShuttingDown : shutdownCommand
}

Idle --> ShuttingDown : shutdownCommand
@enduml
