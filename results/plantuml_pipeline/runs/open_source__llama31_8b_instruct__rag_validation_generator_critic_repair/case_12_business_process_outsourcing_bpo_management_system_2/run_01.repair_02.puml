@startuml
title UML State Machine Diagram (Search Users)

[*] --> SearchByCategory

state SearchByCategory <<choice>>
SearchByCategory --> SearchByPrice : [Search by price]
SearchByCategory --> DisplayMatchingUsers : [Search by category]

state "Search by price" as SearchByPrice
state "Search by category" as SearchByCategory

SearchByPrice --> DisplayMatchingUsers : [Search by price]
SearchByCategory --> DisplayMatchingUsers : [Search by category]

state "Display matching users" as DisplayMatchingUsers

[*] --> SearchByPrice
SearchByCategory --> DisplayMatchingUsers : [Search by category]

DisplayMatchingUsers --> [*]

@enduml
