@startuml
title UML State Machine Diagram (Search Users)

[*] --> SearchCategory

state SearchCategory <<choice>>
SearchCategory --> PriceRange : [price range]
SearchCategory --> FilterCategory : [filter category]

state "Search by price range" as PriceRange
state "Search by filter category" as FilterCategory

SearchCategory --> PriceRange : [price range]
SearchCategory --> FilterCategory : [filter category]

PriceRange --> DisplayResults : [matching users]
FilterCategory --> DisplayResults : [matching users]

state "Display matching users" as DisplayResults

DisplayResults --> [*]

@enduml
