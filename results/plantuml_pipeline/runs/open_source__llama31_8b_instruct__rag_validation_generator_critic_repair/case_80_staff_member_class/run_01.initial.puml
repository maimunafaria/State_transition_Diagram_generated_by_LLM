@startuml
[*] --> Assigned
state Assigned {
  [*] --> AssignedToClient
  AssignedToClient --> AssignedToCampaign : assign to campaign
  AssignedToClient --> AssignedToClient : assign to client
  AssignedToCampaign --> Unassigned : remove from campaign
  Unassigned --> Assigned : reassign
}

state Unemployed {
  [*] --> Unemployed : mark as unemployed
}

state Archived {
  [*] --> Archived : archive record
}

AssignedToClient --> Unemployed : leave job
AssignedToCampaign --> Unemployed : leave job
Unemployed --> Archived : archive record
Archived --> [*] : record archived

@enduml
