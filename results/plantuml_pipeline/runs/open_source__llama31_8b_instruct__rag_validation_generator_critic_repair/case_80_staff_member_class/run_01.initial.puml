@startuml
[*] --> StaffMember

state StaffMember {
  [*] --> Assigned
  Assigned --> [*] : remove assignment
  Assigned --> Assigned : switch assignment
  Assigned --> Unassigned : remove assignment

  state Unassigned {
    [*] --> Assigned : assign to client or campaign
  }

  state Employed {
    [*] --> Unemployed : mark as unemployed
  }

  state Unemployed {
    [*] --> Archived : archive record
  }

  state Archived {
    [*] --> Unemployed : restore record
  }
}

@enduml
