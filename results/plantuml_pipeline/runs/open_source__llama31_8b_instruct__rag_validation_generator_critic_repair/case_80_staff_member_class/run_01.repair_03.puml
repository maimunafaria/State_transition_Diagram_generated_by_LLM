@startuml
[*] --> Assigned
state Assigned {
  Assigned --> AssignedToClient : assign to client
  AssignedToClient --> AssignedToCampaign : assign to campaign
  AssignedToCampaign --> Unassigned : remove from campaign
  Unassigned --> Assigned : reassign
}

state Unemployed {
  Unemployed --> Unemployed : mark as unemployed
}

state Archived {
  Archived --> Archived : archive record
}

AssignedToClient --> Unemployed : leave job
AssignedToCampaign --> Unemployed : leave job
Unemployed --> Archived : archive record
Archived --> [*] : record archived

state Unassigned {
  Unassigned --> Unemployed : mark as unemployed
  Unemployed --> Unassigned : rehire
}

UnassignedToClient --> Unemployed : leave job
UnassignedToCampaign --> Unemployed : leave job
@enduml
