@startuml
[*] --> StaffMember

state StaffMember {
  [*] --> Assigned
  Assigned --> [*] : remove assignment
  StaffMember --> Unassigned : assign to client or campaign

  state Unassigned {
    Unassigned --> Assigned : remove assignment
  }

  state Employed {
    StaffMember --> Employed :
    Employed --> Unemployed : mark as unemployed
  }

  state Unemployed {
    Unemployed --> Archived : archive record
  }

  state Archived {
    Unemployed --> Archived : archive record
  }
}

@enduml
