@startuml
[*] --> CreateAccount
state CreateAccount {
  CreateAccount --> Login
  Login --> [*] : login successful
  Login --> InvalidLogin : login failed
}

state Login {
  Login --> Dashboard
  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
}

state Dashboard {
  Dashboard --> ViewWeather
  ViewWeather --> [*] : view weather
  ViewWeather --> InvalidLocation : invalid location
}

state ViewWeather {
  ViewWeather --> SelectWeatherInfo
  SelectWeatherInfo --> [*] : select weather info
  SelectWeatherInfo --> InvalidSelection : invalid selection
}

state SelectWeatherInfo {
  SelectWeatherInfo --> ViewAdditionalDetails
  ViewAdditionalDetails --> [*] : view additional details
  ViewAdditionalDetails --> InvalidSelection : invalid selection
}

state ViewAdditionalDetails {
  ViewAdditionalDetails --> Logout
  Logout --> [*] : logout
}

state Logout {
  Logout --> End
  End --> [*] : end
}

[*] --> End
@enduml
