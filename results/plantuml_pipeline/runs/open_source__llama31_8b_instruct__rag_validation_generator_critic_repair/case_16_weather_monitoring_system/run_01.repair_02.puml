@startuml
[*] --> J1 : [check user]
state J1 <<choice>>
state J2 <<choice>>
state J3 <<choice>>
state J4 <<choice>>
state "Register" as Register
Register : entry/when the user are user
Register : do/Register process
Register : exit/ successful registration
Register : exit/ invalid registration
Register --> [*] : [end registration]

state "Login" as Login {
  state "Patient dashboard" as PatientDashboard
  PatientDashboard : entry/if the user is logged in as patient
  PatientDashboard : do/dashboard is displayed
  PatientDashboard --> [*] : [end session]
  PatientDashboard --> Login : [login again]

  state "LoggedOut" as LoggedOut
  LoggedOut : entry/user logged out
  LoggedOut --> [*] : [end session]
  LoggedOut --> Login : [login again]

  state "AccessEnded" as AccessEnded
  AccessEnded : entry/access ended
  AccessEnded --> [*] : [end session]
  AccessEnded --> Login : [login again]
}

J1 --> J2 : [register]
J1 --> J3 : [login]
J2 --> Register : [register]
J3 --> Login : [login]
J4 --> Login : [login]

[*] --> J4 : [check user]

@enduml
