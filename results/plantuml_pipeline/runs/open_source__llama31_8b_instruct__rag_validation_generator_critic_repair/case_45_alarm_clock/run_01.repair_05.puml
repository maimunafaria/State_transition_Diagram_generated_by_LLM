@startuml
[*] --> Off
Off --> Idle

state Off {
  Idle --> SetAlarm : set alarm
}

state Idle {
  SetAlarm --> AlarmActive : alarm active
}

state AlarmActive {
  RingAlarm --> [*] : stop alarm
}

AlarmActive --> Off : next alarm
Off --> Idle : idle

state AlarmActive {
  AlarmActive --> RingAlarm : ring alarm
}

state RingAlarm {
  AlarmActive --> Off : next alarm
}

@enduml
