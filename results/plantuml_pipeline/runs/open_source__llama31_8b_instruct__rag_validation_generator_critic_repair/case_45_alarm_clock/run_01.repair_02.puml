@startuml
[*] --> Off
Off --> Idle

state Off {
  Idle --> [*]
}

state Idle {
  [*] --> SetAlarm : set alarm
  SetAlarm --> AlarmActive : alarm active
}

state AlarmActive {
  [*] --> RingAlarm : ring alarm
  RingAlarm --> [*] : stop alarm
}

AlarmActive --> Off : next alarm
Off --> Idle : idle

@enduml
