@startuml
[*] --> Off

state Off {
  Off --> Idle
}

state Idle {
  Idle --> SetAlarm : set alarm
  SetAlarm --> AlarmActive : alarm active
}

state AlarmActive {
  AlarmActive --> RingAlarm : ring alarm
  RingAlarm --> AlarmActive : stop alarm
}

AlarmActive --> Off : next alarm
Off --> Idle : idle

@enduml
