@startuml
title State diagram of the system operations of "Process Sale"

[*] --> WaitingForSale

state "Waiting for sale" as WaitingForSale
state "Enter items" as EnterItems
state "Waiting for payment" as WaitingPayment
state "Payment approved" as PaymentApproved
state "Sale completed" as SaleCompleted

[*] --> WaitingForSale : new sale
WaitingForSale --> EnterItems : new sale
EnterItems --> EnterItems : add item
EnterItems --> WaitingPayment : end of sale
WaitingPayment --> PaymentApproved : payment confirmed
PaymentApproved --> SaleCompleted : payment approved
SaleCompleted --> WaitingForSale : next customer
SaleCompleted --> [*] : sale ended

@enduml
