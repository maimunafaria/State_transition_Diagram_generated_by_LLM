@startuml
title Microwave Oven State Machine

[*] --> Idle
Idle --> [*]

state Idle {
  [*] --> DisplayTime
  DisplayTime --> Idle : user input
}

state DisplayTime {
  [*] --> ChoosePower
  ChoosePower --> DisplayTime : user input
}

state ChoosePower {
  [*] --> SetTime
  SetTime --> ChoosePower : user input
}

state SetTime {
  [*] --> Cooking
  Cooking --> DoorOpen : door opened
}

state Cooking {
  [*] --> DoorOpenItem
  DoorOpenItem --> Cooking : door opened
}

state DoorOpenItem {
  [*] --> DoorShutItem
  DoorShutItem --> Cooking : door closed
}

state DoorShutItem {
  [*] --> ReadyToCook
  ReadyToCook --> Cooking : cooking time entered
}

state ReadyToCook {
  [*] --> Cooking
  Cooking --> DoorOpenItem : start
}

state DoorOpenItem {
  [*] --> DoorShutItem
  DoorShutItem --> Cooking : door closed
}

state DoorShutItem {
  [*] --> ReadyToCook
  ReadyToCook --> Cooking : cooking time entered
}

state Cooking {
  [*] --> DoorOpenItem : timer expired
}

