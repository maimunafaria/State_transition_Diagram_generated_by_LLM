@startuml
title Microwave Oven State Machine

[*] --> Idle
Idle --> DisplayTime
DisplayTime --> ChoosePower
ChoosePower --> SetTime
SetTime --> Cooking
Cooking --> DoorOpenItem
DoorOpenItem --> DoorShutItem
DoorShutItem --> ReadyToCook
ReadyToCook --> Cooking
Cooking --> DoorOpenItem : timer expired

state DisplayTime {
  [*] --> ChoosePower
  ChoosePower --> DisplayTime : user input
}

state ChoosePower {
  [*] --> SetTime
  SetTime --> ChoosePower : user input
}

state SetTime {
  [*] --> Cooking
  Cooking --> DoorOpenItem : door opened
}

state DoorOpenItem {
  [*] --> DoorShutItem
  DoorShutItem --> Cooking : door closed
}

state DoorShutItem {
  [*] --> ReadyToCook
  ReadyToCook --> Cooking : cooking time entered
}

state Cooking {
  [*] --> DoorOpenItem : timer expired
}

state DoorOpenItem {
  [*] --> DoorShutItem
  DoorShutItem --> Cooking : door closed
}

state DoorShutItem {
  [*] --> ReadyToCook
  ReadyToCook --> Cooking : cooking time entered
}

state ReadyToCook {
  [*] --> Cooking
  Cooking --> DoorOpenItem : start
}

state DoorOpenItem {
  [*] --> DoorShutItem
  DoorShutItem --> Cooking : door closed
}

state DoorShutItem {
  [*] --> ReadyToCook
  ReadyToCook --> Cooking : cooking time entered
