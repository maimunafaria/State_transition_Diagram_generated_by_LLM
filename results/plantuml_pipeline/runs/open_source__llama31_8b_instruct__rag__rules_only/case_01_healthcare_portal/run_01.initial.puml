@startuml
[*] --> Registered
Registered --> SignedIn : sign in successful
SignedIn --> FacilitiesAvailable : access granted
FacilitiesAvailable --> NewsAndExpertContent : available
NewsAndExpertContent --> HealthInfo : health-related info
HealthInfo --> ContinueOrFinish : continue or finish session
ContinueOrFinish --> PaymentProcessed : payment processed
PaymentProcessed --> InsuranceValidation : insurance validation
InsuranceValidation --> PaymentMethodSelected : payment method selected
PaymentMethodSelected --> CashPaymentDetails : cash payment details
CashPaymentDetails --> InsuranceBasedPayment : insurance-based payment
InsuranceBasedPayment --> PaymentCompleted : payment completed
PaymentCompleted --> UserFeedback : user feedback collected
UserFeedback --> LoggedOut : session ended

state "Waiting for Registration" as WaitingRegistration
state "Registration Failed" as RegistrationFailed
state "Signing In" as SigningIn
state "Access Denied" as AccessDenied
state "News and Expert Content" as NewsAndExpertContent
state "Health Information" as HealthInfo
state "Payment Processing" as PaymentProcessing

note right of SignedIn : validate user credentials
note left of FacilitiesAvailable : check access permissions
note right of NewsAndExpertContent : display content
note left of HealthInfo : provide health-related info
note right of ContinueOrFinish : allow user to continue or finish session
note left of PaymentProcessed : process payment
note right of InsuranceValidation : validate insurance
note left of PaymentMethodSelected : select payment method
note right of CashPaymentDetails : display cash payment details
note left of InsuranceBasedPayment : complete insurance-based payment
note right of PaymentCompleted : complete payment
note left of UserFeedback : collect user feedback
note right of LoggedOut : log out user

state "Registration" {
  [*] --> WaitingRegistration
  WaitingRegistration --> Registered : registration successful
  Registered --> RegistrationFailed : registration failed
}

state "Payment" {
  PaymentProcessing --> PaymentCompleted : payment completed
  PaymentProcessing --> AccessDenied : access denied
}
@enduml
