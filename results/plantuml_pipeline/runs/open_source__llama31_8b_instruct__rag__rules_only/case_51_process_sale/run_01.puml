@startuml
state "Waiting for New Sale" as WaitingSale
state "Adding Items to Order" as AddingItems
state "Payment Method Selected" as PaymentMethod
state "Verifying Payment" as VerifyingPay
state "Order Completed Successfully" as OrderComplete
state "Returning to Waiting State" as ReturningWait

[*] --> WaitingSale [*]
WaitingSale --> AddingItems : new sale detected
AddingItems --> PaymentMethod : all items added
PaymentMethod --> VerifyingPay : payment method selected
VerifyingPay --> OrderComplete : payment verified
OrderComplete --> ReturningWait : order completed
ReturningWait --> WaitingSale [*]

@enduml
