@startuml
state "Select Amount" as SelectAmount
state "Enter Custom Value" as EnterCustomValue
state "Verify Transaction" as VerifyTransaction
state "Re-enter Amount" as ReenterAmount

[*] --> SelectAmount
SelectAmount --> EnterCustomValue : user wants custom value
SelectAmount --> VerifyTransaction : user selects amount from options
EnterCustomValue --> VerifyTransaction : user enters custom value
VerifyTransaction --> ReenterAmount : transaction rejected
VerifyTransaction --> "Transaction Complete" : transaction verified

@enduml
