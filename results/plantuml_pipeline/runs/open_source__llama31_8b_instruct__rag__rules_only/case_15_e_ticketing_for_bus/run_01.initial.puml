@startuml
[*] --> CreateAccount : create new account
CreateAccount --> ValidateRegistration : validate registration
ValidateRegistration --> LoginSuccessful : successful registration
LoginSuccessful --> CheckTicketStatus : check ticket status
CheckTicketStatus --> BookTicket : book ticket
BookTicket --> ConfirmPayment : confirm payment
ConfirmPayment --> OrderComplete : order complete

state CreateAccount {
  [*] --> ValidateRegistration : fill in details
}

state ValidateRegistration {
  ValidateRegistration --> LoginSuccessful : valid registration
  ValidateRegistration --> Error : invalid registration
}

state LoginSuccessful {
  LoginSuccessful --> CheckTicketStatus : logged in
  LoginSuccessful --> Logout : logout
}

state CheckTicketStatus {
  CheckTicketStatus --> BookTicket : check ticket status
  CheckTicketStatus --> Dashboard : dashboard
}

state BookTicket {
  BookTicket --> ConfirmPayment : book ticket
  BookTicket --> Cancel : cancel booking
}

state ConfirmPayment {
  ConfirmPayment --> OrderComplete : payment confirmed
  ConfirmPayment --> Cancel : cancel payment
}

state OrderComplete {
  OrderComplete --> Logout : order complete
}

state Dashboard {
  Dashboard --> Settings : dashboard
  Dashboard --> Logout : logout
}

state Settings {
  Settings --> Dashboard : back
}

Logout --> [*] : logout

@enduml
