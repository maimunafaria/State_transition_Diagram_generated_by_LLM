@startuml
[*] --> IdentifyUserType
IdentifyUserType --> RegisterCitizen : user not registered
RegisterCitizen --> LoginDetailsCorrect : login details correct
LoginDetailsCorrect --> LoggedIn : logged in successfully
LoggedIn --> UploadDocuments : upload documents
LoggedIn --> ViewProfile : view profile
LoggedIn --> ApplyForCertificate : apply for certificate
UploadDocuments --> ContinueUploading : continue uploading documents
ApplyForCertificate --> ReapplyCertificate : reapply after sending request
ReapplyCertificate --> RequestedCertificates : certificates requested
RequestedCertificates --> ContinueRequesting : continue requesting more certificates
LoginDetailsCorrect --> LoginFailed : login details incorrect
LoggedIn --> EndSession : end session

state "Logged In" as LoggedIn {
  [*] --> Dashboard
  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
}

LoggedIn --> [*] : logout
@enduml
