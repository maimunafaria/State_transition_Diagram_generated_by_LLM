@startuml
[*] --> Idle
Idle --> ConfigMode : changes or power-saving settings required
ConfigMode --> Running : configuration completed
Running --> CollectData : triggered by clock
CollectData --> PrepareSummary : data collection complete
PrepareSummary --> SendSummary : summary prepared and sent
SendSummary --> CheckStatus : summary preparation complete
CheckStatus --> Running : status checked and transmitted
Running --> ControlledMode : remote control command received
ControlledMode --> Shutdown : shutdown command received while running
Shutdown --> [*] : shut down condition reached

state ConfigMode {
  [*] --> Configure : configuration mode entered
  Configure --> Running : configuration completed
}

state CollectData {
  [*] --> PrepareSummary : data collection complete
}
@enduml
