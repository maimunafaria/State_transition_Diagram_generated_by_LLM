@startuml
[*] --> LoggedIn

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> MarketConditions : show market conditions
  Dashboard --> PestControlHelp : pest control help
  PestControlHelp --> ShowPestControlTechniques : show pest control techniques
  Dashboard --> SoilSuggestions : soil suggestions
  Dashboard --> WeatherInsights : weather insights
  Dashboard --> LabourAvailability : labour availability
}

LoggedIn --> [*] : logout

state MarketConditions {
  [*] --> ViewMarketReport : view market report
}

state PestControlHelp {
  [*] --> ProvidePhoto : provide photo
}

state SoilSuggestions {
  [*] --> ShowCropSuitability : show crop suitability
}

state WeatherInsights {
  [*] --> DisplayWeatherForecast : display weather forecast
}

state LabourAvailability {
  [*] --> ViewLabourDetails : view labour details
}
@enduml
