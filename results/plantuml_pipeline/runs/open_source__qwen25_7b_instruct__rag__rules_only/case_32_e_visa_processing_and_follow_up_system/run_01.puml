@startuml
[*] --> AccountCreated

state AccountCreated {
  [*] --> LoggedIn : login
}

state LoggedIn {
  LoggedIn --> VisaApplication : apply for visa, make payment, accept application
  VisaApplication --> ViewStatus : view status
  ViewStatus --> CheckStatus : check status
  CheckStatus --> CancelApplication : cancel application
  CheckStatus --> ModifyDetails : modify details
  ModifyDetails --> ViewDetails : view details
  ViewDetails --> ViewPurpose : view purpose of application, based on document check, update status
  ViewPurpose --> GiveFeedback : give feedback
  GiveFeedback --> Logout : log out
}

state CancelApplication {
  [*] --> LoggedIn : login
}

state ModifyDetails {
  [*] --> LoggedIn : login
}

state ViewDetails {
  [*] --> LoggedIn : login
}

state ViewPurpose {
  [*] --> LoggedIn : login
}

state GiveFeedback {
  [*] --> CheckedStatus : check status
}

LoggedIn --> [*] : logout
@enduml
