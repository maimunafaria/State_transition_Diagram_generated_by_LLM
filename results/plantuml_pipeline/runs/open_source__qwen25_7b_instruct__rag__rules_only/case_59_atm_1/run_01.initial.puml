@startuml

state "Waiting for Withdrawal Amount Selection" as WaitingSelection

[*] --> WaitingSelection : start

WaitingSelection --> PredefinedAmountSelected : user selects predefined amount
WaitingSelection --> CustomAmountEntered : user enters custom amount
WaitingSelection --> TransactionCancelled : user cancels transaction

PredefinedAmountSelected --> TransactionProcessed : process withdrawal
CustomAmountEntered --> TransactionProcessed : process withdrawal
TransactionCancelled --> CardReturned : stop transaction and return card

TransactionProcessed --> WithdrawalCompleted : withdrawal processed successfully
WithdrawalCompleted --> CardReturned : return card to user

CardReturned : end

@enduml
