@startuml
[*] --> Assigned

state Assigned {
  [*] --> ClientAssigned : assign to client
  [*] --> CampaignAssigned : add to campaign
}

ClientAssigned --> Unassigned : remove assignment
CampaignAssigned --> Unassigned : remove assignment

Unassigned --> Assigned : switch assignments

Assigned --> Unemployed : leave job
Unemployed --> Archived : after some time
@enduml
