@startuml
[*] --> AssignedStaffAndManager

state AssignedStaffAndManager {
  [*] --> ApprovedAndSigned : everything approved and contract signed
}

ApprovedAndSigned --> ActivatedCampaign

state ActivatedCampaign {
  [*] --> PreparingAdverts : prepare adverts
}

PreparingAdverts --> AdvertsScheduled : approve and schedule adverts

state AdvertsScheduled {
  [*] --> RunningAdverts : run adverts
}

RunningAdverts --> ExtendOrAdjustCampaign : extension or adjustment needed

ExtendOrAdjustCampaign --> RunningAdverts : adjust campaign

RunningAdverts --> CampaignCompleted : all adverts finished

state CampaignCompleted {
  [*] --> PreparingFinalStatement : prepare final statement
}

PreparingFinalStatement --> CompletedAndPaid : complete and paid

state CompletedAndPaid {
  [*] --> HandlingPayment : handle payment
}

HandlingPayment --> PaymentConfirmed : correct balance settled

PaymentConfirmed --> MarkedAsPaid : mark as paid

MarkedAsPaid --> ArchivedCampaign : archive campaign

ArchivedCampaign --> [*] : release staff and managers
}

@enduml
