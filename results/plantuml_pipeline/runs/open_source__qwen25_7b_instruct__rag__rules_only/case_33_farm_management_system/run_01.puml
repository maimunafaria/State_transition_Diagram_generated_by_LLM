@startuml
hide empty description
[*] --> LoggedIn

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> MarketConditions : select market conditions
  MarketConditions --> PestControlHelp : select pest control help
  PestControlHelp --> Techniques : provide photo
  Techniques --> Techniques : show techniques
  [*] --> SoilSuggestions : provide soil information
  SoilSuggestions --> WeatherInsights : provide location
  WeatherInsights --> LabourAvailability : provide location
  LabourAvailability --> [*] : continue using service
}

LoggedIn --> [*] : logout
@enduml
