@startuml
[*] --> LoggedIn

state LoggedIn {
  [*] --> JourneyDetails : login and select destination
  JourneyDetails --> DrivingMode : view journey details, activate driving mode
  JourneyDetails --> OtherOptions : view journey details, choose other options
}

DrivingMode --> EatingPlace : user is hungry, select a place to eat
EatingPlace --> ViewMenu : view menu
ViewMenu --> PlaceOrder : order food

state AccidentDetected {
  [*] --> InformAuthorities : accident detected
  InformAuthorities --> SendNotifications : inform relevant authorities
}

LoggedIn --> DrivingMode : send driving notifications
DrivingMode --> SendNotifications : send driving notifications
AccidentDetected --> SendNotifications : send accident notifications

JourneyDetails --> Feedback : provide feedback upon journey completion
Feedback --> [*] : end journey
@enduml
