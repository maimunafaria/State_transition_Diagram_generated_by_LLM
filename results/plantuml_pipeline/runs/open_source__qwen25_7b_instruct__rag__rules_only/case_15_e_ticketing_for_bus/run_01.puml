@startuml
[*] --> Registered

state Registered {
  [*] --> LoggedIn
  Registered --> Registered : validate registration
}

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> Dashboard : check ticket status
  Dashboard --> Booking : book a ticket
  Booking --> PaymentConfirmed : payment confirmed
  PaymentConfirmed --> TicketBooked : confirm booking
  TicketBooked --> AccountManagement : manage account details
  AccountManagement --> Dashboard : back to dashboard
  Dashboard --> [*] : logout
}

note right of Registered : validates user registration
note left of Dashboard : displays ticket status or allows booking
note right of Booking : processes payment and confirms booking
note left of PaymentConfirmed : payment is confirmed
note right of TicketBooked : updates user account details
@enduml
