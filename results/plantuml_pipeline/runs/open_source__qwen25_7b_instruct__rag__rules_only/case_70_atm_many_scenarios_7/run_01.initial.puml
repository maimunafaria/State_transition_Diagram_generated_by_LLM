@startuml

state "Waiting for Card Insertion" as WaitingCard
state "Checking PIN" as CheckingPIN
state "Incorrect PIN" as IncorrectPIN
state "Validating PIN" as ValidatingPIN
state "Displaying Options" as DisplayingOptions
state "Processing Request" as ProcessingRequest
state "Returning Card" as ReturningCard

[*] --> WaitingCard

WaitingCard --> CheckingPIN : card inserted
CheckingPIN --> ValidatingPIN : PIN entered
ValidatingPIN --> ValidatingPIN : try again [entered incorrect PIN]
ValidatingPIN --> IncorrectPIN : too many incorrect attempts
IncorrectPIN --> ReturningCard : cancel
ValidatingPIN --> DisplayingOptions : correct PIN
DisplayingOptions --> ProcessingRequest : choice made

ReturningCard --> [*] : card returned

@enduml
