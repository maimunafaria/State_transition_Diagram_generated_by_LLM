@startuml
[*] --> Registering

state Registering {
  [*] --> Registered
  Registered --> LoggingIn : enter login details
}

LoggingIn --> LoggedIn : correct login details
LoggedIn {
  [*] --> UploadingDocuments
  UploadingDocuments --> ViewingProfileOrApplyingForCertificate : upload documents, view profile, or apply for certificate
  ViewingProfileOrApplyingForCertificate --> UploadingDocuments : continue uploading documents
  ViewingProfileOrApplyingForCertificate --> LoggedIn : done with actions
}

state "Registrars Request Certificates" as RegistrarRequestingCertificates {
  [*] --> RequestedCertificate
  RequestedCertificate --> RequestedMoreCertificates : request more certificates after receiving one
}

LoggedIn --> RegistrarRequestingCertificates : registrar requests certificate for verification
RegistrarRequestingCertificates --> LoggedIn : done with actions

[*] --> EndSession
@enduml
