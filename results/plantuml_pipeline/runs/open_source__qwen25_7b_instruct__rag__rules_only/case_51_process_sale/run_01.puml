@startuml

state "Waiting for New Sale" as WaitingNewSale
state "Adding Items" as AddingItems
state "Payment Selection" as PaymentSelection
state "Verifying Payment" as VerifyingPayment
state "Payment Confirmed" as PaymentConfirmed
state "Order Completed" as OrderComplete
state "Returning to Wait" as ReturningToWait

[*] --> WaitingNewSale

WaitingNewSale --> AddingItems : enter items one by one
AddingItems --> PaymentSelection : all items added
PaymentSelection --> VerifyingPayment : pay by card or check
VerifyingPayment --> PaymentConfirmed : payment verified
PaymentConfirmed --> OrderComplete : payment approved
OrderComplete --> ReturningToWait : complete sale

@enduml
