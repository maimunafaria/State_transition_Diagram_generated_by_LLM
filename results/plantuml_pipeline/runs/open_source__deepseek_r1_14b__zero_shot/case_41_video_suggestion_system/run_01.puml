@startuml
state Start {
  initial
}

state Request_Received {
  when user submits suggestion request
}

state Processing {
  when begin processing
}

state Suggestions_Sent {
  when suggestions ready
}

state End {
  final
}

Start --> Request_Received: User Submits Suggestion Request

Request_Received --> Processing: Begin Processing

Processing --> Suggestions_Sent: Suggestions Ready

Suggestions_Sent --> End: Process Complete
@enduml
