@startuml
state Off {
  when setTime -> Activated
}
state Activated {
  when currentTimeMatches -> Ringing
  when turnOff -> Off
}
state Ringing {
  when stopAlarm -> Activated
}

Off --> Activated : setTime
Activated --> Ringing : currentTimeMatches
Activated --> Off : turnOff
Ringing --> Activated : stopAlarm

initial state: Off
@enduml
