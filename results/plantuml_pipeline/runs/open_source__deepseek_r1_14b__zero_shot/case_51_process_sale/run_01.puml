@startuml
state Waiting for Sale {
  when a customer starts a sale
}
state Adding Items {
  when items are being entered
}
state Payment Processing {
  when payment method is selected
}
state Cash Payment {
  when cash is used to pay
}
state Card/Check Verification {
  when card or check is used and verification is needed
}
state Sale Completed {
  when sale is completed
}

start
activate Waiting for Sale

transition: Add Item -> Adding Items
transition: All Items Added -> Payment Processing
transition: Cash Selected -> Cash Payment
transition: Card/Check Selected -> Card/Check Verification
transition: Payment Approved -> Sale Completed
transition: Sale Complete -> Waiting for Sale

@enduml
