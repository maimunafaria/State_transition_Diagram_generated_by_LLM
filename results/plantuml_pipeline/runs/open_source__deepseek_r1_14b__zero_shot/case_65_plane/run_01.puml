@startuml
state Order {
  <<Initial>> 
}
state Arrival
state Preparation
state Operations
state Maintenance
state Retired {
  <<Final>>
}

Order -> Arrival : Arrive
Arrival -> Preparation : Prepare

Preparation -> Operations : Ready for Ops
Preparation -> Maintenance : Needs Maintenance

Operations -> Maintenance : No Flights or Maintenance Required

Maintenance -> Preparation : Servicing Complete

Operations --> Maintenance : Maintenance Required

Retired --> {} 

@enduml
