@startuml
state Idle {
}
state Adding_Goods {
  when done: transition to Idle
}
state Updating_Price {
  when done: transition to Idle
}
state Removing_Goods {
  when done: transition to Idle
}
state Placing_Order {
  when order_placed: transition to Generating_Invoice
}
state Generating_Invoice {
  when invoice_generated: transition to Idle
}
state Searching_Inventory {
  when search_completed: transition to Idle
}
state Calculating_Totals {
  when totals_calculated: transition to Processing_Purchase
}
state Processing_Purchase {
  when purchase_processed: transition to Generating_Receipt
}
state Generating_Receipt {
  when receipt_generated: transition to Idle
}
state Adjusting_Receipt {
  when adjustment_done: transition to Idle
}
state Requesting_Items {
  when request_recorded: transition to Idle
}
state Viewing_Report {
  when report_viewed: transition to Idle
}

Idle -> Adding_Goods: add_goods
Adding_Goods --> Idle

Idle -> Updating_Price: update_price
Updating_Price --> Idle

Idle -> Removing_Goods: remove_goods
Removing_Goods --> Idle

Idle -> Placing_Order: place_order
Placing_Order --> Generating_Invoice

Generating_Invoice --> Idle

Idle -> Searching_Inventory: search_inventory
Searching_Inventory --> Idle

Idle -> Calculating_Totals: calculate_totals
Calculating_Totals --> Processing_Purchase

Processing_Purchase --> Generating_Receipt

Generating_Receipt --> Idle

Idle -> Adjusting_Receipt: adjust_receipt
Adjusting_Receipt --> Idle

Idle -> Requesting_Items: request_item
Requesting_Items --> Idle

Idle -> Viewing_Report: view_report
Viewing_Report --> Idle

@enduml
