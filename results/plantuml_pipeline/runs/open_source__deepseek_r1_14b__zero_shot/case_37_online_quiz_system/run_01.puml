@startuml
state "LoggedIn" {
    when selecting role as Teacher -> transition to TeacherState
    when selecting role as Student -> transition to StudentState
}
state TeacherState {
    when creating new quiz -> transition to CreateQuizState
    when editing existing quiz -> transition to EditQuizState
    when viewing results -> transition to ViewResultsState
}
state CreateQuizState {
    when saving as draft -> transition to DraftSavedState
    when posting quiz -> transition to QuizPostedState
}
state EditQuizState {
    when making changes -> transition to UpdatedQuizState
    when deleting quiz -> transition to DeleteQuizState
}
state StudentState {
    when selecting a quiz -> transition to SelectQuizState
    when viewing results -> transition to ViewResultsState
}
state SubmitQuizState {
    when submitting answers -> transition to QuizSubmittedState
}
state AnsweringState {
    when answering questions -> transition to SubmitQuizState
}
state ViewResultsState {
    when done viewing -> transition to EndState
}
state DraftSavedState {
    when opening again -> transition to CreateQuizState
}
state UpdatedQuizState {
    when saving changes -> transition to QuizPostedState
}
state DeleteQuizState {
    when deleting quiz -> transition to TeacherState
}
state SelectQuizState {
    when selecting a quiz -> transition to AnsweringState
}
state QuizSubmittedState {
    when viewing result -> transition to ViewResultState
}
state ViewResultState {
    when done -> transition to EndState
}

LoggedIn -> TeacherState : select role as Teacher
LoggedIn -> StudentState : select role as Student

initial "LoggedIn"

end state EndState
@enduml
