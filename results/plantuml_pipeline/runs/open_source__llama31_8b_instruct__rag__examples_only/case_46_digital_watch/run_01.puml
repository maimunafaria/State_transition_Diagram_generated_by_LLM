@startuml
title Digital Watch - State Diagram

state "Idle" as Idle
Idle : entry/initial state

state "Adjusting Time" as AdjustingTime
AdjustingTime : entry/button pressed
AdjustingTime : do/increase values while adjusting time settings
AdjustingTime : exit/button released

state "Alarm On" as AlarmOn
AlarmOn : entry/alarm turned on by user
AlarmOn : do/trigger alarm to ring when set alarm time matches current time
AlarmOn : exit/alarm turned off by user

state "Alarm Off" as AlarmOff
AlarmOff : entry/alarm turned off by user
AlarmOff : do/do nothing
AlarmOff : exit/button pressed

state "Light On" as LightOn
LightOn : entry/light feature turned on by user
LightOn : do/turn light on when button is pressed
LightOn : exit/light feature turned off by user

state "Light Off" as LightOff
LightOff : entry/light feature turned off by user
LightOff : do/do nothing
LightOff : exit/button pressed

[*] --> Idle

Idle --> AdjustingTime : [button pressed]
AdjustingTime --> AlarmOn : [alarm turned on]

AlarmOn --> AlarmOff : [alarm turned off]
AlarmOff --> LightOn : [light feature turned on]

LightOn --> LightOff : [light feature turned off]
LightOff --> Idle : [button released]

@enduml
