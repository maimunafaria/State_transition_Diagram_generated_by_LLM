@startuml
title UML State Machine Diagram (Bpo Management System)

state "Search by filter category" as SearchCategory {
    [*] --> SelectFilter : [filter category]
}

state "Select filter" as SelectFilter {
    [*] --> SelectPriceRange : [price range]
}

state "Select price range" as SelectPriceRange {
    [*] --> DisplayMatchingUsers : [matching users]
}

state "Display matching users" as DisplayMatchingUsers

SearchCategory : entry / Search by filter category
SearchCategory : do / Select filter
SearchCategory : exit / After displaying matching users

SelectFilter : entry / Select price range
SelectFilter : do / Select price range
SelectFilter : exit / After selecting price range

SelectPriceRange : entry / Display matching users
SelectPriceRange : do / Display matching users
SelectPriceRange : exit / After displaying matching users

DisplayMatchingUsers --> [*]

@enduml
