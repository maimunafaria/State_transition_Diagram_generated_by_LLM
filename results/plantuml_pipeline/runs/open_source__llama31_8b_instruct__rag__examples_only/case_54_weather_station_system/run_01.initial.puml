@startuml
title Weather Station System States

[*] --> Startup

state "Startup" as Startup
state "Running" as Running
state "Configuring" as Configuring
state "Collecting Data" as CollectingData
state "Preparing Summary" as PreparingSummary
state "Checking Status" as CheckingStatus
state "Controlled Mode" as ControlledMode
state "Shut Down" as ShutDown

Startup --> [*] : restart
Startup --> Configuring : configRequired()

Configuring --> Running : configComplete()
Running --> CollectingData : clockTriggered()
CollectingData --> Running : dataCollectionComplete()
PreparingSummary --> Running : summaryPrepared()
CheckingStatus --> Running : statusChecked()
ControlledMode --> Running : remoteControlCommand()
ShutDown --> [*] : shutdownCommand()

@enduml
