@startuml
title Safehome Security Function

state "Power On" as PowerOn
state "Startup" as Startup
state "Ready to Use" as ReadyToUse
state "Monitoring" as Monitoring
state "Alarm" as Alarm
state "Normal" as Normal

[*] --> PowerOn

PowerOn --> Startup : [*]

Startup --> ReadyToUse : [no problems]
Startup --> Alarm : [problem detected]

ReadyToUse --> Monitoring : [activated]
Monitoring --> Alarm : [sensor triggered]

Alarm --> Monitoring : [false alarm or time ends]
Monitoring --> Normal : [deactivated]

Normal --> ReadyToUse : [password entered]

@enduml
