@startuml
title Alarm Clock

state Off {
  state Idle
  Idle : do / No Alarm Set
}

state On {
  state Waiting
  Waiting : do / Wait for Alarm Time
  state Ringing
  Ringing : do / Sound Alarm
}

[*] --> Off[*]

Off --> On : [Alarm Set]
On --> Waiting : [Alarm Time Reached]
Waiting --> Ringing : [Alarm Time Reached]
Ringing --> On : [Stop Alarm]

On --> Off : [Next Scheduled Alarm Time]

@enduml
