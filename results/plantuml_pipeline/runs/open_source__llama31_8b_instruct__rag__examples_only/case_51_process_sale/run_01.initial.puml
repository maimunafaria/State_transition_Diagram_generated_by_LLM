@startuml
title State diagram of the system operations of "Process Sale"

[*] --> WaitForNewSale

state "Wait for new sale" as WaitForNewSale
state "Add items" as AddItems
state "Verify payment" as VerifyPayment
state "Complete sale" as CompleteSale
state "Return to waiting" as ReturnToWaiting

WaitForNewSale --> [*]
AddItems --> AddItems : add item
AddItems --> VerifyPayment : end of sale
VerifyPayment --> CompleteSale : approved payment
CompleteSale --> ReturnToWaiting : complete sale
VerifyPayment --> ReturnToWaiting : declined payment

@enduml
