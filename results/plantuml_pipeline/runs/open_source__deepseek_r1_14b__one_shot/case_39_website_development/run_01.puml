@startuml
title UML state machine diagram

state Homepage
state ProjectPage
state PhotoView
state VideoView
state CareerPage
state JobUpdates
state ApplicationForm
state JobApplicationCheck

Homepage --> ProjectPage : [Navigation Bar Click]
Homepage --> CareerPage : [Navigation Bar Click]

ProjectPage --> PhotoView : [View Photos]
ProjectPage --> VideoView : [View Videos]

CareerPage --> JobUpdates : [View Updates]
CareerPage --> ApplicationForm : [Open Application Form]

ApplicationForm --> JobApplicationCheck : [Submit Application]

JobApplicationCheck --> [*] : [Application Checked]

PhotoView --> ProjectPage : [Back to Project]
VideoView --> ProjectPage : [Back to Project]

JobUpdates --> CareerPage : [Back to Career]
@enduml
