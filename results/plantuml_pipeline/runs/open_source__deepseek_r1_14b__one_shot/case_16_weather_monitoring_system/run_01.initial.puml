@startuml
title WeatherMonitoringSystem
[*] --> InitialState

state InitialState {
  [*] --> CreateAccount
  [*] --> Login
}

state CreateAccount {
  CreateAccount --> Login : successful
  CreateAccount --> EndState : unsuccessful
}

state Login {
  Login --> MainMenu : successful
  Login --> EndState : unsuccessful
}

state MainMenu {
  MainMenu --> CheckWeather : checkWeather
  MainMenu --> Logout : logout
}

state CheckWeather {
  CheckWeather --> SelectWeatherInfo : validLocation
  CheckWeather --> LocationInvalid : invalidLocation
}

state LocationInvalid {
  LocationInvalid --> EndState
}

state SelectWeatherInfo {
  SelectWeatherInfo --> DisplayWeather : selected
}

state DisplayWeather {
  DisplayWeather --> AdditionalDetails : viewDetails
  DisplayWeather --> MainMenu : backToMenu
}

state AdditionalDetails {
  AdditionalDetails --> DisplayWeather : back
  AdditionalDetails --> MainMenu : menu
}

state Logout {
  Logout --> EndState
}

state EndState

MainMenu --> Logout : logout

@enduml
