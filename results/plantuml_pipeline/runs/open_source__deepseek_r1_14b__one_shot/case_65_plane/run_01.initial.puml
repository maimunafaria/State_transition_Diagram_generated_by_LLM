@startuml
title UML State Machine Diagram (Plane Management System)

[*] --> Order

state Order {
    [*] --> Arrival : [Delivery]
}

state Arrival {
    [*] --> Preparation : [Arrival]
}

state Preparation <<choice>> {
    Preparation --> Operations : [Condition: Ready for Ops]
    Preparation --> Maintenance : [Condition: Needs Maintenance]
}

state Operations {
    Operations --> Maintenance : [No more flights]
}

state Maintenance {
    Maintenance --> Preparation : [Servicing complete]
}

state Retired {
    [*] --> Retired : [Final State]
}

Operations --> Retired : [Plane withdrawn]
Preparation --> Retired : [Plane retired]
Maintenance --> Retired : [Plane retired]

@enduml
