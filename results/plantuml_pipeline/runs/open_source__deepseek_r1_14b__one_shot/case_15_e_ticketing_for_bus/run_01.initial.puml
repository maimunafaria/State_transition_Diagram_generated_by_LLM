@startuml
title UML state machine diagram

state "Create Account" as CreateAccount
CreateAccount : entry/Start registration
CreateAccount : do/Submit registration form
CreateAccount : exit/Registration submitted

state "Validate Registration" as ValidateRegistration
ValidateRegistration : entry/Registration submitted
ValidateRegistration : do/Check validity
ValidateRegistration : exit/Validated

state "Login" as Login
Login : entry/Valid registration
Login : do/Input credentials
Login : exit/Logged in

state "Check Ticket Status" as CheckTicketStatus
CheckTicketStatus : entry/Logged in
CheckTicketStatus : do/Display ticket status
CheckTicketStatus : exit/Ready for next action

state "Book Ticket" as BookTicket
BookTicket : entry/Select ticket
BookTicket : do/Initiate booking
BookTicket : exit/Ticket selected

state "Confirm Payment" as ConfirmPayment
ConfirmPayment : entry/Ticket selected
ConfirmPayment : do/Process payment
ConfirmPayment : exit/Payment confirmed

state "Manage Account" as ManageAccount
ManageAccount : entry/Account details
ManageAccount : do/Edit or delete
ManageAccount : exit/Details updated

state "Logout" as Logout
Logout : entry/Complete action
Logout : do/End session
Logout : exit/Logged out

state J1 <<choice>>
state J2 <<choice>>

[*] --> J1

J1 --> CreateAccount
J1 --> Login

CreateAccount --> ValidateRegistration

ValidateRegistration --> J2
J2 --> Login : [Valid]
J2 --> CreateAccount : [
@enduml
