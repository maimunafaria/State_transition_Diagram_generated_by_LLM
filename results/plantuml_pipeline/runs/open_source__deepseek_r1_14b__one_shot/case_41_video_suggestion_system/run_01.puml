@startuml
title VideoSuggestionState
[*] --> AwaitingRequest
state AwaitingRequest {
  [*] --> IdentifyingUser : ReceiveRequest
}
state IdentifyingUser {
  [*] --> GatheringVideos : IdentifyUser
}
state GatheringVideos {
  [*] --> AddingDetails : GatherVideos
}
state AddingDetails {
  [*] --> SendingSuggestions : AddDetails
}
state SendingSuggestions {
  [*] --> FinalState : SendSuggestions
}
state FinalState
@enduml
