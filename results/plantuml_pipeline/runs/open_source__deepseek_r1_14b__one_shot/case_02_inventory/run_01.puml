@startuml
title UML State Machine Diagram (Inventory Management System)

state "Ready" as Ready {
    [*] --> Ready

    Ready : entry / System initialization
    Ready : exit / System shutdown
}

state "Adding Goods" as AddGoods {
    Ready --> AddGoods : [User adds new goods]
    AddGoods --> UpdatedInventory : [Goods added successfully]
}

state "Updating Prices" as UpdatePrices {
    Ready --> UpdatePrices : [User updates price]
    UpdatePrices --> UpdatedInventory : [Price updated successfully]
}

state "Removing Goods" as RemoveGoods {
    Ready --> RemoveGoods : [User removes goods]
    RemoveGoods --> UpdatedInventory : [Goods removed successfully]
}

state "Handling Expiration" as HandleExpiration {
    UpdatedInventory --> HandleExpiration : [Goods expired]
    HandleExpiration --> UpdatedInventory : [Goods notified and removed]
}

state "Placing Order" as PlaceOrder {
    Ready --> PlaceOrder : [User places order]
    PlaceOrder --> OrderPlaced : [Order placed successfully]
}

state "Generating Invoice" as GenerateInvoice {
    OrderPlaced --> GenerateInvoice : [Generate invoice]
    GenerateInvoice --> UpdatedInventory : [Invoice generated]
}

state "Searching Inventory" as SearchInventory {
    Ready --> SearchInventory : [User searches items]
    SearchInventory --> SearchResults : [Search completed]
}

state "Selecting Items" as SelectItems {
    SearchResults --> SelectItems : [User selects items]
    SelectItems --> PurchaseRequested : [Items selected]
}

state "Calculating Discount" as CalculateDiscount {
    PurchaseRequested --> CalculateDiscount : [Calculate discount]
    CalculateDiscount --> DiscountApplied : [Discount calculated]
}

state "Calculating Tax" as CalculateTax {
    DiscountApplied --> CalculateTax : [Calculate tax]
    CalculateTax --> TaxApplied : [Tax calculated]
@enduml
