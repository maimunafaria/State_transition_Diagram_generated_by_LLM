@startuml
title AlarmClock State Machine

state Off {
  [*] --> AlarmActivated : settingAlarm
}

state AlarmActivated {
  [*] --> AlarmRinging : timeMatches
  AlarmActivated --> Off : userTurnsOff
}

state AlarmRinging {
  [*] --> AlarmActivated : userStopsAlarm
}

AlarmActivated : entry / alarmTime = currentTime
userTurnsOff --> Off
@enduml
