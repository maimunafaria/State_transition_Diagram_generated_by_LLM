@startuml
title UML state machine diagram

state "Idle" as Idle
Idle : entry/Idle
Idle : do/Waiting for user action
Idle : exit/No action

state "Identify user" as IdentifyUser
IdentifyUser : entry/Identify user
IdentifyUser : do/Identify user type based on details
IdentifyUser : exit/Register/Login/Invalid details

state "Register" as Register
Register : entry/Register
Register : do/Validate registration details
Register : exit/Login/Invalid registration

state "Invalid registration" as InvalidRegistration
InvalidRegistration : entry/Invalid registration
InvalidRegistration : do/Cannot register
InvalidRegistration : exit/Abnormal termination

state "Login" as Login
Login : entry/Login
Login : do/Login using valid credentials
Login : exit/Invalid login/Upload documents

state "Invalid login" as InvalidLogin
InvalidLogin : entry/Invalid login
InvalidLogin : do/Cannot login
InvalidLogin : exit/Abnormal termination

state "Upload documents" as UploadDocuments
UploadDocuments : entry/Upload
UploadDocuments : do/Upload documents
UploadDocuments : exit/View profile/Apply for certificate/Continue upload/End session

state "View profile" as ViewProfile
ViewProfile : entry/View profile
ViewProfile : do/View profile information
ViewProfile : exit/Idle

state "Apply for certificate" as ApplyForCertificate
ApplyForCertificate : entry/Apply
ApplyForCertificate : do/Apply for certificate
ApplyForCertificate : exit/Reapply/End session

state "Continue upload" as ContinueUpload
ContinueUpload : entry/Continue upload
ContinueUpload : do/Continue uploading documents
ContinueUpload : exit/Upload documents/End session

state "Request verification" as RequestVerification
RequestVerification : entry/Request
RequestVerification : do/Request certificate for verification
RequestVerification : exit/Continue requesting/End session

state "Continue request" as ContinueRequest
ContinueRequest : entry/Continue request
ContinueRequest : do/Continue requesting certificates
ContinueRequest : exit/Request verification/End session

state "End session" as EndSession
EndSession : entry/End
EndSession : do/End session
EndSession : exit/No
@enduml
