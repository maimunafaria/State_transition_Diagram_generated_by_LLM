@startuml
title Staff Member State Transition Diagram

state "Employed" as Employed {
  state "Assigned" as Assigned
  state "Unassigned" as Unassigned
}

state Unemployed
state Archived

Employed --> Assigned : Assignment Added
Assigned --> Unassigned : Assignment Removed
Unassigned --> Assigned : Assignment Added
Employed --> Unemployed : Staff Leaves Job
Unemployed --> Archived : Time Elapsed

@enduml
