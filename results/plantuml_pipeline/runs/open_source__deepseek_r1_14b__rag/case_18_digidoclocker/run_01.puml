@startuml
title UML State Machine Diagram (Digidoclocker)

[*] --> Registration

state Registration
Registration : entry / User enters details
Registration : do / Validate registration details
Registration : exit / Registration successful or failed

Registration --> Login : [Valid Registration]
Registration --> Registration : [Invalid Registration]

state Login
Login : entry / User enters login details
Login : do / Validate login credentials
Login : exit / Login successful or failed

Login --> Choice1 : [Valid Login]

state Choice1 <<choice>>
Choice1 --> UploadDocuments : [Upload Documents]
Choice1 --> ViewProfile : [View Profile]
Choice1 --> ApplyCertificate : [Apply for Certificate]
Choice1 --> UpdateProfile : [Update Profile]

state UploadDocuments
UploadDocuments --> Choice1 : [Continue Upload]
UploadDocuments --> End : [Finish Upload]

state ViewProfile
ViewProfile --> Choice1 : [Back to Menu]
ViewProfile --> End : [End Session]

state ApplyCertificate
ApplyCertificate --> Choice1 : [Reapply]
ApplyCertificate --> End : [Finish Application]

state UpdateProfile
UpdateProfile --> Choice1 : [Back to Menu]
UpdateProfile --> End : [End Session]

state End
End --> [*]

state RegistrarRequest <<choice>>
RegistrarRequest --> RegistrarRequest : [Request More]
RegistrarRequest --> Choice1 : [Back to Menu]

Choice1 --> RegistrarRequest : [Request Certificate]

@enduml
