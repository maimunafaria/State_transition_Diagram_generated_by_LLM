@startuml
hide empty description

state Login {
  [*] --> Dashboard
}

state Dashboard {
  --> MarketConditions : select market conditions
  --> PestControl : select pest control
  --> SoilSuggestions : select soil
  --> Weather : select weather
  --> Labour : select labour
  --> Logout : select logout
}

state MarketConditions {
  --> Dashboard : back
}

state PestControl {
  [*] --> PestPhoto
}

state PestPhoto {
  --> PestTechniques : submit photo
}

state PestTechniques {
  --> Dashboard : back
}

state SoilSuggestions {
  [*] --> SoilInfo
}

state SoilInfo {
  --> SoilResults : submit info
}

state SoilResults {
  --> Dashboard : back
}

state Weather {
  [*] --> LocationWeather
}

state LocationWeather {
  --> Dashboard : back
}

state Labour {
  [*] --> LocationLabour
}

state LocationLabour {
  --> LabourResults : submit location
}

state LabourResults {
  --> Dashboard : back
}

state Logout {
  --> [*] : end session
}

end
@enduml
