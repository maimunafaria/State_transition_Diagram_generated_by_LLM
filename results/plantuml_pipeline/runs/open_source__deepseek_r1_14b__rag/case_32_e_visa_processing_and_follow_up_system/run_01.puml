@startuml
[*] --> CreateUser

state CreateUser
CreateUser --> Login : account created

state Login
Login --> CreateUser : invalid credentials
Login --> MainMenu : valid credentials

state MainMenu <<choice>>
MainMenu --> ViewStatus
MainMenu --> CheckStatus
MainMenu --> CancelApplication
MainMenu --> ModifyDetails
MainMenu --> ViewDetails
MainMenu --> GiveFeedback
MainMenu --> Logout

state ViewStatus
ViewStatus --> MainMenu

state CheckStatus
CheckStatus --> MainMenu

state CancelApplication
CancelApplication --> MainMenu

state ModifyDetails
ModifyDetails --> MainMenu

state ViewDetails
ViewDetails --> MainMenu

state GiveFeedback
GiveFeedback --> MainMenu

state Logout
Logout --> [*]

state ApplyVisa {
  [*] --> MakePayment
  MakePayment --> Accepted
  Accepted --> ViewStatus
}

state ApplicationProcessing {
  [*] --> DocumentCheck
  DocumentCheck --> Approved
  DocumentCheck --> Rejected
  Approved --> ViewStatus
  Rejected --> ViewStatus
}
@enduml
