@startuml
[*] --> WaitingForAmountSelection

state WaitingForAmountSelection
state AmountSelected
state CustomAmountEntered
state TransactionVerification
state TransactionComplete
state WaitingForAmountReentry

WaitingForAmountSelection --> AmountSelected : amount selected
WaitingForAmountSelection --> CustomAmountEntered : custom amount entered

AmountSelected --> TransactionVerification
CustomAmountEntered --> TransactionVerification

TransactionVerification --> TransactionComplete : transaction approved
TransactionVerification --> WaitingForAmountReentry : transaction rejected

TransactionComplete --> [*]

WaitingForAmountReentry --> WaitingForAmountSelection : re-enter amount
@enduml
