@startuml
state Start {
  [*] --> Start
}

state "Register/Login" as RegLogin {
  RegLogin --> Teacher
  RegLogin --> Student
}

state Teacher {
  Teacher --> CreateQuiz
  Teacher --> EditQuiz
  Teacher --> SaveDraft
  Teacher --> PostQuiz
  Teacher --> ViewResults
}

state Student {
  Student --> SelectQuiz
  Student --> AnswerQuiz
  Student --> SubmitQuiz
  Student --> ViewResult
}

state CreateQuiz {
  CreateQuiz --> EditQuiz
}

state EditQuiz {
  EditQuiz --> SaveDraft
  EditQuiz --> PostQuiz
}

state SaveDraft {
  SaveDraft --> Teacher
}

state PostQuiz {
  PostQuiz --> Teacher
}

state ViewResults {
  ViewResults --> Teacher
}

state SelectQuiz {
  SelectQuiz --> AnswerQuiz
}

state AnswerQuiz {
  AnswerQuiz --> SubmitQuiz
}

state SubmitQuiz {
  SubmitQuiz --> ViewResult
}

state ViewResult {
  ViewResult --> [*]
}

[*] --> Start
Start --> RegLogin

RegLogin --> [*] : [Logout]
RegLogin --> Start

Teacher --> [*] : [Logout]

Student --> [*] : [Logout]
@enduml
