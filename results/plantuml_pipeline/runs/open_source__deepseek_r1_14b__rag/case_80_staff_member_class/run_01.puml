@startuml
[*] --> Unassigned

state Unassigned {
  [*] --> Assigned
}

state Assigned {
  --> ClientAssignment
  ClientAssignment --> CampaignAssignment : switchAssignment
  CampaignAssignment --> ClientAssignment : switchAssignment
}

Assigned --> Unemployed : terminateEmployment

state Unemployed {
  --> Archived : afterTimeElapsed
}

Unassigned --> Assigned : assignClient\nassignCampaign
Assigned --> Unassigned : removeAssignment

Archived --> [*] 
@enduml
