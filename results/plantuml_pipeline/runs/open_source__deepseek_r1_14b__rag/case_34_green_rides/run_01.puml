@startuml
title Green Rides State Machine

state "Logged In" as LoggedIn
state "Destination Selected" as DestinationSelected
state "Journey Details Displayed" as JourneyDetails
state "Driving Mode Activated" as DrivingMode
state "Other Options Selected" as OtherOptions
state "Place to Eat Selected" as PlaceToEat
state "Menu Viewed" as MenuViewed
state "Order Placed" as OrderPlaced
state "Report Submitted" as ReportSubmitted
state "Journey Ended" as JourneyEnded

LoggedIn -> DestinationSelected : Select destination
DestinationSelected -> JourneyDetails : View journey details

JourneyDetails -> DrivingMode : Activate driving mode
JourneyDetails -> OtherOptions : Choose other options
JourneyDetails -> JourneyEnded : End journey

DrivingMode -> PlaceToEat : Look for place to eat
DrivingMode -> JourneyEnded : End journey

PlaceToEat -> MenuViewed : View menu
MenuViewed -> OrderPlaced : Place order
MenuViewed -> DrivingMode : Return to driving mode

OrderPlaced -> DrivingMode : Return to driving mode

JourneyDetails -> JourneyEnded : End journey

JourneyDetails -> ReportSubmitted : Accident occurs
ReportSubmitted -> JourneyEnded : Submit report

@enduml
