@startuml
[*] --> Shutdown

state Shutdown {
  [*] --> Running
}

state Running {
  Running --> Configuration : change/settings
  Running --> DataCollection : clock trigger
  Running --> SummaryPreparation : summary request
  Running --> StatusCheck : status request
  Running --> ControlledMode : remote control
  Running --> Shutdown : shutdown command
}

state Configuration {
  Configuration --> Running
}

state DataCollection {
  DataCollection --> Running
}

state SummaryPreparation {
  SummaryPreparation --> Running
}

state StatusCheck {
  StatusCheck --> Running
}

state ControlledMode {
  ControlledMode --> Running
}
@enduml
