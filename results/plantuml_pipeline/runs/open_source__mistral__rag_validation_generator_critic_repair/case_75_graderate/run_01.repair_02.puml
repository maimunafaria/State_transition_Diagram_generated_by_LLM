@startuml
title Rate State Machine Diagram
!define PUMLOFFICIAL_SYNTAX_CHECK
!define PU_OFFICIAL_PLANTUML_CMD "plantuml"
!if ${PU_OFFICIAL_PLANTUML_CMD} != ""
!define PU_PLANTUML_CMD "${PU_OFFICIAL_PLANTUML_CMD}"
!else
!define PU_PLANTUML_CMD "plantuml -graphviz"
!endif
!includeexample "${PU_PLANTUML_CMD} --syntax-check"

title Rate State Machine Diagram

[*] --> Inactive

state Inactive
state Active
state Expired
state Archived

Inactive --> Active : startDateReached
Active --> Expired : finishDateReached
Expired --> Archived : oneYearPassed
Archived --> [*]

@enduml
