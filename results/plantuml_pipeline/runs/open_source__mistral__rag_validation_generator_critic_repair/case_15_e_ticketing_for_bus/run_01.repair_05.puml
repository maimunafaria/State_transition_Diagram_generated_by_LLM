@startuml
[*] --> LoggedIn

state LoggedIn {
  Dashboard --> LoggedIn : open dashboard
  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
  Dashboard --> BookTicket : book ticket
  BookTicket --> PaymentConfirmation : payment confirmed
  PaymentConfirmation --> OrderComplete : payment made
  OrderComplete --> LoggedIn : ticket booked
  Dashboard --> Logout : logout
}

LoggedIn --> [*] : logout
@enduml
