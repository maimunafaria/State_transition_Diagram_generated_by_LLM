@startuml
title Microwave Oven State Machine Diagram

state Idle {
  [*] --> TimeDisplay
}

TimeDisplay {
  [*] --> PowerSelection
  state PowerSelection {
    [*] --> CookingTimeInput
    state CookingTimeInput {
      [*] --> DoorOpen
      state DoorOpen {
        [*] --> FoodPlaced
        state FoodPlaced {
          [*] --> DoorClosed
          state DoorClosed {
            [*] --> Cooking
            state Cooking {
              DoorClosed --> DoorOpened : TimerExpired
              DoorClosed --> DoorClosed : DoorOpen
            }
          }
        }
        FoodPlaced --> DoorClosed
      }
      DoorOpen --> Cancel
    }
    PowerSelection --> CookingTimeInput : PowerSelected
  }
}
Idle --> Inactive : DoorOpenDuringOperation
Inactive --> Idle : DoorClosed

state LoggedOut {
  [*] --> Idle
}
LoggedOut --> [*]
@enduml
