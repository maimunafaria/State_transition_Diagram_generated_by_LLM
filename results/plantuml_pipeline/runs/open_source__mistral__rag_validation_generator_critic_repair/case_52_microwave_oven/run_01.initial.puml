@startuml
title Microwave Oven State Machine Diagram

state Idle {
  [*] --> TimeDisplay
  state TimeDisplay {
    [*] --> PowerSelection
    state PowerSelection {
      [*] --> CookingTimeInput
      state CookingTimeInput {
        [*] --> DoorOpen
        state DoorOpen {
          [*] --> FoodPlaced
          state FoodPlaced {
            [*] --> DoorClosed
            state DoorClosed {
              [*] --> Cooking
              state Cooking {
                DoorClosed --> DoorOpened : TimerExpired
                DoorClosed --> DoorClosed : DoorOpen
              }
            }
          }
          FoodPlaced --> DoorClosed : DoorClosed
        }
        DoorOpen --> Cancel : DoorOpen
      }
      PowerSelection --> CookingTimeInput : PowerSelected
    }
  }
  TimeDisplay --> Inactive : DoorOpen
}
Idle --> Inactive : DoorOpenDuringOperation
Inactive --> Idle : DoorClosed
@enduml
