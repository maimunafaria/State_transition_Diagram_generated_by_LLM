@startuml
title Microwave Oven State Machine Diagram

state Idle {
  [*] --> TimeDisplay
}

state TimeDisplay {
  [*] --> PowerLevelSelection
}

state PowerLevelSelection {
  [*] --> CookingTimeInput
}

state CookingTimeInput {
  [*] --> DoorOpen
  DoorOpen --> Inactive : doorOpenDuringOperation()
  CookingTimeInput --> DoorOpen : enterCookingTime()
}

state DoorOpen {
  [*] --> Cancel : cancelButtonClicked()
  state Inactive {
    Inactive --> Idle : doorClosed()
  }
  DoorOpen --> Stop : doorOpenedDuringCooking()
}

state Cancel {
  [*] --> Idle
}
@enduml
