@startuml
title Microwave Oven State Machine Diagram

state Idle {
  [*] --> TimeDisplay
}
TimeDisplay {
  [*] --> PowerSelection
}
PowerSelection {
  [*] --> CookingTimeInput
}
CookingTimeInput {
  [*] --> DoorOpen
}
DoorOpen {
  [*] --> FoodPlaced
}
FoodPlaced {
  [*] --> DoorClosed
}
DoorClosed {
  [*] --> Cooking
}
Cooking {
  DoorClosed --> DoorOpened : TimerExpired
  DoorClosed --> DoorClosed : DoorOpen
}
DoorOpened {
  [*] --> Cancel
}
Cancel {
  [*] --> Idle
}
Idle --> Inactive : DoorOpenDuringOperation
Inactive --> Idle : DoorClosed
Cooking --> Idle : StoppedOrCancelled
@enduml
