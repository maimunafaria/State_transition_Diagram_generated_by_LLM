@startuml
!define PLANTUML_SYNTAX_CHECK
@import "https://raw.githubusercontent.com/plantuml-stdlib/PLANTUML4SCM/master/tagclouds/plantuml-syntax-check.puml"
!include PLANTUML_SYNTAX_CHECK

Inventory

[*] --> AddGoods
AddGoods --> UpdatePrice
UpdatePrice --> RemoveGoods
RemoveGoods --> ExpiredGoodsNotification
ExpiredGoodsNotification --> RemoveExpiredGoods
