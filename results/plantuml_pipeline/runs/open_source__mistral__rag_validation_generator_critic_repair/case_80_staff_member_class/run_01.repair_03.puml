@startuml
title Staff Member Class State Machine Diagram

state Unemployed
state Assigned
state CampaignActive
state CampaignCompleted

[*] --> LoggedIn
LoggedOut --> [*]

LoggedIn --> Assigned : assignToClientOrCampaign
Assigned --> CampaignActive : campaignApproved
CampaignActive --> CampaignCompleted : campaignFinished
CampaignCompleted --> Unemployed : leftJob

Assigned --> Unemplied : removedFromAssignment
AccessEnded --> [*]
@enduml
