@startuml
title Safehome Security Function State Diagram

state Startup {
  [*] --> Checking

  state Checking
  Checking : do / Check everything during startup

  state ReadyToUse
  Checking --> ReadyToUse : Everything fine

  state Problem
  Checking --> Problem : Problem during startup

  state Reset
  Problem --> Reset : User request

  state Activate
  ReadyToUse --> Activate : User request

  state Deactivate
  ReadyToUse --> Deactivate : User request

  state Monitoring
  Activate --> Monitoring : System activated

  state Alarm
  Monitoring --> Alarm : Sensor triggered

  state FalseAlarm
  Alarm --> FalseAlarm : False alarm or time ended

  state Normal
  FalseAlarm --> Normal : Continue monitoring

  state AlertSent
  Alarm --> AlertSent : Send alerts

  state PasswordEntered
  Normal --> PasswordEntered : User enters password at any time

  state Stopped
  PasswordEntered --> Stopped : System stops and returns to normal
}
@enduml
