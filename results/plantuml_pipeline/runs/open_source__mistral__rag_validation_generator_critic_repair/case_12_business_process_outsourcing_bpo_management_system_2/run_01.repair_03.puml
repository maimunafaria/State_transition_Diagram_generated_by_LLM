@startuml
title UML State Machine Diagram - Search Users

[*] --> ChooseUserType

state ChooseUserType <<choice>>
ChooseUserType --> NewUser : [New user]
ChooseUserType --> RegisteredUser : [Registered user]

state "New User Registration" as NewUserRegistration {
    EnterDetails --> ChoiceReg : [Registration verification]
    ChoiceReg --> UpdateDB : [valid]
    ChoiceReg --> EndInvalid : [invalid]

    EndInvalid --> [*]
}

NewUserRegistration : entry / New user registration
NewUserRegistration : do / Registration details
NewUserRegistration : exit / After updation

UpdateDB --> Login : [verified]

state Login {
    Login --> Checking : [valid credentials]
}

Login : entry / Enter username and password
Login : do / Checking
Login : exit / After verification

EnterCredentials --> Profile : [valid uname & pwd]

state "Profile" as Profile {
    ChoiceProfile --> EditProfile : [edit profile data]
    ChoiceProfile --> SearchUsers : [search user]
    ChoiceProfile --> ViewDeals : [current deals]
    ChoiceProfile --> AddToWishlist : [add product to wishlist]
    ChoiceProfile --> MoveFromWishlistToCart : [move from wishlist to cart]

}

Profile : entry / View or Edit profile
Profile : do / Search users
Profile : do / View current deals
Profile : do / Add to wishlist
Profile : do / Move from wishlist to cart
Profile : exit / Logout

    EditProfile --> [*] : [Logout]
    SearchUsers --> [*] : [Logout]
    ViewDeals --> [*] : [Logout]
    AddToWishlist --> [*] : [Logout]
    MoveFromWishlistToCart --> [*] : [Logout]
@enduml
