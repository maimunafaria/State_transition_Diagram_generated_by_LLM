@startuml
title UML State Machine Diagram - Search Users

[*] --> ChooseFilter

state "Choose filter category" as ChooseFilter {
    state PriceRange
    state OtherCategory

    ChooseFilter --> PriceRange : [user chooses price range]
    ChooseFilter --> OtherCategory : [user chooses other category]
}

PriceRange --> DisplayMatches : [displays matching users based on chosen criteria]
OtherCategory --> DisplayMatches : [displays matching users based on chosen criteria]

DisplayMatches --> [*] : [user continues searching or exits]
@enduml
