@startuml

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> ApplyForVisa : apply for visa
  ApplyForVisa --> PaymentConfirmation : make payment
  PaymentConfirmation --> Accepted : application accepted
  Accepted --> ViewStatus : view status
  ViewStatus --> CheckStatus : check status
  CheckStatus --> CancelApplication : cancel application
  CheckStatus --> ModifyDetails : modify details
  ModifyDetails --> ViewDetails : view details
  ViewDetails --> GiveFeedback : give feedback
  GiveFeedback --> Logout : log out
  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
  Logout --> [*] : logout
}

@enduml
