@startuml
[*] --> LoggedIn

state LoggedIn {
  Dashboard --> Market : check market conditions
  Dashboard --> PestControl : pest control help
  state SoilAnalysis {
    SoilInfo --> Suggestions
  }
  LoggedIn --> Dashboard
  Dashboard --> WeatherInsights : weather insights
  Dashboard --> LabourAvailability : labour availability details
  Dashboard --> [*] : continue using service
  LoggedIn --> LabourAvailability
  LoggedIn --> WeatherInsights
}

LoggedIn --> Logout : logout
@enduml
