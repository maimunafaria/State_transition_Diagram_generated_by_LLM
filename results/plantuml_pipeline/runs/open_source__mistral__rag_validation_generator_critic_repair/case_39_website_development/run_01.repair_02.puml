@startuml
!define PLANTUML_CMD #green
!define PLANTUML_ERR #red
!define PLANTUML_OK #blue

Homepage[Homepage] -down-> NavigationBar[NavigationBar]

NavigationBar[NavigationBar] --up--> Projects[Projects]
NavigationBar[NavigationBar] --up--> CareerOpportunities[CareerOpportunities]

[*] -down- Homepage[Homepage]

state Projects {
    Projects --> PhotoView[PhotoView]
    Projects --> VideoView[VideoView]
}

state CareerOpportunities {
    CareerOpportunities --> Updates[Updates]
    CareerOpportunities --> ApplicationForm[ApplicationForm]
}

ApplicationForm[ApplicationForm] --up--> Submitted[Submitted]
Submitted[Submitted] -down- Checked[Checked]
Checked[Checked] -down- [*]
@enduml
