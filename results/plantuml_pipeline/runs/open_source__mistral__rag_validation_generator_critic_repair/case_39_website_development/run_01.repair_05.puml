@startuml
!define PLANTUML_CMD #green
!define PLANTUML_ERR #red
!define PLANTUML_OK #blue

state Homepage
Homepage --> NavigationBar

NavigationBar --> Projects
NavigationBar --> CareerOpportunities

[*] --> Homepage: PLANTUML_CMD "home"

state Projects
Projects --> PhotoView
Projects --> VideoView

state CareerOpportunities
CareerOpportunities --> Updates
CareerOpportunities --> ApplicationForm

ApplicationForm --> Submitted
Submitted --> Checked
Checked --> [*]: PLANTUML_ERR "submitted"
Checked --> [*]: PLANTUML_OK "checked"
@enduml
