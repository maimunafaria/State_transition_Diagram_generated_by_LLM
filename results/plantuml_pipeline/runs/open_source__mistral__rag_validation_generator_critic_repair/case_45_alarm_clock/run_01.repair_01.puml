@startuml
title Alarm Clock State Diagram

state Off {
  [*] --> SetAlarm
}

Off --> ActiveAlarm : User sets alarm time

state ActiveAlarm {
  state Ringing {
    ActiveAlarm --> Ringing : Time matches alarm time
    Ringing --> Stopped : User stops alarm
  }
  state Stopped {
    [*] --> NextAlarm : Next scheduled alarm time
  }
}

state SetAlarm {
  state AlarmSet {
    [*] --> ActiveAlarm : Activate alarm
  }
}

ActiveAlarm --> Off : User turns off activated alarm
Stopped --> Off : Next scheduled alarm time
@enduml
