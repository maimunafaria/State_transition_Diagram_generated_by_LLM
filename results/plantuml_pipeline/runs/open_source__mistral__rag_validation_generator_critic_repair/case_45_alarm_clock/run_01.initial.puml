@startuml
title Alarm Clock State Diagram

state Off {
  [*] --> SetAlarmTime
}

state ActiveAlarm {
  state Ringing {
    [*] --> StartRinging : current time matches set alarm time
    Ringing --> StoppedByUser : user stops alarm
    Ringing --> NextScheduledAlarm : time passes
  }

  state Stopped {
    [*] --> StoppedByUser : user turns off activated alarm
    Stopped --> ActiveAlarm : next scheduled alarm time
  }
}

Off --> ActiveAlarm : user sets an alarm time
ActiveAlarm --> Off : no active alarms
@enduml
