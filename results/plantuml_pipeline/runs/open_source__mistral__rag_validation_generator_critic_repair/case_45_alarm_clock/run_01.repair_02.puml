@startuml
title Alarm Clock State Diagram

state Off {
  [*] --> ActiveAlarm : user sets an alarm time
}

state ActiveAlarm {
  state Ringing {
    ActiveAlarm --> Ringing : current time matches set alarm time
    Ringing --> Stopped : user stops alarm or time passes
  }

  state Stopped {
    [*] --> Stopped : user turns off activated alarm
    Stopped --> ActiveAlarm : next scheduled alarm time
  }
}
@enduml
