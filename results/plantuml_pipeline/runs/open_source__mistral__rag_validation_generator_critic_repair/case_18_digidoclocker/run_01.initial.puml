@startuml
title UML State Machine Diagram (Digidoclocker)

[*] --> LoggedIn

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
  CitizenUploadDocs : upload documents
  CitizenUploadDocs --> ContinueUploading : more documents
  CitizenUploadDocs --> Uploaded : all documents uploaded
  CitizenBuyProduct : buy product
  CitizenBuyProduct --> Paid : payment successful
  CitizenBuyProduct --> NotPaid : payment unsuccessful
  CitizenLogout : logout
}

state StartLogin <<choice>>

[*] --> StartLogin
StartLogin --> CitizenLogin
StartLogin --> SellerLogin

CitizenLogin --> Registration
SellerLogin --> Registration

Registration {
  [*] --> EnterDetails
  EnterDetails --> MemberIDIssued : correct details entered
  EnterDetails --> ReEnterDetails : incorrect details entered
}

state MemberIDIssued {
  MemberIDIssued --> Authentication
}

state Authentication {
  [*] --> EnterMemberID
  EnterMemberID --> EnterPassword
  EnterPassword --> SuccessfulLogin : correct password
  EnterPassword --> InvalidCreds : incorrect password
}

CitizenLogout --> [*]
SellerLogout --> [*]
@enduml
