@startuml
title ATM Control - Withdrawal Scenario

state "Waiting for Input" as WaitingForInput
state "Choosing Amount" as ChoosingAmount
state "Selecting Predefined Amount" as SelectingPredefinedAmount
state "Entering Custom Amount" as EnteringCustomAmount
state "Cancelling Transaction" as CancellingTransaction
state "Dispensing Cash" as DispensingCash
state "Returning Card" as ReturningCard

[*] --> WaitingForInput : Initial transition
WaitingForInput --> ChoosingAmount : User chooses option
ChoosingAmount --> SelectingPredefinedAmount : Predefined amount selected
SelectingPredefinedAmount --> DispensingCash : Amount approved
EnteringCustomAmount --> DispensingCash : Custom amount entered and approved
CancellingTransaction --> ReturningCard : Transaction cancelled
DispensingCash --> ReturningCard : Cash dispensed
@enduml
