@startuml
title ATM Control - Withdrawal Scenario

state "Waiting for Input" as WaitingForInput
state "Choosing Amount" as ChoosingAmount
state "Choosing Predefined Amount" as ChoosingPredefinedAmount
state "Selecting Predefined Amount" as SelectingPredefinedAmount
state "Entering Custom Amount" as EnteringCustomAmount
state "Cancelling Transaction" as CancellingTransaction
state "Processing Withdrawal" as ProcessingWithdrawal
state "Dispensing Cash" as DispensingCash
state "Printing Receipt" as PrintingReceipt
state "Ejecting Card" as EjectingCard

[*] --> WaitingForInput : Initial transition
WaitingForInput --> ChoosingAmount : User chooses option
ChoosingAmount --> ChoosingPredefinedAmount
ChoosingAmount --> EnteringCustomAmount
ChoosingPredefinedAmount --> SelectingPredefinedAmount
SelectingPredefinedAmount --> DispensingCash : Amount dispensed
EnteringCustomAmount --> ProcessingWithdrawal : Valid amount entered
ProcessingWithdrawal --> DispensingCash : Withdrawal approved
ProcessingWithdrawal --> EjectingCard : Rejected / Eject, Display Apology
CancellingTransaction --> EjectingCard : Cancel / Eject
DispensingCash --> PrintingReceipt : Cash dispensed
PrintingReceipt --> EjectingCard : Receipt printed
EjectingCard --> "Waiting for Input" : Card ejected
@enduml
