@startuml
title Website Development State Machine Diagram

state Homepage
Homepage : entry / User arrives at website
Homepage : do / Display homepage content
Homepage : exit / Navigation options available

state ProjectInfo
ProjectInfo : entry / Project selected by user
ProjectInfo : do / Display project details
ProjectInfo : exit / Ready for photo/video choice

state PhotoVideoChoice <<choice>>
PhotoVideoChoice --> [*] : [Choose Photos]
PhotoVideoChoice --> [*] : [Choose Videos]

state CareerInfo
CareerInfo : entry / Career opportunities selected
CareerInfo : do / Display career information
CareerInfo : exit / Ready for action choice

state ApplicationForm
ApplicationForm : entry / User selects to apply
ApplicationForm : do / Open application form
ApplicationForm : exit / Form submitted

state CheckApplication
CheckApplication : entry / Application submitted
CheckApplication : do / Validate and process application
CheckApplication : exit / [Application Confirmed] or [Rejected]

state ApplicationConfirmation
ApplicationConfirmation : entry / Application approved
ApplicationConfirmation : do / Confirm approval
ApplicationConfirmation : exit / Process completed

state ApplicationRejected
ApplicationRejected : entry / Application denied
ApplicationRejected : do / Notify rejection
ApplicationRejected : exit / Process terminated

[*] --> Homepage

Homepage --> ProjectInfo : [View Projects]
Homepage --> CareerInfo : [View Careers]

ProjectInfo --> PhotoVideoChoice

CareerInfo --> ApplicationForm : [Apply Now]
CareerInfo --> CheckApplication : [View Updates]

PhotoVideoChoice --> [*] : [Back to Projects]

ApplicationForm --> CheckApplication

CheckApplication --> ApplicationConfirmation : [Approved]
CheckApplication --> ApplicationRejected : [Rejected]

ApplicationConfirmation --> [*] : [Exit]
ApplicationRejected --> [*] : [Exit]

@enduml
