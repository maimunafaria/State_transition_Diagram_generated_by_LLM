@startuml
title Digital Watch State Diagram

state "Normal" as Normal
state "Adjustment Mode" as AdjustmentMode
state "Alarm" as Alarm

[*] --> Normal

Normal --> AdjustmentMode : Adjust Button Pressed
Normal --> Alarm : Alarm Time Matched

AdjustmentMode --> Normal : Adjust Button Pressed (Exit)
AdjustmentMode --> Adjustment_Hour : Button Pressed
AdjustmentMode --> Adjustment_Minute : Button Pressed
AdjustmentMode --> Adjustment_AlarmHour : Button Pressed
AdjustmentMode --> Adjustment_AlarmMinute : Button Pressed

state "Adjustment_Hour" as Adjustment_Hour
Adjustment_Hour --> Adjustment_Minute : Button Pressed
Adjustment_Hour --> Normal : Adjust Button Pressed (Exit)
Adjustment_Hour --> Adjustment_Hour : Increase Button Pressed

state "Adjustment_Minute" as Adjustment_Minute
Adjustment_Minute --> Adjustment_AlarmHour : Button Pressed
Adjustment_Minute --> Adjustment_Hour : Button Pressed
Adjustment_Minute --> Normal : Adjust Button Pressed (Exit)
Adjustment_Minute --> Adjustment_Minute : Increase Button Pressed

state "Adjustment_AlarmHour" as Adjustment_AlarmHour
Adjustment_AlarmHour --> Adjustment_AlarmMinute : Button Pressed
Adjustment_AlarmHour --> Adjustment_Minute : Button Pressed
Adjustment_AlarmHour --> Normal : Adjust Button Pressed (Exit)
Adjustment_AlarmHour --> Adjustment_AlarmHour : Increase Button Pressed

state "Adjustment_AlarmMinute" as Adjustment_AlarmMinute
Adjustment_AlarmMinute --> Adjustment_Hour : Button Pressed
Adjustment_AlarmMinute --> Adjustment_Minute : Button Pressed
Adjustment_AlarmMinute --> Normal : Adjust Button Pressed (Exit)
Adjustment_AlarmMinute --> Adjustment_AlarmMinute : Increase Button Pressed

Alarm --> Normal : Stop Button Pressed
@enduml
