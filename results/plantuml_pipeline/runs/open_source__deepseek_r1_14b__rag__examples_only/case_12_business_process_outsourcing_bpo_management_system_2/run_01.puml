@startuml
title UML State Machine Diagram (Search Filters)

[*] --> SearchFilters : [Initial search]

state "Search Filters" as SearchFilters {
    [*] --> ChoiceFilter

    state ChoiceFilter <<choice>>
    ChoiceFilter --> ProcessCategory : [Select category filter]
    ChoiceFilter --> ProcessPriceRange : [Select price range]
}

state "Process Category Filter" as ProcessCategory
ProcessCategory --> DisplayResults

state "Process Price Range" as ProcessPriceRange
ProcessPriceRange --> DisplayResults

state "Display Results" as DisplayResults {
    DisplayResults --> [*] : [Back to search]
    DisplayResults --> ChoiceAction : [View details]
}

state ChoiceAction <<choice>>
ChoiceAction --> [*] : [Done searching]
@enduml
