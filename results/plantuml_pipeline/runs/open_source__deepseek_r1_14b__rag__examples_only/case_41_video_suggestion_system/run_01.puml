@startuml
title Video Suggestion System State Machine

[*] --> ReceivingRequest

state ReceivingRequest {
  entry / Process video suggestion request
  exit / Move to identify user
}

ReceivingRequest --> IdentifyingUser : identifyUser

state IdentifyingUser {
  entry / Identify user details
  exit / Proceed to gather videos
}

IdentifyingUser --> GatheringVideos : gatherVideos

state GatheringVideos {
  entry / Gather videos based on criteria
  exit / Prepare data for next step
}

GatheringVideos --> AddingDetails : addDetails

state AddingDetails {
  entry / Add thumbnails and view counts
  exit / Send suggestions to user
}

AddingDetails --> SendingSuggestions : sendSuggestions

state SendingSuggestions {
  entry / Transmit suggested videos
  exit / System completes process
}

SendingSuggestions --> [*]

@enduml
