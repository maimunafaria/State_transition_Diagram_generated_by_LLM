@startuml
title Safehome Security Function State Diagram

state Checking {
  [*] --> Checking : Power On
}

state Ready {
  <+/-> do / System Ready
}

state Stopped {
  <+/-> do / System Stop
}

state Monitoring {
  <+/-> do / Start Monitor
}

state Alarm {
  <+/-> do / Trigger Alarm
}

Checking --> Ready : OK
Checking --> Stopped : Problem

Ready --> Ready : Reset
Ready --> Monitoring : Activate
Ready --> Stopped : Turn Off

Monitoring --> Alarm : Sensor Triggered
Alarm --> Monitoring : False Alarm or Time Elapsed
Alarm --> Ready : Password Entered

Stopped --> Checking : Power Cycle
@enduml
