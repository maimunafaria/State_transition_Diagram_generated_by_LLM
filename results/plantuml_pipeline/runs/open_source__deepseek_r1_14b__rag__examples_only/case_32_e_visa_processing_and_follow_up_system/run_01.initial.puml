@startuml
title E Visa Processing And Follow Up System State Machine Diagram

state "Create Account" as CreateAccount
CreateAccount : entry / Provide account details
CreateAccount : do / Verify and create account
CreateAccount : exit / Created successfully

state "Login" as Login
Login : entry / Provide login credentials
Login : do / Validate credentials
Login : exit / Logged in

state "MainMenu" as MainMenu
MainMenu : entry / After successful login
MainMenu : do / Display main menu options
MainMenu : exit / Ready for next action

state "Apply for Visa" as ApplyVisa
ApplyVisa : entry / Initiate visa application
ApplyVisa : do / Submit application details
ApplyVisa : exit / Application submitted

state "Payment" as Payment
Payment : entry / Proceed to payment
Payment : do / Process payment
Payment : exit / Payment completed

state "Application Status" as AppStatus
AppStatus : entry / Check visa status
AppStatus : do / Display current status
AppStatus : exit / Ready for next action

state "Modify Details" as ModifyDetails
ModifyDetails : entry / Update account information
ModifyDetails : do / Save changes
ModifyDetails : exit / Details updated

state "Cancel Application" as CancelApp
CancelApp : entry / Start cancellation process
CancelApp : do / Review and cancel application
CancelApp : exit / Application canceled

state "Give Feedback" as GiveFeedback
GiveFeedback : entry / Provide feedback
GiveFeedback : do / Submit feedback
GiveFeedback : exit / Feedback submitted

state "Logout" as Logout
Logout : entry / End session
Logout : do / Terminate session
Logout : exit / Session ended

[*] --> J1 <<choice>>
J1 --> CreateAccount
J1 -->
@enduml
