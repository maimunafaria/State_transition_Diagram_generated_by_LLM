@startuml
title UML State Chart Diagram

[*] --> UserType

state UserType <<choice>>

UserType --> CitizenLogin : [Citizen user]
UserType --> RegistrarLogin : [Registrar user]

state "Citizen Login" as CitizenLogin
CitizenLogin : entry / Action needed
CitizenLogin : do / enter login credentials
CitizenLogin : exit / Entered into system

state "Registrar Login" as RegistrarLogin
RegistrarLogin : entry / Action needed
RegistrarLogin : do / enter login credentials
RegistrarLogin : exit / Entered into system

state CitizenRegister <<choice>>
CitizenLogin --> CitizenRegister

state "Citizen Register" as CitizenRegister
CitizenRegister : entry / Registration needed
CitizenRegister : do / register
CitizenRegister : exit / Registered

CitizenRegister --> CitizenHome

state "Citizen Home" as CitizenHome
CitizenHome : entry / Logged in state
CitizenHome : do / view profile, upload documents, apply for certificate
CitizenHome : exit / NIL

CitizenHome --> UploadDocs
CitizenHome --> ApplyCertificate

state "Upload Documents" as UploadDocs
UploadDocs : entry / Uploading documents
UploadDocs : do / upload documents
UploadDocs : exit / NIL

UploadDocs --> UploadDocs

state "Apply for Certificate" as ApplyCertificate
ApplyCertificate : entry / Applying for certificate
ApplyCertificate : do / apply for certificate
ApplyCertificate : exit / NIL

ApplyCertificate --> ApplyCertificate

state "Multiple Certificates" as MultipleCertificates
MultipleCertificates : entry / Applying for multiple certificates
MultipleCertificates : do / reapply after sending a request to the issuer
MultipleCertificates : exit / NIL

CitizenHome --> MultipleCertificates

state RegistrarRequest <<choice>>
RegistrarLogin --> RegistrarRequest

state "Registrar Request" as RegistrarRequest
RegistrarRequest : entry / Requesting certificates for verification
RegistrarRequest : do / request certificates
RegistrarRequest : exit / NIL

RegistrarRequest --> RegistrarRequest

@enduml
