@startuml
title UML State Machine Diagram - Website Navigation

[*] --> Homepage

state "Homepage" as Homepage
state "Projects" as Projects
state "Career Opportunities" as CareerOpportunities
state "Job Application" as JobApplication
state "Internship Application" as InternshipApplication

Homepage : do / Navigation bar
Homepage --> Projects
Homepage --> CareerOpportunities

Projects : do / Select project
Projects --> PhotosOrVideos

PhotosOrVideos : do / Choose photos or videos
PhotosOrVideos --> [*]

CareerOpportunities : do / View updates or application form
CareerOpportunities --> Updates
CareerOpportunities --> ApplicationForm

Updates : do / Display information about career opportunities
Updates --> [*]

ApplicationForm : do / Submit job application
ApplicationForm --> CheckSubmitted

InternshipApplication : do / Submit internship application
InternshipApplication --> CheckSubmitted

CheckSubmitted : do / Check submitted applications
CheckSubmitted --> [*]
@enduml
