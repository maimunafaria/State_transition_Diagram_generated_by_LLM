@startuml
title UML State Machine Diagram (Microwave Oven)

state "Display Current Time" as DCT {
    [*] --> UserInput
}

state "User Input" as UI {
    UI : entry / Wait for user input
    UI : do / Choose power level and cooking time
    UI : exit / After user input

    state PowerLevel <<choice>>
    PowerLevel --> HalfPower : [Half power selected]
    PowerLevel --> FullPower : [Full power selected]

    state TimeInput {
        TimeInput : entry / Wait for cooking time
        TimeInput : do / Validate and store cooking time
        TimeInput : exit / After user input
    }

    UI --> DoorOpen : [Door is open during operation]
    UI --> Cancel : [User cancels the cooking process]
}

state "Door Open" as DO {
    DO : entry / Door opened during operation
    DO : do / Stop immediately
    DO : exit / Return to Display Current Time
}

state "Cancel" as CN {
    CN : entry / User cancels the cooking process
    CN : do / Return to Display Current Time and wait for the next use
    CN --> [*]
}
@enduml
