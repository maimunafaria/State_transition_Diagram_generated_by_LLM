@startuml
title UML State Machine Diagram (Alarm Clock)

[*] --> Off

state Off {
    Off : do / Initial state
}

Off --> SettingAlarm

state SettingAlarm {
    SettingAlarm : do / User sets alarm time
    SettingAlarm : exit / Alarm set
}

SettingAlarm --> Active

state Active {
    Active : do / Activated alarm
    Active : entry / Alarm activated
}

Active --> Ringing

state Ringing {
    Ringing : do / Start ringing the alarm
    Ringing : exit / Stopped by user
}

Ringing --> Off

Off --> SettingAlarm
@enduml
