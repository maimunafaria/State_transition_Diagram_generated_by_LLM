@startuml
title UML State Chart Diagram - Green Rides User

state "Login" as Login {
  [*] --> EnterCredentials

  state "Enter Credentials" as EnterCredentials
  state "Successful Login" as SuccessfulLogin
  state "Invalid Credentials" as InvalidCreds

  EnterCredentials --> SuccessfulLogin : [Valid]
  EnterCredentials --> InvalidCreds : [Invalid]
}

state "Destination Selection" as DestSelection {
  SuccessfulLogin --> DestSelection

  state "Select Destination" as SelectDest
  state "View Journey Details" as ViewJourneyDetails

  SelectDest --> ViewJourneyDetails
}

state "Driving Mode" as DrivingMode {
  ViewJourneyDetails --> ActivateDrivingMode

  state "Activate Driving Mode" as ActivateDrivingMode
  state "Choose Other Options" as ChooseOtherOptions

  ActivateDrivingMode --> [*]
  ChooseOtherOptions --> [*]
}

state "Food Selection" as FoodSelection {
  ViewJourneyDetails --> SelectPlaceToEat

  state "Select Place to Eat" as SelectPlaceToEat
  state "View Menu" as ViewMenu
  state "Place Order" as PlaceOrder
  state "No Hunger" as NoHunger

  SelectPlaceToEat --> ViewMenu
  ViewMenu --> PlaceOrder : [Hungry]
  ViewMenu --> NoHunger : [Not Hungry]
  NoHunger --> [*]
}

state "Accident Handling" as AccidentHandling {
  ActivateDrivingMode --> Drive
  Drive --> Accident : [Accident Occurs]

  state "Send Notifications" as SendNotifications
  state "Inform Authorities" as InformAuthorities

  Accident --> SendNotifications
  SendNotifications --> InformAuthorities
}

state "Feedback" as Feedback {
  [*] --> ProvideFeedback

  state "Provide Feedback" as ProvideFeedback
  state "Complete Journey" as CompleteJourney

  ProvideFeedback --> CompleteJourney
}

state Start <<choice>>

[*] --> Start
Start --> Login
Start --> FoodSelection
@enduml
