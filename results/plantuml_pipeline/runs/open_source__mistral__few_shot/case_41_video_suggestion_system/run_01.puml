@startuml
title State machine for Video Suggestion System

state RequestReceived
state UserIdentified
state VideoGathered
state DetailsAdded
state SuggestionsSent

[*] --> RequestReceived : userRequest()

RequestReceived --> UserIdentified : userIdentified()
UserIdentified --> VideoGathered : gatherVideos(userProfile, trending, tags, genres, promoted)
VideoGathered --> DetailsAdded : addThumbnailsAndViewCounts()
DetailsAdded --> SuggestionsSent : sendSuggestionsToUser()
@enduml
