@startuml
title E Visa State Machine Diagram

state CreateAccount {
    [*] --> Login
}

Login : entry / account created

state LoggedIn {
    state ApplyForVisa
    state ViewStatus
    state CheckStatus
    state CancelApplication
    state ModifyDetails
    state ViewDetails
    state CheckDocument
    state GiveFeedback
    state Logout

    Login --> ApplyForVisa : [apply for visa]
    ApplyForVisa --> Payment : [make payment]
    Payment --> Accepted : [application accepted]
    Accepted --> ViewStatus : [view status]
    ViewStatus --> CheckStatus : [check status]
    CheckStatus --> [*] : [status updated]
    CancelApplication --> [*] : [cancel application]
    ModifyDetails --> [*] : [modify details]
    ViewDetails --> [*] : [view details]
    CheckDocument --> Approved : [document check approved]
    CheckDocument --> Rejected : [document check rejected]
    GiveFeedback --> [*] : [give feedback]
    Logout --> [*] : [logged out]
}
@enduml
