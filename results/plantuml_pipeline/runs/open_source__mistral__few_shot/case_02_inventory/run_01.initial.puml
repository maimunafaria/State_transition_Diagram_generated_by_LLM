@startuml
title State machine for Inventory

state AddingGoods
state UpdatingPrice
state RemovingGoods
state ExpiredGoodsNotified
state OrderingSupplier
state PendingOrder
state GeneratingInvoice
state SelectingItemsForPurchase
state CalculatingDiscountAndTax
state GeneratingReceipt
state ReplacingOrCancellingReceipt
state RecordingCustomerRequest
state ViewingTransactionSummary

[*] --> AddingGoods : addNewGood
AddingGoods --> UpdatingPrice : updatePrice
UpdatingPrice --> RemovingGoods : removeExpiredGoodsNotified
RemovingGoods --> ExpiredGoodsNotified : expiredGoodsDetected
ExpiredGoodsNotified --> [*] : notifyUser
OrderingSupplier --> PendingOrder : orderPlaced
PendingOrder --> GeneratingInvoice : invoiceGenerated
GeneratingInvoice --> SelectingItemsForPurchase : itemsSelected
SelectingItemsForPurchase --> CalculatingDiscountAndTax : discountAndTaxCalculated
CalculatingDiscountAndTax --> GeneratingReceipt : receiptGenerated
GeneratingReceipt --> [*] : receiptReceived
ReplacingOrCancellingReceipt --> [*] : receiptUpdated
RecordingCustomerRequest --> [*] : requestRecorded
ViewingTransactionSummary --> [*] : summaryViewed
@enduml
