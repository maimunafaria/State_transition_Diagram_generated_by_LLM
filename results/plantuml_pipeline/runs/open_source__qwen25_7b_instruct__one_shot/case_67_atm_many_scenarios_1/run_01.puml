@startuml
title ATM Transaction State Machine
[*] --> InsertCard
state InsertCard {

  state WaitForPIN
  state VerifyPIN

  state DisplayOptions

  state ProcessWithdrawal

  state PrintReceipt

  state ReturnCard

  state Reset
}

state InsertCard --> WaitForPIN : insertCard
WaitForPIN --> VerifyPIN : enterPIN
VerifyPIN --> VerifyPIN : verifyPIN
VerifyPIN --> DisplayOptions : pinVerified
VerifyPIN --> WaitForPIN : pinInvalid

DisplayOptions --> ProcessWithdrawal : selectWithdrawal
ProcessWithdrawal --> PrintReceipt : dispenseCash
PrintReceipt --> ReturnCard : printReceipt
ReturnCard --> Reset : returnCard

Reset --> [*] : reset
@enduml
