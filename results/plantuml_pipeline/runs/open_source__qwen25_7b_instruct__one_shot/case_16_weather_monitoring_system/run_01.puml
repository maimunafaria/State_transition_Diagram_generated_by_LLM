@startuml
title State machine for Weather Monitoring System

state Initial
state Registered
state LoggedIn
state LocationInvalid
state WeatherCheck
state WeatherDetails
state Logout

[*] --> Initial

Initial --> Registered : createUserAccount

Registered --> LoggedIn : login

LoggedIn --> LocationInvalid : checkLocationValidity(location)

LocationInvalid --> [*] : endProcess

LoggedIn --> WeatherCheck : checkWeather

WeatherCheck --> WeatherDetails : chooseWeatherInfo

WeatherCheck --> WeatherDetails : checkWeather

WeatherDetails --> [*] : logout

WeatherDetails --> [*] : endSession

@enduml
