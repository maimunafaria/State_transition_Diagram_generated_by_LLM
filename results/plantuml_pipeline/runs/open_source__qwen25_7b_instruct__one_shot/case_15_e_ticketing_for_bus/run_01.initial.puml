@startuml
title UML State Machine Diagram

[*] --> Register

state "Register" as Register
Register : entry / start
Register : do / user creates account
Register : exit / registration complete

state "Validate Registration" as Validate
Validate : entry / validate user
Validate : do / registration validation
Validate : exit / validation complete

state "Login" as Login
Login : entry / user logs in
Login : do / authentication
Login : exit / login complete

state "Logged In" as LoggedIn
LoggedIn : entry / user is logged in
LoggedIn : do / manage account details
LoggedIn : do / check ticket status
LoggedIn : do / book ticket
LoggedIn : do / make payment
LoggedIn : do / logout
LoggedIn : exit / user logged out

state "Account Management" as AccountManagement
AccountManagement : entry / manage account
AccountManagement : do / edit or delete account
AccountManagement : exit / account management complete

state "Check Ticket Status" as CheckStatus
CheckStatus : entry / check ticket
CheckStatus : do / retrieve ticket status
CheckStatus : exit / status retrieved

state "Book Ticket" as BookTicket
BookTicket : entry / book ticket
BookTicket : do / select ticket
BookTicket : do / confirm booking
BookTicket : do / make payment
BookTicket : exit / ticket booked

state "Make Payment" as MakePayment
MakePayment : entry / make payment
MakePayment : do / payment process
MakePayment : exit / payment complete

state "Logout" as Logout
Logout : entry / user logs out
Logout : do / logout process
Logout : exit / user logged out

Validate --> Login
Login --> LoggedIn
LoggedIn --> AccountManagement
LoggedIn --> CheckStatus
LoggedIn --> BookTicket
BookTicket --> MakePayment
MakePayment --> LoggedIn
LoggedIn --> Logout
Logout --> [*]

@enduml
