@startuml
title UML State Chart Diagram

[*] --> StartCampaign

state StartCampaign <<choice>>

StartCampaign --> AssignManager
StartCampaign --> AssignStaff

state "Campaign Assigned" as Assigned
Assigned : entry / manager and staff are assigned
Assigned : do / assign manager and staff
Assigned : exit / assignment complete

state "Campaign Approved" as Approved
Approved : entry / campaign is approved and contract is signed
Approved : do / sign contract and approve campaign
Approved : exit / campaign approved

state "Prepare Adverts" as PrepareAdverts
PrepareAdverts : entry / campaign is approved
PrepareAdverts : do / prepare adverts
PrepareAdverts : exit / adverts prepared

state "Adverts Approved" as AdvertsApproved
AdvertsApproved : entry / adverts are approved and scheduled
AdvertsApproved : do / approve and schedule adverts
AdvertsApproved : exit / adverts approved and scheduled

state "Run Adverts" as RunAdverts
RunAdverts : entry / adverts are running
RunAdverts : do / run adverts
RunAdverts : exit / adverts are running

state "Extend/Adjust Campaign" as ExtendAdjust
ExtendAdjust : entry / campaign is running
ExtendAdjust : do / extend or adjust campaign
ExtendAdjust : exit / campaign extended or adjusted

state "Campaign Completed" as Completed
Completed : entry / all adverts have finished
Completed : do / complete campaign
Completed : exit / campaign completed

state "Final Statement" as FinalStatement
FinalStatement : entry / final statement is prepared
FinalStatement : do / prepare final statement
FinalStatement : exit / final statement prepared

state "Handle Payment" as HandlePayment
HandlePayment : entry / handle payment after campaign completion
HandlePayment : do / handle payment and generate refund if needed
HandlePayment : exit / payment handled

state "Wait for Balance" as WaitForBalance
WaitForBalance : entry / wait for correct balance to be settled
WaitForBalance : do / wait for balance to be settled
WaitForBalance : exit / balance settled

state "Campaign Paid" as Paid
Paid : entry / full amount is properly paid
Paid : do / mark campaign as paid
Paid : exit / campaign marked as paid

state "Campaign Archived" as Archived
Archived : entry / campaign is archived
Archived : do / archive campaign and release staff and managers
Archived : exit / campaign archived

Completed --> FinalStatement
FinalStatement --> HandlePayment
HandlePayment --> WaitForBalance
WaitForBalance --> Paid
Paid --> Archived
Archived --> [*]

Assigned --> Approved
Approved --> PrepareAdverts
PrepareAdverts --> AdvertsApproved
AdvertsApproved --> RunAdverts
RunAdverts --> ExtendAdjust
ExtendAdjust --> [*]

@enduml
