@startuml
title UML state machine diagram

state "Initial State" as Initial
Initial : entry/Start

state "Add Goods" as AddGoods
AddGoods : entry/Add new goods
AddGoods : do/Add goods to inventory
AddGoods : exit/Add goods

state "Update Price" as UpdatePrice
UpdatePrice : entry/Update price
UpdatePrice : do/Update price of existing items
UpdatePrice : exit/Price updated

state "Remove Goods" as RemoveGoods
RemoveGoods : entry/Remove goods
RemoveGoods : do/Remove goods from inventory
RemoveGoods : exit/Goods removed

state "Identify Expired Goods" as IdentifyExpired
IdentifyExpired : entry/Check expiration
IdentifyExpired : do/Identify expired goods
IdentifyExpired : exit/Notify user

state "Place Order" as PlaceOrder
PlaceOrder : entry/Place order
PlaceOrder : do/Order additional goods
PlaceOrder : exit/Order placed

state "Generate Invoice" as GenerateInvoice
GenerateInvoice : entry/Generate invoice
GenerateInvoice : do/Generate invoice for order
GenerateInvoice : exit/Invoice generated

state "Search Items" as SearchItems
SearchItems : entry/Search items
SearchItems : do/Search and select items for purchase
SearchItems : exit/Items selected

state "Calculate Discount and Tax" as CalculateDiscountTax
CalculateDiscountTax : entry/Calculate discount and tax
CalculateDiscountTax : do/Calculate applicable discount and tax
CalculateDiscountTax : exit/Discount and tax calculated

state "Generate Receipt" as GenerateReceipt
GenerateReceipt : entry/Generate receipt
GenerateReceipt : do/Generate receipt for purchase
GenerateReceipt : exit/Receipt generated

state "Replace Item or Cancel Receipt" as ReplaceCancel
ReplaceCancel : entry/Replace or cancel receipt
ReplaceCancel : do/Replace item or cancel receipt
ReplaceCancel : exit/Action completed

state "Record Customer Requests" as RecordRequests
RecordRequests : entry/Record requests
RecordRequests : do/Record customer requests
RecordRequests : exit/Requests recorded

state "View Summary Report" as ViewSummary
ViewSummary : entry/View report
ViewSummary : do/Generate summary report
ViewSummary : exit/Report generated

state "Final State" as Final
Final : entry/End

Initial --> AddGoods
Initial --> UpdatePrice
Initial --> RemoveGoods
Initial --> IdentifyExpired
Initial --> PlaceOrder
Initial --> GenerateInvoice
Initial --> SearchItems
Initial --> CalculateDiscountTax
Initial --> GenerateReceipt
Initial --> ReplaceCancel
Initial --> RecordRequests
Initial --> ViewSummary

AddGoods --> Initial
UpdatePrice --> Initial
RemoveGoods --> Initial
IdentifyExpired --> Initial
PlaceOrder --> Initial
GenerateInvoice --> Initial
SearchItems --> Initial
CalculateDiscountTax --> Initial
GenerateReceipt --> Initial
ReplaceCancel --> Initial
RecordRequests --> Initial
ViewSummary --> Final

@enduml
