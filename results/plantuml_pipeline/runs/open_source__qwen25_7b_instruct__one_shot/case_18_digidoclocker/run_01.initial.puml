@startuml
title UML State Chart Diagram - Digidoclocker

[*] --> Register

state Register <<choice>>
Register --> Login : [Login]

state Login <<choice>>
Login --> CitizenLogin : [Citizen]
Login --> RegistrarLogin : [Registrar]

state "Citizen Login" as CitizenLogin
CitizenLogin : entry / entered the app
CitizenLogin : do / check login details
CitizenLogin : exit / logged in

state "Registrar Login" as RegistrarLogin
RegistrarLogin : entry / entered the app
RegistrarLogin : do / check login details
RegistrarLogin : exit / logged in

state "Citizen Home" as CitizenHome
CitizenHome : entry / logged in
CitizenHome : do / upload documents, view profile, apply for certificate
CitizenHome : exit / actions completed

state "Upload Documents" as UploadDocuments
UploadDocuments : entry / need to upload documents
UploadDocuments : do / upload documents
UploadDocuments : exit / documents uploaded

state "View Profile" as ViewProfile
ViewProfile : entry / need to view profile
ViewProfile : do / view profile
ViewProfile : exit / profile viewed

state "Apply for Certificate" as ApplyCertificate
ApplyCertificate : entry / need to apply for certificate
ApplyCertificate : do / apply for certificate
ApplyCertificate : exit / certificate applied

state "Continue Uploading Documents" as ContinueUpload
ContinueUpload : entry / need to continue uploading documents
ContinueUpload : do / continue uploading documents
ContinueUpload : exit / documents uploaded

state "Apply for Multiple Certificates" as ApplyMultipleCertificates
ApplyMultipleCertificates : entry / need to apply for multiple certificates
ApplyMultipleCertificates : do / apply for multiple certificates
ApplyMultipleCertificates : exit / certificates applied

state "Registrar Home" as RegistrarHome
RegistrarHome : entry / logged in
RegistrarHome : do / request certificates for verification
RegistrarHome : exit / actions completed

state "Request Certificates" as RequestCertificates
RequestCertificates : entry / need to request certificates
RequestCertificates : do / request certificates
RequestCertificates : exit / certificates requested

state "Continue Requesting Certificates" as ContinueRequest
ContinueRequest : entry / need to continue requesting certificates
ContinueRequest : do / continue requesting certificates
ContinueRequest : exit / certificates requested

state "End Session" as EndSession
EndSession : entry / done with actions
EndSession : do / end session
EndSession : exit / session ended

CitizenHome --> UploadDocuments
CitizenHome --> ViewProfile
CitizenHome --> ApplyCertificate
CitizenHome --> ContinueUpload
CitizenHome --> ApplyMultipleCertificates

RegistrarHome --> RequestCertificates
RegistrarHome --> ContinueRequest

CitizenLogin --> CitizenHome
RegistrarLogin --> RegistrarHome

UploadDocuments --> CitizenHome
ViewProfile --> CitizenHome
ApplyCertificate --> CitizenHome
ContinueUpload --> CitizenHome
ApplyMultipleCertificates --> CitizenHome

RequestCertificates --> RegistrarHome
ContinueRequest --> RegistrarHome

CitizenHome --> EndSession : [End Session]
RegistrarHome --> EndSession : [End Session]

@enduml
