@startuml
title Digital Watch State Transition Diagram

state "Idle" as Idle
[*] --> Idle

state "Time Adjustment" as TimeAdjustment

state "Hour Adjustment" as HourAdjustment
state "Minute Adjustment" as MinuteAdjustment
state "Alarm Hour Adjustment" as AlarmHourAdjustment
state "Alarm Minute Adjustment" as AlarmMinuteAdjustment

state "Alarm On" as AlarmOn
state "Alarm Off" as AlarmOff

state "Light On" as LightOn
state "Light Off" as LightOff

Idle --> TimeAdjustment : pressButton

TimeAdjustment --> HourAdjustment : pressButton
TimeAdjustment --> MinuteAdjustment : pressButton
TimeAdjustment --> AlarmHourAdjustment : pressButton
TimeAdjustment --> AlarmMinuteAdjustment : pressButton

HourAdjustment --> Idle : pressButton
MinuteAdjustment --> Idle : pressButton
AlarmHourAdjustment --> Idle : pressButton
AlarmMinuteAdjustment --> Idle : pressButton

HourAdjustment --> HourAdjustment : increaseValue
MinuteAdjustment --> MinuteAdjustment : increaseValue
AlarmHourAdjustment --> AlarmHourAdjustment : increaseValue
AlarmMinuteAdjustment --> AlarmMinuteAdjustment : increaseValue

AlarmOn --> Idle : pressStopButton
AlarmOff --> Idle : pressStopButton

LightOn --> LightOff : pressButton
LightOff --> LightOn : pressButton

@enduml
