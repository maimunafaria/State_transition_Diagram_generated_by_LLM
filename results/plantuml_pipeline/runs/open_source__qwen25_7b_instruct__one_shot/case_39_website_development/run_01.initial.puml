@startuml
title Website Navigation State Machine

[*] --> Home : /navigateHome

state Home {
  state NavigationBar
  state ProjectInfo
  state CareerOpportunities
}

NavigationBar --> ProjectInfo : selectProjects
NavigationBar --> CareerOpportunities : selectCareer

ProjectInfo {
  state PhotoView
  state VideoView
  PhotoView --> VideoView : changeView
  VideoView --> PhotoView : changeView
}

CareerOpportunities {
  state UpdateInfo
  state ApplicationForm
  UpdateInfo --> ApplicationForm : openForm
  ApplicationForm --> UpdateInfo : viewUpdates
}

state Home : initial

CareerOpportunities --> Home : returnHome

ProjectInfo --> Home : returnHome

ApplicationForm --> Home : returnHome

UpdateInfo --> Home : returnHome

state Home : final
@enduml
