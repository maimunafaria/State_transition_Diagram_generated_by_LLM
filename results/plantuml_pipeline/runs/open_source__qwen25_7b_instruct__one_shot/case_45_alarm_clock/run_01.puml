@startuml
title UML state machine diagram

state "Off" as Off
state "Alarm Set" as AlarmSet
state "Alarm Ringing" as AlarmRinging
state "Alarm Stopped" as AlarmStopped


[*] --> Off

Off --> AlarmSet : [Set Alarm]
AlarmSet --> AlarmRinging : [Alarm Time Reached]
AlarmRinging --> AlarmStopped : [Stop Alarm]

state "Off" as Off
Off : entry / System is off
Off : do / Wait for alarm set or stop

state "Alarm Set" as AlarmSet
AlarmSet : entry / Alarm time set
AlarmSet : do / Wait for alarm time to reach

state "Alarm Ringing" as AlarmRinging
AlarmRinging : entry / Alarm is ringing
AlarmRinging : do / Ring alarm

state "Alarm Stopped" as AlarmStopped
AlarmStopped : entry / Alarm stopped
AlarmStopped : do / Wait for next alarm set

state "Alarm Set Choice" <<choice>>
state "Alarm Ringing Choice" <<choice>>

AlarmSet --> AlarmRingingChoice
AlarmRinging --> AlarmRingingChoice
AlarmStopped --> AlarmSetChoice

AlarmRingingChoice --> Off : [Turn Off]
AlarmRingingChoice --> AlarmStopped : [Stop Alarm]
AlarmSetChoice --> AlarmSet : [Set Alarm Again]
AlarmSetChoice --> Off : [Turn Off]

@enduml
