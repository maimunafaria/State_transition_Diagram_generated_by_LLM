@startuml
title State machine for Weather Station System

state Shutdown
state Running
state Configuring
state Configured
state SummaryPreparation
state StatusChecking
state Controlled

[*] --> Shutdown

Shutdown --> Running : powerOn
Shutdown --> Configuring : enterConfigMode

Running --> Running : clockTrigger
Running --> SummaryPreparation : prepareSummaryRequest
Running --> StatusChecking : checkStatusRequest
Running --> Running : activityCompleted

Configuring --> Configured : configCompleted

Configured --> Running : exitConfigMode
Configured --> Running : clockTrigger

SummaryPreparation --> Running : summaryPrepared

StatusChecking --> Running : statusChecked

Controlled --> Running : remoteControlCommand

Running --> Shutdown : shutdownCommand

@enduml
