state "Greeting" as Greeting
Greeting : entry/user arrives
Greeting : do/greet user
Greeting : exit/greeting complete

state "Card Inserted" as CardInserted
CardInserted : entry/card inserted
CardInserted : do/check card validity
CardInserted : exit/card valid

state "PIN Incorrect" as PINIncorrect
PINIncorrect : entry/PIN entered incorrectly
PINIncorrect : do/try again
PINIncorrect : exit/try again

state "PIN Correct" as PINCorrect
PINCorrect : entry/PIN entered correctly
PINCorrect : do/display options
PINCorrect : exit/options displayed

state "Card Kept" as CardKept
CardKept : entry/card kept for security
CardKept : do/keep card
CardKept : exit/card kept

state "Card Returned" as CardReturned
CardReturned : entry/card returned
CardReturned : do/return card
CardReturned : exit/card returned

state "Transaction Processing" as TransactionProcessing
TransactionProcessing : entry/transaction selected
TransactionProcessing : do/process transaction
TransactionProcessing : exit/transaction complete

state "Cancel Operation" as CancelOperation
CancelOperation : entry/cancel operation
CancelOperation : do/cancel operation
CancelOperation : exit/cancel operation complete

state "Final State" as FinalState
FinalState : entry/operation complete
FinalState : do/complete operation
FinalState : exit/operation complete

