@startuml
title UML State Machine Diagram

state StartChoice <<choice>>
state SelectAmountChoice <<choice>>
state CustomAmountChoice <<choice>>
state CancelChoice <<choice>>
state EndChoice <<choice>>

[*] --> StartChoice

state "Select predefined amount" as SelectAmount
SelectAmount : entry / User selects predefined amount
SelectAmount : exit / Amount selected

state "Input custom amount" as CustomAmount
CustomAmount : entry / User inputs custom amount
CustomAmount : exit / Amount entered

state "Transaction in progress" as TransactionInProgress
TransactionInProgress : entry / Transaction initiated
TransactionInProgress : do / Process withdrawal
TransactionInProgress : exit / Transaction completed

state Cancel
Cancel : entry / User cancels transaction
Cancel : exit / Transaction stopped and card returned

StartChoice --> SelectAmount
StartChoice --> CustomAmount

SelectAmount --> TransactionInProgress
CustomAmount --> TransactionInProgress

TransactionInProgress --> Cancel
TransactionInProgress --> EndChoice

Cancel --> [*]

EndChoice --> [*]

@enduml
