@startuml
title State diagram for the Microwave Oven class

[*] --> Idle : Power On

state "Idle" as Idle
state "Display Time" as DisplayTime
state "Cooking" as Cooking
state "Stopped" as Stopped

Idle --> DisplayTime : Door Closed

DisplayTime --> DisplayTime : Time
DisplayTime --> Cooking : Power Selected
DisplayTime --> Idle : Door Open

Cooking --> DisplayTime : Door Open
Cooking --> Stopped : Cancel
Cooking --> DisplayTime : Time Up

Stopped --> Idle : Next Use

@enduml
