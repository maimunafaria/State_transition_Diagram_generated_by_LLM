@startuml
title Staff Member Class State Machine

state "Unassigned" as Unassigned
state "Assigned to Client" as AssignedToClient
state "Assigned to Campaign" as AssignedToCampaign
state "Unemployed" as Unemployed
state "Archived" as Archived

[*] --> Unassigned

Unassigned --> AssignedToClient : assignToClient()
Unassigned --> AssignedToCampaign : assignToCampaign()
AssignedToClient --> Unassigned : removeAssignment()
AssignedToClient --> AssignedToCampaign : switchAssignment()
AssignedToCampaign --> Unassigned : removeAssignment()
AssignedToCampaign --> AssignedToClient : switchAssignment()
Unemployed --> Archived : archiveRecord()
Unemployed --> Unassigned : returnToUnassigned()

@enduml
