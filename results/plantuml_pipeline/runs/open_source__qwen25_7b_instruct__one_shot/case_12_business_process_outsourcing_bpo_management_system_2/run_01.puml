@startuml
title UML State Chart Diagram

state "Initial State" as InitialState {
  [*] --> SelectFilterCategory
  [*] --> SelectPriceRange
}

state "SelectFilterCategory" as SelectFilterCategory
state "SelectPriceRange" as SelectPriceRange
state "DisplayMatchingUsers" as DisplayMatchingUsers
state "End" as End

SelectFilterCategory --> DisplayMatchingUsers : [Valid]
SelectPriceRange --> DisplayMatchingUsers : [Valid]

DisplayMatchingUsers --> End

InitialState --> SelectFilterCategory
InitialState --> SelectPriceRange

@enduml
