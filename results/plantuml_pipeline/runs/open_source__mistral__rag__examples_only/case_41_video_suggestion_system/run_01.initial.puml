@startuml
title Video Suggestion System State Machine Diagram

[*] --> RequestVideo

state RequestVideo {
    state IdentifyUser
    IdentifyUser : do / identify user
    IdentifyUser : exit / identified user

    state GatherVideos
    GatherVideos : entry / gather videos based on user's profile or preferences, trending videos from the user’s area, videos with similar tags, videos from similar genres, and promoted videos
    GatherVideos : do / add additional details such as thumbnails and view counts to the suggested videos
    GatherVideos : exit / gathered videos

    state SendSuggestions
    SendSuggestions : entry / send suggested videos to user
    SendSuggestions : exit / sent suggestions
}

RequestVideo --> IdentifyUser
IdentifyUser --> GatherVideos
GatherVideos --> SendSuggestions
SendSuggestions --> [*]

@enduml
