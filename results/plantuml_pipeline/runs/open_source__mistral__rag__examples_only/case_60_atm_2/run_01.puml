@startuml
title ATM Scenario 2 - Withdrawal

[*] --> SelectAmount

state "SelectAmount" as SelectAmount
state VerifyTransaction
state Rejected
state CustomValue
state Dispensing
state Printing
state Ejecting

SelectAmount --> VerifyTransaction : amount
VerifyTransaction --> Dispensing : approved
VerifyTransaction --> Rejected : rejected
Rejected --> CustomValue : re-enter
CustomValue --> VerifyTransaction : custom value
Dispensing --> Printing : dispensed
Printing --> Ejecting : ejected

@enduml
