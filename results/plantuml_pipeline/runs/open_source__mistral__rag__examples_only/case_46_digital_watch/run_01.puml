@startuml
title Digital Watch - State Diagram

state "Time Display" as TimeDisplay
TimeDisplay : do / Show current time
TimeDisplay : entry / Button pressed

state "Adjust Hour" as AdjustHour
AdjustHour : do / Increment hour value
AdjustHour : exit / Button released
AdjustHour : entry / Alarm set to the same time

state "Adjust Minute" as AdjustMinute
AdjustMinute : do / Increment minute value
AdjustMinute : exit / Button released
AdjustMinute : entry / Alarm set to the same time

state "Alarm Enable/Disable" as AlarmEnableDisable
AlarmEnableDisable : do / Toggle alarm on/off
AlarmEnableDisable : entry / Button pressed

state "Alarm Ring" as AlarmRing
AlarmRing : do / Ring alarm
AlarmRing : exit / Button pressed to stop alarm
AlarmRing : entry / Set alarm time matches current time

state "Light Control" as LightControl
LightControl : do / Turn light on/off
LightControl : entry / Button pressed
LightControl : exit / Button released

[*] --> TimeDisplay
TimeDisplay --> AdjustHour
TimeDisplay --> AdjustMinute
AdjustHour --> TimeDisplay
AdjustMinute --> TimeDisplay
AlarmEnableDisable --> AlarmRing : [alarm on]
AlarmEnableDisable --> TimeDisplay : [alarm off]
AlarmRing --> LightControl
LightControl --> TimeDisplay
@enduml
