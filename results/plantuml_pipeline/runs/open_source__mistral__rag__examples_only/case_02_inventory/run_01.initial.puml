@startuml
title UML State Machine Diagram - Inventory Management System

[*] --> AddGoods
state "Add goods" as AddGoods
state UpdatePrice
state RemoveGoods
state ExpiredGoodsNotification
state OrderSupplier
state GenerateInvoice
state PurchaseSelection
state CalculateDiscountAndTax
state GenerateReceipt
state ReplaceOrCancelReceipt
state RecordRequest
state SummaryReport

AddGoods --> UpdatePrice
UpdatePrice --> RemoveGoods
RemoveGoods --> ExpiredGoodsNotification
ExpiredGoodsNotification --> OrderSupplier
OrderSupplier --> GenerateInvoice
GenerateInvoice --> PurchaseSelection
PurchaseSelection --> CalculateDiscountAndTax
CalculateDiscountAndTax --> GenerateReceipt
GenerateReceipt --> ReplaceOrCancelReceipt
ReplaceOrCancelReceipt --> RecordRequest
RecordRequest --> SummaryReport
SummaryReport --> [*]
@enduml
