@startuml
title UML state machine diagram

state GreenRidesLogin <<choice>>
state JourneyDetails <<choice>>
state DrivingModeChoice <<choice>>
state EatPlaceSelection <<choice>>
state OrderPlacement <<choice>>
state AccidentNotification <<choice>>
state NotificationDuringDriveOrAccident <<choice>>
state FeedbackSubmission <<choice>>

[*] --> GreenRidesLogin

GreenRidesLogin --> JourneyDetails
JourneyDetails --> DrivingModeChoice : [Activate driving mode or choose other options]
JourneyDetails --> EatPlaceSelection : [Select a place to eat if they are hungry]

DrivingModeChoice --> NotificationDuringDriveOrAccident
EatPlaceSelection --> OrderPlacement
OrderPlacement --> FeedbackSubmission

NotificationDuringDriveOrAccident --> AccidentNotification
AccidentNotification --> RelevantAuthoritiesInformed

FeedbackSubmission --> [*]
RelevantAuthoritiesInformed --> [*]

@enduml
