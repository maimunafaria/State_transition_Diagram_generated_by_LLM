@startuml
title UML state machine diagram - E Visa Processing And Follow Up System

state "Create Account" as CreateAccount
CreateAccount : entry/User wants to create account
CreateAccount : do/Provide details and submit
CreateAccount : exit/Account created

state "Login" as Login
Login : entry/User has created account
Login : do/Verify credentials
Login : exit/Logged in or Invalid login

state "Apply for Visa" as ApplyForVisa
ApplyForVisa : entry/Logged in user
ApplyForVisa : do/Make payment and submit application
ApplyForVisa : exit/Application accepted

state "View Status" as ViewStatus
ViewStatus : entry/Logged in user
ViewStatus : do/Show status of application
ViewStatus : exit/User can check status

state "Check Status" as CheckStatus
CheckStatus : entry/User has viewed status
CheckStatus : do/Update status if needed
CheckStatus : exit/User can check again

state "Cancel Application" as CancelApplication
CancelApplication : entry/Logged in user
CancelApplication : do/Cancel application
CancelApplication : exit/Application cancelled

state "Modify Details" as ModifyDetails
ModifyDetails : entry/Logged in user
ModifyDetails : do/Update details
ModifyDetails : exit/Details updated

state "View Details" as ViewDetails
ViewDetails : entry/Logged in user
ViewDetails : do/Show details of user
ViewDetails : exit/User can view again

state "Give Feedback" as GiveFeedback
GiveFeedback : entry/User has checked status
GiveFeedback : do/Provide feedback
GiveFeedback : exit/Feedback given

state "Logout" as Logout
Logout : entry/User wants to log out
Logout : do/End session
Logout : exit/User is logged out

[*] --> CreateAccount
CreateAccount --> Login
Login --> ApplyForVisa
ApplyForVisa --> ViewStatus
ViewStatus --> CheckStatus
CheckStatus --> CancelApplication
CheckStatus --> ModifyDetails
ModifyDetails --> ViewDetails
ModifyDetails --> GiveFeedback
ViewDetails --> Logout
GiveFeedback --> Logout

@enduml
