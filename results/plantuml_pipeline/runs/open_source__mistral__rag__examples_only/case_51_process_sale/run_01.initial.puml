@startuml
title UML State Chart Diagram - Process Sale

[*] --> WaitingForSale

state "Waiting for a new sale" as WaitingForSale
state "Enter items one by one" as EnterItems
state "Move to payment" as MoveToPayment
state "Complete the sale with cash" as CompleteWithCash
state "Verify payment" as VerifyPayment
state "Complete the sale" as CompleteSale
state "Return to waiting for next customer" as ReturnCustomer

WaitingForSale --> EnterItems : item selected
EnterItems --> EnterItems : add another item
EnterItems --> MoveToPayment : all items added
MoveToPayment --> VerifyPayment : cash payment
VerifyPayment --> CompleteWithCash : approved
CompleteWithCash --> CompleteSale
CompleteWithCash --> ReturnCustomer

MoveToPayment --> CompleteSale : card or check payment
VerifyPayment --> CompleteSale : approved
CompleteSale --> ReturnCustomer
@enduml
