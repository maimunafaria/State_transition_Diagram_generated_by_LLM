@startuml
title Staff Member Class - UML State Machine Diagram

[*] --> Assigned

state Assigned {
  state Unassigned
  state ClientAssigned(client)
  state CampaignAssigned(campaign)
}

state Unemployed
state Archived

Assigned --> Unemployed : leavesJob
Unemployed --> Archived : afterSomeTimePasses

Assigned --> Unassigned : switchAssignment
ClientAssigned --> ClientAssigned(anotherClient) : switchToAnotherClient
CampaignAssigned --> CampaignAssigned(anotherCampaign) : switchToAnotherCampaign
Unassigned --> Assigned : assignedToClient or assignedToCampaign

@enduml
