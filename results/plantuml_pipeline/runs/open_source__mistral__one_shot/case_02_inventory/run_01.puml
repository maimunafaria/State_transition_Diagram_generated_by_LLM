@startuml
title UML State Machine Diagram (Inventory System)

[*] --> InventoryState

state InventoryState {
    [*] --> AddGoods : [Add new goods]
    AddGoods --> UpdatePrice : [Update price of existing items]
    AddGoods --> RemoveGoods : [Remove goods no longer required]
    RemoveGoods --> CheckExpiry : [Identify expired goods]
    CheckExpiry --> NotifyUser : [Notify user about removal]
    AddGoods --> PlaceOrder : [Place order to supplier]
    PlaceOrder --> GenerateInvoice : [Generate invoice for the order]
    AddGoods --> SearchItems : [Search for items available in inventory]
    SearchItems --> SelectItems : [Select items for purchase]
    SelectItems --> CalculateDiscountTax : [Calculate applicable discount and tax]
    CalculateDiscountTax --> GenerateReceipt : [Generate receipt for the customer]
    GenerateReceipt --> BillingProcess : [Billing process]
    BillingProcess --> ReplaceItemOrCancel : [Replace an item or cancel the receipt during billing process if needed]
    BillingProcess --> RecordRequest : [Record customer requests for items that may not be currently available]
    BillingProcess --> ViewSummaryReport : [View a summary report of all transactions carried out in the system at any point]
}
@enduml
