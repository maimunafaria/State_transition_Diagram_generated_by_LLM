@startuml
title ATM State Machine (Scenario 1)

[*] --> InsertedCard : /insertCard

state InsertedCard
state VerifyingPIN
state OptionsAvailable
state WithdrawalProcessing
state ReceiptPrinting
state CardReturned
state Ready

InsertedCard --> VerifyingPIN : /enterPin

VerifyingPIN --> SuccessfulAuthentication : pinMatches\n/provideOptions
VerifyingPIN --> IncorrectPIN : pinDoesNotMatch\n/denyAccess

SuccessfulAuthentication --> OptionsAvailable
IncorrectPIN --> [*] : /denyAccess

state OptionsAvailable {
  [*] --> WithdrawalRequest : withdrawalOptionSelected
}

WithdrawalRequest --> WithdrawalProcessing : /processWithdrawal

WithdrawalProcessing --> ReceiptPrinting : cashDispensed\n/printReceipt

ReceiptPrinting --> CardReturned : cardReturned\n/returnCard

CardReturned --> Ready : briefMomentPasses\n/resetATM

@enduml
