@startuml
title UML State Machine Diagram - User

[*] --> Register

state "Register" as Register
state "Signed in" as SignedIn
state "Access facilities" as AccessFacilities
state "Read news and content" as ReadNewsContent
state "Check symptoms or fitness" as CheckSymptomsFitness
state "View result" as ViewResult
state "Payment process" as PaymentProcess
state "Insurance validation" as InsuranceValidation
state "Select payment method" as SelectPaymentMethod
state "Cash payment details" as CashPaymentDetails
state "Insurance-based payment" as InsuranceBasedPayment
state "Feedback collection" as FeedbackCollection
state "Logged out" as LoggedOut

Register --> SignedIn
SignedIn --> AccessFacilities
AccessFacilities --> ReadNewsContent
ReadNewsContent --> CheckSymptomsFitness
CheckSymptomsFitness --> ViewResult
ViewResult --> AccessFacilities
AccessFacilities --> PaymentProcess
PaymentProcess --> InsuranceValidation
InsuranceValidation --> SelectPaymentMethod
SelectPaymentMethod --> CashPaymentDetails
CashPaymentDetails --> PaymentProcess
InsuranceValidation --> InsuranceBasedPayment
InsuranceBasedPayment --> PaymentProcess
PaymentProcess --> LoggedOut
LoggedOut --> [*]

@enduml
