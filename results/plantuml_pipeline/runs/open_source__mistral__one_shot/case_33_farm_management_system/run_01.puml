@startuml
title State diagram for Farm Management System

[*] --> Login

state Login
state MainArea
state MarketConditions
state MarketReport
state PestControlHelp
state PestControlTechniques
state SoilSuggestions
state WeatherInsights
state LabourAvailability
state ContinueService
state Logout

' user login
Login --> MainArea : valid credentials provided
Login --> [*] : invalid credentials

' main area
MainArea --> MarketConditions : market conditions selected
MainArea --> PestControlHelp : pest control help selected
MainArea --> SoilSuggestions : soil information received
MainArea --> WeatherInsights : location provided
MainArea --> LabourAvailability : location provided
MainArea --> ContinueService : continue using service

' market conditions
MarketConditions --> MarketReport : market report selected
MarketReport --> [*] : back to main area

' pest control help
PestControlHelp --> PestControlTechniques : photo provided
PestControlTechniques --> [*] : back to main area

' soil suggestions
SoilSuggestions --> [*] : suitable crops suggested

' weather insights
WeatherInsights --> [*] : weather insights displayed

' labour availability
LabourAvailability --> [*] : labour availability details shown

' continue service
ContinueService --> MainArea : continue using service

' logout
Logout --> Logout : user logs out

@enduml
