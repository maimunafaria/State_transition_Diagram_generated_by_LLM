@startuml
title UML State Machine Diagram - Campaign

[*] --> AssignManagerAndStaff

state "Assign Manager and Staff" as AssignManagerAndStaff
state "Wait for Approval" as WaitForApproval
state "Sign Contract" as SignContract
state "Prepare Adverts" as PrepareAdverts
state "Approve and Schedule Adverts" as ApproveAndScheduleAdverts
state "Run Adverts" as RunAdverts
state "Adjust Campaign" as AdjustCampaign
state "Complete Campaign" as CompleteCampaign
state "Handle Payment" as HandlePayment
state "Wait for Balance Settlement" as WaitForBalanceSettlement
state "Mark Campaign as Paid" as MarkCampaignAsPaid
state "Archive Campaign" as ArchiveCampaign

AssignManagerAndStaff --> WaitForApproval
WaitForApproval --> SignContract
SignContract --> PrepareAdverts
PrepareAdverts --> ApproveAndScheduleAdverts
ApproveAndScheduleAdverts --> RunAdverts
RunAdverts --> AdjustCampaign
AdjustCampaign --> RunAdverts
RunAdverts --> CompleteCampaign
CompleteCampaign --> HandlePayment
HandlePayment --> WaitForBalanceSettlement
WaitForBalanceSettlement --> MarkCampaignAsPaid
MarkCampaignAsPaid --> ArchiveCampaign
ArchiveCampaign --> [*]

@enduml
