@startuml
title UML State Chart Diagram

[*] --> TimeView

state TimeView
TimeView : entry / display Current Time
TimeView : do / allow Adjusting Time Settings
TimeView : exit / adjust Time Settings

state TimeChoice <<choice>>
TimeView --> TimeChoice

state HourAdjust
HourAdjust : entry / contain Hour Value
HourAdjust : do / increase Hour Value
HourAdjust : exit / save New Hour Value

state MinuteAdjust
MinuteAdjust : entry / contain Minute Value
MinuteAdjust : do / increase Minute Value
MinuteAdjust : exit / save New Minute Value

state AlarmHourAdjust
AlarmHourAdjust : entry / contain Alarm Hour Value
AlarmHourAdjust : do / increase Alarm Hour Value
AlarmHourAdjust : exit / save New Alarm Hour Value

state AlarmMinuteAdjust
AlarmMinuteAdjust : entry / contain Alarm Minute Value
AlarmMinuteAdjust : do / increase Alarm Minute Value
AlarmMinuteAdjust : exit / save New Alarm Minute Value

TimeChoice --> HourAdjust
TimeChoice --> MinuteAdjust
TimeChoice --> AlarmHourAdjust
TimeChoice --> AlarmMinuteAdjust

state AlarmOnOff <<choice>>
HourAdjust --> AlarmOnOff
MinuteAdjust --> AlarmOnOff
AlarmHourAdjust --> AlarmOnOff
AlarmMinuteAdjust --> AlarmOnOff

state "Alarm On" as AlarmOn
AlarmOn : entry / alarm Enabled
AlarmOn : do / check if Alarm Time matches Current Time
AlarmOn : exit / trigger Alarm if match

state "Alarm Off" as AlarmOff
AlarmOff : entry / alarm Disabled
AlarmOff : do / no action if no alarm
AlarmOff : exit / no action

AlarmOnOff --> AlarmOn
AlarmOnOff --> AlarmOff

state AlarmStop
AlarmStop : entry / stop Alarm
AlarmStop : do / disable Alarm
AlarmStop : exit / return to TimeView

AlarmOn --> AlarmStop

state LightControl
LightControl : entry / turn On/Off Light
LightControl : do / toggle Light State
LightControl : exit / light State

TimeChoice --> LightControl

@enduml
