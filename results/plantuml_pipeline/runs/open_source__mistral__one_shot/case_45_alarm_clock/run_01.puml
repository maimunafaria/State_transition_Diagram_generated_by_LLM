@startuml
title AlarmClock State Machine

state Off {
  [*] --> SettingAlarm
}

state SettingAlarm
state Active
state Ringing
state Stopped

SettingAlarm --> Active : ok
Active --> Off : noAlarmSet
Active --> Ringing : alarmTimeMatchesCurrentTime
Ringing --> Stopped : userStoppedAlarm
Stopped --> Active : nextScheduledAlarm

Off : entry / currentState := "Off"
@enduml
