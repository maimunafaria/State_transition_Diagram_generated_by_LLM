@startuml
title UML State Machine Diagram (Weather Monitoring System)

state "Account Creation/Login" as Account {
    [*] --> ChoiceUser

    Account : entry / Regarding account details
    Account : do / Account management
    Account : exit / After logging out

    state ChoiceUser <<choice>>

    ChoiceUser --> Register : [New user]
    ChoiceUser --> Login : [Existing user]

    state "Registration" as Registration {
        Registration : entry / Registration details
        Registration : do / Registration process
        Registration : exit / After registration result

        state SuccessfulRegistration <<choice>>
        state UnsuccessfulRegistration <<choice>>

        UnsuccessfulRegistration --> EndRegistration : [Invalid input]
        SuccessfulRegistration --> Account : [Successful registration]
    }

    state "Login" as Login {
        Login : entry / Login details
        Login : do / Login process
        Login : exit / After login result

        state SuccessfulLogin <<choice>>
        state UnsuccessfulLogin <<choice>>

        UnsuccessfulLogin --> EndLogin : [Invalid input]
        SuccessfulLogin --> Account : [Successful login]
    }
}

state "Weather Check" as Weather {
    Weather : entry / Regarding location details
    Weather : do / Weather data retrieval
    Weather : exit / After weather information display

    state LocationCheck <<choice>>

    Weather --> LocationCheck : [Valid input]
    LocationCheck --> EndWeather : [Invalid input]

    state "Weather Information Display" as InfoDisplay {
        InfoDisplay : entry / Regarding selected weather details
        InfoDisplay : do / Weather data display
        InfoDisplay : exit / After weather information display

        state TemperatureCheck <<choice>>
        state HumidityCheck <<choice>>
        state RainfallCheck <<choice>>
        state PressureCheck <<choice>>
        state DewPointCheck <<choice>>

        WeatherInformation --> TemperatureCheck : [Temperature selected]
        WeatherInformation --> HumidityCheck : [Humidity selected]
        WeatherInformation --> RainfallCheck : [Rainfall selected]
        WeatherInformation --> PressureCheck : [Pressure selected]
        WeatherInformation --> DewPointCheck : [Dew point selected]
    }
}

state "Additional Details" as Additional {
    Additional : entry / Regarding additional weather details
    Additional : do / Additional data retrieval
    Additional : exit / After additional data display

    state AlertsCheck <<choice>>
    state WeeklyAnalysisCheck <<choice>>
    state FuturePredictionCheck <<choice>>
    state GraphCheck <<choice>>

    AdditionalDetails --> AlertsCheck : [Alerts selected]
    AdditionalDetails --> WeeklyAnalysisCheck : [Weekly analysis selected]
    AdditionalDetails --> FuturePredictionCheck : [Future prediction selected]
    AdditionalDetails --> GraphCheck : [Graph selected]
}

@enduml
