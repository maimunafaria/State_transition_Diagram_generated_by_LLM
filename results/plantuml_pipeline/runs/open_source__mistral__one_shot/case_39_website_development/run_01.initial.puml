@startuml
title UML State Machine Diagram (Website Navigation)

state "Homepage" as Home {
    [*] --> Navigate
    Home : entry / Display home content
    Home : do / User navigation
    Home : exit / After user selection
}

state "Projects" as Projects {
    Home : ProjectSelected --> ProjectDetails
    ProjectDetails : entry / Display project details
    ProjectDetails : do / User chooses media type
    ProjectDetails : exit / Media displayed or application opened
}

state "Career Opportunities" as Career {
    [*] --> OpportunitySelected
    Career : entry / Display career opportunities
    Career : do / User chooses update or application
    Career : exit / Update displayed or application opened
}

state "Job Application" as JobApp {
    Career : ApplicationOpened --> SubmitApplication
    SubmitApplication : entry / User fills and submits application
    SubmitApplication : do / System checks application
    SubmitApplication : exit / Application processed
}
@enduml
