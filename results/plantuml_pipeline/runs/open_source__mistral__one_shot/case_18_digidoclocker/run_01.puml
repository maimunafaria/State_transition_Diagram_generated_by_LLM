@startuml
title Digidoclocker - State Diagram

[*] --> Unregistered

state "Unregistered" as Unregistered
state "Registered" as Registered
state "Logged Out" as LoggedOut
state "Logged In" as LoggedIn
state "Uploading Documents" as UploadingDocs
state "Certificate Application Pending" as CertAppPending
state "Certificate Request Pending" as CertReqPending
state "Session Ended" as SessionEnded

Unregistered --> Registered : Registration
Registered --> LoggedOut : Logout
LoggedOut --> LoggedIn : Login

LoggedIn --> UploadingDocs : Document Upload
UploadingDocs --> UploadingDocs : More Documents
UploadingDocs --> CertAppPending : Certificate Application
CertAppPending --> SessionEnded : Certificate Issued or Rejected

LoggedIn --> CertReqPending : Registrar Request
CertReqPending --> CertReqPending : More Requests

SessionEnded --> LoggedOut : End Session
@enduml
