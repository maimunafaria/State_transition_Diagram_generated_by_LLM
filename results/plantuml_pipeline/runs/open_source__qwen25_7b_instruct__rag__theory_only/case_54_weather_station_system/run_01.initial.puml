@startuml
[*] --> Shutdown
Shutdown --> Running : "System restarts"
Running --> ConfigMode : "Changes/Power-saving settings required"
ConfigMode --> Running : "Configuration completed"
Running --> Running : "Data collection triggered by clock" : "Collect data"
Running --> SummaryMode : "Prepare and send out weather summary requested" : "Prepare and send summary"
SummaryMode --> Running : "After preparing and sending summary"
Running --> StatusCheckMode : "Status checking requested" : "Check status"
StatusCheckMode --> Running : "After status check"
Running --> ControlledMode : "Remote control command received" : "Move into controlled mode"
ControlledMode --> Shutdown : "Shutdown command given while running" : "System shuts down"
@enduml
