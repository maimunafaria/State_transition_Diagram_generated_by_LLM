@startuml

[*] --> WaitingForInput : "System starts"

WaitingForInput --> DisplayTime : "Display current time"
WaitingForInput --> FullPowerSelection : "User selects full power", [user inputs 'f']
FullPowerSelection --> Cooking : "Start cooking at full power", [system starts cooking]
HalfPowerSelection --> Cooking : "Start cooking at half power", [system starts cooking]

Cooking --> WaitingForInput : "Door opened during cooking"
Cooking --> CancelCooking : "User cancels cooking", [user inputs 'c']
CancelCooking --> WaitingForInput : "Return to display time"

WaitingForInput --> Stopped : "Stop or cancel", [system stops]
Stopped --> WaitingForInput : "System returns to displaying current time"

@enduml
