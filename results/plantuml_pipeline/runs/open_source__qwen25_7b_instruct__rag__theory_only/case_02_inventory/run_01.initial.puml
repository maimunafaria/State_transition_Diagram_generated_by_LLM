@startuml
[*] -> AddNewGood : "User adds new goods"
AddNewGood -> AddNewGood : "Goods added successfully"

[*] -> UpdatePrice : "User updates price of existing items"
UpdatePrice -> UpdatePrice : "Price updated successfully"

[*] -> RemoveGood : "User removes goods from inventory"
RemoveGood -> RemoveGood : "Goods removed successfully"

[*] -> IdentifyExpired : "System identifies expired goods"
IdentifyExpired -> NotifyRemoval : "Notify user about removal" : "Expired goods identified"

[*] -> PlaceOrder : "User places order for additional goods"
PlaceOrder -> GenerateInvoice : "Generate invoice for order" : "Order placed"

[*] -> SearchItems : "User searches for items in inventory"
SearchItems -> SelectForPurchase : "Select items for purchase" : "Item found and selected"

[*] -> CalculateDiscountTax : "System calculates discount and tax based on selected items"
CalculateDiscountTax -> GenerateReceipt : "Generate receipt after purchase" : "Discount and tax calculated"

[*] -> ReplaceOrCancel : "User replaces item or cancels receipt during billing process"
ReplaceOrCancel -> ReceiptSummary : "Record customer requests for unavailable items" : "Item replaced or receipt canceled"

[*] -> ViewTransactions : "User views summary report of transactions"
ViewTransactions -> SummaryReport : "Generate and display transaction summary" : "Transaction summary generated"

@enduml
