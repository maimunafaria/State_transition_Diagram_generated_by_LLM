@startuml

[*] --> WaitingForInput : "Start"

WaitingForInput --> ShowingWithdrawOptions : selectAmount
ShowingWithdrawOptions --> VerifyingTransaction : verifyAmount
VerifyingTransaction --> TransactionApproved : approve / notify user
TransactionApproved --> End : end transaction

VerifyingTransaction --> ReenterAmount : reject, re-enter amount
ReenterAmount --> ShowingWithdrawOptions : selectAmount

WaitingForInput --> CustomValueEntry : enterCustomAmount
CustomValueEntry --> VerifyingTransaction : verifyAmount

@enduml
