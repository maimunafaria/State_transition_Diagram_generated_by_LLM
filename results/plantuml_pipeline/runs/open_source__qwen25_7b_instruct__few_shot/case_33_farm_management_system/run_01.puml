@startuml
title UML State Chart Diagram for Farm Management System

state "Logged Out" as LoggedOut
[*] --> LoggedOut

state "Logged In" as LoggedIn {
  state "Main Area" as MainArea
  state "Market Conditions" as MarketConditions
  state "Market Report" as MarketReport
  state "Pest Control Help" as PestControlHelp
  state "Pest Control Techniques" as PestControlTechniques
  state "Soil Suggestions" as SoilSuggestions
  state "Weather Insights" as WeatherInsights
  state "Labour Availability" as LabourAvailability
  state "Continue Using Service" as ContinueUsingService
}

state "LoggedOut" --> "LoggedIn" : login

LoggedIn --> MainArea : [Select Main Area]
MainArea --> MainArea : [Continue Using Service]
MainArea --> MarketConditions : [Select Market Conditions]
MainArea --> MarketReport : [Select Market Report]
MainArea --> PestControlHelp : [Select Pest Control Help]
MainArea --> SoilSuggestions : [Select Soil Suggestions]
MainArea --> WeatherInsights : [Select Weather Insights]
MainArea --> LabourAvailability : [Select Labour Availability]

MarketConditions --> ContinueUsingService : [Continue Using Service]
MarketReport --> ContinueUsingService : [Continue Using Service]
PestControlHelp --> ContinueUsingService : [Continue Using Service]
PestControlTechniques --> ContinueUsingService : [Continue Using Service]
SoilSuggestions --> ContinueUsingService : [Continue Using Service]
WeatherInsights --> ContinueUsingService : [Continue Using Service]
LabourAvailability --> ContinueUsingService : [Continue Using Service]

ContinueUsingService --> MainArea : [Back to Main Area]

LoggedIn --> LoggedOut : logout
LoggedOut --> [*]
@enduml
