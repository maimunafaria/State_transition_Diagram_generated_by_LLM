@startuml
title State diagram for the Website Development class

state "Homepage" as Homepage
Homepage : entry/Initial State

state "Projects" as Projects
Projects : entry/View Projects
Projects : do/Select Project
Projects : exit/View Project Details

state "View Project Details" as ViewProjectDetails
ViewProjectDetails : entry/View Project
ViewProjectDetails : do/Choose Media
ViewProjectDetails : exit/View Photos
ViewProjectDetails : exit/View Videos

state "View Photos" as ViewPhotos
ViewPhotos : entry/View Photos

state "View Videos" as ViewVideos
ViewVideos : entry/View Videos

state "Career Opportunities" as CareerOpportunities
CareerOpportunities : entry/View Career Opportunities
CareerOpportunities : do/Select Opportunity
CareerOpportunities : exit/View Updates
CareerOpportunities : exit/Apply for Job

state "View Updates" as ViewUpdates
ViewUpdates : entry/View Updates

state "Apply for Job" as ApplyForJob
ApplyForJob : entry/Apply for Job
ApplyForJob : do/Submit Application
ApplyForJob : exit/Check Application Status

state "Check Application Status" as CheckApplicationStatus
CheckApplicationStatus : entry/Check Status

[*] --> Homepage

Homepage --> Projects : Select Projects
Projects --> ViewProjectDetails : Choose Media
ViewProjectDetails --> ViewPhotos : View Photos
ViewProjectDetails --> ViewVideos : View Videos
ViewPhotos --> ViewProjectDetails : Return to Details
ViewVideos --> ViewProjectDetails : Return to Details
CareerOpportunities --> ViewUpdates : View Updates
CareerOpportunities --> ApplyForJob : Apply for Job
ApplyForJob --> CheckApplicationStatus : Submit Application
CheckApplicationStatus --> ApplyForJob : Check Status
CheckApplicationStatus --> CareerOpportunities : Return to Opportunities

@enduml
