@startuml
title ATM State Transition Diagram

[*] --> Greeting
state Greeting
state "Card Inserted" as CardInserted
state "Invalid Card" as InvalidCard
state "PIN Incorrect" as PINIncorrect
state "Card Kept" as CardKept
state "Card Returned" as CardReturned
state "Options Displayed" as OptionsDisplayed
state "Transaction Processing" as TransactionProcessing
state "Transaction Complete" as TransactionComplete

Greeting : «M» User Arrives/
Greeting --> CardInserted : «M» Card Inserted/
CardInserted --> CardReturned : «M» User Cancels/
CardInserted --> PINIncorrect : «M» Incorrect PIN/
PINIncorrect --> CardReturned : «M» Try Again/
PINIncorrect --> CardKept : «M» Too Many Incorrect PIN Attempts/
CardKept --> [*] : «M» Card Kept For Security/
CardInserted --> OptionsDisplayed : «M» Correct PIN/
OptionsDisplayed --> TransactionProcessing : «M» User Chooses Option/
TransactionProcessing --> TransactionComplete : «M» Transaction Completed/
TransactionComplete --> [*] : «M» Transaction Complete/

@enduml
