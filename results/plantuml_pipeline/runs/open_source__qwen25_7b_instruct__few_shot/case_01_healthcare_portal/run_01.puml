@startuml
title UML State Machine Diagram - Healthcare Portal

state "Initial State" as Initial
state "Registration" as Registration
state "Registration Failed" as RegistrationFailed
state "Login" as Login
state "Access Facilities" as AccessFacilities
state "Read News/Content" as ReadNewsContent
state "Check Symptoms/Fitness" as CheckSymptomsFitness
state "Continue Session" as ContinueSession
state "Finish Session" as FinishSession
state "Process Insurance" as ProcessInsurance
state "Validate Insurance" as ValidateInsurance
state "Payment Process" as PaymentProcess
state "Cash Payment" as CashPayment
state "Insurance Payment" as InsurancePayment
state "Feedback Collection" as FeedbackCollection
state "Logout" as Logout

[*] --> Initial

Initial --> Registration : Register
Initial --> RegistrationFailed : Registration Failed

Registration --> Login : Login
Login --> AccessFacilities : Access Facilities

AccessFacilities --> ReadNewsContent : Read News/Content
ReadNewsContent --> CheckSymptomsFitness : Check Symptoms/Fitness
CheckSymptomsFitness --> ContinueSession : Continue Session
ContinueSession --> AccessFacilities : Continue Session
ContinueSession --> FinishSession : Finish Session

FinishSession --> Logout : Logout

AccessFacilities --> ProcessInsurance : Process Insurance
ProcessInsurance --> ValidateInsurance : Validate Insurance
ValidateInsurance --> PaymentProcess : Payment Process

PaymentProcess --> CashPayment : Cash Payment
CashPayment --> FinishSession : Finish Session

PaymentProcess --> InsurancePayment : Insurance Payment
InsurancePayment --> FinishSession : Finish Session

ReadNewsContent --> ContinueSession : Continue Session
ReadNewsContent --> FinishSession : Finish Session

CheckSymptomsFitness --> ContinueSession : Continue Session
CheckSymptomsFitness --> FinishSession : Finish Session

ProcessInsurance --> ValidateInsurance : Validate Insurance

ValidateInsurance --> PaymentProcess : Payment Process

FeedbackCollection : Collect Feedback
FeedbackCollection --> FinishSession : Finish Session

Logout --> [*]

@enduml
