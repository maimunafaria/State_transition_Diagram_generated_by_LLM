@startuml
title Weather Monitoring System State Diagram

[*] --> Register

state Register <<choice>>
Register --> Success : registration successful
Register --> [*] : registration unsuccessful

state "Login" as Login
Login : entry / user enters credentials
Login : do / validate credentials
Login : exit / login successful

Login --> [*] : login unsuccessful

state "Check Weather" as CheckWeather
CheckWeather : entry / user selects location
CheckWeather : do / validate location
CheckWeather : exit / location valid

CheckWeather --> [*] : location invalid

state "Select Weather Info" as SelectInfo
SelectInfo : entry / user selects info type
SelectInfo : do / select info type
SelectInfo : exit / info type selected

state "Show Weather Info" as ShowInfo
ShowInfo : entry / show selected weather info
ShowInfo : do / update and show info
ShowInfo : exit / info shown

state "View Additional Details" as ViewDetails
ViewDetails : entry / user selects additional details
ViewDetails : do / show additional details
ViewDetails : exit / details shown

state "Logout" as Logout
Logout : entry / user logs out
Logout : do / end session
Logout : exit / session ended

CheckWeather --> SelectInfo : [Select info ?]
SelectInfo --> ShowInfo : [Show info ?]
ShowInfo --> ViewDetails : [View details ?]

SelectInfo --> [*] : [No select info]
ViewDetails --> [*] : [No view details]

Login --> CheckWeather
CheckWeather --> Logout
Register --> Login

@enduml
