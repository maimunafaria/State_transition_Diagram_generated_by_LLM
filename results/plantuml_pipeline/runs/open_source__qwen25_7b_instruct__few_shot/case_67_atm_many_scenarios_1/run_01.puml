@startuml
title ATM State Machine Diagram

[*] --> InsertCard

state InsertCard

state "Waiting for PIN" as WaitForPIN
WaitForPIN : entry / Prompt user to enter PIN
WaitForPIN : do / Verify PIN
WaitForPIN : exit / PIN Verified

state "PIN Verified" as PINVerified
PINVerified : entry / PIN verified successfully
PINVerified : do / Provide options to user
PINVerified : exit / User approved

state "Withdrawal Requested" as WithdrawalRequested
WithdrawalRequested : entry / User approved withdrawal
WithdrawalRequested : do / Process withdrawal
WithdrawalRequested : exit / Dispense cash

state "Cash Dispensed" as CashDispensed
CashDispensed : entry / Cash dispensed
CashDispensed : do / Print receipt
CashDispensed : exit / Return card

state "Card Returned" as CardReturned
CardReturned : entry / Return user's card
CardReturned : do / Reset system
CardReturned : exit / Ready for next user

[*] --> CardReturned

@enduml
