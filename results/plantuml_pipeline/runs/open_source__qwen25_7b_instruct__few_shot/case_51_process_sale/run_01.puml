@startuml
title Process Sale State Diagram

[*] --> WaitingForSale

state WaitingForSale

state AddingItems

state PaymentVerification

state PaymentCompleted

state SaleCompleted

AddingItems --> PaymentVerification : all items added

PaymentVerification --> PaymentCompleted : payment verified

PaymentCompleted --> SaleCompleted : payment approved

SaleCompleted --> WaitingForSale : next customer

PaymentVerification --> SaleCompleted : payment approved

PaymentCompleted --> [*] : sale finished

@enduml
