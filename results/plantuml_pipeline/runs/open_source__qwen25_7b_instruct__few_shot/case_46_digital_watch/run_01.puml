@startuml
title UML State Machine Diagram - Digital Watch

[*] --> ViewTime

state "View Time" as ViewTime
state "Adjust Hour" as AdjustHour
state "Adjust Minute" as AdjustMinute
state "Adjust Alarm Hour" as AdjustAlarmHour
state "Adjust Alarm Minute" as AdjustAlarmMinute
state "Alarm On" as AlarmOn
state "Alarm Off" as AlarmOff
state "Alarm Triggered" as AlarmTriggered
state "Light On" as LightOn
state "Light Off" as LightOff

ViewTime --> AdjustHour : press button
AdjustHour --> AdjustMinute : press button
AdjustMinute --> ViewTime : press button
AdjustMinute --> AdjustAlarmHour : press button
AdjustAlarmHour --> AdjustAlarmMinute : press button
AdjustAlarmMinute --> ViewTime : press button

ViewTime --> AlarmOn : press button
AlarmOn --> AlarmOff : press button
AlarmOff --> AlarmOn : press button
AlarmOff --> AlarmTriggered : alarm time matches current time

AlarmTriggered --> AlarmOff : press stop button

LightOn --> LightOff : press button
LightOff --> LightOn : press button

@enduml
