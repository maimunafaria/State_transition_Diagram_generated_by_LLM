@startuml
title Video Suggestion System State Machine

[*] --> Idle

state Idle
state "Receive Suggestion Request" as ReceiveRequest
state "Identify User" as IdentifyUser
state "Gather Videos" as GatherVideos
state "Add Details" as AddDetails
state "Send Suggestions" as SendSuggestions
state "Final" as Final

Idle --> ReceiveRequest : Suggestion Request Received

ReceiveRequest --> IdentifyUser : Identify User
IdentifyUser --> GatherVideos : User Identified
GatherVideos --> AddDetails : Gathered Videos
AddDetails --> SendSuggestions : Added Details
SendSuggestions --> Final : Suggestions Sent

@enduml
