@startuml
title UML State Machine Diagram - ATM Withdrawal

[*] --> SelectAmount

state "Select Amount" as SelectAmount
state "Enter Custom Amount" as EnterCustomAmount
state "Verify Transaction" as VerifyTransaction
state "Re-enter Amount" as ReEnterAmount
state "Transaction Successful" as TransactionSuccessful
state "Transaction Rejected" as TransactionRejected
state "End" as End

SelectAmount --> EnterCustomAmount
SelectAmount --> VerifyTransaction

state "Transaction Verification" <<choice>>

VerifyTransaction --> TransactionSuccessful : [valid]
VerifyTransaction --> TransactionRejected : [invalid]

TransactionRejected --> ReEnterAmount

ReEnterAmount --> VerifyTransaction

TransactionSuccessful --> End

TransactionRejected --> End

@enduml
