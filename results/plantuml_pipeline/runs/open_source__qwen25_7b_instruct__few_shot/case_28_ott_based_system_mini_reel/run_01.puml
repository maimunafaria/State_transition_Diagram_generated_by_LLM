@startuml
title State machine for Ott Based System Mini Reel

state "Initial State" as Initial
state "Account Created" as AccountCreated
state "Watching Videos" as WatchingVideos
state "Uploading Videos" as UploadingVideos
state "Saved Videos" as SavedVideos
state "Discussion" as Discussion

[*] --> Initial

Initial --> AccountCreated : createUserAccount

AccountCreated --> WatchingVideos : watchVideos

WatchingVideos --> AccountCreated : exitVideoWatch
WatchingVideos --> UploadingVideos : uploadVideo
WatchingVideos --> SavedVideos : saveVideo

UploadingVideos --> AccountCreated : exitVideoUpload

SavedVideos --> AccountCreated : exitVideoSave
SavedVideos --> WatchingVideos : viewSavedVideos

Discussion --> AccountCreated : enterDiscussion

@enduml
