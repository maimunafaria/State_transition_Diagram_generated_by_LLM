@startuml
title Inventory State Machine

[*] --> InventoryMenu

state InventoryMenu {
  [*] --> AddGoods : [Add Goods]
  AddGoods : entry / start state
  AddGoods : do / add new goods
  AddGoods : exit / goods added
  AddGoods --> InventoryMenu
}

state InventoryMenu {
  AddGoods --> UpdatePrice : [Update Price]
  UpdatePrice : entry / start state
  UpdatePrice : do / update price of existing items
  UpdatePrice : exit / price updated
  UpdatePrice --> InventoryMenu
}

state InventoryMenu {
  AddGoods --> RemoveGoods : [Remove Goods]
  RemoveGoods : entry / start state
  RemoveGoods : do / remove goods from inventory
  RemoveGoods : exit / goods removed
  RemoveGoods --> InventoryMenu
}

state InventoryMenu {
  AddGoods --> ExpireCheck : [Check for Expired Goods]
  ExpireCheck : entry / start state
  ExpireCheck : do / check for expired goods
  ExpireCheck : exit / expired goods identified
  ExpireCheck --> RemoveGoods
}

state InventoryMenu {
  AddGoods --> PlaceOrder : [Place Order]
  PlaceOrder : entry / start state
  PlaceOrder : do / place order with supplier
  PlaceOrder : exit / order placed
  PlaceOrder --> GenerateInvoice
}

state InventoryMenu {
  AddGoods --> SearchItems : [Search Items]
  SearchItems : entry / start state
  SearchItems : do / search for items in inventory
  SearchItems : exit / items selected
  SearchItems --> PurchaseItems
}

state InventoryMenu {
  AddGoods --> CalculateDiscount : [Calculate Discount]
  CalculateDiscount : entry / start state
  CalculateDiscount : do / calculate applicable discount
  CalculateDiscount : exit / discount calculated
  CalculateDiscount --> GenerateReceipt
}

state InventoryMenu {
  AddGoods --> GenerateReceipt : [Generate Receipt]
  GenerateReceipt : entry / start state
  GenerateReceipt : do / generate receipt for purchase
  GenerateReceipt : exit / receipt generated
  GenerateReceipt --> InventoryMenu
}

state InventoryMenu {
  AddGoods --> ReplaceItem : [Replace Item]
  ReplaceItem : entry / start state
  ReplaceItem : do / replace an item or cancel receipt
  ReplaceItem : exit / item replaced or receipt cancelled
  ReplaceItem --> InventoryMenu
}

state InventoryMenu {
  AddGoods --> RecordRequest : [Record Request]
  RecordRequest : entry / start state
  RecordRequest : do / record customer requests
  RecordRequest : exit / request recorded
  RecordRequest --> InventoryMenu
}

state InventoryMenu {
  AddGoods --> GenerateSummary : [Generate Summary Report]
  GenerateSummary : entry / start state
  GenerateSummary : do / generate summary report
  GenerateSummary : exit / report generated
  GenerateSummary --> InventoryMenu
}

state InventoryMenu
InventoryMenu --> [*] : [Exit]
@enduml
