@startuml
title UML State Machine Diagram - Microwave Oven

[*] --> DisplayTime

state "Display time" as DisplayTime
state "Choose power level" as ChoosePowerLevel
state "Set cooking time" as SetCookingTime
state "Cooking" as Cooking
state "Door open" as DoorOpen
state "Cancel cooking" as CancelCooking

DisplayTime --> ChoosePowerLevel
ChoosePowerLevel --> SetCookingTime
SetCookingTime --> Cooking
Cooking --> DoorOpen
DoorOpen --> CancelCooking
CancelCooking --> DisplayTime
Cooking --> CancelCooking
CancelCooking --> DisplayTime

@enduml
