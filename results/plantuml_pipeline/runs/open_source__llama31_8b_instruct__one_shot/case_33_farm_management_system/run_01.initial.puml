@startuml
title UML State Chart Diagram

state Start <<choice>>
state Login
Login : entry / user login
Login : do / validate user credentials
Login : exit / successful login or failed login

state MainArea
MainArea : entry / user signed in
MainArea : do / display main area options
MainArea : exit / user selects an option

state MarketConditions
MarketConditions : entry / user selects market conditions
MarketConditions : do / display market conditions
MarketConditions : exit / user views market conditions

state MarketReport
MarketReport : entry / user selects market report
MarketReport : do / display market report
MarketReport : exit / user views market report

state PestControl
PestControl : entry / user selects pest control help
PestControl : do / require user photo
PestControl : exit / display pest control techniques

state SoilSuggestions
SoilSuggestions : entry / user provides soil information
SoilSuggestions : do / provide suitable crops
SoilSuggestions : exit / user views suggestions

state WeatherInsights
WeatherInsights : entry / user provides location
WeatherInsights : do / provide weather insights
WeatherInsights : exit / user views insights

state LabourAvailability
LabourAvailability : entry / user provides location
LabourAvailability : do / display labour availability details
LabourAvailability : exit / user views details

state EndSession
EndSession : entry / user logs out
EndSession : do / end session
EndSession : exit / session ended

[*] --> Start
Start --> Login
Login --> MainArea

MainArea --> MarketConditions
MainArea --> MarketReport
MainArea --> PestControl
MainArea --> SoilSuggestions
MainArea --> WeatherInsights
MainArea --> LabourAvailability

MarketConditions --> [*]
MarketReport --> [*]
PestControl --> [*]
SoilSuggestions --> [*]
WeatherInsights --> [*]
LabourAvailability --> [*]

PestControl --> Login
EndSession --> [*]

@enduml
