@startuml
title UML State Machine Diagram - Healthcare Portal

[*] --> Register
state "Register" as Register
state "Sign in" as SignIn
state "Access facilities" as AccessFacilities
state "Read news and expert content" as ReadContent
state "Check symptoms or fitness" as CheckSymptoms
state "View result" as ViewResult
state "Process insurance" as ProcessInsurance
state "Check payment with insurance" as CheckPayment
state "Complete payment process" as CompletePayment
state "Select payment method" as SelectPayment
state "Inform cash payment details" as InformCashPayment
state "Complete insurance-based payment" as CompleteInsurancePayment
state "Collect user feedback" as CollectFeedback
state "Log out" as LogOut

Register -->* SignIn
SignIn --> AccessFacilities
AccessFacilities --> ReadContent
ReadContent --> CheckSymptoms
CheckSymptoms --> ViewResult
ViewResult -->* (Continue using system or finish session)
(Continue using system or finish session) -->* ProcessInsurance
ProcessInsurance --> CheckPayment
CheckPayment --> CompletePayment
CompletePayment --> SelectPayment
SelectPayment --> InformCashPayment
InformCashPayment --> CompleteInsurancePayment
CompleteInsurancePayment --> CollectFeedback
CollectFeedback --> LogOut
LogOut --> [*]

@enduml
