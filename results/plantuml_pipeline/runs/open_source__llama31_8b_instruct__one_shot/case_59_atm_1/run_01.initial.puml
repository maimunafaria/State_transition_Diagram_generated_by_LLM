@startuml
title UML State Chart Diagram

state "Initial State" as IS
IS : entry / User starts the transaction

state "Choose Predefined Amount" as CPA
CPA : entry / User selects a predefined amount
CPA : do / System displays the selected amount
CPA : exit / Proceeds to confirm withdrawal

state "Enter Custom Amount" as EA
EA : entry / User inputs a custom amount
EA : do / System verifies the custom amount
EA : exit / Proceeds to confirm withdrawal

state "Confirm Withdrawal" as CW
CW : entry / User confirms the withdrawal
CW : do / System processes the withdrawal
CW : exit / Dispenses cash

state "Cancel Transaction" as CT
CT : entry / User cancels the transaction
CT : do / System stops the transaction
CT : exit / Returns the card

state Choice <<choice>>
IS --> Choice : User starts the transaction
Choice --> CPA : Selects a predefined amount
Choice --> EA : Inputs a custom amount

CPA --> CW : Proceeds to confirm withdrawal
EA --> CW : Proceeds to confirm withdrawal

CW --> [*]
CT --> [*]

@enduml
