@startuml
title Green Rides Control - Processing Journey

state "Waiting for User Login" as WaitingForLogin

state "Displaying Journey Details" as DisplayingJourneyDetails {
  state "Displaying Destination" as DisplayingDestination
  state "Displaying Options" as DisplayingOptions
}

state "Processing User Choice" as ProcessingUserChoice {
  state "Activating Driving Mode" as ActivatingDrivingMode
  state "Selecting Place to Eat" as SelectingPlaceToEat
  state "Placing Order" as PlacingOrder
}

state "Sending Notifications" as SendingNotifications
state "Informing Authorities" as InformingAuthorities
state "Providing Feedback" as ProvidingFeedback

WaitingForLogin --> DisplayingJourneyDetails : Login Successful /\nDisplay Journey Details
DisplayingJourneyDetails --> DisplayingDestination : Destination Selected /\nDisplay Destination
DisplayingJourneyDetails --> DisplayingOptions : Options Selected /\nDisplay Options

DisplayingOptions --> ProcessingUserChoice : Driving Mode Selected /\nActivate Driving Mode
DisplayingOptions --> ProcessingUserChoice : Place to Eat Selected /\nSelect Place to Eat
ProcessingUserChoice --> ActivatingDrivingMode : Driving Mode Activated /\nStart Driving
ProcessingUserChoice --> SelectingPlaceToEat : Place to Eat Selected /\nView Menu
SelectingPlaceToEat --> PlacingOrder : Order Placed /\nSend Order

DisplayingJourneyDetails --> SendingNotifications : Journey Started /\nSend Notifications
SendingNotifications --> InformingAuthorities : Accident Detected /\nInform Authorities
InformingAuthorities --> ProvidingFeedback : Journey Completed /\nProvide Feedback

@enduml
