@startuml
title E Ticketing For Bus state diagram

[*] --> Registration

state Registration
state "Validation" as Validation
state Login
state "TicketStatusCheck" as TicketStatusCheck
state Booking
state "PaymentConfirmation" as PaymentConfirmation
state AccountManagement
state Logout

Registration --> Validation : submit registration form
Validation --> Login : successful registration
Login --> TicketStatusCheck : logged in
TicketStatusCheck --> Booking : book ticket
Booking --> PaymentConfirmation : confirm payment
PaymentConfirmation --> Login : logout after payment
Login --> AccountManagement : manage account
AccountManagement --> Logout : logout after action
Validation --> Registration : cancel registration
TicketStatusCheck --> Login : logout after checking ticket status
Booking --> PaymentConfirmation : confirm payment
PaymentConfirmation --> Logout : logout after payment
AccountManagement --> Logout : logout after managing account

state cancelled <<final>>
state completed <<final>>
state rejected <<final>>

@enduml
