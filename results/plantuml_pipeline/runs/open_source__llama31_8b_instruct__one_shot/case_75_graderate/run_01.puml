@startuml
title UML State Machine Diagram

[*] --> C1

state C1 <<choice>>
C1 --> Waiting : [possibilities to start]

state "Waiting" as Waiting
Waiting : entry / rate created
Waiting : do / waiting for start date
Waiting : exit / start date arrived

Waiting --> Active

state "Active" as Active
Active : entry / start date arrived
Active : do / rate active
Active : exit / end date reached

Active --> Expired

state "Expired" as Expired
Expired : entry / end date reached
Expired : do / rate expired
Expired : exit / one year passed

Expired --> Archived

state "Archived" as Archived
Archived : entry / one year passed
Archived : do / rate removed
Archived --> [*]

@enduml
