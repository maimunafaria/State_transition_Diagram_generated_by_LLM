@startuml
title UML state machine diagram

[*] --> J1 : [check user]
state J1 <<choice>>
state J2 <<choice>>
state J3 <<choice>>
state J4 <<choice>>
state "Register" as Register
Register : entry/when the user are user
Register : do/Register process
Register : exit/ successful registration
Register : exit/ invalid registration

state "Login" as Login {
  state "Video Watching" as VideoWatching
  VideoWatching : entry/if the user is logged in
  VideoWatching : do/display video
  VideoWatching : exit/when user logout

  state "Video Upload" as VideoUpload
  VideoUpload : entry/if the user is logged in
  VideoUpload : do/upload video
  VideoUpload : exit/after video upload is completed

  state "Likes List" as LikesList
  LikesList : entry/if the user is logged in
  LikesList : do/display likes list
  LikesList : exit/when user logout

  state "Discussion" as Discussion
  Discussion : entry/if the user is logged in
  Discussion : do/enter discussion
  Discussion : exit/after discussion is completed

  [*] --> LJ
  state LJ <<choice>>

  LJ --> VideoWatching
  LJ --> VideoUpload
  LJ --> LikesList
  LJ --> Discussion

  VideoWatching --> LikesList
  VideoUpload --> VideoWatching
  LikesList --> VideoWatching
  Discussion --> VideoWatching
}

state "Logout" as Logout
Logout : entry/when the user completes his process
Logout : do/logout user
Logout : exit/successfully logged out

J1 --> Register : [ new user ]
Register --> J2
J1 --> J2
J2 --> J3
J3 --> Login
J3 --> J4
Login --> J4
J4 --> Logout
J2 --> [*]
Logout --> [*]

@enduml
