@startuml
title UML State Chart Diagram - Sale Process

[*] --> WaitSale

state WaitSale <<choice>>
WaitSale --> EnterItems : [New Sale]

state "Enter items one by one" as EnterItems
EnterItems : entry / entered the app
EnterItems : do / enter items one by one
EnterItems : exit / all items added

EnterItems --> Payment

state "Move to payment" as Payment
Payment : entry / entered the app
Payment : do / move to payment
Payment : exit / payment method selected

state "Complete sale with cash" as CompleteCash
CompleteCash : entry / entered the app
CompleteCash : do / complete sale with cash
CompleteCash : exit / sale completed

state "Verify payment with card or check" as VerifyPayment
VerifyPayment : entry / entered the app
VerifyPayment : do / verify payment with card or check
VerifyPayment : exit / payment verified

state "Complete sale" as CompleteSale
CompleteSale : entry / entered the app
CompleteSale : do / complete sale
CompleteSale : exit / sale completed

state "Return to waiting" as ReturnWait
ReturnWait : entry / entered the app
ReturnWait : do / return to waiting
ReturnWait : exit / waiting for next customer

CompleteCash --> ReturnWait
VerifyPayment --> CompleteSale
CompleteSale --> ReturnWait

Payment --> CompleteCash : [Cash]
Payment --> VerifyPayment : [Card or Check]

EnterItems --> Payment
CompleteSale --> ReturnWait
VerifyPayment --> CompleteSale
ReturnWait --> [*]

@enduml
