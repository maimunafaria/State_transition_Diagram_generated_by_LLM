@startuml
title UML State Machine Diagram (Online Quiz System)

state "Register or Log in" as RegisterLogIn {

    [*] --> Choice1

    RegisterLogIn : entry / To Register
    RegisterLogIn : do / Log in
    RegisterLogIn : exit / After login

    state Choice1 <<choice>>

    Choice1 --> ContinueAsTeacher : [continue as teacher]
    Choice1 --> ContinueAsStudent : [continue as student]

    state "Continue as teacher" as ContinueAsTeacher
    state "Continue as student" as ContinueAsStudent
    state "Register" as Register
    state "Log in" as LogIn
    state "Create new quiz" as CreateNewQuiz
    state "Edit existing quiz" as EditExistingQuiz
    state "Save as draft" as SaveAsDraft
    state "Post for students" as PostForStudents
    state "View quiz results" as ViewQuizResults
    state "Select quiz" as SelectQuiz
    state "Answer quiz" as AnswerQuiz
    state "Submit quiz" as SubmitQuiz
    state "View result" as ViewResult
    state InvalidEnd <<choice>>
    state ValidEnd <<choice>>

    ContinueAsTeacher --> CreateNewQuiz
    ContinueAsTeacher --> EditExistingQuiz
    ContinueAsTeacher --> SaveAsDraft
    ContinueAsTeacher --> PostForStudents
    ContinueAsTeacher --> ViewQuizResults

    ContinueAsStudent --> SelectQuiz
    ContinueAsStudent --> AnswerQuiz
    ContinueAsStudent --> SubmitQuiz
    ContinueAsStudent --> ViewResult

    Register --> LogIn
    LogIn --> Choice1

    CreateNewQuiz --> SaveAsDraft
    CreateNewQuiz --> PostForStudents
    EditExistingQuiz --> SaveAsDraft
    EditExistingQuiz --> PostForStudents
    SaveAsDraft --> PostForStudents
    PostForStudents --> ViewQuizResults

    SelectQuiz --> AnswerQuiz
    AnswerQuiz --> SubmitQuiz
    SubmitQuiz --> ViewResult
    ViewResult --> ValidEnd

    InvalidEnd --> [*]
    ValidEnd --> [*]
}

@enduml
