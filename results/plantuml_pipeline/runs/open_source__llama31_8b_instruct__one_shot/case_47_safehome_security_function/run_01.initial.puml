@startuml
title Safehome Security Function State Machine

state Safehome {
  [*] --> CheckingStartup

  state CheckingStartup
  state ReadyToUse
  state Monitoring
  state AlarmActive
  state Normal

  state ProblemDuringStartup {
    state Stopped
  }

  state UserInteraction {
    state Resetting
    state Activating
    state TurningOff
  }

  ProblemDuringStartup --> Stopped : problemFound
  CheckingStartup --> ReadyToUse : startupSuccess
  ReadyToUse --> UserInteraction : userReady
  UserInteraction --> Resetting : resetPressed
  UserInteraction --> Activating : activatePressed
  UserInteraction --> TurningOff : turnOffPressed
  ReadyToUse --> Monitoring : activatePressed
  Monitoring --> AlarmActive : sensorTriggered
  AlarmActive --> Normal : falseAlarmOrTimeEnded
  Normal --> ReadyToUse : passwordEntered
}

Safehome : entry / state = CheckingStartup

state Stopped
state Resetting
state Activating
state TurningOff
state AlarmActive
state Normal
@enduml
