@startuml
title UML State Machine Diagram (Search System)

[*] --> SearchCategory

state SearchCategory <<choice>>
SearchCategory --> SearchPrice : [Price range]
SearchCategory --> DisplayResults : [Filter category]

state "SearchPrice" as SearchPrice {
    [*] --> GettingPriceRange

    state GettingPriceRange
    state ChoicePrice <<choice>>
    state "Display Results" as DisplayResults

    GettingPriceRange --> ChoicePrice : [Price range verification]
    ChoicePrice --> DisplayResults : [valid]
    ChoicePrice --> [*] : [invalid]

    DisplayResults --> DisplayResults : [display results]
}

SearchPrice : entry / Price range
SearchPrice : do / Display results
SearchPrice : exit / After verification

state "DisplayResults" as DisplayResults {
    [*] --> ChoiceDisplay

    state ChoiceDisplay <<choice>>
    state "View results" as ViewResults
    state "Back to search" as BackToSearch

    ChoiceDisplay --> ViewResults : [view results]
    ChoiceDisplay --> BackToSearch : [back to search]

    ViewResults --> [*] : [back to search]
    BackToSearch --> SearchCategory : [back to search]
}

@enduml
