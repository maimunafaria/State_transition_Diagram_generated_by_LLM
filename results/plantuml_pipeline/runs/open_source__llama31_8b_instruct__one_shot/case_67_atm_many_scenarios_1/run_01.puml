@startuml
title UML State Machine Diagram

[*] --> C1

state C1 <<choice>>
C1 --> InsertCard : [possibilities to start]

state "Insert Card" as InsertCard
InsertCard : entry / card inserted
InsertCard : do / prompt for PIN
InsertCard : exit / PIN requested

InsertCard --> Auth : [PIN verification]

state "Authentication of PIN" as Auth
Auth : entry / PIN entered
Auth : do / verify PIN
Auth : exit / PIN verified

Auth --> Options : [PIN verified]

state "Options" as Options
Options : entry / PIN verified
Options : do / display options
Options : exit / options displayed

Options --> Withdraw : [user selects withdrawal]

state "Withdrawal" as Withdraw
Withdraw : entry / user selects withdrawal
Withdraw : do / process withdrawal request
Withdraw : exit / withdrawal completed

Withdraw --> DispenseCash : [withdrawal request processed]

state "Dispense Cash" as DispenseCash
DispenseCash : entry / withdrawal request processed
DispenseCash : do / dispense cash
DispenseCash : exit / cash dispensed

DispenseCash --> PrintReceipt : [cash dispensed]

state "Print Receipt" as PrintReceipt
PrintReceipt : entry / cash dispensed
PrintReceipt : do / print receipt
PrintReceipt : exit / receipt printed

PrintReceipt --> ReturnCard : [transaction completed]

state "Return Card" as ReturnCard
ReturnCard : entry / transaction completed
ReturnCard : do / return card
ReturnCard : exit / card returned

ReturnCard --> Reset : [transaction completed]

state "Reset" as Reset
Reset : entry / transaction completed
Reset : do / reset system
Reset : exit / system reset

Reset --> [*]

@enduml
