@startuml
title Campaign State Machine

[*] --> AssignManagerStaff

state "AssignManagerStaff <<final>>" as AssignManagerStaff

state ApproveContract {
  AssignManagerStaff --> ApproveContract : approveContract
  state ApproveContract
  ApproveContract --> [*] : contractSigned
}

state ActivateCampaign {
  ApproveContract --> ActivateCampaign : activateCampaign
  state ActivateCampaign
  ActivateCampaign --> [*] : campaignStarted
}

state PrepareAdverts {
  ActivateCampaign --> PrepareAdverts : prepareAdverts
  state PrepareAdverts
  PrepareAdverts --> [*] : advertsReady
}

state ApproveScheduleAdverts {
  PrepareAdverts --> ApproveScheduleAdverts : approveScheduleAdverts
  state ApproveScheduleAdverts
  ApproveScheduleAdverts --> [*] : advertsScheduled
}

state RunAdverts {
  ApproveScheduleAdverts --> RunAdverts : runAdverts
  state RunAdverts
  RunAdverts --> [*] : advertsRunning
}

state ExtendAdjustCampaign {
  RunAdverts --> ExtendAdjustCampaign : extendAdjustCampaign
  state ExtendAdjustCampaign
  ExtendAdjustCampaign --> [*] : campaignExtended
}

state CompleteCampaign {
  ExtendAdjustCampaign --> CompleteCampaign : completeCampaign
  state CompleteCampaign
  CompleteCampaign --> [*] : campaignFinished
}

state HandlePayment {
  CompleteCampaign --> HandlePayment : handlePayment
  state HandlePayment
  HandlePayment --> [*] : paymentProcessed
}

state MarkCampaignPaid {
  HandlePayment --> MarkCampaignPaid : markCampaignPaid
  state MarkCampaignPaid
  MarkCampaignPaid --> [*] : campaignPaid
}

state ArchiveCampaign {
  MarkCampaignPaid --> ArchiveCampaign : archiveCampaign
  state ArchiveCampaign
  ArchiveCampaign --> [*] : campaignArchived
}

state ReleaseStaffManagers {
  ArchiveCampaign --> ReleaseStaffManagers : releaseStaffManagers
  state ReleaseStaffManagers
  ReleaseStaffManagers --> [*] : staffReleased
}

AssignManagerStaff --> OutOfService : outOfService / <<final>>
ApproveContract --> OutOfService : outOfService / <<final>>
ActivateCampaign --> OutOfService : outOfService / <<final>>
PrepareAdverts --> OutOfService : outOfService / <<final>>
ApproveScheduleAdverts --> OutOfService : outOfService / <<final>>
RunAdverts --> OutOfService : outOfService / <<final>>
ExtendAdjustCampaign --> OutOfService : outOfService / <<final>>
CompleteCampaign --> OutOfService : outOfService / <<final>>
HandlePayment --> OutOfService : outOfService / <<final>>
MarkCampaignPaid --> OutOfService : outOfService / <<final>>
ArchiveCampaign --> OutOfService : outOfService / <<final>>
ReleaseStaffManagers --> OutOfService : outOfService / <<final>>
CompleteCampaign --> ArchiveCampaign : campaignFinished
HandlePayment --> MarkCampaignPaid : paymentProcessed
ArchiveCampaign --> ReleaseStaffManagers : campaignArchived

@enduml
