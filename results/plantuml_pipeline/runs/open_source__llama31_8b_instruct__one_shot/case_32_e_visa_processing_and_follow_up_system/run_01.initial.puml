@startuml
title UML State Machine Diagram

[*] --> C1

state C1 <<choice>>
C1 --> Login : [possibilities to start]

state "Login" as Login
Login : entry / user credentials
Login : do / authentication
Login : exit / login completed

Login --> C2

state C2 <<choice>>
C2 --> CreateAccount : [possibilities to create account]
C2 --> ApplyVisa : [possibilities to apply visa]

state "Create Account" as CreateAccount
CreateAccount : entry / user credentials
CreateAccount : do / account creation
CreateAccount : exit / account created

CreateAccount --> Login

state "Apply Visa" as ApplyVisa
ApplyVisa : entry / user credentials
ApplyVisa : do / payment
ApplyVisa : do / application accepted
ApplyVisa : exit / visa application submitted

ApplyVisa --> ViewStatus

state "View Status" as ViewStatus
ViewStatus : entry / visa application
ViewStatus : do / status shown
ViewStatus : exit / status viewed

ViewStatus --> CheckStatus

state "Check Status" as CheckStatus
CheckStatus : entry / status viewed
CheckStatus : do / status checked
CheckStatus : exit / status checked

CheckStatus --> CancelApplication

state "Cancel Application" as CancelApplication
CancelApplication : entry / status checked
CancelApplication : do / application cancelled
CancelApplication : exit / application cancelled

CancelApplication --> ModifyDetails

state "Modify Details" as ModifyDetails
ModifyDetails : entry / user credentials
ModifyDetails : do / details modified
ModifyDetails : exit / details modified

ModifyDetails --> ViewDetails

state "View Details" as ViewDetails
ViewDetails : entry / user credentials
ViewDetails : do / details shown
ViewDetails : exit / details viewed

ViewDetails --> GiveFeedback

state "Give Feedback" as GiveFeedback
GiveFeedback : entry / status checked
GiveFeedback : do / feedback given
GiveFeedback : exit / feedback given

GiveFeedback --> UpdateStatus

state "Update Status" as UpdateStatus
UpdateStatus : entry / status checked
UpdateStatus : do / status updated
UpdateStatus : exit / status updated

UpdateStatus --> Logout

state "Logout" as Logout
Logout : entry / user credentials
Logout : do / logout completed
Logout : exit / logout completed

Logout --> [*]

@enduml
