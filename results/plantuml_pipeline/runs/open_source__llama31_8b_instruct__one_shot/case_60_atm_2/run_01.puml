@startuml
title UML State Machine Diagram - Atm

[*] --> SelectAmount

state "Select amount" as SelectAmount
state "Enter custom value" as EnterCustomValue
state "Verify transaction" as VerifyTransaction
state "Re-enter amount" as ReEnterAmount

SelectAmount --> EnterCustomValue
EnterCustomValue --> VerifyTransaction
VerifyTransaction --> SelectAmount
VerifyTransaction --> ReEnterAmount
ReEnterAmount --> SelectAmount

@enduml
