@startuml
[*] --> Idle
Idle --> Active : Press Button
Active --> [*] : Release Button

state AdjustHour {
    Active --> AdjustHour : Press Button
    AdjustHour --> AdjustMinutes : Press Button
    AdjustHour --> AdjustHour : Increase Value
}
state AdjustMinutes {
    AdjustMinutes --> AdjustAlarmHour : Press Button
    AdjustMinutes --> AdjustMinutes : Increase Value
}
state AdjustAlarmHour {
    AdjustAlarmHour --> AdjustAlarmMinutes : Press Button
    AdjustAlarmHour
@enduml
