@startuml
state "Initial State" as Initial
state "Select Predefined Amount" as SelectPredef
state "Enter Custom Amount" as EnterCustom
state "Validate Amount" as Validate
state "Invalid Amount" as Invalid
state "Cancel Transaction" as Cancel
state "End Transaction" as End

[*] --> Initial

Initial --> SelectPredef : select predefined
Initial --> EnterCustom : enter custom

SelectPredef --> Validate : amount selected
EnterCustom --> Validate : amount entered

Validate --> End : valid
Validate --> Invalid : invalid

Invalid --> Validate : re-enter

Cancel --> Initial : cancel transaction

@enduml
