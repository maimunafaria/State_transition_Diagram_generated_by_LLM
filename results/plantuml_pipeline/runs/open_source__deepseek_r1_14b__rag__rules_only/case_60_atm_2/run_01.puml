@startuml
state Initial
state "Main Menu" as MainMenu
state "Amount Selection" as AmountSelection
state "Transaction Verification" as TransactionVerification
state Final

Initial [*] --> MainMenu

MainMenu:
  --> AmountSelection: select amount
  --> AmountSelection: enter custom amount

AmountSelection --> TransactionVerification: verify transaction

TransactionVerification:
  --> Final: success
  --> MainMenu: re-enter amount

enduml
@enduml
