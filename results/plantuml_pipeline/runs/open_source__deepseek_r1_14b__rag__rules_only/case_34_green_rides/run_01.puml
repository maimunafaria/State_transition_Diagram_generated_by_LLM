@startuml
[*] --> LoggedIn

state LoggedIn {
  [*] --> Dashboard
}

state Dashboard {
  --> DrivingMode : activate driving mode
  --> OtherOptions : choose other options
  --> FoodSelection : hungry
}

state DrivingMode {
  --> DrivingMode : continue driving
  --> AccidentReported : accident occurs
}

state AccidentReported {
  --> NotificationSent : notify authorities
  --> Dashboard : back to dashboard
}

state FoodSelection {
  state EatPlace
  state MenuView
  state OrderPlaced

  --> EatPlace : select place
  EatPlace --> MenuView : view menu
  MenuView --> OrderPlaced : place order
  OrderPlaced --> Dashboard : done ordering
}

state JourneyComplete {
  --> FeedbackRequest : provide feedback
}

state FeedbackRequest {
  --> Dashboard : journey complete
}
@enduml
