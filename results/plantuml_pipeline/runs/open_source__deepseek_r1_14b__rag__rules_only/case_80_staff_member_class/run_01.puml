@startuml
[*] --> LoggedIn

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
}

LoggedIn --> Assignment : assign to client/campaign
LoggedIn --> Unemployed : remove assignment
LoggedIn --> Archived : archive record

state Assignment {
  [*] --> ClientAssignment
  ClientAssignment --> CampaignAssignment : switch to campaign
  CampaignAssignment --> ClientAssignment : switch to client
  ClientAssignment --> Unassigned : remove assignment
  CampaignAssignment --> Unassigned : remove assignment
}

Unemployed --> Archived : mark as unemployed
@enduml
