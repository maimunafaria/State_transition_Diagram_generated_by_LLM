@startuml
hide empty description
[*] --> Unauthenticated

state Unauthenticated {
  [*] --> Login : attempt
  Login --> LoggedIn : successful
}

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> MarketConditions : select market conditions
  MarketConditions --> MarketReport : show report
  MarketReport --> Dashboard : back

  Dashboard --> PestControl : select pest control
  PestControl --> PhotoRequest : request photo
  PhotoRequest --> PestTechniques : show techniques
  PestTechniques --> Dashboard : continue

  Dashboard --> SoilInfo : select soil
  SoilInfo --> CropSuggestions : show suggestions
  CropSuggestions --> Dashboard : continue

  Dashboard --> Weather : select weather
  Weather --> WeatherReport : show report
  WeatherReport --> Dashboard : continue

  Dashboard --> Labour : select labour
  Labour --> LabourAvailability : show availability
  LabourAvailability --> Dashboard : continue

  Dashboard --> ContinueUsing : continue using
}

LoggedIn --> Unauthenticated : logout
@enduml
