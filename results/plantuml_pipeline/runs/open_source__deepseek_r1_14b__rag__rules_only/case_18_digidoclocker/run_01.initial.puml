@startuml
[*] --> Initial

state Initial {
  [*] --> UserIdentification
}

state UserIdentification {
  UserIdentification --> Registration : not registered
  UserIdentification --> Login : already registered
}

state Registration {
  Registration --> Login : registration complete
}

state Login {
  Login --> LoggedIn : login successful
}

state LoggedIn {
  [*] --> UploadDocument
  [*] --> ViewProfile
  [*] --> ApplyForCertificate

  state UploadDocument {
    UploadDocument --> ContinueUpload : continue uploading
    UploadDocument --> Logout : done
  }

  state ViewProfile {
    ViewProfile --> Logout : done
  }

  state ApplyForCertificate {
    ApplyForCertificate --> Reapply : reapply
    ApplyForCertificate --> RequestMore : request more
    ApplyForCertificate --> Logout : done
  }
}

LoggedIn --> Logout : logout

state Logout {
  note right of Logout: End session
}
@enduml
