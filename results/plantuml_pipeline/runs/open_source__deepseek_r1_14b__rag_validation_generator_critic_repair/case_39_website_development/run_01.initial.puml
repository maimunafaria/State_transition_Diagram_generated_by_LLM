@startuml
[*] --> Homepage
Homepage --> ProjectSelection
Homepage --> CareerSelection

state ProjectSelection {
    [*] --> ViewProject
    ViewProject --> Photos
    ViewProject --> Videos
}

state CareerSelection {
    [*] --> ViewCareer
    ViewCareer --> Updates
    ViewCareer --> ApplicationForm
}

state ApplicationCheck {
    [*] --> Submitted
    Submitted --> [*]
}

Photos --> Homepage
Videos --> Homepage
Updates --> Homepage
ApplicationForm --> ApplicationCheck
@enduml
