@startuml
title Green Rides State Machine

[*] --> E
state "EntryPoint" as E
state "LoggedIn" as L
state "DestinationSelected" as D
state "JourneyDetailsDisplayed" as J
state "DrivingModeActivated" as Dr
state "OptionsMenu" as O
state "PlaceSelected" as P
state "MenuDisplayed" as M
state "OrderPlaced" as Or
state "Logout" as Lo

E --> L
E --> D
E --> J
E --> Dr
E --> O
E --> P
E --> M
E --> Or
E --> Lo

L --> D
D --> J
J --> Dr
J --> O
O --> P
P --> M
M --> Or
Or --> J

Dr --> Lo
O --> Lo
J --> Lo

Lo --> [*]
@enduml
