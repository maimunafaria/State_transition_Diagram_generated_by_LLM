@startuml
title ATM - Withdrawal Process

[*] --> Start

state Start
state "Waiting for Amount Selection" as WaitingAmount
state "Verifying Transaction" as Verifying
state "Waiting for Amount Re-entry" as WaitingReentry
state Success
state "System Shutdown" as Shutdown

Start --> WaitingAmount : start transaction
WaitingAmount --> Verifying : amount selected / verify
WaitingAmount --> Verifying : custom amount / verify

Verifying --> Success : transaction approved
Verifying --> WaitingReentry : transaction rejected

WaitingReentry --> Verifying : amount re-entered / verify

Verifying --> Shutdown : system shutdown
WaitingAmount --> Shutdown : system shutdown
WaitingReentry --> Shutdown : system shutdown

Success --> [*] : end
@enduml
