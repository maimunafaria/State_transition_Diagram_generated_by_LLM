@startuml
[*] --> SelectAmount

state SelectAmount
state VerifyTransaction
state RejectTransaction
state ApprovedTransaction

SelectAmount --> VerifyTransaction : amount selected\nverify transaction

VerifyTransaction --> RejectTransaction : transaction rejected\nre-enter amount
RejectTransaction --> SelectAmount : re-enter amount

VerifyTransaction --> ApprovedTransaction : transaction approved

ApprovedTransaction --> [*] : transaction completed
@enduml
