@startuml
title Campaign Version 2 State Machine

[*] --> Commissioned : /assignManager; assignStaff

state Commissioned
state Active
state Completed
state Paid
state WaitingPayment

Commissioned --> Active : authorized(authorizationCode)\n[contract signed]\n/setCampaignActive

Active --> Completed : campaignCompleted\n/prepareFinalStatement

Completed --> Paid : paymentReceived(payment)\n[paymentDue - payment = zero]
Completed --> WaitingPayment : paymentReceived(payment)\n[paymentDue - payment > zero]
Completed --> Paid : paymentReceived(payment)\n[paymentDue - payment < zero]\n/generateRefund

Paid --> [*] : archiveCampaign\n/unassignStaff;\nunassignManager

Active {
  state AdvertPreparation {
    [*] --> Scheduling : advertsApproved\n/authorize
    Scheduling --> RunningAdverts : confirmSchedule
    RunningAdverts --> AdvertPreparation : extendCampaign\n/modifyBudget
  }
  state RunningAdverts
  state Monitoring {
    [*] --> Survey
    state Survey
    state Evaluation
    Survey --> Evaluation : surveyComplete
    Evaluation --> Survey : runSurvey
  }
}

@enduml
