@startuml
[*] --> Initial

state Initial
Initial --> SearchingInventory
Initial --> AddingGoods
Initial --> UpdatingPrice
Initial --> RemovingGoods

state SearchingInventory
SearchingInventory --> SelectingItems
SearchingInventory --> AddingGoods

state SelectingItems
SelectingItems --> CalculatingDiscountsTaxes
SelectingItems --> ReplacingCancelingReceipt

state CalculatingDiscountsTaxes
CalculatingDiscountsTaxes --> GeneratingInvoice
CalculatingDiscountsTaxes --> SelectingItems

state GeneratingInvoice
GeneratingInvoice --> PlacingOrder
GeneratingInvoice --> SearchingInventory

state PlacingOrder
PlacingOrder --> GeneratingReport
PlacingOrder --> SearchingInventory

state GeneratingReport
GeneratingReport --> [*]

state ReplacingCancelingReceipt
ReplacingCancelingReceipt --> SelectingItems
ReplacingCancelingReceipt --> SearchingInventory

state AddingGoods
AddingGoods --> Initial

state UpdatingPrice
UpdatingPrice --> Initial

state RemovingGoods
RemovingGoods --> Initial

state ExpiredGoodsNotification
ExpiredGoodsNotification --> RemovingExpiredGoods
RemovingExpiredGoods --> Initial

@enduml
