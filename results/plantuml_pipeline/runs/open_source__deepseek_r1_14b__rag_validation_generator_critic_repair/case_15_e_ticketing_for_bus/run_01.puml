@startuml
[*] --> Start

state Start {
    [*] --> CreateUser
    CreateUser --> Login : [Registered]
}

state CreateUser {
    [*] --> RegEnterDetails
}

state RegEnterDetails {
    RegEnterDetails --> RegValidate : [Valid]
    RegEnterDetails --> RegInvalid : [Invalid]
}

state RegValidate {
    RegValidate --> Login
}

state RegInvalid {
    RegInvalid --> CreateUser
}

state Login {
    Login --> LoggedIn : [Valid]
    Login --> LoginFailed : [Invalid]
}

state LoginFailed {
    LoginFailed --> CreateUser
}

state LoggedIn {
    [*] --> Dashboard

    state Dashboard {
        Dashboard --> CheckTicket : [Check Status]
        Dashboard --> BookTicket : [Book Ticket]
        Dashboard --> ManageAccount : [Manage Account]
        Dashboard --> Logout : [Logout]
    }

    state BookTicket {
        BookTicket --> PaymentConfirmation : [Confirm Payment]
        BookTicket --> BookFailed : [Payment Failed]
    }

    state PaymentConfirmation {
        PaymentConfirmation --> OrderComplete : [Payment Confirmed]
    }

    state OrderComplete {
        OrderComplete --> Dashboard
    }

    state ManageAccount {
        ManageAccount --> EditProfile : [Edit]
        ManageAccount --> DeleteAccount : [Delete]
    }

    state EditProfile {
        EditProfile --> Dashboard
    }

    state DeleteAccount {
        DeleteAccount --> Dashboard
    }

    state Logout {
        Logout --> Start
    }
}

@enduml
