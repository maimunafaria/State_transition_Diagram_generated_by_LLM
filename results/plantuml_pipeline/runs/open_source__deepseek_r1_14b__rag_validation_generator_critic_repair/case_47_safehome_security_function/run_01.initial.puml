@startuml
[*] --> PowerOnCheck

state PowerOnCheck {
  [*] --> Ready : everything fine
  PowerOnCheck --> Stopped : problem during startup
}

state Ready {
  Ready --> Ready : reset
  Ready --> Monitoring : activate
  Ready --> Stopped : turn off
}

state Monitoring {
  Monitoring --> Alarm : sensor triggered
  Monitoring --> Monitoring : continue monitoring
}

state Alarm {
  Alarm --> Monitoring : false alarm or time ends
  Alarm --> Stopped : password entered
}

state Stopped {
  Stopped --> [*]
}

Monitoring --> Stopped : password entered
@enduml
