@startuml
state InsertedCard
state WaitingForPIN
state ValidatingPIN
state MainMenu
state ProcessingWithdrawal
state DispensingCash
state PrintingReceipt
state EjectingCard
state Resetting
state Idle

[*] --> InsertedCard

InsertedCard --> WaitingForPIN : "Card Inserted / Get PIN"

WaitingForPIN --> ValidatingPIN : "PIN Entered / Validate PIN"

ValidatingPIN --> MainMenu : "Valid PIN / Display Menu"

MainMenu --> ProcessingWithdrawal : "Withdrawal Selected / Request Withdrawal, Display Wait"

ProcessingWithdrawal --> DispensingCash : "Withdrawal Approved / Dispense Cash, Update Status"

DispensingCash --> PrintingReceipt : "Cash Dispensed / Print Receipt,\nDisplay Cash Dispensed,\nConfirm Cash Dispensed"

PrintingReceipt --> EjectingCard : "Receipt Printed / Eject"

EjectingCard --> Resetting : "Card Ejected / Display Ejected"

Resetting --> Idle : "After (Elapsed Time)\n[Ready for Next User]"

Idle --> [*]

Idle : "entry / Display Welcome"
@enduml
