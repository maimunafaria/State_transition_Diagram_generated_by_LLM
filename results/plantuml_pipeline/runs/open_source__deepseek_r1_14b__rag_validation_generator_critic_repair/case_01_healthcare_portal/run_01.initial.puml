@startuml
[*] --> Registration

state Registration {
  [*] --> RegistrationSuccess
  RegistrationSuccess --> Login : successful registration
  Registration --> RegistrationFailure
  RegistrationFailure --> [*] : access ended
}

state Login {
  [*] --> LoginSuccess
  LoginSuccess --> LoggedIn
  Login --> LoginFailure
  LoginFailure --> [*] : access denied
}

state LoggedIn {
  [*] --> MainMenu
  MainMenu --> News : view news
  MainMenu --> SymptomCheck : check symptoms
  MainMenu --> FitnessOptions : use fitness options
  MainMenu --> InsuranceProcessing : process insurance
  MainMenu --> PaymentSelection : select payment
  MainMenu --> Logout : end session
}

state News {
  [*] --> MainMenu : back to main menu
}

state SymptomCheck {
  [*] --> SymptomResult : check result
  SymptomResult --> MainMenu : continue
  SymptomResult --> Logout : finish session
}

state FitnessOptions {
  [*] --> MainMenu : back to main menu
}

state InsuranceProcessing {
  [*] --> InsuranceValidation
  InsuranceValidation --> InsuranceProcessed : valid
  InsuranceValidation --> InsuranceRejected : invalid
  InsuranceProcessed --> MainMenu
  InsuranceRejected --> MainMenu
}

state PaymentSelection {
  [*] --> CashPayment : choose cash
  CashPayment --> PaymentInfo : provide details
  PaymentInfo --> MainMenu : confirm
  PaymentSelection --> InsurancePayment : choose insurance
  InsurancePayment --> InsuranceProcessing
}

state Logout {
  [*] --> EndState : session ended
}
@enduml
