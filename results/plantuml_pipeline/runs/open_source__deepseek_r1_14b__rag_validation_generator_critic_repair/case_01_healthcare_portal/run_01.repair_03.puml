@startuml
[*] --> Registration

state Registration {
  Registration --> RegistrationSuccess : successful
  Registration --> RegistrationFailure : failed
}

state RegistrationSuccess {
  RegistrationSuccess --> Login : successful registration
}

state RegistrationFailure {
  RegistrationFailure --> [*] : access ended
}

state Login {
  Login --> LoginSuccess : successful login
  Login --> LoginFailure : failed login
}

state LoginSuccess {
  LoginSuccess --> LoggedIn
}

state LoginFailure {
  LoginFailure --> [*] : access denied
}

state LoggedIn {
  LoggedIn --> MainMenu
}

state MainMenu {
  MainMenu --> News : view news
  MainMenu --> SymptomCheck : check symptoms
  MainMenu --> FitnessOptions : use fitness options
  MainMenu --> InsuranceProcessing : process insurance
  MainMenu --> PaymentSelection : select payment
  MainMenu --> Logout : end session
}

state News {
  News --> MainMenu : back to main menu
}

state SymptomCheck {
  SymptomCheck --> SymptomResult : check result
}

state SymptomResult {
  SymptomResult --> MainMenu : continue
  SymptomResult --> Logout : finish session
}

state FitnessOptions {
  FitnessOptions --> MainMenu : back to
}
@enduml
