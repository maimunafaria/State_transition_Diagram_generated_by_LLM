@startuml
[*] --> Registration

state Registration
Registration : entry / start registration
Registration : do / validate inputs
Registration : exit / successful registration
Registration : exit / registration failed

state RegistrationDecision <<choice>>
Registration --> RegistrationDecision

state "Successful Registration" as SuccessReg
SuccessReg : entry / registration completed
SuccessReg : do / allow access
SuccessReg : exit / proceed to login

state "Registration Failed" as FailReg
FailReg : entry / registration error
FailReg : do / display error message
FailReg : exit / return to start

RegistrationDecision -->[successful] SuccessReg
RegistrationDecision -->[failed] FailReg

SuccessReg --> Login

state Login
Login : entry / start login
Login : do / verify credentials
Login : exit / login successful
Login : exit / login failed

state LoginDecision <<choice>>
Login --> LoginDecision

state "Valid Login" as ValidLogin
ValidLogin : entry / login completed
ValidLogin : do / access granted
ValidLogin : exit / proceed to dashboard

state "Invalid Login" as InvalidLogin
InvalidLogin : entry / login error
InvalidLogin : do / display error message
InvalidLogin : exit / return to login

LoginDecision -->[valid] ValidLogin
LoginDecision -->[invalid] InvalidLogin

ValidLogin --> Dashboard

state Dashboard
Dashboard : entry / show facilities
Dashboard : do / access features
Dashboard : exit / continue or logout

state DashboardDecision <<choice>>
Dashboard --> DashboardDecision

state "Continue Session" as Continue
Continue : entry / continue using
Continue : do / access features
Continue : exit / proceed

state Logout
Logout : entry / start logout
Logout : do / terminate session
Logout : exit / logged out

DashboardDecision -->[continue] Continue
DashboardDecision -->[logout] Logout

Continue --> Dashboard

Continue --> PaymentOptions

state PaymentOptions
PaymentOptions : entry / select payment
PaymentOptions : do / choose method
PaymentOptions : exit / proceed

state PaymentMethod <<choice>>
PaymentOptions --> PaymentMethod

state InsurancePayment
InsurancePayment : entry / process insurance
InsurancePayment : do / validate insurance
InsurancePayment : exit / payment completed

state CashPayment
CashPayment : entry / cash payment
CashPayment : do / confirm details
CashPayment : exit / payment completed

PaymentMethod -->[insurance] InsurancePayment
PaymentMethod -->[cash] CashPayment

InsurancePayment --> PaymentConfirmation

state PaymentConfirmation
PaymentConfirmation : entry / confirm payment
PaymentConfirmation : do / finalize
PaymentConfirmation : exit / proceed

CashPayment --> PaymentConfirmation

PaymentConfirmation --> Feedback

state Feedback
Feedback : entry / collect feedback
Feedback : do / submit feedback
Feedback : exit / proceed

Feedback --> Logout

Logout --> [*]

@enduml
