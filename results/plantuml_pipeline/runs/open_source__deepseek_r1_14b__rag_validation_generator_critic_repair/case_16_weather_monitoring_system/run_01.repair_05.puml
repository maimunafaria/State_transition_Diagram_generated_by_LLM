@startuml
title Weather Monitoring System

state "Start" as Start
state "Register" as Register
state "Login" as Login
state "MainMenu" as MainMenu
state "CheckWeather" as CheckWeather
state "InvalidLocation" as InvalidLocation
state "ViewDetails" as ViewDetails
state "Logout" as Logout

[*] --> Start

Start -> J1
Register -> J2
Login -> J3
MainMenu -> J4
CheckWeather -> J5
InvalidLocation -> J6
ViewDetails -> J7
Logout -> J8

J1 <<choice>>
J2 <<choice>>
J3 <<choice>>
J4 <<choice>>
J5 <<choice>>
J6 <<choice>>
J7 <<choice>>
J8 <<choice>>

Start --> J1
J1 --> Register
J1 --> Login

Register --> J2
J2 --> Start : [Invalid]
J2 --> Login : [Valid]

Login --> J3
J3 --> MainMenu : [Valid]
J3 --> Start : [Invalid]

MainMenu --> J4
J4 --> CheckWeather
J4 --> Logout

CheckWeather --> J5
J5 --> InvalidLocation : [Invalid]
J5 --> ViewDetails : [Valid]

InvalidLocation --> J6
J6 --> MainMenu

ViewDetails --> J7
J7 --> MainMenu
J7 --> Logout

Logout --> J8
J8 --> [*]

@enduml
