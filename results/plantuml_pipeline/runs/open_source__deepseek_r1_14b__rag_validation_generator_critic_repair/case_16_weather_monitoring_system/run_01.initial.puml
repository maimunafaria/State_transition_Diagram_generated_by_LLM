@startuml
title Weather Monitoring System

state "Start" as Start
state "Register" as Register
state "Login" as Login
state "MainMenu" as MainMenu
state "CheckWeather" as CheckWeather
state "SelectDataType" as SelectDataType
state "ViewAdditionalDetails" as ViewAdditionalDetails
state "Logout" as Logout
state "End" as End

Start --> Register : Registration attempt
Start --> Login : Login attempt

Register --> Start : Successful registration
Register --> End : Invalid registration

Login --> MainMenu : Successful login
Login --> Start : Invalid login

MainMenu --> CheckWeather : Check weather
MainMenu --> ViewAdditionalDetails : View additional details
MainMenu --> Logout : Logout

CheckWeather --> MainMenu : Back to main menu
CheckWeather --> End : Invalid location
CheckWeather --> SelectDataType : Valid location

SelectDataType --> MainMenu : Back to main menu
SelectDataType --> CheckWeather : Recheck weather

ViewAdditionalDetails --> MainMenu : Back to main menu

Logout --> End : Logout confirmed
Logout --> MainMenu : Cancel logout

@enduml
