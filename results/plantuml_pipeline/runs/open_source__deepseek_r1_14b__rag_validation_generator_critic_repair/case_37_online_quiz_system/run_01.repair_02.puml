@startuml
state [*] {
}
state LoggedIn {
  transition Student -> StudentOptions
  transition Teacher -> TeacherOptions
}
state TeacherOptions {
  transition create_quiz -> CreateQuiz
  transition edit_quiz -> EditQuiz
  transition save_quiz -> SaveQuiz
  transition view_results -> ViewResults
}
state StudentOptions {
  transition select_quiz -> SelectQuiz
  transition answer_quiz -> AnswerQuiz
  transition submit_quiz -> SubmitQuiz
  transition view_results -> ViewResults
}
state CreateQuiz, EditQuiz, SaveQuiz, ViewResults, SelectQuiz, AnswerQuiz, SubmitQuiz {
  transition logout -> LoggedOut
}
state LoggedOut {
  transition [*] -> [*]
}
[*] --> LoggedIn
@enduml
