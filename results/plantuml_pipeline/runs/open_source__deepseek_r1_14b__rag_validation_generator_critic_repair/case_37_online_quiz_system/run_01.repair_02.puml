@startuml
title Online Quiz System State Diagram

start
state "Registration/Login" as Auth
state "Choose Role" as RoleChoice
state "Teacher Mode" as Teacher
state "Create Quiz" as CreateQuiz
state "Edit Quiz" as EditQuiz
state "Save Draft/Post Quiz" as SaveQuiz
state "View Results" as ViewResults
state "Student Mode" as Student
state "Select Quiz" as SelectQuiz
state "Answer Quiz" as Answer
state "Submit Quiz" as Submit
state "View Result" as ViewResult
state "End" as End

[*] --> Auth
Auth --> RoleChoice

RoleChoice --> Teacher
@enduml
