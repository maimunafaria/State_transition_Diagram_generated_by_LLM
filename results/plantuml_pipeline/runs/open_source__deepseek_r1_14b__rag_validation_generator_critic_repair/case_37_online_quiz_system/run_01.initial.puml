@startuml
title Online Quiz System State Diagram

state Start {
  [*] --> Start_Login_Register
}

state Start_Login_Register as "Login/Register"

state After_Login {
  [*] --> Choose_UserType
}

state Choose_UserType as "Choose User Type (Teacher/Student)"

state Teacher_Menu {
  --> CreateQuiz
  --> EditQuiz
  --> SaveDraft
  --> PostQuiz
  --> ViewResults
}

state CreateQuiz as "Create New Quiz"
state EditQuiz as "Edit Existing Quiz"
state SaveDraft as "Save as Draft"
state PostQuiz as "Post Quiz"
state ViewResults as "View Results"

state Student_Menu {
  --> SelectQuiz
  --> AnswerQuiz
  --> SubmitQuiz
  --> ViewResult
}

state SelectQuiz as "Select Quiz"
state AnswerQuiz as "Answer Quiz"
state SubmitQuiz as "Submit Quiz"
state ViewResult as "View Result"

Start_Login_Register --> After_Login
Choose_UserType --> Teacher_Menu
Choose_UserType --> Student_Menu

CreateQuiz --> EditQuiz
CreateQuiz --> SaveDraft
CreateQuiz --> PostQuiz
EditQuiz --> CreateQuiz
EditQuiz --> SaveDraft
EditQuiz --> PostQuiz
SaveDraft --> CreateQuiz
SaveDraft --> EditQuiz
PostQuiz --> ViewResults
ViewResults --> PostQuiz
ViewResults --> [*]

SelectQuiz --> AnswerQuiz
AnswerQuiz --> SubmitQuiz
SubmitQuiz --> ViewResult
ViewResult --> [*]

@enduml
