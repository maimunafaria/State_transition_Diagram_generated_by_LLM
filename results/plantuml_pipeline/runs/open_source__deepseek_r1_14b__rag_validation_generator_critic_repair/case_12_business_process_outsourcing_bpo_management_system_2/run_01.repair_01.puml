@startuml
title UML State Machine Diagram - BPO Management System Search

state SearchProduct
state SelectCategory
state SelectPrice
state ProcessRequest
state DisplayResults

initial state SearchProduct

SearchProduct --> SelectCategory : [select category]
SearchProduct --> SelectPrice : [select price range]

SelectCategory --> ProcessRequest : [apply category filter]
SelectPrice --> ProcessRequest : [apply price filter]

ProcessRequest --> DisplayResults : [show matching users]

DisplayResults --> SearchProduct : [back to search]
@enduml
