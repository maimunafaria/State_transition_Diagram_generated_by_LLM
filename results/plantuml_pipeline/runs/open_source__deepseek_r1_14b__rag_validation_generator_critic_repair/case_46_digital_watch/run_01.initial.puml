@startuml
[*] --> Idle

Idle --> TimeAdjustment : button pressed
Idle --> LightOn : light button pressed
Idle --> AlarmSettings : alarm button pressed

state TimeAdjustment {
    [*] --> AdjustingHour
    AdjustingHour --> AdjustingMinutes : button pressed
    AdjustingMinutes --> AdjustingAlarmHour : button pressed
    AdjustingAlarmHour --> AdjustingAlarmMinutes : button pressed
    AdjustingAlarmMinutes --> TimeAdjustment : button pressed
}

state AlarmSettings {
    [*] --> AlarmOff
    AlarmOff --> AlarmOn : alarm enabled
    AlarmOn --> AlarmOff : alarm disabled
}

state Light {
    [*] --> LightOff
    LightOff --> LightOn : light button pressed
    LightOn --> LightOff : light button pressed
}

Idle --> AlarmRinging : alarm time matches current time
AlarmRinging --> AlarmOff : button pressed

@enduml
