@startuml
start
state Unassigned {
  Unassigned --> AssignedToClient
  Unassigned --> AssignedToCampaign
}

state AssignedToClient {
  AssignedToClient --> AssignedToCampaign : switch to campaign
  AssignedToClient --> Unassigned : remove assignment
  AssignedToClient --> self : continue in client assignment
}

state AssignedToCampaign {
  AssignedToCampaign --> AssignedToClient : switch to client
  AssignedToCampaign --> Unassigned : remove assignment
  AssignedToCampaign --> self : continue in campaign
}

Unassigned --> Unemployed : leave job

state Unemployed {
  Unemployed --> Archived : after some time
}

Archived --> end
@enduml
