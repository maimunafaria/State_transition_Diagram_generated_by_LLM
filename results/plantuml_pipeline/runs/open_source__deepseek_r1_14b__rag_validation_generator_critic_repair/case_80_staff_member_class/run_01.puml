@startuml
[*] --> Unassigned

state Unassigned {
  [*] --> Assigned : assign
}

state Assigned {
  state ClientAssignment
  state CampaignAssignment
  ClientAssignment --> CampaignAssignment : switchAssignment
  CampaignAssignment --> ClientAssignment : switchAssignment
}

Assigned --> Terminated : terminate
Terminated --> Archived : archive

Archived --> [*]

@enduml
