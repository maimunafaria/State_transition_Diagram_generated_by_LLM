@startuml
[*] --> Login

rectangle Login {
  Login --> LoggedIn
}

rectangle LoggedIn <<choice>> {
  LoggedIn --> MarketConditions : Market Conditions
  LoggedIn --> PestControl : Pest Control
  LoggedIn --> SoilInfo : Soil Info
  LoggedIn --> Weather : Weather
  LoggedIn --> Labour : Labour
  LoggedIn --> Continue : Continue
  LoggedIn --> Logout : Logout
}

rectangle MarketConditions {
  MarketConditions --> MarketReport
}

rectangle MarketReport {
  MarketReport --> LoggedIn
  MarketReport --> Logout
}

rectangle PestControl {
  PestControl --> PestControlTechniques
}

rectangle PestControlTechniques {
  PestControlTechniques --> LoggedIn
}

rectangle SoilInfo {
  SoilInfo --> SoilSuggestions
}

rectangle SoilSuggestions {
  SoilSuggestions --> LoggedIn
}

rectangle Weather {
  Weather --> WeatherReport
}

rectangle WeatherReport {
  WeatherReport --> LoggedIn
}

rectangle Labour {
  Labour --> LabourReport
}

rectangle LabourReport {
  LabourReport --> LoggedIn
}

rectangle Continue {
  Continue --> [*]
}

rectangle Logout {
  Logout --> [*]
}
@enduml
