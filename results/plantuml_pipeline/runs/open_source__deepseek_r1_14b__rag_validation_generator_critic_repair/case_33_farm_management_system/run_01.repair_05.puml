@startuml
[*] --> Login

state Login {
  Login --> LoggedIn
}

state LoggedIn <<choice>> {
  LoggedIn --> MarketConditions : Check Market Conditions
  LoggedIn --> PestControl : Pest Control Help
  LoggedIn --> SoilInfo : Soil Information
  LoggedIn --> Weather : Weather Insights
  LoggedIn --> Labour : Labour Availability
  LoggedIn --> Continue : Continue Using Service
  LoggedIn --> Logout : Logout
}

state MarketConditions {
  MarketConditions --> MarketReport : View Market Report
}

state MarketReport {
  MarketReport --> LoggedIn : Back to Menu
  MarketReport --> Logout : Logout
}

state PestControl {
  PestControl --> PestControlTechniques : View Techniques
}

state PestControlTechniques {
  PestControlTechniques --> LoggedIn : Back to Menu
}

state SoilInfo {
  SoilInfo --> SoilSuggestions : Get Suggestions
}

state SoilSuggestions {
  SoilSuggestions --> LoggedIn : Back to Menu
}

state Weather {
  Weather --> WeatherReport : View Report
}

state WeatherReport {
  WeatherReport --> LoggedIn : Back to Menu
}

state Labour {
  Labour --> LabourReport : View Report
}

state LabourReport {
  LabourReport --> LoggedIn : Back to Menu
}
@enduml
