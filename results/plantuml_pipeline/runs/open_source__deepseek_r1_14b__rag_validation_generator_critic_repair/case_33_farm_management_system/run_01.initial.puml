@startuml
[*] --> Login

state Login {
  [*] --> LoggedIn
}

state LoggedIn <<choice>> {
  LoggedIn --> MarketConditions : select market condition
  LoggedIn --> PestControl : select pest control help
  LoggedIn --> SoilInfo : select soil info
  LoggedIn --> Weather : select weather
  LoggedIn --> Labour : select labour
  LoggedIn --> Continue : continue using service
  LoggedIn --> Logout : log out
}

state MarketConditions {
  MarketConditions --> MarketReport
}

state MarketReport {
  MarketReport --> LoggedIn
  MarketReport --> Logout
}

state PestControl {
  PestControl --> PestControlTechniques
}

state PestControlTechniques {
  PestControlTechniques --> LoggedIn
}

state SoilInfo {
  SoilInfo --> SoilSuggestions
}

state SoilSuggestions {
  SoilSuggestions --> LoggedIn
}

state Weather {
  Weather --> WeatherReport
}

state WeatherReport {
  WeatherReport --> LoggedIn
}

state Labour {
  Labour --> LabourReport
}

state LabourReport {
  LabourReport --> LoggedIn
}

state Continue {
  Continue --> [*]
}

state Logout {
  Logout --> [*]
}

@enduml
