@startuml
[*] --> Login
state Login {
  Login --> Dashboard
}

state Dashboard {
  --> Market : select market conditions
  --> PestControl : select pest control
  --> Soil : select soil info
  --> Weather : select weather
  --> Labor : select labor
  --> Logout : log out
}

state Market {
  --> MarketReport : show report
  MarketReport --> Dashboard
}

state PestControl {
  --> PestPhoto : provide photo
  PestPhoto --> PestTechniques
  PestTechniques --> Dashboard
}

state Soil {
  --> SoilInfo : provide info
  SoilInfo --> SoilSuggestions
  SoilSuggestions --> Dashboard
}

state Weather {
  --> WeatherLocation : provide location
  WeatherLocation --> WeatherInsights
  WeatherInsights --> Dashboard
}

state Labor {
  --> LaborLocation : provide location
  LaborLocation --> LaborAvailability
  LaborAvailability --> Dashboard
}

state Logout {
  --> [*]
}

state Dashboard {
  transition [*] --> Dashboard
}
@enduml
