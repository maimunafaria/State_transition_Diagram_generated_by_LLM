@startuml
[*] --> Running

Running {
  Running --> Configuration : configChange
  Running --> DataCollection : collectData
  Running --> SummaryPreparation : prepareSummary
  Running --> StatusChecking : checkStatus
  Running --> ControlledMode : remoteControl
  Running --> Shutdown : shutdownCommand
}

Configuration {
  Configuration --> Running
}

DataCollection {
  DataCollection --> Running
}

SummaryPreparation {
  SummaryPreparation --> Running
}

StatusChecking {
  StatusChecking --> Running
}

ControlledMode {
  ControlledMode --> Running
}

Shutdown {
  Shutdown --> [*]
}

Running --> Running : noEvent
@enduml
