@startuml
start --> Registration

state Registration {
  Registration --> RegEnterDetails : [Enter Details]
  RegEnterDetails --> RegSuccess : [Valid Details]
  RegEnterDetails --> ReEnterDetails : [Invalid Details]
  ReEnterDetails --> RegEnterDetails
}

state Login {
  RegSuccess --> Login : [Valid Registration]
  Login : entry / Get Login Details
  Login : do / Validate Login Details
  Login : exit / Valid or Invalid Login

  Login --> Login : [Invalid Login]
  Login --> Choice1 : [Valid Login]
}

state Choice1 <<choice>> {
  Choice1 --> UploadDocs : [Upload Documents]
  Choice1 --> ViewProfile : [View Profile]
  Choice1 --> ApplyCert : [Apply for Certificate]
  Choice1 --> UpdateProfile : [Update Profile]
  Choice1 --> RegistrarLogin : [Registrar Login]
}

state UploadDocs {
  UploadDocs --> Choice1 : [Continue Uploading]
  UploadDocs --> Choice1 : [Done Uploading]
}

state ViewProfile {
  ViewProfile --> Choice1 : [Back to Menu]
}

state ApplyCert {
  ApplyCert --> IssueCert : [Certificate
@enduml
