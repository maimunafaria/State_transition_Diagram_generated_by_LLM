@startuml
[*] --> LoggedOut

state LoggedOut {
  [*] --> AccountCreation : create account
  [*] --> Login : login
}

state AccountCreation {
  [*] --> LoggedIn : account created
}

state Login {
  [*] --> LoggedIn : logged in
}

state LoggedIn {
  [*] --> Applying : apply for visa
  Applying --> PaymentProcessing : make payment
  PaymentProcessing --> ApplicationAccepted : payment successful
  ApplicationAccepted --> Approved : visa approved
  ApplicationAccepted --> Rejected : visa rejected
  ApplicationAccepted --> StatusCheck : check status
  StatusCheck --> ApplicationAccepted : status updated
  [*] --> ModifyDetails : modify details
  [*] --> ViewDetails : view details
  [*] --> GiveFeedback : give feedback
  [*] --> Logout : log out
}

state Approved {
  [*] --> LoggedIn : back to dashboard
}

state Rejected {
  [*] --> LoggedIn : back to dashboard
}

state ModifyDetails {
  [*] --> LoggedIn : details modified
}

state ViewDetails {
  [*] --> LoggedIn : details viewed
}

state GiveFeedback {
  [*] --> LoggedIn : feedback given
}

state Logout {
  [*] --> LoggedOut : logged out
}
@enduml
