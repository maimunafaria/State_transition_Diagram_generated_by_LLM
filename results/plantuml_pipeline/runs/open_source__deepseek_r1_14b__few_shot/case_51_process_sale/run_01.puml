@startuml
title Process Sale State Diagram

state "Waiting for Sale" as WaitingSale
state "Selecting Items" as SelectingItems
state "Payment" as Payment
state "Sale Completed" as SaleCompleted
state "Payment Declined" as PaymentDeclined

[*] --> WaitingSale

WaitingSale --> SelectingItems : customerSelectsItems

SelectingItems --> Payment : allItemsAdded

Payment --> SaleCompleted : payWithCash
Payment --> VerifyingPayment : payWithCardOrCheck

VerifyingPayment --> SaleCompleted : paymentApproved
VerifyingPayment --> PaymentDeclined : paymentDeclined

SaleCompleted --> WaitingSale : nextCustomer

PaymentDeclined --> [*]

@enduml
