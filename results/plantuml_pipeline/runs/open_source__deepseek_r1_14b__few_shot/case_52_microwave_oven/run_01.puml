@startuml
title Microwave Oven Control - State Diagram

[*] --> Idle

state "Idle" as Idle
state "Full Power" as FullPower
state "Half Power" as HalfPower
state "Set Time" as SetTime
state "Cooking" as Cooking
state "Door Open" as DoorOpen

Idle --> FullPower : Select Full Power
Idle --> HalfPower : Select Half Power

FullPower --> SetTime : Set Time
HalfPower --> SetTime : Set Time

SetTime --> Cooking : Start Cooking

Cooking --> DoorOpen : Door Opened
Cooking --> Idle : Cancel

DoorOpen --> Idle : Door Closed

@enduml
