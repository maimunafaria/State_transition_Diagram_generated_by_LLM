@startuml
title ATM State Transition Diagram

state InitialState {
  [*] --> CardInserted
}

state CardInserted {
  entry / Display "Please Insert PIN"
}

state EnterPIN {
  entry / Waiting for PIN input
}

state PINVerified {
  entry / PIN verified successfully
}

state ProcessTransaction {
  entry / Processing transaction
}

state DispenseCash {
  entry / Dispensing cash
}

state PrintReceipt {
  entry / Printing receipt
}

state ReturnCard {
  entry / Returning card
}

state Reset {
  entry / Resetting system
}

CardInserted --> EnterPIN : Insert PIN

EnterPIN --> PINVerified : PIN entered correctly

PINVerified --> ProcessTransaction : Process transaction

ProcessTransaction --> DispenseCash : Cash withdrawal approved

DispenseCash --> PrintReceipt : Dispense cash

PrintReceipt --> ReturnCard : Print receipt

ReturnCard --> Reset : Return card

ReturnCard --> InitialState : System reset

@enduml
