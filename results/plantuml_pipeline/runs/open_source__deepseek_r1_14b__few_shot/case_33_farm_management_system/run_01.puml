@startuml
title UML State Machine Diagram - Farm Management System

state "Idle" as Idle
state "LoggedIn MainMenu" as MainMenu
state "MarketConditions" as Market
state "PestControl" as Pest
state "SoilSuggestions" as Soil
state "WeatherInsights" as Weather
state "LabourAvailability" as Labour
state "Logout" as Logout

[*] --> Idle

Idle --> MainMenu : Login

MainMenu --> Market : Select Market Conditions
MainMenu --> Pest : Select Pest Control
MainMenu --> Soil : Select Soil Suggestions
MainMenu --> Weather : Select Weather Insights
MainMenu --> Labour : Select Labour Availability

Market --> MainMenu : Back to MainMenu
Market --> Logout : Logout

Pest --> MainMenu : Back to MainMenu
Pest --> Logout : Logout

Soil --> MainMenu : Back to MainMenu
Soil --> Logout : Logout

Weather --> MainMenu : Back to MainMenu
Weather --> Logout : Logout

Labour --> MainMenu : Back to MainMenu
Labour --> Logout : Logout

MainMenu --> Logout : Logout

Logout --> [*]

@enduml
