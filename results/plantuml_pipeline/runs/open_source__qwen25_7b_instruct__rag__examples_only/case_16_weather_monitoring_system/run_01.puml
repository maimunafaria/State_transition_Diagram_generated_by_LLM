@startuml
title UML state machine diagram

state "Idle" as Idle
Idle : entry/To action
Idle : do/Remain in same state
Idle : exit/Login/Register

state "Register" as Register
Register : entry/Register
Register : do/Register after validating
Register : exit/Login/Invalid registration

state "Invalid registration" as InvalidRegistration
InvalidRegistration : entry/Invalid registration
InvalidRegistration : do/Cannot register
InvalidRegistration : exit/Abnormal termination

state "Login" as Login
Login : entry/Login
Login : do/Login using valid username and password
Login : exit/Invalid login/To home page

state "Invalid login" as InvalidLogin
InvalidLogin : entry/Invalid login
InvalidLogin : do/Cannot login
InvalidLogin : exit/Abnormal termination

state "Home page" as HomePage
HomePage : entry/Logged in user
HomePage : do/Home page actions
HomePage : exit/Login/Register

state "Check weather" as CheckWeather
CheckWeather : entry/After logging in
CheckWeather : do/Choose location and check weather details
CheckWeather : exit/Home page

state "View additional details" as ViewDetails
ViewDetails : entry/After checking weather
ViewDetails : do/View alerts, weekly analysis, future prediction, or graph
ViewDetails : exit/Home page

state "Logout" as Logout
Logout : entry/User completes process
Logout : do/End session
Logout : exit/Successfully logged out

state J1 <<choice>>
state J2 <<choice>>
state J3 <<choice>>
state J4 <<choice>>

[*] --> Idle

Idle --> Register
Idle --> Login

Register --> InvalidRegistration
InvalidRegistration --> [*]

Login --> InvalidLogin
Login --> HomePage
InvalidLogin --> [*]

HomePage --> CheckWeather
CheckWeather --> ViewDetails
ViewDetails --> HomePage
HomePage --> Logout
Logout --> [*]

@enduml
