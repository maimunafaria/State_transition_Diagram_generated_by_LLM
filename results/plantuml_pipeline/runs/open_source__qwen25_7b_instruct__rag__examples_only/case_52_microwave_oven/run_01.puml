@startuml
title Microwave Oven Control - State Diagram

[*] --> Idle

state "Idle" as Idle {
  state "Display Time" as DisplayTime
}

state "Waiting For Input" as WaitingForInput

state "Power Selection" as PowerSelection
state "Set Cooking Time" as SetCookingTime
state "Door Open During Operation" as DoorOpenOperation
state "Cancel Cooking" as CancelCooking
state "Stopped Or Canceled" as StoppedOrCanceled

Idle --> DisplayTime : User Input Not Detected

DisplayTime --> WaitingForInput : User Input Detected

WaitingForInput --> PowerSelection : Full/Half Power Selected
PowerSelection --> SetCookingTime : Cooking Time Entered
SetCookingTime --> DoorOpenOperation : Door Opened During Operation
DoorOpenOperation --> CancelCooking : Cancel Button Pressed
CancelCooking --> StoppedOrCanceled : Cooking Process Canceled

StoppedOrCanceled --> DisplayTime : User Input Not Detected

@enduml
