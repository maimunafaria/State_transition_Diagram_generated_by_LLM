@startuml
title Digital Watch - State Diagram

state "Initial" as Initial
Initial : entry/Watch Ready

state "Display Time" as DisplayTime
DisplayTime : do/Show Current Time

state "Change Hour" as ChangeHour
ChangeHour : do/Set New Hour

state "Change Minute" as ChangeMinute
ChangeMinute : do/Set New Minute

state "Alarm On" as AlarmOn
AlarmOn : entry/Alarm Enabled

state "Alarm Off" as AlarmOff
AlarmOff : entry/Alarm Disabled

state "Alarm Ringing" as AlarmRinging
AlarmRinging : do/Ring Alarm

state "Light On" as LightOn
LightOn : do/Light Turned On

state "Light Off" as LightOff
LightOff : entry/Light Disabled

[*] --> Initial

Initial --> DisplayTime : View/Adjust Time
DisplayTime --> ChangeHour : Press Button
ChangeHour --> ChangeMinute : Press Button
ChangeMinute --> DisplayTime : Press Button
DisplayTime --> AlarmOn : Set Alarm On
AlarmOn --> DisplayTime : Press Button
AlarmOn --> AlarmRinging : Current Time Matches Alarm Time
AlarmRinging --> DisplayTime : Stop Alarm
AlarmOff --> DisplayTime : Set Alarm Off
LightOn --> LightOff : Press Button

@enduml
