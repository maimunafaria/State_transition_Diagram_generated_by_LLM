@startuml
title ATM State Machine for Withdrawal

[*] --> SelectAmount

state "SelectAmount" as SelectAmount {
  [*] --> CustomValue : custom value entered
}

state VerifyTransaction as VerifyTransaction

state ReenterAmount as ReenterAmount

SelectAmount --> VerifyTransaction : amount selected / verify transaction
VerifyTransaction --> Dispensing : transaction approved / dispense cash, eject card
VerifyTransaction --> ReenterAmount : transaction rejected / re-enter amount

ReenterAmount --> SelectAmount : re-enter amount / select new amount

@enduml
