@startuml
title UML State Machine Diagram - BPO Management System Search

[*] --> FilterSelection

state "Filter Selection" as FilterSelection {
    [*] --> CategoryFilter : [Select filter category]
    [*] --> PriceRangeFilter : [Select price range]

    state "Category Filter" as CategoryFilter
    state "Price Range Filter" as PriceRangeFilter

    CategoryFilter --> MatchingUsers : [Search based on category]
    PriceRangeFilter --> MatchingUsers : [Search based on price range]

    state "Matching Users" as MatchingUsers
    MatchingUsers : entry / Display matching users
}

FilterSelection : do / Apply filters
FilterSelection : exit / After filtering

@enduml
