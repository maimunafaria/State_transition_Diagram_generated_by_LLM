@startuml
title UML State Machine Diagram

state "Register/Login" as RegisterLogin {
  [*] --> RegEnterDetails

  state "Enter Details" as RegEnterDetails
  state "Login" as Login
}

state "Teacher Actions" as TeacherActions {
  Login --> CreateQuiz : [Teacher]
  CreateQuiz --> EditQuiz : [Existing Quiz]
  EditQuiz --> SaveDraftOrPost : [Save Draft/Post]
  SaveDraftOrPost --> ViewResults : [Quiz Over]
}

state "Student Actions" as StudentActions {
  Login --> SelectQuiz : [Student]
  SelectQuiz --> AnswerQuiz
  AnswerQuiz --> SubmitQuiz : [Submit]
  SubmitQuiz --> ViewResult : [View Result]
}

RegisterLogin --> TeacherActions
RegisterLogin --> StudentActions

CreateQuiz --> EditQuiz
EditQuiz --> SaveDraftOrPost
SaveDraftOrPost --> ViewResults

SelectQuiz --> AnswerQuiz
AnswerQuiz --> SubmitQuiz
SubmitQuiz --> ViewResult

@enduml
