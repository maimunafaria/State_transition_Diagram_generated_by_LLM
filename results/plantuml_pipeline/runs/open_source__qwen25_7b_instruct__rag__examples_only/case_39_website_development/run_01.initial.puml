@startuml
title UML State Machine Diagram for Website Development

state "Homepage" as Homepage
Homepage : entry/Initial state
Homepage : do/Navigate using navigation bar
Homepage : exit/User navigated

state "Projects" as Projects
Projects : entry/Selected projects
Projects : do/View photos or videos
Projects : exit/User selected option

state "Career Opportunities" as CareerOpportunities
CareerOpportunities : entry/Selected career opportunities
CareerOpportunities : do/View updates or apply for job
CareerOpportunities : exit/User selected option

state "Job Application Submitted" as JobApplicationSubmitted
JobApplicationSubmitted : entry/Application submitted
JobApplicationSubmitted : do/Check application
JobApplicationSubmitted : exit/Application checked

[*] --> Homepage

Homepage --> Projects
Homepage --> CareerOpportunities

Projects --> "View Photos"
Projects --> "View Videos"

CareerOpportunities --> "View Updates"
CareerOpportunities --> "Apply for Job"

"View Updates" --> JobApplicationSubmitted
"Apply for Job" --> JobApplicationSubmitted

@enduml
