@startuml
title Video Suggestion System State Machine Diagram

[*] --> RequestReceived

state RequestReceived {

  state IdentifyUser

  state GatherVideos {
    [*] --> AddDetails
  }

  state AddDetails
  state SendSuggestions
}

RequestReceived --> IdentifyUser : process request
IdentifyUser --> GatherVideos : identify user
GatherVideos --> AddDetails : gather videos
AddDetails --> SendSuggestions : add details
SendSuggestions --> [*] : send suggestions

@enduml
