@startuml
title Video Suggestion System

state "Idle" as Idle
state "Receiving Request" as ReceivingRequest
state "Identifying User" as IdentifyingUser
state "Gathering Videos" as GatheringVideos
state "Adding Details" as AddingDetails
state "Sending Suggestions" as SendingSuggestions
state "User Profile" as UserProfile
state "User Preferences" as UserPreferences
state "Trending Videos" as TrendingVideos
state "Similar Videos" as SimilarVideos
state "Promoted Videos" as PromotedVideos

Idle --> ReceivingRequest : Video Suggestion Request

ReceivingRequest --> IdentifyingUser : Identify User

IdentifyingUser --> GatheringVideos : Gather Videos
GatheringVideos --> UserProfile : User Profile
GatheringVideos --> UserPreferences : User Preferences
GatheringVideos --> TrendingVideos : Trending Videos
GatheringVideos --> SimilarVideos : Similar Videos
GatheringVideos --> PromotedVideos : Promoted Videos

GatheringVideos --> AddingDetails : Add Details

AddingDetails --> SendingSuggestions : Send Suggestions

[*] --> Idle
Idle --> ReceivingRequest

@enduml
