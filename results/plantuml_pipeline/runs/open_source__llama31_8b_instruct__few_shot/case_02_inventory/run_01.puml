@startuml
title Inventory State Machine

[*] --> Idle

state Idle
state Adding
state Updating
state Removing
state Expired
state Ordering
state Invoicing
state Searching
state Billing
state Cancelled
state Replaced
state Summary

Idle --> Adding : addNewGoods
Adding --> Idle : saveGoods

Idle --> Updating : updatePrice
Updating --> Idle : savePrice

Idle --> Removing : removeGoods
Removing --> Idle : removeGoods

Idle --> Ordering : placeOrder
Ordering --> Invoicing : generateInvoice
Invoicing --> Idle : saveInvoice

Idle --> Searching : searchItems
Searching --> Idle : selectItems

Idle --> Expired : identifyExpiredGoods
Expired --> Idle : notifyUser

Idle --> Billing : generateReceipt
Billing --> Cancelled : cancelReceipt
Billing --> Replaced : replaceItem
Billing --> Summary : saveTransaction

Idle --> Summary : viewSummary

@enduml
