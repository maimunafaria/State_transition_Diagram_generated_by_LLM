@startuml
title ATM State Machine Diagram

[*] --> SelectAmount

state SelectAmount
SelectAmount : entry / Display list of withdrawal options
SelectAmount : do / User selects an amount
SelectAmount : exit / Amount selected or custom value entered

SelectAmount --> VerifyTransaction : [Transaction verified]

state VerifyTransaction
VerifyTransaction : entry / Verify transaction
VerifyTransaction : do / Transaction verified or rejected
VerifyTransaction : exit / Transaction accepted or rejected

VerifyTransaction --> SelectAmount : [Transaction rejected]
VerifyTransaction --> DispenseCash : [Transaction accepted]

state DispenseCash
DispenseCash : entry / Dispense cash
DispenseCash : do / Cash dispensed
DispenseCash : exit / Transaction complete

DispenseCash --> [*]

@enduml
