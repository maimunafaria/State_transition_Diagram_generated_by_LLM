@startuml
title UML State Machine Diagram - Healthcare Portal

[*] --> Registration

state "Registration" as Registration
state "Failed Registration" as FailedRegistration
state "Signed In" as SignedIn
state "Access Denied" as AccessDenied
state "View Facilities" as ViewFacilities
state "Read News" as ReadNews
state "Check Symptoms" as CheckSymptoms
state "Fitness Checking" as FitnessChecking
state "View Result" as ViewResult
state "Payment Process" as PaymentProcess
state "Select Payment Method" as SelectPaymentMethod
state "Cash Payment Details" as CashPaymentDetails
state "Insurance Payment Process" as InsurancePaymentProcess
state "User Feedback" as UserFeedback
state "Logged Out" as LoggedOut

Registration --> FailedRegistration : registration fails
Registration --> SignedIn : registration successful

SignedIn --> ViewFacilities : access granted
ViewFacilities --> ReadNews : access granted
ReadNews --> CheckSymptoms : access granted
CheckSymptoms --> FitnessChecking : access granted
FitnessChecking --> ViewResult : access granted
ViewResult --> PaymentProcess : access granted
PaymentProcess --> SelectPaymentMethod : payment method selection
SelectPaymentMethod --> CashPaymentDetails : cash payment selected
CashPaymentDetails --> PaymentProcess : payment process
PaymentProcess --> InsurancePaymentProcess : insurance payment selected
InsurancePaymentProcess --> PaymentProcess : payment process
PaymentProcess --> UserFeedback : payment completed
UserFeedback --> LoggedOut : user logged out

AccessDenied --> [*]
FailedRegistration --> AccessDenied
LoggedOut --> [*]

@enduml
