@startuml
title UML State Machine Diagram

[*] --> NavigationBar

state HomePage {
  [*] --> Projects
  [*] --> CareerOpportunities
}

state Projects {
  Projects --> ViewPhotos
  Projects --> ViewVideos
  ViewPhotos --> Projects
  ViewVideos --> Projects
}

state CareerOpportunities {
  CareerOpportunities --> ViewUpdates
  CareerOpportunities --> ApplicationForm
  ViewUpdates --> CareerOpportunitiesReview
  ApplicationForm --> CareerOpportunitiesReview
  CareerOpopportunitiesReview --> [*]
}

@enduml
