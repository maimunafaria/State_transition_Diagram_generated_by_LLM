@startuml
title UML State Machine Diagram for Website Navigation

[*] --> HomePage

state "Home" as Home {
  [*] --> NavigationBar
}

state "ProjectView" as ProjectView {
  Home --> NavigationBar
  NavigationBar --> Projects : selectProjects
  Projects --> PhotosOrVideos : choosePhotosOrVideos
  PhotosOrVideos --> Photos : viewPhotos
  Photos --> [*]
  PhotosOrVideos --> Videos : viewVideos
  Videos --> [*]
}

state "CareerOpportunities" as CareerOpportunities {
  Home --> NavigationBar
  NavigationBar --> Careers : selectCareers
  Careers --> UpdatesOrForm : chooseUpdatesOrForm
  UpdatesOrForm --> Updates : viewUpdates
  Updates --> [*]
  UpdatesOrForm --> Form : openApplicationForm
  Form --> [*]
}

state "JobApplications" as JobApplications {
  CareerOpportunities --> SubmitApp : submitApplication
  SubmitApp --> [*] : checkSubmittedJobs
}
@enduml
