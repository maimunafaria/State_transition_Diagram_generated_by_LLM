@startuml
title UML State Machine Diagram

[*] --> Navigation

state Navigation {
  state Home
  state Projects
  state CareerOpportunities
}

Navigation --> Home
Home --> Projects : selectProjects
Projects --> Home : selectHome
Home --> CareerOpportunities : selectCareerOpportunities
CareerOpportunities --> Home : selectHome

state ProjectDetails {
  state Photos
  state Videos
}

Projects --> ProjectDetails : chooseView
ProjectDetails --> Photos : viewPhotos
ProjectDetails --> Videos : viewVideos
Photos --> ProjectDetails : returnToProjects
Videos --> ProjectDetails : returnToProjects

state CareerDetails {
  state Updates
  state ApplicationForm
}

CareerOpportunities --> CareerDetails : chooseView
CareerDetails --> Updates : viewUpdates
CareerDetails --> ApplicationForm : viewApplicationForm
Updates --> CareerDetails : returnToCareerOpportunities
ApplicationForm --> CareerDetails : returnToCareerOpportunities

state ApplicationReview {
  state Submitted
  state Reviewing
}

ApplicationForm --> ApplicationReview : submitForm
ApplicationReview --> ApplicationForm : reviewForm
ApplicationReview --> [*] : checkForm
@enduml
