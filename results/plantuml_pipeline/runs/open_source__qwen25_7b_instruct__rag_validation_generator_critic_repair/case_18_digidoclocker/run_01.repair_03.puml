@startuml
title UML State Machine Diagram (Digidoclocker)

[*] --> Registration

state Registration {
  [*] --> CitizenLogin
  CitizenLogin : entry / Get Citizen Login Details
  CitizenLogin : do / Validate Login Details
  CitizenLogin : exit / Login Successful or Failed
}

Registration --> [*] : [Login Failed]

Registration --> CitizenDashboard : [Login Successful]

state CitizenDashboard {
  [*] --> DocumentUpload
  DocumentUpload : entry / Upload Documents
  DocumentUpload : do / Validate Upload
  DocumentUpload : exit / Upload Successful or Failed
}

DocumentUpload --> CitizenDashboard : [Upload Successful]

CitizenDashboard --> ProfileView : [View Profile]
CitizenDashboard --> CertificateApply : [Apply for Certificate]
CertificateApply --> [*] : [Certificate Applied]

state CertificateApply {
  Registration --> CertificateApply : [Registration Successful]
  [*] --> CertificateRequest
  CertificateRequest : entry / Request for Certificate
  CertificateRequest : do / Validate Request
  CertificateRequest : exit / Request Successful or Failed
}

CertificateRequest --> CertificateApply : [Request Successful]

state ProfileView {
  [*] --> [*] : [Exit Profile View]
}

state CertificateApply {
  CertificateApply --> CertificateRequest : [Request More Certificates]
}

state CitizenLogin {
  Registration --> CitizenLogin : [Registration Successful]
}

state CitizenDashboard {
  Registration --> CitizenDashboard : [Registration Successful]
}

[*] --> Logout : session ended

@enduml
