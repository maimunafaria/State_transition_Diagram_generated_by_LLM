@startuml
[*] --> Login

state Login {
  [*] --> Authenticated
  Authenticated : entry / verify credentials
  Authenticated : do / authenticate user
  Authenticated : exit / authenticated
}

Login --> AuthenticatedDecision <<choice>>

state "Valid Authentication" as ValidAuth
ValidAuth : entry / valid credentials
ValidAuth : do / display main area
ValidAuth : exit / main area

state "Invalid Authentication" as InvalidAuth
InvalidAuth : entry / invalid credentials
InvalidAuth : do / show error message
InvalidAuth : exit / return to login

AuthenticatedDecision --> ValidAuth
AuthenticatedDecision --> InvalidAuth

ValidAuth --> MainAreaChoice <<choice>>

state MainArea {
  [*] --> MarketConditions
  MarketConditions : entry / display market conditions
  MarketConditions : do / user selects market condition
  MarketConditions : exit / show market report
}

MainAreaChoice --> MarketConditions

MarketConditions --> ShowReport

ValidAuth --> PestControlHelp
PestControlHelp : entry / user selects pest control help
PestControlHelp : do / require photo
PestControlHelp : exit / show pest control techniques

ValidAuth --> SoilSuggestions
SoilSuggestions : entry / user provides soil information
SoilSuggestions : do / provide suggestions
SoilSuggestions : exit / end

ValidAuth --> WeatherInsights
WeatherInsights : entry / user provides location
WeatherInsights : do / offer weather insights
WeatherInsights : exit / end

ValidAuth --> LabourAvailability
LabourAvailability : entry / user provides location
LabourAvailability : do / display labour availability details
LabourAvailability : exit / end

ValidAuth --> [*] : continue using service

ValidAuth --> Logout
Logout : entry / user logs out
Logout : do / end session
Logout : exit / end

@enduml
