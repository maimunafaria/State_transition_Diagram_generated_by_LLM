@startuml
[*] --> Login

state Login
Login : entry / verify credentials
Login : do / validate credentials
Login : exit / login successful

state LoginDecision <<choice>>
Login --> LoginDecision

state "Valid Login" as ValidLogin
ValidLogin : entry / user logged in
ValidLogin : do / display main area
ValidLogin : exit / user can choose options

state "Invalid Login" as InvalidLogin
InvalidLogin : entry / credentials incorrect
InvalidLogin : do / display error message
InvalidLogin : exit / return to login

LoginDecision --> ValidLogin
LoginDecision --> InvalidLogin

ValidLogin --> MainArea

state MainArea
MainArea : entry / display main area
MainArea : do / user selects option
MainArea : exit / user can choose options

MainArea --> MarketConditions
MainArea --> PestControlHelp
MainArea --> SoilSuggestions
MainArea --> WeatherInsights
MainArea --> LabourAvailability
MainArea --> [*] : logout

state MarketConditions
MarketConditions : entry / display market conditions
MarketConditions : do / user can view conditions
MarketConditions : exit / user can choose options

MarketConditions --> MainArea

state PestControlHelp
PestControlHelp : entry / display pest control help
PestControlHelp : do / user provides photo
PestControlHelp : exit / display pest control techniques

PestControlHelp --> MainArea

state SoilSuggestions
SoilSuggestions : entry / user provides soil information
SoilSuggestions : do / display soil-related suggestions
SoilSuggestions : exit / user can choose options

SoilSuggestions --> MainArea

state WeatherInsights
WeatherInsights : entry / user provides location
WeatherInsights : do / display weather insights
WeatherInsights : exit / user can choose options

WeatherInsights --> MainArea

state LabourAvailability
LabourAvailability : entry / user provides location
LabourAvailability : do / display labour availability details
LabourAvailability : exit / user can choose options

LabourAvailability --> MainArea

@enduml
