@startuml
title UML State Chart Diagram

[*] --> Login

state Login
Login : entry / getInfo
Login : do / verifyData
Login : exit / verified

state LoginDecision <<choice>>
Login --> LoginDecision

state "Valid Login" as ValidLogin
ValidLogin : entry / contain Info
ValidLogin : do / allow Access to system
ValidLogin : exit / mainArea

state "Invalid Login" as InvalidLogin
InvalidLogin : entry / wrong Info
InvalidLogin : do / display Error message
InvalidLogin : exit / return To Start

LoginDecision --> ValidLogin
LoginDecision --> InvalidLogin

state MainArea
MainArea : entry / show Main Area
MainArea : do / allow user to choose options
MainArea : exit / continue using service

state MarketConditions
MarketConditions : entry / show Market Conditions
MarketConditions : do / allow user to view conditions
MarketConditions : exit / continue using service

state MarketReport
MarketReport : entry / show Market Report
MarketReport : do / allow user to view report
MarketReport : exit / continue using service

state PestControlHelp
PestControlHelp : entry / require photo
PestControlHelp : do / show Pest Control Techniques
PestControlHelp : exit / continue using service

state SoilSuggestions
SoilSuggestions : entry / receive soil info
SoilSuggestions : do / provide suggestions
SoilSuggestions : exit / continue using service

state WeatherInsights
WeatherInsights : entry / receive location
WeatherInsights : do / provide weather insights
WeatherInsights : exit / continue using service

state LabourAvailability
LabourAvailability : entry / receive location
LabourAvailability : do / provide labour availability details
LabourAvailability : exit / continue using service

MainArea --> MarketConditions
MainArea --> MarketReport
MainArea --> PestControlHelp
MainArea --> SoilSuggestions
MainArea --> WeatherInsights
MainArea --> LabourAvailability

MarketConditions --> [*]
MarketReport --> [*]
PestControlHelp --> [*]
SoilSuggestions --> [*]
WeatherInsights --> [*]
LabourAvailability --> [*]

state Logout
Logout : entry / end session
Logout : do / end session
Logout : exit / [*]

MainArea --> Logout

@enduml
