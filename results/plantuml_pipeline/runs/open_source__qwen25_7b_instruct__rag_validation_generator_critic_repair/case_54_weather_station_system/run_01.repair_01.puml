@startuml
[*] --> Idle

state Idle {
  ConfigMode : configCompleted
}

Running --> DataCollection : clockTriggered
DataCollection --> Running : activityComplete

Running --> SummaryPreparation : requestSummary
SummaryPreparation --> Running : activityComplete

Running --> StatusCheck : requestStatus
StatusCheck --> Running : activityComplete

Running --> ControlledMode : remoteControl
ControlledMode --> Shutdown : shutdownCommand
Shutdown --> [*]
@enduml
