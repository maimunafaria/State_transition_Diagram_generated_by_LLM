@startuml
[*] --> Running

state Running {
  Running --> Configuring : configuration required
  Configuring --> Running : configuration completed
  Running --> DataCollection : clock triggered
  DataCollection --> Running : activity completed
  Running --> SummaryPreparation : request received
  SummaryPreparation --> Running : summary prepared
  Running --> StatusChecking : request received
  StatusChecking --> Running : status checked
  Running --> ControlledMode : remote control received
  ControlledMode --> Running : mode changed
  Running --> Shutdown : shutdown command received
  Shutdown --> [*] : system shut down
}

state Configuring {
  Configuring --> Running : configuration completed
}

state DataCollection {
  DataCollection --> Running : activity completed
}

state SummaryPreparation {
  SummaryPreparation --> Running : summary prepared
}

state StatusChecking {
  StatusChecking --> Running : status checked
}

state ControlledMode {
  ControlledMode --> Running : mode changed
}

@enduml
