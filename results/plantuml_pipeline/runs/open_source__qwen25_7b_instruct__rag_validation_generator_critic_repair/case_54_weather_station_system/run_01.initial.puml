@startuml
[*] --> Running

state Running {
  [*] --> Configuring : configurationRequired
  Configuring --> Running : configurationCompleted
  [*] --> DataCollection : clockTriggered
  DataCollection --> Running : activityCompleted
  [*] --> SummaryPreparation : summaryRequest
  SummaryPreparation --> Running : activityCompleted
  [*] --> StatusChecking : statusRequest
  StatusChecking --> Running : activityCompleted
  [*] --> ControlledMode : remoteControl
  ControlledMode --> Running : modeExited
  [*] --> Shutdown : shutdownCommand
  Shutdown --> [*]
}

@enduml
