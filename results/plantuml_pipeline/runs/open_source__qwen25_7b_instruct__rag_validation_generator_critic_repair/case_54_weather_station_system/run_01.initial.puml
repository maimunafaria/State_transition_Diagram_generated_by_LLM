@startuml
[*] --> Running

state Running {
  [*] --> Configuring : configuration required
  Configuring --> Running : configuration completed
  [*] --> DataCollection : clock triggered
  DataCollection --> Running : activity completed
  [*] --> SummaryPreparation : request received
  SummaryPreparation --> Running : summary prepared
  [*] --> StatusChecking : request received
  StatusChecking --> Running : status checked
  [*] --> ControlledMode : remote control received
  ControlledMode --> Running : mode changed
  [*] --> Shutdown : shutdown command received
  Shutdown --> [*] : system shut down
}

@enduml
