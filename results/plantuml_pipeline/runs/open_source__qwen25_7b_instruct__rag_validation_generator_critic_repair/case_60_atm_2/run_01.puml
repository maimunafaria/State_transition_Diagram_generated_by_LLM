@startuml
title ATM State Machine

[*] --> SelectAmount

state SelectAmount {
  state "SelectAmount <<initial>>" as SelectAmountInit
  SelectAmountInit --> [*] : amount
}

state VerifyTransaction

VerifyTransaction --> VerifyTransaction : verifyTransaction

state ReleaseCard

ReleaseCard --> ReleaseCard : releaseCard / <<final>>

@enduml
