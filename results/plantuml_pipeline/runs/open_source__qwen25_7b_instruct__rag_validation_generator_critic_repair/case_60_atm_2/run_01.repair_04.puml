@startuml
title ATM State Machine

[*] --> SelectAmount

state "SelectAmount" as SelectAmount {
  state "CustomValueEntry"
}

state VerifyTransaction

SelectAmount --> CustomValueEntry : enterCustomValue
SelectAmount --> VerifyTransaction : verifyTransaction

VerifyTransaction --> SelectAmount : reEnterAmount
VerifyTransaction --> [*] : transactionRejected

@enduml
