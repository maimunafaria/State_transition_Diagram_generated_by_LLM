@startuml
title ATM State Machine

[*] --> InitialSelect : amount

state SelectAmount {
  state "SelectAmount <<initial>>" as InitialSelect
  InitialSelect --> [*] : amount
}

state VerifyTransaction

state ReleaseCard

SelectAmount --> VerifyTransaction : verifyTransaction
VerifyTransaction --> ReleaseCard : releaseCard / <<final>>

@enduml
