@startuml
title ATM State Machine

[*] --> SelectAmount

state "SelectAmount <<initial>>" as SelectAmount
SelectAmount --> [*] : amount

state VerifyTransaction
VerifyTransaction --> VerifyTransaction : verifyTransaction

state ReenterAmount
ReenterAmount --> VerifyTransaction : reenterAmount

state ReleaseCard <<final>>
ReleaseCard --> ReleaseCard : releaseCard

@enduml
