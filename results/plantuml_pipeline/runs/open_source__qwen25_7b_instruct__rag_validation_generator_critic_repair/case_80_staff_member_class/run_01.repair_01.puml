@startuml
title UML State Machine Diagram for Staff Member Class

[*] --> Assigned

state Assigned {
  Working --> SwitchingAssignments : switchAssignment
}

Assigned --> Unassigned : endWorkPeriod
Unassigned --> Archived : markUnemployedAfterSomeTime

Working --> Unassigned : endSwitchingAssignments
[*] --> [*]
@enduml
