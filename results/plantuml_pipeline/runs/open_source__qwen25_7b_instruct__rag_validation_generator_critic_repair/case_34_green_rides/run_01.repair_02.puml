@startuml
[*] --> LoggedIn

state LoggedIn {
  [*] --> JourneyDetails : view journey details
  JourneyDetails --> DrivingMode : activate driving mode
  JourneyDetails --> OtherOptions : choose other options
  JourneyDetails --> EatPlace : select place to eat
  EatPlace --> MenuView : view menu
  MenuView --> Order : place order if hungry
  Order --> JourneyDetails : return to journey details
}

state EatPlace {
  JourneyDetails --> EatPlace : select place to eat
  MenuView --> Order : place order if hungry
  Order --> EatPlace : return to select place to eat
}

state DrivingMode {
  JourneyDetails --> DrivingMode : return to journey details
}

state OtherOptions {
  JourneyDetails --> OtherOptions : return to journey details
}

state JourneyDetails {
  [*] --> AccidentNotification : inform relevant authorities
  AccidentNotification --> Notifications : send notifications
  Notifications --> JourneyDetails : return to journey details
  AccidentNotification --> Feedback : provide feedback
  Feedback --> JourneyDetails : return to journey details
}

state AccidentNotification {
  AccidentNotification --> Notifications : send notifications
  Notifications --> Feedback : provide feedback
}

state Notifications {
  Notifications --> JourneyDetails : return to journey details
}

state Feedback {
  Feedback --> JourneyDetails : return to journey details
}

state LoggedOut {
  [*] --> [*] : end session
}

@enduml
