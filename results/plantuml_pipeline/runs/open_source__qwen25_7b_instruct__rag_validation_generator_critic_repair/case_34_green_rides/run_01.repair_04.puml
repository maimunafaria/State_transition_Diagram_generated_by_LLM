@startuml
[*] --> LoggedIn

state LoggedIn {
  [*] --> JourneyDetails : view journey details
  JourneyDetails --> DrivingMode : activate driving mode or choose options
  JourneyDetails --> EatPlaceSelection : select place to eat, view menu, and order
}

state DrivingMode {
  DrivingMode --> AccidentNotification : inform relevant authorities in case of an accident
  AccidentNotification --> NotificationSending : send notifications during driving or in case of an accident
  NotificationSending --> FeedbackProviding : provide feedback upon journey completion
}

state EatPlaceSelection {
  EatPlaceSelection --> AccidentNotification : inform relevant authorities in case of an accident
  AccidentNotification --> NotificationSending : send notifications during driving or in case of an accident
  NotificationSending --> FeedbackProviding : provide feedback upon journey completion
}

state AccidentNotification {
  AccidentNotification --> NotificationSending : send notifications during driving or in case of an accident
  NotificationSending --> FeedbackProviding : provide feedback upon journey completion
}

state NotificationSending {
  NotificationSending --> FeedbackProviding : provide feedback upon journey completion
}

state FeedbackProviding {
  FeedbackProviding --> LoggedIn : view journey details
}

[*] --> LoggedOut

@enduml
