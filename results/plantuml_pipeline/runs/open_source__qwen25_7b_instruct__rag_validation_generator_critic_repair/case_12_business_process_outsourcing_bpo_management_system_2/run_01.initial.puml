@startuml
title UML State Machine Diagram - BPO Management System Search

[*] --> SearchCriteria

state "SearchCriteria" as SearchCriteria {
    [*] --> FilterCategory : [Select filter category]
    [*] --> PriceRange : [Select price range]
}

FilterCategory --> MatchingUsers : [Search based on category]
PriceRange --> MatchingUsers : [Search based on price range]

state "MatchingUsers" as MatchingUsers
MatchingUsers : entry / Display matching users
MatchingUsers : do / Based on chosen criteria
MatchingUsers : exit / End search

@enduml
