@startuml
title UML State Machine Diagram - BPO Management System Search

[*] --> SearchCriteria

state "SearchCriteria" as SearchCriteria {
    SearchCriteria --> FilterCategory
    FilterCategory --> PriceRange
    PriceRange --> MatchingUsers
}

state "FilterCategory" as FilterCategory
FilterCategory : entry / Select filter category
FilterCategory : do / Filter by category
FilterCategory : exit / After selection

state "PriceRange" as PriceRange
PriceRange : entry / Select price range
PriceRange : do / Filter by price range
PriceRange : exit / After selection

state "MatchingUsers" as MatchingUsers
MatchingUsers : entry / Display matching users
MatchingUsers : do / Show results
MatchingUsers : exit / After display

MatchingUsers --> [*]

@enduml
