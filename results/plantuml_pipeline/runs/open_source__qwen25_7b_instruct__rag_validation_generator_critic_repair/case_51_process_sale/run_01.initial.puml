@startuml
title State diagram for Process Sale

[*] --> WaitingForNewSale

state "Waiting for New Sale" as WaitingForNewSale
state "Recording Items" as RecordingItems
state "Waiting for Payment" as WaitingForPayment

WaitingForNewSale --> RecordingItems : enter item
RecordingItems --> RecordingItems : enter item
RecordingItems --> WaitingForPayment : end of sale
WaitingForPayment --> WaitingForNewSale : payment confirmed

@enduml
