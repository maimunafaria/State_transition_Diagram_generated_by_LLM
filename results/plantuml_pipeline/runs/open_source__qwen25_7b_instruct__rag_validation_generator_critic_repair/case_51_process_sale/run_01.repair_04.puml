@startuml
title State diagram for Process Sale

[*] --> WaitingForNewSale

state "Waiting for New Sale" as WaitingForNewSale
state "Recording Items" as RecordingItems
state "Waiting for Payment" as WaitingForPayment

WaitingForNewSale --> RecordingItems : enter item
RecordingItems --> RecordingItems : enter item
RecordingItems --> WaitingForPayment : end of sale
WaitingForPayment --> WaitingForNewSale : payment confirmed
WaitingForNewSale --> [*] : end

state "Unreachable State 1" as UnreachableState1
state "Unreachable State 2" as UnreachableState2
state "Unreachable State 3" as UnreachableState3

WaitingForNewSale --> UnreachableState1 : enter item (cash payment)
UnreachableState1 --> WaitingForPayment : verify payment

UnreachableState1 --> UnreachableState2 : verify payment (card or check)
UnreachableState2 --> WaitingForPayment : verify payment

UnreachableState2 --> UnreachableState3 : verify payment
UnreachableState3 --> WaitingForNewSale : payment confirmed

@enduml
