@startuml
title State diagram of the system operations of "Process Sale"

[*] --> WaitingCustomer

state "Waiting for customer" as WaitingCustomer
state "Record items" as RecordItems
state "Waiting for payment" as WaitingPayment
state "Payment verified" as PaymentVerified
state "Payment completed" as PaymentComplete

WaitingCustomer --> RecordItems : enter item
RecordItems --> RecordItems : enter item
RecordItems --> WaitingPayment : end of sale
WaitingPayment --> PaymentVerified : payment by card or check
PaymentVerified --> PaymentComplete : payment approved
PaymentComplete --> [*] : enter next customer

state "Unreachable state" as UnreachableState

WaitingCustomer --> UnreachableState : process sale with cash
UnreachableState --> RecordItems : enter item
UnreachableState --> WaitingPayment : end of sale

@enduml
