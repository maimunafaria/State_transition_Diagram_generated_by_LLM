@startuml
[*] --> Register

state Register {
  [*] --> Login : registration successful
  Login --> [*] : registration unsuccessful
}

state Login {
  Login --> CheckLocation : user checks weather
  CheckLocation --> [*] : invalid location
}

state CheckLocation {
  CheckLocation --> CheckWeather : user selects weather information
  CheckWeather --> [*] : user views additional details
}

state CheckWeather {
  CheckWeather --> ShowWeather : user checks weather for current or another location
  ShowWeather --> ViewDetails : user views additional details
  ViewDetails --> [*] : user logs out
}

state [*] {
  Logout --> [*] : session ended
}
@enduml
