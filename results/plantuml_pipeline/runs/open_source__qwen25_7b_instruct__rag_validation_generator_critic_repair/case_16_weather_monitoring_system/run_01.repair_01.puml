@startuml
[*] --> Register

state Register {
  [*] --> Login : registration successful
  Login --> [*] : registration unsuccessful
}

state Login {
  [*] --> CheckLocation : login successful
  CheckLocation --> [*] : invalid location
}

state CheckLocation {
  [*] --> CheckInfo : location valid
  CheckInfo --> [*] : location invalid
}

state CheckInfo {
  [*] --> ChooseInfo : location valid
  ChooseInfo --> [*] : invalid selection
}

state ChooseInfo {
  [*] --> ShowInfo : valid selection
  ShowInfo --> [*] : logout
}

state ShowInfo {
  ShowInfo --> ViewDetails : view additional details
}

state ViewDetails {
  ViewDetails --> [*] : additional details viewed
  ShowInfo --> [*] : session ended
}

@enduml
