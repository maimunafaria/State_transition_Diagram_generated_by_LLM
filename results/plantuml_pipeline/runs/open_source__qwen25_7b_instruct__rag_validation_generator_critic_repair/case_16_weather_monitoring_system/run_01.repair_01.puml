@startuml
[*] --> Register

state Register {
  [*] --> Login : registration successful
  Login --> [*] : registration unsuccessful
}

state Login {
  Login --> CheckLocation : user checks weather
  CheckLocation --> [*] : invalid location
}

state CheckLocation {
  CheckLocation --> CheckWeather : user chooses weather details
  CheckWeather --> [*] : user views additional details
}

state CheckWeather {
  CheckWeather --> DisplayWeather : user checks weather
  DisplayWeather --> [*] : user logs out
}

state DisplayWeather {
  DisplayWeather --> ViewDetails : user views additional details
}

state ViewDetails {
  ViewDetails --> [*] : user logs out
}

[*] --> Logout : session ended

@enduml
