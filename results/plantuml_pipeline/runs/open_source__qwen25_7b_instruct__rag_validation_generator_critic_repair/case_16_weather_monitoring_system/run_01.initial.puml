@startuml
[*] --> Register

state Register {
  [*] --> Login : registration successful
  Login --> [*] : registration unsuccessful
}

Login --> Dashboard
Dashboard --> CheckWeather : check weather for location
CheckWeather --> [*] : invalid location entered
CheckWeather --> SelectInfo : valid location entered
SelectInfo --> ShowInfo : select info to check

state ShowInfo {
  [*] --> ShowInfo : show selected info
}

ShowInfo --> ViewDetails : view additional details
ViewDetails --> Logout : logout user

Logout --> [*]
@enduml
