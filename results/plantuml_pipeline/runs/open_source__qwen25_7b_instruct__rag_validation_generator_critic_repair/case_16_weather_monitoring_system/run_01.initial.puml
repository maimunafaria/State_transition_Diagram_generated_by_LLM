@startuml
[*] --> Register

state Register {
  [*] --> Login : registration successful
  Login --> [*] : registration unsuccessful
}

state Login {
  [*] --> CheckLocation : user checks weather
  CheckLocation --> [*] : invalid location
}

state CheckLocation {
  [*] --> CheckWeather : user chooses weather details
  CheckWeather --> [*] : user views additional details
}

state CheckWeather {
  [*] --> DisplayWeather : user checks weather
  DisplayWeather --> [*] : user logs out
}

state DisplayWeather {
  [*] --> ViewDetails : user views additional details
}

state ViewDetails {
  [*] --> [*] : user logs out
}

@enduml
