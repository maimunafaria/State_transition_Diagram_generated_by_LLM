@startuml
[*] --> Register

state Register {
  [*] --> Login : registration successful
  Login --> [*] : registration unsuccessful
}

state Login {
  [*] --> CheckLocation : user checks weather
  CheckLocation --> [*] : invalid location
}

state CheckLocation {
  [*] --> CheckWeather : user selects weather information
  CheckWeather --> [*] : user views additional details
}

state CheckWeather {
  [*] --> ShowWeather : user checks weather for current or another location
  ShowWeather --> [*] : user views additional details
}

state ShowWeather {
  [*] --> ViewDetails : user views additional weather details
  ViewDetails --> [*] : user logs out
}

state ViewDetails {
  [*] --> [*] : user views details
}

state [*] {
  [*] --> [*] : user logs out
}
@enduml
