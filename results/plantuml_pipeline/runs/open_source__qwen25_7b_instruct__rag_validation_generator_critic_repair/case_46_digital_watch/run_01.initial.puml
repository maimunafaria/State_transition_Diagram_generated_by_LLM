@startuml
title Digital Watch State Diagram

[*] --> Idle

state "Idle" as Idle
Idle --> SettingTime : Time Button Pressed
Idle --> SettingAlarm : Alarm Button Pressed

state "SettingTime" as SettingTime
SettingTime --> IncreasingHour : Increase Hour Button Pressed
SettingTime --> IncreasingMinute : Increase Minute Button Pressed
IncreasingHour --> Idle : Time Button Pressed
IncreasingMinute --> Idle : Time Button Pressed

state "SettingAlarm" as SettingAlarm
SettingAlarm --> IncreasingAlarmHour : Increase Alarm Hour Button Pressed
SettingAlarm --> IncreasingAlarmMinute : Increase Alarm Minute Button Pressed
IncreasingAlarmHour --> Idle : Alarm Button Pressed
IncreasingAlarmMinute --> Idle : Alarm Button Pressed

state "Alarm Triggered" as AlarmTriggered
AlarmTriggered : do/Alarm Ringing
AlarmTriggered --> Idle : Stop Alarm Button Pressed

state "Alarm Stopped" as AlarmStopped
AlarmStopped : do/Alarm Stopped
AlarmStopped --> Idle : Any Button Pressed

state "Light On" as LightOn
LightOn : do/Light On
LightOn --> Idle : Any Button Pressed

state "Light Off" as LightOff
LightOff : do/Light Off
LightOff --> Idle : Any Button Pressed

Idle --> AlarmTriggered : Current Time Matches Alarm Time
AlarmTriggered --> AlarmStopped : Stop Alarm Button Pressed
AlarmStopped --> LightOn : Light Button Pressed
LightOn --> LightOff : Light Button Released

@enduml
