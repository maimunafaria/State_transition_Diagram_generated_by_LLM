@startuml
[*] --> Idle

state "Idle" as Idle
Idle --> SettingTime : Time Button Pressed
SettingTime --> ChangingHour : Hour Button Pressed
ChangingHour --> Idle : Hour Set
ChangingHour --> ChangingMinute : Minute Button Pressed
ChangingMinute --> Idle : Minute Set
ChangingMinute --> AlarmSetting : Alarm Button Pressed
AlarmSetting --> Idle : Alarm Set

state "Alarm Setting" as AlarmSetting
AlarmSetting --> Idle : Alarm Off
Idle --> AlarmOnOff : Alarm Toggle Button Pressed
AlarmOnOff --> Idle : Alarm On/Off

state "Alarm Trigger" as AlarmTrigger
AlarmTrigger : do/Ring Alarm
AlarmTrigger --> Idle : Alarm Stopped

state "Light Feature" as LightFeature
LightFeature : do/Light On
LightFeature --> Idle : Light Off

Idle --> [*] : All Button Pressed or System Reset

@enduml
