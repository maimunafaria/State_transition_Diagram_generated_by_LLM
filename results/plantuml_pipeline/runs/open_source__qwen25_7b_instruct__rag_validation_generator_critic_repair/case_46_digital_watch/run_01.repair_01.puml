@startuml
title Digital Watch State Diagram

[*] --> Idle

state "Idle" as Idle
state "Adjusting Time" as AdjustingTime
state "Alarm Settings" as AlarmSettings
state "Alarm Triggered" as AlarmTriggered
state "Alarm Stopped" as AlarmStopped
state "Light On" as LightOn

Idle --> AdjustingTime : Press Button
Idle --> AlarmSettings : Press Button
AdjustingTime --> Idle : Press Button
AlarmSettings --> Idle : Press Button
AdjustingTime --> AdjustingTime : Increase Value
AdjustingTime --> AlarmSettings : Press Button
AlarmSettings --> AlarmSettings : Press Button
AlarmSettings --> AlarmTriggered : Set Alarm Time Matches Current Time
AlarmTriggered --> AlarmStopped : Press Button
AlarmStopped --> Idle : Press Button
LightOn --> Idle : Press Button
AlarmStopped --> [*] : Press Button

@enduml
