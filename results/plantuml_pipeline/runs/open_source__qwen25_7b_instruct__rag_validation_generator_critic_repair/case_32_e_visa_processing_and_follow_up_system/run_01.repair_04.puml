@startuml
[*] --> LoggedIn

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
  Dashboard --> ViewStatus : view status
  ViewStatus --> ViewStatus : check status
  ViewStatus --> CancelApp : cancel application
  ViewStatus --> ModifyDetails : modify details
  ViewStatus --> ViewDetails : view details
  ViewDetails --> ViewPurposeOfApplication : view purpose of application
  ViewDetails --> ViewStatus : view status
  ViewDetails --> Feedback : give feedback
  ModifyDetails --> ViewDetails : view details
  ModifyDetails --> ViewStatus : view status
  CancelApp --> ViewStatus : view status
  CancelApp --> ViewDetails : view details
  CancelApp --> Feedback : give feedback
  ViewStatus --> ViewDetails : view details
  ViewStatus --> Feedback : give feedback
  Feedback --> ViewDetails : view details
  Feedback --> ViewStatus : view status
  ViewDetails --> ViewStatus : view status
}

LoggedIn --> [*] : logout
@enduml
