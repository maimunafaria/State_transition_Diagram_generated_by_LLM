@startuml
[*] --> LoggedIn

state LoggedIn {
  Dashboard --> ApplyForVisa : apply for visa
  ApplyForVisa --> PaymentConfirmed : payment confirmed
  PaymentConfirmed --> ApplicationAccepted : application accepted
  ApplicationAccepted --> ViewStatus : view status
  ViewStatus --> CheckStatus : check status
  CheckStatus --> CancelApplication : cancel application
  CancelApplication --> ModifyDetails : modify details
  ModifyDetails --> ViewDetails : view details
  ViewDetails --> ViewPurpose : view purpose of application
  ViewPurpose --> UpdateStatus : update status
  UpdateStatus --> GiveFeedback : give feedback
  GiveFeedback --> Logout : logout
}

LoggedIn --> [*] : logout

@enduml
