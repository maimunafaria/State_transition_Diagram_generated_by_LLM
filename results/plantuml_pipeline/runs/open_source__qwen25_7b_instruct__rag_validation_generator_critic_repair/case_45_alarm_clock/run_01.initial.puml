@startuml
[*] --> Off

state Off {
  [*] --> Idle
  Idle --> [*]
}

state Idle {
  Idle --> SetAlarm : set alarm
  SetAlarm --> AlarmActive : alarm time set
}

state AlarmActive {
  AlarmActive --> StopAlarm : stop alarm
  StopAlarm --> Idle : alarm stopped
}

state Idle {
  Idle --> AlarmActive : current time matches alarm time
}

@enduml
