@startuml
[*] --> Off

state Off {
  Off --> Idle
  Idle --> AlarmActive : set alarm time
}

state Idle {
  Idle --> AlarmActive : current time matches alarm time
}

state AlarmActive {
  AlarmActive --> Off : turn off alarm
  AlarmActive --> Idle : stop ringing
}

Off --> Idle
Idle --> Off : turn off system

AlarmActive --> [*] : stop ringing

@enduml
