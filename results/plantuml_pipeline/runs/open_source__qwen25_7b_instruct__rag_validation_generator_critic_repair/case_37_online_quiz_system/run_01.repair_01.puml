@startuml
title UML State Machine Diagram

state "Register or Login" as RegisterLogin
state "Continue as Teacher" as ContinueTeacher
state "Continue as Student" as ContinueStudent
state "Create Quiz" as CreateQuiz
state "Edit Quiz" as EditQuiz
state "Save Quiz" as SaveQuiz
state "Post Quiz" as PostQuiz
state "View Quiz Results" as ViewResults
state "Select Quiz" as SelectQuiz
state "Answer Quiz" as AnswerQuiz
state "Submit Quiz" as SubmitQuiz
state "View Quiz Result" as ViewResult

[*] --> RegisterLogin

RegisterLogin --> ContinueTeacher : [Teacher]
RegisterLogin --> ContinueStudent : [Student]

ContinueTeacher --> CreateQuiz
ContinueTeacher --> EditQuiz
ContinueTeacher --> SaveQuiz
ContinueTeacher --> PostQuiz
ContinueTeacher --> ViewResults

ContinueStudent --> SelectQuiz
ContinueStudent --> AnswerQuiz
ContinueStudent --> SubmitQuiz
ContinueStudent --> ViewResult

SelectQuiz --> AnswerQuiz

AnswerQuiz --> SubmitQuiz

SubmitQuiz --> ViewResult

ViewResults --> [*]

@enduml
