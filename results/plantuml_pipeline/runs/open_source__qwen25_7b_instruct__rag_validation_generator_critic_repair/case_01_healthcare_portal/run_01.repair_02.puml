@startuml
title UML State Machine Diagram for Healthcare Portal

[*] --> Register

state Register {
  [*] --> Registered : [registration successful]
  Registered --> Login : [user signed in]
  Registered --> Login : [registration failed]
}

state Login {
  [*] --> Login : [user signed in]
  Login --> Dashboard : [continue using system]
  Login --> Logout : [finish session]
}

state Dashboard {
  [*] --> News : [read news and expert content]
  News --> Dashboard : [continue using system]
  News --> Logout : [finish session]
  [*] --> Facilities : [access available facilities]
  Facilities --> Dashboard : [continue using system]
  Facilities --> Logout : [finish session]
  [*] --> SymptomCheck : [check symptoms or use fitness checking options]
  SymptomCheck --> Dashboard : [continue using system]
  SymptomCheck --> Logout : [finish session]
  [*] --> Insurance : [process and validate insurance for finance-related services]
  Insurance --> Payment : [complete payment process]
  Insurance --> Dashboard : [continue using system]
  Insurance --> Logout : [finish session]
}

state Payment {
  [*] --> Cash : [choose cash payment method]
  Cash --> PaymentComplete : [complete payment]
  Cash --> Dashboard : [continue using system]
  Cash --> Logout : [finish session]
  [*] --> Insurance : [choose insurance payment method]
  Insurance --> PaymentComplete : [complete payment]
  Insurance --> Dashboard : [continue using system]
  Insurance --> Logout : [finish session]
}

state PaymentComplete {
  [*] --> Feedback : [collect user feedback]
  Feedback --> Logout : [finish session]
}

state Logout {
  [*] --> [*] : [logout successfully]
}

@enduml
