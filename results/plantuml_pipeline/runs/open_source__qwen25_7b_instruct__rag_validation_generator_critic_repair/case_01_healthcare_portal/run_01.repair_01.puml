@startuml
title UML State Machine Diagram for Healthcare Portal

[*] --> Register

state Register {
  Register --> Login : [registration successful]
  Login : [registration failed]
}

state Login {
  Login --> Dashboard : [login successful]
  Dashboard : [logout]
}

state Dashboard {
  Dashboard --> News : [read news]
  News --> Dashboard : [back to dashboard]
  Dashboard --> Facilities : [access facilities]
  Facilities --> Dashboard : [back to dashboard]
  Dashboard --> SymptomCheck : [check symptoms]
  SymptomCheck --> Dashboard : [back to dashboard]
  Dashboard --> FitnessCheck : [use fitness checking options]
  FitnessCheck --> Dashboard : [back to dashboard]
  Dashboard --> Payment : [select payment method]
  Payment --> FinishSession : [finish session]
}

state Payment {
  Payment --> InsurancePayment : [insurance payment]
  InsurancePayment --> DoctorConsultation : [doctor consultation]
  DoctorConsultation --> PaymentComplete : [payment completed]
  PaymentComplete --> FinishSession : [finish session]
}

state InsurancePayment {
  InsurancePayment --> CashPayment : [choose cash payment]
  CashPayment --> FinishSession : [display cash payment details, finish session]
}

state FinishSession {
  FinishSession --> Feedback : [provide feedback]
  Feedback --> Logout : [logout]
  Logout : [logout successfully]
}

[*] --> [*]

@enduml
