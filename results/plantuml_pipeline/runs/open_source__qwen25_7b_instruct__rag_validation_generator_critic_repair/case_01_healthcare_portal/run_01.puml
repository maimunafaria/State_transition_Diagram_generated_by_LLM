@startuml
title UML State Machine Diagram for Healthcare Portal

[*] --> Register

state Register {
  [*] --> Login : [registration completed]
  Login : entry / check registration
  Login : do / validate registration
  Login : exit / valid registration
  Login : exit / invalid registration
}

state Login {
  [*] --> Dashboard : [user signed in]
  Dashboard : entry / display dashboard
  Dashboard : do / provide access to facilities
  Dashboard : exit / user action
  Dashboard : exit / user logout
}

state "Patient Dashboard" as PatientDashboard
PatientDashboard : entry / user is patient
PatientDashboard : do / display patient dashboard
PatientDashboard : exit / user logout

state "Health Worker Dashboard" as HealthWorkerDashboard
HealthWorkerDashboard : entry / user is health worker
HealthWorkerDashboard : do / display health worker dashboard
HealthWorkerDashboard : exit / user logout

state "Government Dashboard" as GovernmentDashboard
GovernmentDashboard : entry / user is government official
GovernmentDashboard : do / display government dashboard
GovernmentDashboard : exit / user logout

state Feedback {
  [*] --> [*] : [user feedback]
}

state Logout {
  [*] --> [*] : [user logout]
}

Register --> Login
Login --> PatientDashboard
Login --> HealthWorkerDashboard
Login --> GovernmentDashboard
PatientDashboard --> Feedback
HealthWorkerDashboard --> Feedback
GovernmentDashboard --> Feedback
Feedback --> Logout
Logout --> [*]

@enduml
