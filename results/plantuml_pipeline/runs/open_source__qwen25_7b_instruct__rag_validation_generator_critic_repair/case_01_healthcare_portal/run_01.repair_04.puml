@startuml
title UML State Machine Diagram for Healthcare Portal

[*] --> Register

state Register {
  [*] --> Login : [registration completed]
  Login : entry / check registration status
  Login : do / validate user credentials
  Login : exit / logged in successfully
}

Login --> AccessAvailableFacilities
AccessAvailableFacilities --> ReadContent
ReadContent --> ContinueOrFinishSession : [continue using system]

state "Continue Or Finish Session" as ContinueOrFinishSession {
  Register --> ContinueUsingSystem : [continue]
  ContinueUsingSystem : entry / continue session
  ContinueUsingSystem : do / allow continued use
  ContinueUsingSystem : exit / still in session

  Register --> FinishSession : [finish session]
  FinishSession : entry / end session
  FinishSession : do / log out user
  FinishSession : exit / session finished
}

ContinueOrFinishSession --> ProcessInsurancePayment : [process insurance for finance-related services]

state "Process Insurance Payment" as ProcessInsurancePayment {
  ContinueUsingSystem --> ConfirmPayment : [payment confirmed]
  ConfirmPayment : entry / confirm payment with insurance
  ConfirmPayment : do / complete payment process
  ConfirmPayment : exit / payment completed

  ContinueUsingSystem --> CashPaymentDetails : [cash payment chosen]
  CashPaymentDetails : entry / provide cash payment details
  CashPaymentDetails : do / inform user about cash payment
  CashPaymentDetails : exit / cash payment details provided
}

ProcessInsurancePayment --> CompletePaymentForDoctorConsultation : [complete payment for doctor consultations]

state "Complete Payment For Doctor Consultation" as CompletePaymentForDoctorConsultation {
  ConfirmPayment --> InsuranceBasedPayment : [insurance-based payment]
  InsuranceBasedPayment : entry / process insurance-based payment
  InsuranceBasedPayment : do / complete payment with insurance
  InsuranceBasedPayment : exit / payment completed

  ConfirmPayment --> CashBasedPayment : [cash-based payment]
  CashBasedPayment : entry / process cash-based payment
  CashBasedPayment : do / complete payment with cash
  CashBasedPayment : exit / payment completed
}

CompletePaymentForDoctorConsultation --> CollectUserFeedback : [collect user feedback]

state "Collect User Feedback" as CollectUserFeedback {
  InsuranceBasedPayment --> FeedbackCollected : [feedback collected]
  FeedbackCollected : entry / collect feedback
  FeedbackCollected : do / gather user feedback
  FeedbackCollected : exit / feedback recorded

  CashBasedPayment --> FeedbackCollected : [feedback collected]
  FeedbackCollected : entry / collect feedback
  FeedbackCollected : do / gather user feedback
  FeedbackCollected : exit / feedback recorded

  FeedbackCollected --> Logout : [logout]
  Logout : entry / end session
  Logout : do / log out user
  Logout : exit / logged out successfully
}

CollectUserFeedback --> [*]

@enduml
