@startuml
title Microwave Oven - State Diagram

[*] --> Idle

state "Idle" as Idle {
  [*] --> WaitingForInput
  WaitingForInput --> Idle : Door Opened
  WaitingForInput --> FullPower : Full Power Selected
  WaitingForInput --> HalfPower : Half Power Selected
  WaitingForInput --> SetTime : Time Entered
}

state "WaitingForInput" as WaitingForInput {
  [*] --> Idle
}

state "Full Power" as FullPower {
  [*] --> Cooking
  Cooking --> FullPower : Door Opened
  Cooking --> Idle : Door Closed
}

state "Half Power" as HalfPower {
  [*] --> Cooking
  Cooking --> HalfPower : Door Opened
  Cooking --> Idle : Door Closed
}

state "Set Time" as SetTime {
  [*] --> Cooking
  Cooking --> SetTime : Door Opened
  Cooking --> Idle : Door Closed
}

state "Cooking" as Cooking {
  [*] --> Idle : Door Opened
  Cooking --> Idle : Timer Expired
}

Cooking --> [*] : Door Opened

@enduml
