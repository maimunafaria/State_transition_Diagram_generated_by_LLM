@startuml
title UML State Chart Diagram for E Ticketing For Bus

state "User Registration" as Registration {
  [*] --> EnterDetails

  state EnterDetails
  state "Validation Success" as ValidationSuccess
  state "Validation Failure" as ValidationFailure

  EnterDetails --> ValidationSuccess : [Valid]
  EnterDetails --> ValidationFailure : [Invalid]
}

Registration --> Login

state "User Login" as Login {
  [*] --> EnterCredentials

  state EnterCredentials
  state "Login Success" as LoginSuccess
  state "Login Failure" as LoginFailure

  EnterCredentials --> LoginSuccess : [Valid]
  EnterCredentials --> LoginFailure : [Invalid]
}

LoginSuccess --> Dashboard

state Dashboard {
  [*] --> CheckTicketStatus
  CheckTicketStatus --> Dashboard
  [*] --> BookTicket
  BookTicket --> ConfirmBooking
  ConfirmBooking --> MakePayment
  MakePayment --> BookingComplete
  BookingComplete --> Dashboard
}

Dashboard --> ManageAccount
ManageAccount --> EditAccount
EditAccount --> Dashboard
ManageAccount --> DeleteAccount
DeleteAccount --> Dashboard

LoginFailure --> Registration
ValidationFailure --> Registration

BookingComplete --> Logout
CheckTicketStatus --> Logout
EditAccount --> Logout
DeleteAccount --> Logout

state Logout {
  Logout --> [*] : session ended
}

state "User Login" {
  [*] --> Login
}

state Registration {
  [*] --> Registration
}
@enduml
