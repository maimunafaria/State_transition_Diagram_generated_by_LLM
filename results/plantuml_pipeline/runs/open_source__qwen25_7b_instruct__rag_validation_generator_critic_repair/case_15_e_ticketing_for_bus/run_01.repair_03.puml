@startuml
title UML State Chart Diagram for E Ticketing For Bus

state "Registration" as Registration {
  [*] --> EnterDetails

  state EnterDetails
  state ValidateUser
  state LoginSuccess
  state LoginFailed

  EnterDetails --> ValidateUser : [Valid]
  EnterDetails --> LoginFailed : [Invalid]

  ValidateUser --> LoginSuccess
}

state "LoggedIn" as LoggedIn {
  [*] --> Dashboard

  state Dashboard
  state Settings
  state TicketStatus
  state ManageAccount
  state Logout

  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
  Dashboard --> TicketStatus : check ticket status
  Dashboard --> ManageAccount : manage account details
}

state "TicketBooking" as TicketBooking {
  [*] --> BookingDetails

  state BookingDetails
  state PaymentConfirmed
  state PaymentFailed

  BookingDetails --> PaymentConfirmed : [Payment successful]
  BookingDetails --> PaymentFailed : [Payment failed]

  PaymentConfirmed --> TicketStatus
  PaymentFailed --> LoginSuccess
}

state "Logout" as Logout {
  [*] --> [*] : session ended
}
[*] --> Registration
Registration --> LoggedIn
LoggedIn --> TicketBooking
TicketBooking --> LoggedIn

LoginSuccess --> Dashboard
LoginFailed --> Registration

Logout --> [*]
@enduml
