@startuml
title UML State Chart Diagram for E Ticketing For Bus

[*] --> Registration

state Registration {
    EnterDetails
    state EnterDetails
    state ValidateDetails
    state RegistrationComplete
    state ReEnterDetails

    Registration --> EnterDetails
    EnterDetails --> ValidateDetails : [Valid]
    EnterDetails --> ReEnterDetails : [Invalid]
    ReEnterDetails --> EnterDetails
    ValidateDetails --> RegistrationComplete
}

RegistrationComplete --> Login

state Login {
    Authenticate
    state Authenticate
    state LoginSuccess
    state LoginFailed

    Login --> Authenticate
    Authenticate --> LoginSuccess : [Valid]
    Authenticate --> LoginFailed : [Invalid]
}

LoginSuccess --> Dashboard

state Dashboard {
    CheckTicketStatus
    BookTicket
    ConfirmBooking
    MakePayment
    PaymentSuccess
    ManageAccount
    Logout
    EditDetails
    DeleteAccount

    [*] --> CheckTicketStatus
    CheckTicketStatus --> Dashboard
    [*] --> BookTicket
    BookTicket --> ConfirmBooking
    ConfirmBooking --> MakePayment
    MakePayment --> PaymentSuccess
    PaymentSuccess --> Dashboard
    [*] --> ManageAccount
    ManageAccount --> Dashboard
    [*] --> Logout
    Logout --> [*]
}

state ManageAccount {
    EditDetails
    DeleteAccount

    ManageAccount --> EditDetails
    EditDetails --> Dashboard
    ManageAccount --> DeleteAccount
    DeleteAccount --> [*]
}

@enduml
