@startuml
title UML State Chart Diagram for E Ticketing For Bus

state "Initial" as Initial
state "Logged In" as LoggedIn
state "Dashboard" as Dashboard
state "Settings" as Settings
state "Ticket Status" as TicketStatus
state "Ticket Booking" as TicketBooking
state "Payment Confirmation" as PaymentConfirmation
state "Account Management" as AccountManagement
state "Logout" as Logout

[*] --> Initial

Initial --> LoggedIn : [New User Registration]

state LoggedIn {
  Dashboard --> Settings : [Open Settings]
  Settings --> Dashboard : [Back to Dashboard]
  Dashboard --> TicketStatus : [Check Ticket Status]
  Dashboard --> TicketBooking : [Book Ticket]
  TicketBooking --> PaymentConfirmation : [Confirm and Pay]
  PaymentConfirmation --> Dashboard : [Payment Confirmed]
  Dashboard --> AccountManagement : [Manage Account]
  AccountManagement --> Dashboard : [Back to Dashboard]
}

LoggedIn --> Logout : [Logout]

Logout --> [*]
@enduml
