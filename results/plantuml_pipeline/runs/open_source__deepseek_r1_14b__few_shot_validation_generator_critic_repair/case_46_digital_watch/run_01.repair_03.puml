@startuml
state DefaultState {
    [*] --> self
}

state ChangeHour
state ChangeMinute
state ChangeAlarmHour
state ChangeAlarmMinute

DefaultState -> ChangeHour : "mode"
ChangeHour -> ChangeMinute : "mode"
ChangeMinute -> ChangeAlarmHour : "mode"
ChangeAlarmHour -> ChangeAlarmMinute : "mode"
ChangeAlarmMinute -> DefaultState : "mode"

ChangeHour --> ChangeHour : "+"
ChangeMinute --> ChangeMinute : "+"
ChangeAlarmHour --> ChangeAlarmHour : "+"
ChangeAlarmMinute --> ChangeAlarmMinute : "+"

state AlarmOff
state AlarmOn

DefaultState --> AlarmOff : "alarm toggle"
AlarmOff --> AlarmOn : "alarm toggle"
AlarmOn --> DefaultState : "alarm toggle"

AlarmOn --> AlarmRinging : "time matches alarm time"

state AlarmRinging
AlarmRinging --> [*] : "button pressed"

state LightOff
state LightOn

LightOff --> LightOn : "light button pressed"
LightOn --> LightOff : "light button released"

start DefaultState
@enduml
