@startuml
state Order {
}
state Arrival {
  Order --> Arrival : on arrival
}
state Preparation {
  Arrival --> Preparation : upon arrival processing
  Order --> Preparation : direct preparation
}
state Operations {
  Preparation --> Operations : Condition OK & Schedule Available
  Maintenance --> Operations : after servicing and schedule available
}
state Maintenance {
  Preparation --> Maintenance : Needs Maintenance
  Operations --> Maintenance : no more flights or maintenance required
}
state Retired {
  Retired --> [*]
}

[*] --> Order : new plane acquired
Order --> Arrival
Preparation --> Operations
Preparation --> Maintenance
Operations --> Maintenance
Maintenance --> Preparation
Operations --> Retired : permanently withdrawn
Preparation --> Retired : retired during preparation
Arrival --> Retired : retired upon arrival
@enduml
