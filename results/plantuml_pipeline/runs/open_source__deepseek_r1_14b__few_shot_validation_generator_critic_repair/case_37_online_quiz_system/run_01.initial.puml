@startuml
state "Start" {
  [*] --> "Login"
}
state "Login" {
  --> "Register"
  --> "Continue as Teacher"
  --> "Continue as Student"
}

state "Teacher Dashboard" {
  --> "Create/Edit Quiz"
  --> "View Results"
}

state "Student Dashboard" {
  --> "Select Quiz"
}

state "Create/Edit Quiz" {
  --> "Draft" --> "Teacher Dashboard"
  --> "Publish" --> "Quiz Posted"
}

state "Quiz Posted" {
  transition_quiz_completed() --> "Teacher Dashboard"
}

state "Select Quiz" {
  --> "Answering Quiz"
}

state "Answering Quiz" {
  --> "Submit Quiz"
}

state "Submit Quiz" {
  --> "View Result"
}

state "Draft" {
  --> "Teacher Dashboard"
}

state "View Results" {
  --> "Teacher Dashboard"
}

state "View Result" {
  --> "Student Dashboard"
}
@enduml
