@startuml
[*] --> CardInserted

state CardInserted {
}

state PINEntered {
  when PIN entered: transition to PINVerified
}

state PINVerified {
  when verified: transition to OptionsProvided
}

state OptionsProvided {
  when option selected: transition to TransactionApproved
}

state TransactionApproved {
  when approved: transition to CashDispensed
}

state CashDispensed {
  when cash dispensed: transition to ReceiptPrinted
}

state ReceiptPrinted {
  when receipt printed: transition to CardReturned
}

state CardReturned {
  when card returned: transition to Reset
}

state Reset {
  when reset: transition to [*]
}

CardInserted --> PINEntered
PINVerified --> OptionsProvided
TransactionApproved --> CashDispensed
CashDispensed --> ReceiptPrinted
ReceiptPrinted --> CardReturned
CardReturned --> Reset
Reset --> [*]
@enduml
