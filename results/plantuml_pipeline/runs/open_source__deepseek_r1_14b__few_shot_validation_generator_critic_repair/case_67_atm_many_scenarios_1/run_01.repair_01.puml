@startuml
state "Ready for next user" {
    on "Card inserted" --> "Waiting for PIN"
    on "User exits" --> [*]
}
state "Waiting for PIN" {
    on "Correct PIN" --> "PIN verified"
    on "Incorrect PIN" --> "Invalid PIN"
}
state "PIN verified" {
    --> "Options displayed"
}
state "Invalid PIN" {
    --> "Ready for next user"
}
state "Options displayed" {
    on "Withdrawal selected" --> "Processing withdrawal"
}
state "Processing withdrawal" {
    --> "Cash dispensed"
}
state "Cash dispensed" {
    --> "Printing receipt"
}
state "Printing receipt" {
    --> "Card returned"
}
state "Card returned" {
    --> "Ready for next user"
}
@enduml
