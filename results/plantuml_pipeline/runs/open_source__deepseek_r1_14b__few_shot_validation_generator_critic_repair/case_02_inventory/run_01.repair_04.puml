@startuml
state Inventory {
  [*] --> self: Start
}

state AddGoods {
  Inventory --> self: Add new goods
}

state UpdatePrice {
  AddGoods --> self: Update price of existing items
}

state RemoveGoods {
  UpdatePrice --> self: Remove goods no longer required
}

state CheckExpiration {
  RemoveGoods --> self: Identify expired goods and notify removal
}

state PlaceOrder {
  CheckExpiration --> self: Place order for additional goods
}

state GenerateInvoice {
  PlaceOrder --> self: Generate invoice once order is placed
}

end
@enduml
