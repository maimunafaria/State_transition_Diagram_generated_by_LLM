@startuml
state Idle {
  [*] --> Active : Receive suggestion request
}
state Active {
  --> IdentifyingUser : Identify user
}
state IdentifyingUser {
  --> GatheringVideos : User identified
}
state GatheringVideos {
  --> AddingDetails : Videos gathered
}
state AddingDetails {
  --> SendingSuggestions : Details added
}
state SendingSuggestions {
  --> Idle : Suggestions sent
}
@enduml
