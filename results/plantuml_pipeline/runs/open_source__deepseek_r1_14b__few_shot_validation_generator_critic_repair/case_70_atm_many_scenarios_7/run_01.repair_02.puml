@startuml
state Start {
  entry: User arrives at ATM
}
state Greeting {
  entry: System displays greeting message
}
state CheckPIN {
  entry: Insert card and check PIN
}
state IncorrectPIN {
  entry: PIN entered incorrectly; allow retry
}
state ProcessRequest {
  entry: Process selected transaction request
}
state ReturnOrKeepCard {
  entry: Determine if card is returned or kept
}
state End

[*] --> Start
Start --> Greeting
Greeting --> CheckPIN
CheckPIN -->|correct| ProcessRequest
ProcessRequest --> ReturnOrKeepCard
ReturnOrKeepCard -->|return card| End
ReturnOrKeepCard -->|keep card| End
CheckPIN -->|incorrect| IncorrectPIN
IncorrectPIN -->|retry| CheckPIN
IncorrectPIN -->|too many retries| KeepCardState
KeepCardState -->|cancel or timeout| ReturnCardState
ReturnCardState --> End

note right of ProcessRequest: "Process the selected request"
@enduml
