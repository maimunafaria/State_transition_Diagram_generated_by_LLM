@startuml
state Initial {
    [*] --> self: Start
}
state CardInserted {
    on CardInserted --> self: Check PIN
}
state PINInput {
    on PINEntered --> PINChecked
}
state PINChecked {
    if (Correct) then
        --> MenuOptionsDisplayed : Correct
    else
        --> PINInput : Incorrect
    endif
}
state MenuOptionsDisplayed {
    on ChoiceMade --> ProcessingRequest : Process request
}
state ProcessingRequest {
    on RequestProcessed --> MenuOptionsDisplayed : Continue
}
state CardKept {
    on Cancel --> Initial : Return card
}
Initial --> CardInserted : Insert card
@enduml
