@startuml
state "Power Off" {
    [*] --> self: Check everything upon power-on
}
state "Startup Problem" {
    --> "Stopped": Stop if problem during startup
}
state "Ready" {
    --> "Monitoring": Activate
    --> "Power Off": Turn off
    --> "Ready": Reset
}
state "Stopped" {
    --> "Ready": Resume when user enters password
}
state "Monitoring" {
    --> "Alarm Triggered": Sensor triggered
}
state "Alarm Triggered" {
    --> "Monitoring": False alarm or time ends
}
@enduml
