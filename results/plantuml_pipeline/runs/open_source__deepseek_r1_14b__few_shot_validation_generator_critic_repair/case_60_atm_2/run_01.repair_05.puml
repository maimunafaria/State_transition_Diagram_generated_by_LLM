@startuml
stop --> start
start --> AmountEntered: select amount from list or enter custom
AmountEntered --> TransactionVerification: verify transaction
TransactionVerification --> {(TransactionApproved: approve transaction), (AmountReentry: reject transaction)}
AmountReentry --> AmountEntered: select amount from list or enter custom
TransactionApproved --> stop
AmountReentry --> stop
@enduml
