@startuml
state "Not Logged In"
state "Account Created"
state "Logged In"
state "Ticket Booking"
state "Payment Confirmed"
state "Account Management"

start --> "Not Logged In" : [*]

"Not Logged In" -> "Account Created" : Register User
"Account Created" -> "Logged In" : Login

"Logged In" -> "Ticket Booking" : Check Ticket Status
"Logged In" -> "Account Management" : Manage Account

"Ticket Booking" -> "Payment Confirmed" : Book Ticket
"Payment Confirmed" --> "Not Logged In" : Log Out

"Account Management" --> "Not Logged In" : Log Out
@enduml
