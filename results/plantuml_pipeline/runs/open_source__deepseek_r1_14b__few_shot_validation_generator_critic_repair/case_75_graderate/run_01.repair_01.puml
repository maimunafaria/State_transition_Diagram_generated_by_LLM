@startuml
state Waiting {
  [*] --> Waiting : start date not reached yet
}
state Active {
  --> Active : between start and finish dates
}
state Expired {
  --> Expired : one year after expiration date
}
state Removed/Archived {
  --> [*]
}

Waiting --> Active : start date reached
Active --> Expired : finish date reached
Expired --> Removed/Archived : one year from expiration date
@enduml
