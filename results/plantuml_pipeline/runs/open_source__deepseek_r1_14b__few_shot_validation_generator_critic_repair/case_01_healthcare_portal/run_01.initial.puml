@startuml
state Start {
  [*] --> Registration
}
state Registration {
  --> SignIn : registration success
  --> end : registration fail
}
state SignIn {
  --> MainMenu : sign in success
}
state MainMenu {
  --> CheckSymptoms : check symptoms
  --> FitnessCheck : fitness checking
  --> NewsReading : read news/expert content
  --> InsuranceProcessing : process insurance for finance services
  --> SelectPaymentMethod : select payment method (cash/insurance)
}
state CheckSymptoms {
  --> MainMenu : continue
  --> Logout : finish session
}
state FitnessCheck {
  --> MainMenu : continue
  --> Logout : finish session
}
state NewsReading {
  --> MainMenu : continue
}
state InsuranceProcessing {
  --> PaymentProcessingInsurance : payment processing (insurance)
  --> end : insurance invalid
}
state PaymentProcessingInsurance {
  --> MainMenu : payment complete
}
state SelectPaymentMethod {
  --> CashPaymentDetails : cash chosen
  --> InsurancePayment : insurance chosen
}
state CashPaymentDetails {
  --> MainMenu : payment details informed
}
state InsurancePayment {
  --> MainMenu : payment processing (insurance)
}
state FeedbackCollection {
  --> Logout : feedback submitted
}
state Logout {
  --> end : session ended
}
@enduml
