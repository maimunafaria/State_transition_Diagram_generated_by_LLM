@startuml
state [*]
state Initial
state Registration
state SignIn
state FacilityAccess
state NewsAndContent
state HealthInfo
state ResultViewing
state PaymentProcessing
state FeedbackCollection
state AccessEnded

[*] --> Initial : Start Process
Initial --> Registration
Registration --> [*] : Fail
Registration --> SignIn
SignIn --> FacilityAccess
FacilityAccess --> NewsAndContent
NewsAndContent --> HealthInfo
HealthInfo --> ResultViewing
ResultViewing --> [*] : Continue or Finish
PaymentProcessing --> [*] : Complete
FeedbackCollection --> AccessEnded
AccessEnded --> [*]
@enduml
