@startuml
state Initial {
  [*] --> LoggedIn
}
state LoggedIn {
  --> MarketConditions : select market conditions
  --> PestControl : select pest control help
  --> SoilSuggestions : select soil suggestions
  --> WeatherInsights : select weather insights
  --> LabourAvailability : select labour availability
  --> ContinueUsingService : continue using service
  --> Logout : log out
}
state MarketConditions {
  --> MarketReport : select market condition
}
state PestControl {
  --> RequirePhoto : provide photo
}
state RequirePhoto {
  --> PestTechniques : select pest control techniques
}
state SoilSuggestions {
  --> SoilResults : receive soil information
}
state WeatherInsights {
  --> WeatherData : provide location
}
state LabourAvailability {
  --> LabourResults : provide location
}
state ContinueUsingService {
  --> ContinueUsingService : continue using service
}
state Logout {
  --> EndSession
}
@enduml
