@startuml
state [*]
state LoggedOut
state Registering
state LoggedIn

[*] --> LoggedOut

LoggedIn:
    when Create Account:
        transition to Registering
    when Logout:
        transition to LoggedOut

Registering:
    when Registered:
        transition to LoggedIn

LoggedIn:
    when Upload Video:
        transition to LoggedIn
    when View Video:
        transition to LoggedIn
    when Discuss:
        transition to LoggedIn

LoggedIn --> [*] : Logout

[*] --> LoggedOut : Start
@enduml
