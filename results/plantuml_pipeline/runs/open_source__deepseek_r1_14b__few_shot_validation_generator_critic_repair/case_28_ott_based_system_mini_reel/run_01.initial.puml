@startuml
state Unauthenticated {
    [*] --> Authenticated : create account
}
state Authenticated {
    --> WatchingVideo : watch video
    --> UploadingVideo : upload video
    --> LikesList : view saved videos
    --> Discussion : enter discussion
}
state WatchingVideo {
    --> Authenticated : back to home
    --> LikesList : save to likes
}
state UploadingVideo {
    --> Authenticated : done uploading
}
state LikesList {
    --> Authenticated : back to home
}
state Discussion {
    --> Authenticated : exit discussion
}
@enduml
