@startuml
state Waiting {
  [*] --> Waiting
}
state AddingItems {
  Waiting --> AddingItems : New Sale
}
state Payment {
  AddingItems --> Payment : All Items Added
}
state VerifyingPayment {
  Payment --> VerifyingPayment : Card or Check
}
state SaleCompleted {
  Payment --> SaleCompleted : Pay Cash
  VerifyingPayment --> SaleCompleted : Approved
  SaleCompleted --> Waiting : Payment Finished
  SaleCompleted --> [*]
}
@enduml
