@startuml
state Initial {
  [*] --> "Display Journey Details"
}

state "Display Journey Details" {
  transition "Activate Driving Mode" --> "Driving Mode"
  transition "Choose Other Options" --> "Other Actions"
}

state "Driving Mode" {
  loop "During driving" --> "Notifications Sent"
  transition "Accident Occurs" --> "Inform Authorities"
}

state "Other Actions" {
  transition "Select Place to Eat" --> "Eat and Order"
}

state "Eat and Order" {
  transition "Order Placed" --> "Completion State"
}

state "Inform Authorities" {
  transition "Authorities Notified" --> "Completion State"
}

state "Notifications Sent" {
  transition "No Accident" --> "Driving Mode"
}

state "Completion State" {
  transition "Feedback Provided" --> end
}

@enduml
