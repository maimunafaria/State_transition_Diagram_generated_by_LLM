@startuml
[*] --> Initial
Initial -> SelectAmount: Choose predefined amount
SelectAmount -> ProcessWithdrawal: Confirm
ProcessWithdrawal -> Final: Complete transaction
Final --> [*]

Initial -> EnterCustomAmount: Enter custom amount
EnterCustomAmount -> ProcessWithdrawal: Confirm
ProcessWithdrawal -> Final: Complete transaction
Final --> [*]

SelectAmount <-|> CancelTransaction: Cancel
CancelTransaction --> Final: Return card
Final --> [*]

EnterCustomAmount <-|> CancelTransaction: Cancel
CancelTransaction --> Final: Return card
Final --> [*]
@enduml
