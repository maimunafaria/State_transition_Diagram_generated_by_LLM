@startuml
state Homepage {
  [*] -->Homepage: start
}
state ProjectsPage {
  --> ViewPhotos : click project photos
  --> ViewVideos : click project videos
}
state ViewPhotos {
  -->ProjectsPage: back
}
state ViewVideos {
  -->ProjectsPage: back
}
state CareerOpportunities {
  -->ViewUpdates : click updates
  -->ApplicationForm : click Apply
}
state ViewUpdates {
  -->CareerOpportunities: back
}
state ApplicationForm {
  -->ApplicationSubmitted: submit application
}
state ApplicationSubmitted {
  -->CareerOpportunities: application checked
}

Homepage --> ProjectsPage : click Projects
Homepage --> CareerOpportunities : click Careers
@enduml
