@startuml
state Campaign_Created {
  --> Active : Start Campaign after assigning manager and staff
}
state Active {
  --> Adverts_Prepared : Prepare adverts during campaign
}
state Adverts_Prepared {
  --> Adverts_Approved_and_Scheduled : Approve and schedule adverts
}
state Adverts_Approved_and_Scheduled {
  --> Running : Run adverts
}
state Running {
  --> Active : Extend or adjust campaign
  --> Campaign_Completed : All adverts finished
}
state Campaign_Completed {
  --> Payment_Handling : Prepare final statement
}
state Payment_Handling {
  [*] --> Paid : Full amount paid
  [*] --> Refund_Generated : Amount paid less than required
  [*] --> Waiting_for_Balance : Amount paid exceeds required
}
state Paid {
  --> Archived : Mark campaign as paid
}
state Refund_Generated {
  --> Payment_Handling : Generate refund
}
state Waiting_for_Balance {
  --> Payment_Handling : Balance settled
}
state Archived {
  --> end : Archive campaign and release staff/manager
}
@enduml
