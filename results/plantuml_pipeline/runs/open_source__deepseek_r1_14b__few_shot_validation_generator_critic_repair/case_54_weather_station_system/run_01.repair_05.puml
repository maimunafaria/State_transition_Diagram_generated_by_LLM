@startuml
skinparam default {
    state {
        BackgroundColor<<Running>> #9CCEFF
        BackgroundColor<<ConfigurationMode>> #E0E0FF
        BackgroundColor<<ControlledMode>> #F0FFF0
        BackgroundColor<<Shutdown>> #FFB8B8
    }
}

state Shutdown {
    [*] --> Running : on startup
}
state Running {
    - collect data : clock trigger --> Running
    - prepare/send summary : request --> Running
    - check status : request --> Running
}
state ConfigurationMode {
    --> Running : config done
}
Running --> ConfigurationMode : config needed
Running --> ControlledMode : remote control
ControlledMode --> Running : exit controlled mode
Running --> Shutdown : shutdown command

@enduml
