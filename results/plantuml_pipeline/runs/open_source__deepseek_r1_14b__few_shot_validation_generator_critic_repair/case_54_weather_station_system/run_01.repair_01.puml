@startuml
state Shutdown {
    [*] --> Running : restart
}
state Running {
    - collect data : clock trigger
    - prepare/send summary : request
    - check status : request
}
state ConfigurationMode {
    --> Running : configuration completed
}
Running --> ConfigurationMode : config needed
Running --> ControlledMode : remote control
Running --> Shutdown : shutdown command

state ControlledMode {
    --> [*] : stop
}
@enduml
