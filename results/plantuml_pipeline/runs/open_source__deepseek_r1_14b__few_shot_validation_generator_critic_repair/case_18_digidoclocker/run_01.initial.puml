@startuml
state Initial {
  [*] --> UserIdentification
}
state UserIdentification {
  transition "Citizen" --> CitizenRegistration
  transition "Registrar" --> LoggedIn_Registrar
}
state CitizenRegistration {
  transition "Success" --> LoggedIn_Citizen
}
state LoggedIn_Citizen {
  transition "Upload Document" --> DocumentUpload
  transition "View Profile" --> ViewProfile
  transition "Apply for Certificate" --> ApplyCertificate
}
state DocumentUpload {
  transition "Continue" --> ContinueUploads
  transition "Proceed" --> LoggedIn_Citizen
}
state ContinueUploads {
  transition "Upload More" --> DocumentUpload
  transition "Done" --> LoggedIn_Citizen
}
state ViewProfile {
  transition "Back" --> LoggedIn_Citizen
}
state ApplyCertificate {
  transition "Apply Again" --> ApplyCertificate
  transition "Proceed" --> LoggedIn_Citizen
}
state LoggedIn_Registrar {
  transition "Request Certificate" --> RequestVerification
}
state RequestVerification {
  transition "Continue" --> ContinueRequests
  transition "Done" --> LoggedIn_Registrar
}
state ContinueRequests {
  transition "Request More" --> RequestVerification
  transition "Proceed" --> LoggedIn_Registrar
}
state EndSession {
  transition "
@enduml
