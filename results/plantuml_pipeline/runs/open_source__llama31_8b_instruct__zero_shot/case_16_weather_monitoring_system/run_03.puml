@startuml
state "Account Creation" as acr {
  [*] --> acr
  acr -->|Create Account|> "Registration Successful"
  acr -->|Registration Failed|> "End Process"
}

state "Login" as lg {
  acr -->|Registration Successful|> lg
  lg -->|Invalid Credentials|> "End Process"
  lg -->|Valid Credentials|> "Weather Check"
}

state "Weather Check" as wc {
  lg -->|Valid Credentials|> wc
  wc -->|Invalid Location|> "End Process"
  wc -->|Valid Location|> "Select Weather Option"
}

state "Select Weather Option" as swo {
  wc -->|Valid Location|> swo
  swo -->|Temperature Selected|> "Update and Show Temperature"
  swo -->|Humidity Selected|> "Update and Show Humidity"
  swo -->|Rainfall Selected|> "Update and Show Rainfall"
  swo -->|Pressure Selected|> "Update and Show Pressure"
  swo -->|Dew Point Selected|> "Update and Show Dew Point"
}

state "Additional Weather Details" as awd {
  swo -->|Alerts Selected|> "Show Alerts"
  swo -->|Weekly Analysis Selected|> "Show Weekly Analysis"
  swo -->|Future Prediction Selected|> "Show Future Prediction"
  swo -->|Graph Selected|> "Show Graph"
}

state "Logout" as ltg {
  awd -->|Back to Main Menu|> ltg
  ltg -->|Logged Out|> "*"
}

[*] --> acr

@enduml
