@startuml
[*] as InitialState
State "Registration" {
  [*] as RegistrationState
  State "Login" as LoginState
  State "WeatherCheck" as WeatherCheckState
  State "Logout" as LogoutState
}

InitialState ->> RegistrationState : Create Account
RegistrationState ->> LoginState : Successful Registration
RegistrationState ->> * : Unsuccessful Registration

LoginState ->> WeatherCheckState : Valid Credentials
LoginState ->> * : Invalid Credentials

WeatherCheckState ->> WeatherCheckState : Valid Location
WeatherCheckState ->> * : Invalid Location

WeatherCheckState ->> WeatherCheckState : Select Weather Option
WeatherCheckState ->> LoginState : Log Out

WeatherCheckState ->> WeatherCheckState : View Additional Details
WeatherCheckState ->> LogoutState : End Session

LogoutState ->> [*] : Successful Logout

[*] as FinalState

@enduml
