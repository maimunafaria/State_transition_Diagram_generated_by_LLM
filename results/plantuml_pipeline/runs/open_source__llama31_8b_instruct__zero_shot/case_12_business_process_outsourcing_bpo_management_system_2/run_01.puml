@startuml
state "Idle" as idle
state "Filter Selected" as filter_selected
state "Search Results Displayed" as search_results_displayed
state "No Matching Users Found" as no_matching_users_found

idle ->down> filter_selected : User selects a filter category or price range
filter_selected ->down> search_results_displayed : System displays matching users based on chosen criteria
search_results_displayed ->up> idle : User navigates back to main menu
no_matching_users_found ->up> idle : No matching users found, user navigates back to main menu

idle ->right> no_matching_users_found : User selects a filter category or price range but no matches are found
filter_selected ->right> no_matching_users_found : System displays "No Matching Users Found" message if no matches are found based on chosen criteria

note right of idle
Initial state
@endnote

note bottom of search_results_displayed
Final state
@endnote

@enduml
