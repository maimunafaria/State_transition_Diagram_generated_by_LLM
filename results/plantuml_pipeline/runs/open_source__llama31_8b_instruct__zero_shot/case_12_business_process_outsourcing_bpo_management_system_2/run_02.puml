@startuml
state "Idle" as s1 {
  [*] --> s2 : Select Filter Category
}
state "Filter Category Selected" as s2 {
  s2 --> s3 : Select Price Range
}
state "Price Range and Filter Category Selected" as s3 {
  s3 --> s4 : Display Matching Users
}

s1 --> s2 : No Filters Applied

state "Displaying Matching Users" as s4 {
  s4 --> s5 : User Selects New Filter
}

state "Idle" as s5 {
  s5 --> s1 : All Filters Cleared
}

@enduml
