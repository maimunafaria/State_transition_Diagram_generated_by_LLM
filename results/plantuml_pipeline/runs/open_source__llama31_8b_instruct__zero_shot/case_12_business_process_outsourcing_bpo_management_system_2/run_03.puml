@startuml
state "Idle" as idle {
  [*] --> select_filter : Select Filter Category
}

state "Selecting Filter Category" as selecting_filter_category {
  select_filter --> search_by_category : Search by Category
}

state "Searching by Category" as searching_by_category {
  search_by_category --> display_matching_users : Display Matching Users
  display_matching_users --> select_price_range : Select Price Range
}

state "Selecting Price Range" as selecting_price_range {
  select_price_range --> search_by_price : Search by Price
}

state "Idle" as idle_final {
  search_by_price --> [*] : Return to Idle
}

idle --> selecting_filter_category : User selects filter category
selecting_filter_category --> searching_by_category : User searches by category
searching_by_category --> selecting_price_range : User selects price range
selecting_price_range --> searching_by_category : User searches by price

@enduml
