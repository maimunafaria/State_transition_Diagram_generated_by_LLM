@startuml
state "Idle" as idle {
  [*] --> idle
}
idle -->|Display Current Time|> "Waiting for User Input"
state "Waiting for User Input" as waiting_for_user_input {
  waiting_for_user_input -->|User Chooses Power Level|> "Selecting Power Level"
  waiting_for_user_input -->|Door Opened During Operation|> "Inactive"
}
state "Selecting Power Level" as selecting_power_level {
  selecting_power_level -->|User Sets Cooking Time|> "Cooking in Progress"
  selecting_power_level -->|Cancel Cooking Process|> "Idle"
}
state "Cooking in Progress" as cooking_in_progress {
  cooking_in_progress -->|Door Opened During Cooking|> "Inactive"
  cooking_in_progress -->|Cancel Cooking Process|> "Idle"
}
state "Inactive" as inactive {
  inactive -->|Close Door|> idle
}

@enduml
