@startuml
state "Idle" as idle
state "Request Received" as requestReceived
state "User Identified" as userIdentified
state "Videos Gathered" as videosGathered
state "Details Added" as detailsAdded
state "Suggested Videos Sent" as suggestedVideosSent

idle ->down> requestReceived: Video Suggestion Request
requestReceived ->down> userIdentified: Identify User
userIdentified ->down> videosGathered: Gather Videos
videosGathered ->down> detailsAdded: Add Details
detailsAdded ->down> suggestedVideosSent: Send Suggested Videos

suggestedVideosSent ->up> idle: System Idle Again

@enduml
