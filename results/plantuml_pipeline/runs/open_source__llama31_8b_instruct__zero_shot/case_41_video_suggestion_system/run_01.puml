@startuml
[*] --> "Receive Video Suggestion Request" : ReceiveRequest
state "Receive Video Suggestion Request" as ReceiveRequest {
  [*] --> "Identify User" : IdentifyUser
  state "Identify User" as IdentifyUser {
    IdentifyUser --> "Gather Videos" : GatherVideos
    state "Gather Videos" as GatherVideos {
      GatherVideos --> "Add Details" : AddDetails
      state "Add Details" as AddDetails {
        AddDetails --> "Send Suggested Videos" : SendVideos
      }
    }
  }
}
state "Send Suggested Videos" as SendVideos {
  SendVideos --> "*"
}

@enduml
