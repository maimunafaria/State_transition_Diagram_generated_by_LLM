@startuml
state "Idle" as idle
state "Request Received" as request_received
state "User Identified" as user_identified
state "Videos Gathered" as videos_gathered
state "Details Added" as details_added
state "Suggested Videos Sent" as suggested_videos_sent

idle ->request_received: Video Suggestion Request Received
request_received ->user_identified: Identify User Who Made Request
user_identified ->videos_gathered: Gather Different Types of Videos
videos_gathered ->details_added: Add Thumbnails and View Counts to Videos
details_added ->suggested_videos_sent: Send Suggested Videos to User

suggested_videos_sent ->idle: System Returns to Idle State

@enduml
