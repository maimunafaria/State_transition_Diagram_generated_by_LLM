@startuml
state "Idle" as s1
state "Request Received" as s2
state "User Identified" as s3
state "Videos Gathered" as s4
state "Details Added" as s5
state "Suggested Videos Sent" as s6

s1 ->down> s2 : Video Suggestion Request
s2 ->down> s3 : Identify User
s3 ->down> s4 : Gather Videos
s4 ->down> s5 : Add Details
s5 ->down> s6 : Send Suggested Videos
s6 ->up> s1 : Suggested Videos Sent

@enduml
