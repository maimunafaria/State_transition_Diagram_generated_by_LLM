@startuml
state "Idle" as idle
state "Greeting User" as greetingUser
state "PIN Check" as pinCheck
state "Invalid Card or PIN" as invalidCardOrPin
state "Options Displayed" as optionsDisplayed
state "Request Processing" as requestProcessing

idle ->down> greetingUser : User Arrives
greetingUser ->down> pinCheck : User Inserts Card
pinCheck ->down> pinCheck : Correct PIN Entered
pinCheck ->up> invalidCardOrPin : Incorrect PIN Entered
invalidCardOrPin ->up> idle : Too Many Attempts or Invalid Card

greetingUser ->down> optionsDisplayed : Correct PIN Entered
optionsDisplayed ->down> requestProcessing : User Makes Choice
requestProcessing ->up> optionsDisplayed : Request Processing Complete
requestDisplayed ->up> idle : User Cancels Operation

state idle {
  initial: true
}

state optionsDisplayed {
  isFinal: true
}
@enduml
