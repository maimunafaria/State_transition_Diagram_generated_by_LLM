@startuml
[*] --> "Greet User" as G1
state "Greet User" {
  [*] --> "Insert Card" as I1
  "Insert Card" --> "Check PIN" as C1
}
state "Check PIN" {
  "Check PIN" --> "PIN Correct" as PC if true
  "Check PIN" --> "PIN Incorrect" as PI if false
}
state "PIN Correct" {
  "PIN Correct" --> "Display Options" as DO
  "Display Options" --> "Select Request" as SR
  "Select Request" --> "Process Request" as PR
  "Process Request" --> "*" as P1
}
state "PIN Incorrect" {
  "PIN Incorrect" --> "Try Again" as TA
  "Try Again" --> "Check PIN" as C2
  "Check PIN" --> "PIN Correct" as PC if true
  "Check PIN" --> "PIN Incorrect" as PI if false
  "PIN Incorrect" --> "Keep Card for Security" as KCS if 3
}
state "Keep Card for Security" {
  "Keep Card for Security" --> "*" as P2
}

[*] --> "Cancel Operation" as CO
"Cancel Operation" --> "Return Card" as RC

@enduml
