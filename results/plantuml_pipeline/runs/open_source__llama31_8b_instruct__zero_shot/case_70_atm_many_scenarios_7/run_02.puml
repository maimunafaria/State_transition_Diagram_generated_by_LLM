@startuml
state "Idle" as idle
state "User Arrived" as arrived
state "Card Inserted" as card_inserted
state "PIN Entered" as pin_entered
state "Invalid PIN" as invalid_pin
state "Too Many Attempts" as too_many_attempts
state "Options Displayed" as options_displayed
state "Request Processed" as request_processed

idle -> arrived : User Arrives
arrived -> card_inserted : Card Inserted
card_inserted -> pin_entered : PIN Entered
pin_entered -> invalid_pin : Incorrect PIN
invalid_pin -> too_many_attempts : Too Many Attempts
too_many_attempts -> idle : Keep Card for Security
pin_entered -> options_displayed : Correct PIN
options_displayed -> request_processed : User Makes Choice

request_processed -> arrived : Operation Cancelled by User

state idle {
  [*]
}

state arrived {
  note: Greet the user when they arrive.
}

state card_inserted {
  note: Check the PIN after the card is inserted.
}

state pin_entered {
  note: Allow the user to try again if the entered PIN is incorrect.
}

state invalid_pin {
  note: Keep the card for security if it is invalid or the PIN is entered incorrectly too many times.
}

state too_many_attempts {
  note: Keep the card for security if it is invalid or the PIN is entered incorrectly too many times.
}

state options_displayed {
  note: Display available options (withdrawing money, checking information, or making a transfer) for the user to choose from.
}

state request_processed {
  note: Process the selected request after the user makes a choice.
}

@enduml
