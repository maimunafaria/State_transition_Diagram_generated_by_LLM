@startuml
state "Idle" as idle
state "Greeting User" as greetingUser
state "PIN Check" as pinCheck
state "Invalid Card/PIN" as invalidCardPin
state "Options Displayed" as optionsDisplayed
state "Request Processing" as requestProcessing

idle ->down> greetingUser : User Arrives
greetingUser ->down> pinCheck : User Inserts Card
pinCheck ->down> pinCheck : PIN is Correct
pinCheck ->up> invalidCardPin : PIN is Incorrect
invalidCardPin ->down> optionsDisplayed : Cancel Operation
optionsDisplayed ->down> requestProcessing : User Selects Option

requestProcessing ->up> idle : Request Completed Successfully
invalidCardPin ->down> idle : Card Kept for Security (Too Many Attempts)

@enduml
