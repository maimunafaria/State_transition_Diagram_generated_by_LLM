@startuml
state "Not Registered" as s1 {
  [*] --> s2 : Create Account
}
state "Registered" as s2 {
  s2 --> s3 : Upload Video
  s2 --> s4 : Watch Video
  s4 --> s5 : Save to Likes List
  s2 --> s6 : Enter Discussion Option
  s5 --> s7 : View Saved Videos
}

state "Uploading Video" as s3 {
  s3 --> s2 : Upload Complete
}

state "Watching Video" as s4 {
  s4 --> s5 : Save to Likes List
}

state "Saving Video" as s5 {
  s5 --> s7 : Save Complete
}

state "Viewing Saved Videos" as s7 {
  [*] --> s8 : Exit
}

state "In Discussion Option" as s6 {
  s6 --> s2 : Exit Discussion
}

s1 --> s8 : No Account Created

@enduml
