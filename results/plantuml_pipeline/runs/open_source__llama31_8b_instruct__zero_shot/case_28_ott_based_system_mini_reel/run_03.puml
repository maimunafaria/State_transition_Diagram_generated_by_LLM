@startuml
[*] --> CreateAccount : User Creates Account
CreateAccount --> WatchVideo : User Watches Video After Creating Account
WatchVideo --> UploadVideo : User Uploads Video While Watching Video
WatchVideo --> SaveToLikesList : User Saves Video to Likes List During Viewing
SaveToLikesList --> ViewSavedVideos : User Views Saved Videos from Likes List
UploadVideo --> EnterDiscussion : User Enters Discussion Option

state "CreateAccount" {
  [*] --> CreateAccount : User Creates Account
}

state "WatchVideo" {
  CreateAccount --> WatchVideo : User Watches Video After Creating Account
  WatchVideo --> UploadVideo : User Uploads Video While Watching Video
  WatchVideo --> SaveToLikesList : User Saves Video to Likes List During Viewing
}

state "UploadVideo" {
  WatchVideo --> UploadVideo : User Uploads Video While Watching Video
}

state "SaveToLikesList" {
  WatchVideo --> SaveToLikesList : User Saves Video to Likes List During Viewing
}

state "ViewSavedVideos" {
  SaveToLikesList --> ViewSavedVideos : User Views Saved Videos from Likes List
}

state "EnterDiscussion" {
  UploadVideo --> EnterDiscussion : User Enters Discussion Option
}

[*] as InitialState
ViewState as FinalState

InitialState --> CreateAccount : Initial State
CreateAccount --> WatchVideo : Transition to Watching Video After Creating Account
WatchVideo --> SaveToLikesList : Transition to Saving Video to Likes List During Viewing
SaveToLikesList --> ViewSavedVideos : Transition to Viewing Saved Videos from Likes List
UploadVideo --> EnterDiscussion : Transition to Entering Discussion Option

ViewState as FinalState
@enduml
