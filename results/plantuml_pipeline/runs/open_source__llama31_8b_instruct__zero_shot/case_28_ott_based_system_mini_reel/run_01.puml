@startuml
state "Account Created" as AC {
  [*] --> AC
  AC --> "User Uploads Video" : UU
  AC --> "User Watches Video" : UW
}

state "User Uploads Video" as UUV {
  UU --> UUV
  UUV --> "Video Uploaded Successfully" : VS
  UUV --> "Account Created" : AC
}

state "Video Uploaded Successfully" as VUS {
  VS --> VUS
  VUS --> "User Watches Video" : UW
  VUS --> "Account Created" : AC
}

state "User Watches Video" as UVW {
  UW --> UVW
  UVW --> "Video Saved in Likes List" : SL
  UVW --> "Discussion Option Entered" : DO
}

state "Video Saved in Likes List" as VSLL {
  SL --> VSLL
  VSLL --> "User Views Saved Videos" : VSV
  VSLL --> "Account Created" : AC
}

state "Discussion Option Entered" as DOP {
  DO --> DOP
  DOP --> "Account Created" : AC
}

state "User Views Saved Videos" as UVVS {
  VSV --> UVVS
  UVVS --> "Account Created" : AC
}

@enduml
