@startuml
[*] --> CreateAccount : User Creates Account
CreateAccount --> WatchVideos : User Has Created Account
WatchVideos --> UploadVideo : User Wants To Upload Video
UploadVideo --> SaveToLikesList : User Saves Video In Likes List During Viewing
SaveToLikesList --> ViewSavedVideos : User Views Saved Videos From Likes List
ViewSavedVideos --> EnterDiscussion : User Enters Discussion Option

state "CreateAccount" {
  [*] --> CreateAccount : User Creates Account
}

state "WatchVideos" {
  CreateAccount --> WatchVideos : User Has Created Account
}

state "UploadVideo" {
  WatchVideos --> UploadVideo : User Wants To Upload Video
}

state "SaveToLikesList" {
  UploadVideo --> SaveToLikesList : User Saves Video In Likes List During Viewing
}

state "ViewSavedVideos" {
  SaveToLikesList --> ViewSavedVideos : User Views Saved Videos From Likes List
}

state "EnterDiscussion" {
  ViewSavedVideos --> EnterDiscussion : User Enters Discussion Option
}

@enduml
