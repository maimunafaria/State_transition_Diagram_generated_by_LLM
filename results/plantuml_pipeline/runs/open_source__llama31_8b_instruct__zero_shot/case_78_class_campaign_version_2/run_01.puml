@startuml
state "Campaign Not Started" as CS1 {
  [*] --> CS2 : Manager and Staff Assigned
}
state "Campaign Started" as CS2 {
  CS2 --> CS3 : Everything Approved and Contract Signed
}
state "Adverts Prepared" as CS3 {
  CS3 --> CS4 : Adverts Approved and Scheduled
}
state "Adverts Running" as CS4 {
  CS4 --> CS5 : Campaign Extension or Adjustment Requested
  CS4 --> CS6 : All Adverts Finished
}
state "Campaign Completed" as CS5 {
  CS5 --> CS7 : Payment Handled and Refund Generated if Necessary
}
state "Payment Settled" as CS6 {
  CS6 --> CS8 : Full Amount Paid
}
state "Campaign Archived" as CS7 {
  CS7 --> CS9 : Staff and Managers Released
}

CS2 --> CS3 : Campaign Activated
CS4 --> CS5 : Adverts Finished Running
CS5 --> CS7 : Campaign Completed
CS6 --> CS8 : Payment Settled
CS7 --> CS9 : Campaign Archived

@enduml
