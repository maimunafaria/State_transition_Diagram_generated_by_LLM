@startuml
state "Campaign Not Started" as cs1 {
  [*] --> cs2 : Manager and Staff Assigned
}
state "Campaign In Progress" as cs2 {
  cs2 --> cs3 : Everything Approved and Contract Signed
  cs2 --> cs4 : Adverts Prepared
  cs2 --> cs5 : Adverts Approved and Scheduled
  cs2 --> cs6 : Adverts Running
  cs6 --> cs7 : Campaign Extension or Adjustment Requested
}
state "Campaign Paused" as cs3 {
  cs3 --> cs8 : Campaign Extended or Adjusted
}
state "Campaign Completed" as cs4 {
  cs4 --> cs9 : All Adverts Finished
}
state "Payment Pending" as cs5 {
  cs5 --> cs10 : Payment Received
}
state "Campaign Paid" as cs6 {
  cs10 --> cs11 : Full Amount Paid
}
state "Campaign Archived" as cs7 {
  cs9 --> cs12 : Final Statement Prepared and Payment Handled
}

cs2 --> cs3 : Campaign Activated
cs4 --> cs5 : Adverts Approved and Scheduled
cs5 --> cs6 : Adverts Running
cs7 --> cs8 : Campaign Paused
cs8 --> cs2 : Campaign Resumed
cs10 --> cs11 : Payment Marked as Paid
cs12 --> cs7 : Campaign Archived

note right of cs1: Initial State
note bottom of cs7: Final State
@enduml
