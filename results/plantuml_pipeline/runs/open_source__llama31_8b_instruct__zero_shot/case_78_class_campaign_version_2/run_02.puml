@startuml
state "Campaign Not Started" as cs1 {
  [*] --> cs2 : Manager and Staff Assigned
}

state "Campaign in Preparation" as cs2 {
  cs2 --> cs3 : Everything Approved and Contract Signed
}

state "Campaign Running" as cs3 {
  cs3 --> cs4 : Adverts Prepared
  cs3 --> cs5 : Adverts Approved and Scheduled
  cs3 --> cs6 : Adverts Running
  cs6 --> cs7 : Extension or Adjustment Requested
  cs7 --> cs8 : Campaign Extended or Adjusted
}

state "Campaign Completed" as cs8 {
  cs8 --> cs9 : All Adverts Finished
  cs9 --> cs10 : Payment Handled and Refund Generated if Necessary
  cs10 --> cs11 : Correct Balance Settled
  cs11 --> cs12 : Campaign Marked as Paid
}

state "Campaign Archived" as cs12 {
  cs12 --> cs13 : Staff and Managers Released
}

cs2 --> cs3 : Campaign Activated

cs4 --> cs5 : Adverts Prepared and Scheduled

cs6 --> cs7 : Adverts Running

cs8 --> cs9 : Campaign Completed

cs10 --> cs11 : Payment Handled

cs11 --> cs12 : Campaign Marked as Paid

[*] --> cs1 : Initial State
cs2 --> cs13 : Final State
@enduml
