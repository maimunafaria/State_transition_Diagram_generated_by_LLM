@startuml
state "Logged Out" as s1
state "Logged In" as s2
state "Main Area" as s3
state "Market Conditions" as s4
state "Market Report" as s5
state "Pest Control Help" as s6
state "Pest Control Techniques" as s7
state "Soil Suggestions" as s8
state "Weather Insights" as s9
state "Labour Availability" as s10

s1 ->down> s2 : Login
s2 ->down> s3 : Sign In
s3 ->right> s4 : Select Market Conditions
s4 ->right> s5 : Select Market Report
s3 ->right> s6 : Select Pest Control Help
s6 ->right> s7 : Provide Photo
s7 ->right> s8 : Show Pest Control Techniques
s3 ->down> s9 : Select Weather Insights
s9 ->down> s10 : Select Labour Availability
s2 ->up> s1 : Logout

s8, s5, s7, s10 ->up> s2 : Continue Using Service

@enduml
