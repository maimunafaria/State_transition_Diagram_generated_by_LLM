@startuml
[*] --> "Inventory is empty"
state "Inventory is empty" as Empty_Inventory
Empty_Inventory --> "User adds new goods" : Add Goods
state "Goods added to inventory" as Goods_Added
Goods_Added --> "User updates price of existing items" : Update Price
Goods_Added --> "Expired goods identified and removed" : Remove Expired
state "Expired goods removed" as Expired_Removed

state "Goods added to inventory" as Goods_Added_2
Goods_Added_2 --> "User places order for additional goods" : Place Order
state "Order placed" as Order_Placed
Order_Placed --> "Invoice generated" : Generate Invoice

state "Inventory is not empty" as Inventory_Not_Empty
Inventory_Not_Empty --> "User searches for items in inventory" : Search Items
state "Items searched and selected for purchase" as Items_Selected
Items_Selected --> "Applicable discount and tax calculated" : Calculate Discount and Tax
state "Discount and tax calculated" as Discount_Tax_Calculated
Discount_Tax_Calculated --> "Receipt generated for customer" : Generate Receipt

Inventory_Not_Empty --> "User views summary report of transactions" : View Report

state "Order placed" as Order_Placed_2
Order_Placed_2 --> "Item or receipt replaced/cancelled during billing process" : Replace/Cancel Item/Receipt

[*] --> Empty_Inventory

Empty_Inventory -->* Inventory_Not_Empty
Goods_Added -->* Goods_Added_2
Expired_Removed -->* Inventory_Not_Empty
Order_Placed -->* Order_Placed_2
Items_Selected -->* Discount_Tax_Calculated
Discount_Tax_Calculated -->* Generate Receipt
Inventory_Not_Empty -->* View Report

@enduml
