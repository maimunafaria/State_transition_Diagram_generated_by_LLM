@startuml
state "Idle" as idle
state "Adding Goods" as adding_goods
state "Updating Price" as updating_price
state "Removing Goods" as removing_goods
state "Expired Goods Removed" as expired_removed
state "Order Placed" as order_placed
state "Invoice Generated" as invoice_generated
state "Searching Items" as searching_items
state "Purchase Made" as purchase_made
state "Billing Process" as billing_process
state "Receipt Generated" as receipt_generated
state "Transaction Summary" as transaction_summary

idle -> adding_goods : Add new goods to inventory
adding_goods -> updating_price : Update price of existing items
updating_price -> removing_goods : Remove goods from inventory that are no longer required
removing_goods -> expired_removed : Identify expired goods and notify user about removal
expired_removed -> order_placed : Place an order to supplier for additional goods when required
order_placed -> invoice_generated : Generate invoice for the order once it is placed
invoice_generated -> searching_items : Search for items available in inventory and select them for purchase
searching_items -> purchase_made : Calculate applicable discount and tax based on selected items
purchase_made -> billing_process : Generate receipt for customer after purchase
billing_process -> receipt_generated : Replace an item or cancel receipt during billing process if needed
receipt_generated -> transaction_summary : Record customer requests for items that may not be currently available
transaction_summary -> idle : View summary report of all transactions carried out in system at any point

note right of idle
Initial state
@endnote

note bottom of transaction_summary
Final state
@endnote

@enduml
