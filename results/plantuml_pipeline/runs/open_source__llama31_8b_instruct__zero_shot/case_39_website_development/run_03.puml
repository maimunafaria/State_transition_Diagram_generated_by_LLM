@startuml
[*] as Initial State
state "Homepage" {
  [*] as Homepage
  transition "Navigation Bar Clicked" ->> "Project Selection"
}
state "Project Selection" {
  [*] as Project Selection
  transition "Photo or Video Selected" ->> "Photos/Videos View"
  transition "Back to Navigation Bar" ->> "Homepage"
}
state "Photos/Videos View" {
  [*] as Photos/Videos View
  transition "Back to Project Selection" ->> "Project Selection"
}
state "Career Opportunities" {
  [*] as Career Opportunities
  transition "Updates or Application Form Selected" ->> "Updates/Application Form View"
  transition "Back to Navigation Bar" ->> "Homepage"
}
state "Updates/Application Form View" {
  [*] as Updates/Application Form View
  transition "Back to Career Opportunities" ->> "Career Opportunities"
}
state "Application Submission" {
  [*] as Application Submission
  transition "Application Checked" ->> "Application Status"
}
state "Application Status" {
  [*] as Application Status
  transition "Back to Navigation Bar" ->> "Homepage"
}

Initial State -> Homepage : Initial State
Homepage -> Project Selection : Navigation Bar Clicked
Project Selection -> Photos/Videos View : Photo or Video Selected
Photos/Videos View -> Project Selection : Back to Project Selection
Project Selection -> Career Opportunities : Select Career Opportunities
Career Opportunities -> Updates/Application Form View : Updates or Application Form Selected
Updates/Application Form View -> Career Opportunities : Back to Career Opportunities
Application Submission -> Application Status : Application Checked

@enduml
