@startuml
state Homepage {
  [*] --> NavigationBar
}
state NavigationBar {
  NavigationBar --> ProjectSelection : Select Project
  NavigationBar --> CareerOpportunities : Select Career Opportunities
}

state ProjectSelection {
  ProjectSelection --> ViewPhotos : Choose Photos
  ProjectSelection --> WatchVideos : Choose Videos
}

state CareerOpportunities {
  CareerOpportunities --> ViewUpdates : Choose Updates
  CareerOpportunities --> OpenApplicationForm : Open Application Form
}

state JobApplications {
  OpenApplicationForm --> CheckSubmittedApplications : Submit Application
}

Homepage -> NavigationBar : Navigate to Navigation Bar
NavigationBar -> ProjectSelection : Select Project from Navigation Bar
ProjectSelection -> ViewPhotos : Choose Photos for Project
ProjectSelection -> WatchVideos : Choose Videos for Project
NavigationBar -> CareerOpportunities : Select Career Opportunities from Navigation Bar
CareerOpportunities -> ViewUpdates : Choose Updates for Career Opportunities
CareerOpportunities -> OpenApplicationForm : Open Application Form for Career Opportunities
OpenApplicationForm -> CheckSubmittedApplications : Submit Job Application
CheckSubmittedApplications -->* JobApplications : Check Submitted Applications

state JobApplications is final

@enduml
