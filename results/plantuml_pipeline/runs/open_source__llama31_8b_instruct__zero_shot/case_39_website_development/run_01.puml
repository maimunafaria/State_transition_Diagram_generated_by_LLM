@startuml
state "Homepage" as homepage
state "Project View" as project_view
state "Photo View" as photo_view
state "Video View" as video_view
state "Career Opportunities" as career_opportunities
state "Update View" as update_view
state "Application Form" as application_form

homepage ->> project_view : Select Project
project_view ->> photo_view : Choose Photo View
project_view ->> video_view : Choose Video View
career_opportunities ->> update_view : Choose Update View
career_opportunities ->> application_form : Choose Application Form
application_form <-[submit]>> career_opportunities : Submit Job Application

history
homepage as initial_state
update_view as final_state

@enduml
