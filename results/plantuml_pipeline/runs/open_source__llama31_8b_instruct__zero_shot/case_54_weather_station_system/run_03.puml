@startuml
state "Shut Down" as sd {
  [*] --> sd : Initial State
  sd --> config_mode : Changes or Power-Saving Settings Required (Req. 2)
  sd --> restart : Restart Command Given (Implicit)
}

state "Restarting" as rs {
  sd --> rs : Restart Command Given (Implicit)
  rs --> running : System Successfully Restarted
}

state "Running" as rn {
  rs --> rn : System Successfully Restarted
  rn --> config_mode : Changes or Power-Saving Settings Required (Req. 2)
  rn --> data_collection : Clock Triggered Data Collection (Req. 4)
  rn --> summary_preparation : Weather Summary Request Received (Req. 5)
  rn --> status_checking : Status Check Request Received (Req. 6)
  rn --> shutdown : Shutdown Command Given (Req. 9)
}

state "Configuration Mode" as cm {
  sd --> cm : Changes or Power-Saving Settings Required (Req. 2)
  cm --> running : Configuration Completed
}

state "Data Collection" as dc {
  rn --> dc : Clock Triggered Data Collection (Req. 4)
  dc --> running : Data Collection Complete
}

state "Summary Preparation" as sp {
  rn --> sp : Weather Summary Request Received (Req. 5)
  sp --> running : Summary Prepared and Sent
}

state "Status Checking" as sc {
  rn --> sc : Status Check Request Received (Req. 6)
  sc --> running : Status Checked and Transmitted
}

state "Controlled Mode" as cm2 {
  rn --> cm2 : Remote Control Command Given (Req. 8)
  cm2 --> shutdown : Shutdown Command Given (Implicit)
}

sd --> shutdown : Shutdown Command Given (Implicit)

note right of shutdown
  System will shut down if a shutdown command is given while running.
end note

@enduml
