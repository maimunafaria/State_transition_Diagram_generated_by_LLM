@startuml
state Running {
  [*] --> Restarted
  Restarted -->^[*]
  
  [*] --> Configured
  Configured -->^Running
  
  [*] --> CollectingData
  CollectingData -->^Running
  
  [*] --> PreparingSummary
  PreparingSummary -->^Running
  
  [*] --> CheckingStatus
  CheckingStatus -->^Running
  
  [*] --> Controlled
  Controlled -->^Running
  
  [*] --> ShutDown
  ShutDown -->^Restarted
}

state Configured {
  [*] --> CompletedConfiguration
  CompletedConfiguration -->^Running
}

state Restarted {
  [*] --> Running
}

state CollectingData {
  [*] --> Running
}

state PreparingSummary {
  [*] --> Running
}

state CheckingStatus {
  [*] --> Running
}

state Controlled {
  [*] --> Running
}

state ShutDown {
  [*] --> Restarted
}

[*] --> Configured
Configured -->^ShutDown

Restarted --> CollectingData
CollectingData -->^Restarted

Restarted --> PreparingSummary
PreparingSummary -->^Restarted

Restarted --> CheckingStatus
CheckingStatus -->^Restarted

Restarted --> Controlled
Controlled -->^Restarted

Restarted --> ShutDown
ShutDown -->^Restarted

Configured --> CollectingData
CollectingData -->^Configured

Configured --> PreparingSummary
PreparingSummary -->^Configured

Configured --> CheckingStatus
CheckingStatus -->^Configured

Configured --> Controlled
Controlled -->^Configured

Configured --> ShutDown
ShutDown -->^Restarted

@enduml
