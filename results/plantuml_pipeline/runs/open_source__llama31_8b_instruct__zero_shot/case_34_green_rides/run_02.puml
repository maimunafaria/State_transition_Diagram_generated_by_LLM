@startuml
[*] as Initial State
state "User Login" as User_Login
state "Destination Selection" as Destination_Selection
state "Journey Details Displayed" as Journey_Details_Displayed
state "Driving Mode Activated" as Driving_Mode_Activated
state "Place to Eat Selected" as Place_to_Eat_Selected
state "Menu Viewed" as Menu_Viewed
state "Order Placed" as Order_Placed
state "Accident Occurred" as Accident_Occurred
state "Notification Sent" as Notification_Sent
state "Feedback Provided" as Feedback_Provided

[*] --> User_Login : Login Event
User_Login --> Destination_Selection : Select Destination
Destination_Selection --> Journey_Details_Displayed : Display Journey Details
Journey_Details_Displayed --> Driving_Mode_Activated : Activate Driving Mode
Driving_Mode_Activated --> Place_to_Eat_Selected : Select Place to Eat
Place_to_Eat_Selected --> Menu_Viewed : View Menu
Menu_Viewed --> Order_Placed : Place Order

Order_Placed --> Accident_Occurred : Accident Occurs
Accident_Occurred --> Notification_Sent : Send Notification
Notification_Sent --> Feedback_Provided : Provide Feedback

Journey_Details_Displayed --> [*] : Journey Completed
Feedback_Provided --> [*] : Final State

@enduml
