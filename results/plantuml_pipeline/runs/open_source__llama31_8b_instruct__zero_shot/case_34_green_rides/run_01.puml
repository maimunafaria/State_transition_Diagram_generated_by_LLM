@startuml
state "Login and Destination Selection" as L1
state "Journey Details Displayed" as L2
state "Driving Mode Activated" as L3
state "Place to Eat Selected" as L4
state "Menu Viewed" as L5
state "Order Placed" as L6
state "Accident Occurred" as L7
state "Notification Sent" as L8
state "Feedback Provided" as L9

L1 --> L2 : User Login and Destination Selection
L2 --> L3 : Activate Driving Mode or Choose Other Options
alt Driving Mode Activated
  L3 --> L4 : Select Place to Eat
  L4 --> L5 : View Menu
  L5 --> L6 : Place Order
else 
  L3 --> L8 : Send Notification During Driving
end

L2 --> L7 : Accident Occurred
L7 --> L8 : Inform Relevant Authorities and Send Notification

L9 --> L1 : User Completes Journey and Provides Feedback

@enduml
