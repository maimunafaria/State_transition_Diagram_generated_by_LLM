@startuml
state "Idle" as idle
state "Selecting Amount" as selectingAmount
state "Entering Custom Value" as enteringCustomValue
state "Verifying Transaction" as verifyingTransaction
state "Rejected" as rejected
state "Completed" as completed

idle ->> selectingAmount : User selects an amount from the list of options
selectingAmount ->> idle : User chooses to enter a custom value
enteringCustomValue ->> verifyingTransaction : User enters a custom value
verifyingTransaction ->> verifyingTransaction : Transaction is verified (success)
verifyingTransaction ->> rejected : Transaction is rejected

rejected ->> selectingAmount : User is asked to re-enter the amount
selectingAmount ->> idle : User selects an amount from the list of options again

verifyingTransaction ->> completed : Transaction is successful
completed ->> completed : Final state (transaction completed)

@enduml
