@startuml
[*] --> State1: Select Amount
State1 -->|Select Custom Value|> State2: Enter Custom Value
State1 -->|Verify Transaction|> State3: Verify Transaction

State2 -->|Confirm Value|> State4: Confirm Value
State2 -->|Cancel|> [*]

State3 -->|Transaction Approved|> State5: Transaction Approved
State3 -->|Transaction Rejected|> State6: Re-enter Amount

State4 -->|Proceed to Withdrawal|> State7: Proceed to Withdrawal
State4 -->|Re-enter Value|> State2: Enter Custom Value

State5 -->|Finalize Transaction|> Final
State6 -->|Re-enter Value|> State2: Enter Custom Value
State7 -->|Finalize Transaction|> Final

[*]: Initial state
Final: Final state
@enduml
