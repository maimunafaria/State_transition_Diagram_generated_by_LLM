@startuml
state "Idle" as s1
state "Selecting Amount" as s2
state "Entering Custom Value" as s3
state "Verifying Transaction" as s4
state "Transaction Rejected" as s5
state "Withdrawal Successful" as s6

s1 ->down> s2 : User selects an amount from the list of options
s2 ->right> s3 : User chooses to enter a custom value
s3 ->up> s2 : User enters a valid custom value
s2 ->down> s4 : User confirms selection or enters custom value
s4 ->down> s5 : Transaction is rejected (e.g., insufficient funds)
s5 ->right> s2 : User is prompted to re-enter the amount
s4 ->up> s6 : Transaction is verified and successful

s1 as initial
s6 as final

@enduml
