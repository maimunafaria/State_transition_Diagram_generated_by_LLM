@startuml
state "Unregistered" as U {
  [*] --> U : User starts from this state
}

state "Registered" as R {
  U --> R : User registers or logs in
}

state "Teacher" as T {
  R --> T : User selects teacher role after logging in
}

state "Student" as S {
  R --> S : User selects student role after logging in
}

state "Quiz Created" as QC {
  T --> QC : Teacher creates a new quiz
}

state "Quiz Edited" as QE {
  QC --> QE : Teacher edits an existing quiz
}

state "Quiz Saved" as QD {
  QE --> QD : Teacher saves the quiz as a draft or posts it for students
}

state "Quiz Started" as QS {
  S --> QS : Student selects and starts the quiz
}

state "Quiz Answered" as QA {
  QS --> QA : Student answers the selected quiz
}

state "Quiz Submitted" as QSUB {
  QA --> QSUB : Student submits their quiz after answering
}

state "Result Viewed" as RV {
  QSUB --> RV : Student views the result after submitting the quiz
}

state "Results Viewed" as RVT {
  T --> RVT : Teacher views quiz results once the quiz is over
}

U --> R : User registers or logs in
R --> T : User selects teacher role after logging in
R --> S : User selects student role after logging in
T --> QC : Teacher creates a new quiz
QC --> QE : Teacher edits an existing quiz
QE --> QD : Teacher saves the quiz as a draft or posts it for students
S --> QS : Student selects and starts the quiz
QS --> QA : Student answers the selected quiz
QA --> QSUB : Student submits their quiz after answering
QSUB --> RV : Student views the result after submitting the quiz
T --> RVT : Teacher views quiz results once the quiz is over

[*] --> U : Initial state
RV --> [*] : Final state for students
RVT --> [*] : Final state for teachers
@enduml
