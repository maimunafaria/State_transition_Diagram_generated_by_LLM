@startuml
[*] --> RegisterOrLogin : Initial State
state "Register Or Login" as register_or_login
register_or_login -->|User Registered|> TeacherOrStudent : User registered successfully
state "Teacher Or Student" as teacher_or_student
teacher_or_student -->|Continue As Teacher|> CreateQuiz : Continue as teacher
teacher_or_student -->|Continue As Student|> SelectQuiz : Continue as student
state "Create Quiz" as create_quiz
create_quiz -->|Save As Draft|> SaveDraftOrPost : Save quiz as draft
create_quiz -->|Post For Students|> PostForStudents : Post quiz for students
state "Save Draft Or Post" as save_draft_or_post
save_draft_or_post -->|Edit Existing Quiz|> EditExistingQuiz : Edit existing quiz
state "Edit Existing Quiz" as edit_existing_quiz
edit_existing_quiz -->|Save As Draft|> SaveDraftOrPost : Save quiz as draft
edit_existing_quiz -->|Post For Students|> PostForStudents : Post quiz for students
state "Post For Students" as post_for_students
post_for_students -->|View Results|> ViewResults : View quiz results
state "Select Quiz" as select_quiz
select_quiz -->|Answer Quiz|> AnswerQuiz : Select and answer quiz
state "Answer Quiz" as answer_quiz
answer_quiz -->|Submit Quiz|> SubmitQuiz : Submit quiz for evaluation
state "Submit Quiz" as submit_quiz
submit_quiz -->|View Result|> ViewResult : View result after submission
state "View Results" as view_results
view_results -->|End|> EndState : Final State

[*] -->|Continue As Teacher|> CreateQuiz : Initial state for teacher
[*] -->|Continue As Student|> SelectQuiz : Initial state for student

@enduml
