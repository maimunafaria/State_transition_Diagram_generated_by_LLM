@startuml
state "Unregistered" as U {
  [*] --> U: Initial State
}
state "Registered" as R {
  U --> R: Register or Login
}
state "Logged In" as LI {
  R --> LI: Continue as Teacher or Student
}
state "Teacher" as T {
  LI --> T: Select as Teacher
  T --> LI: Edit Quiz
  T --> LI: Save Draft or Post Quiz
  T --> LI: View Results
}
state "Student" as S {
  LI --> S: Select as Student
  S --> LI: Answer Quiz
  S --> LI: Submit Quiz
  S --> LI: View Result
}

R --> U: Already Registered

T --> R: Teacher Created a New Quiz
S --> R: Student Selected a Quiz

@enduml
