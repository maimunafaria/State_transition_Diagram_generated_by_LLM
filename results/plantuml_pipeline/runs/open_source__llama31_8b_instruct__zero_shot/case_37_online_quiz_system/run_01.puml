@startuml
state "Unregistered" as unregistered
state "Registered" as registered
state "LoggedIn" as loggedIn
state "Teacher" as teacher
state "Student" as student
state "Quiz Created" as quizCreated
state "Quiz Edited" as quizEdited
state "Quiz Saved" as quizSaved
state "Quiz Posted" as quizPosted
state "Quiz Started" as quizStarted
state "Quiz Finished" as quizFinished

unregistered -> registered : Register
registered -> loggedIn : Login
loggedIn -> teacher : Continue as Teacher
loggedIn -> student : Continue as Student
teacher -> quizCreated : Create New Quiz
quizCreated -> quizEdited : Edit Existing Quiz
quizEdited -> quizSaved : Save as Draft or Post for Students
quizPosted -> quizStarted : Start the Quiz
student -> quizStarted : Select and Start the Quiz

quizStarted -> quizFinished : Finish the Quiz
quizFinished -> teacher: View Results (Teacher)
quizFinished -> student: View Result (Student)

loggedIn -> unregistered : Logout

note right of loggedIn
Initial State: Unregistered
Final States: Teacher, Student, quizFinished
@enduml
