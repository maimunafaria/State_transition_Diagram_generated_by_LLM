@startuml
[*] as InitialState
:User not registered:;
InitialState ->> State1 : User enters details
:User registered:;
State1 ->> State2 : Login details correct
:User logged in:;
State2 ->> State3 : Upload documents, view profile or apply for certificate
:Documents uploaded or action completed;;
State3 ->> State4 : Continue uploading documents if needed
:Uploads complete or user done;;
State4 ->> [*] : Session ended

[*] as InitialState2
:Registrar not registered:;
InitialState2 ->> State5 : Registrar enters details
:Registrar registered:;
State5 ->> State6 : Request certificates for verification
:Certificates requested or action completed;;
State6 ->> State7 : Continue requesting certificates if needed
:Requests complete or user done;;
State7 ->> [*] : Session ended

[*] as InitialState3
:User logged in and has certificate request pending:;
InitialState3 ->> State8 : Reapply for certificate after sending request
:Certificate reapplication completed;;
State8 ->> [*] : Session ended

[*] as FinalState
@enduml
