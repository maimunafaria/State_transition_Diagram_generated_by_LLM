@startuml
state "Initial State" as s0 {
  [*] --> s1 : User enters details
}

state "Registration" as s1 {
  s1 --> s2 : Registration successful
  s1 --> s3 : Registration failed
}

state "Login" as s2 {
  s2 --> s4 : Login successful
  s2 --> s5 : Login failed
}

state "LoggedIn" as s4 {
  s4 --> s6 : User uploads documents
  s4 --> s7 : User views profile
  s4 --> s8 : User applies for certificate
  s4 --> s9 : User ends session
}

state "Upload Documents" as s6 {
  s6 --> s10 : Upload successful
  s6 --> s11 : Upload failed
}

state "Apply Certificate" as s8 {
  s8 --> s12 : Application sent to issuer
  s8 --> s13 : Application cancelled
}

state "Reapply Certificate" as s13 {
  s13 --> s14 : Reapplication sent to issuer
  s13 --> s15 : Reapplication cancelled
}

state "Request Certificate" as s7 {
  s7 --> s16 : Request sent to issuer
  s7 --> s17 : Request cancelled
}

state "Issuer Response" as s12 {
  s12 --> s18 : Certificate issued
  s12 --> s19 : Certificate rejected
}

state "Final State" as s9 {
  s9 -->*: End of session
}

s3 --> s0 : Registration failed, try again
s5 --> s0 : Login failed, try again
s10 --> s4 : Upload successful, continue
s11 --> s6 : Upload failed, retry
s14 --> s8 : Reapplication sent to issuer
s15 --> s13 : Reapplication cancelled
s16 --> s7 : Request sent to issuer
s17 --> s7 : Request cancelled
s18 --> s9 : Certificate issued, end session
s19 --> s9 : Certificate rejected, end session

@enduml
