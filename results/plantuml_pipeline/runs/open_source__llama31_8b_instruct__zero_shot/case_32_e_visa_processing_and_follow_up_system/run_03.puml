@startuml
state "Account Created" as AC {
  [*] --> AC
}

state "Logged In" as LI {
  AC --> LI : Login Successful
}

state "Application Submitted" as AS {
  LI --> AS : Apply for Visa and Payment Made
}

state "Status Viewed" as SV {
  AS --> SV : View Status
}

state "Status Checked" as SC {
  SV --> SC : Check Status
}

state "Application Cancelled" as ACN {
  LI --> ACN : Cancel Application
}

state "Details Modified" as DM {
  LI --> DM : Modify Details
}

state "Feedback Given" as FG {
  SC --> FG : Give Feedback
}

state "Status Updated" as SU {
  SV --> SU : Update Status
}

state "Logged Out" as LO {
  ACN --> LO : Logout
  DM --> LO : Logout
  FG --> LO : Logout
  SU --> LO : Logout
  LI --> LO : Logout
}

AC --> LI : Login Failed (not shown in the diagram, but implied)

note right of SV
  Based on document check, visa is either approved or rejected,
  and then status is updated.
end note

[*] --> AC : Initial State
SU --> [*] : Final State
@enduml
