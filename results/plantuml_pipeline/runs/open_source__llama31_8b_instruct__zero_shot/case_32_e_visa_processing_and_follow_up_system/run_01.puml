@startuml
state "Account Created" as AC {
  [*] --> AC
}

state "Logged In" as LI {
  AC --> LI : Login
}

state "Application Submitted" as AS {
  LI --> AS : Apply Visa
}

state "Status Viewed" as SV {
  AS --> SV : View Status
}

state "Status Checked" as SC {
  SV --> SC : Check Status
}

state "Application Cancelled" as ACN {
  LI --> ACN : Cancel Application
}

state "Details Modified" as DM {
  LI --> DM : Modify Details
}

state "Feedback Given" as FG {
  SC --> FG : Give Feedback
}

state "Status Updated" as SU {
  SV --> SU : Update Status
}

state "Logged Out" as LO {
  ACN --> LO : Logout
  DM --> LO : Logout
  FG --> LO : Logout
  SU --> LO : Logout
  LI --> LO : Logout
}

AC --> LI : Login
LI --> AS : Apply Visa
AS --> SV : View Status
SV --> SC : Check Status
SC --> FG : Give Feedback
SU --> LO : Update Status

@enduml
