@startuml
[*] --> CreateAccount : User Creates Account
CreateAccount --> Login : User Logs In After Creating Account
Login --> ApplyForVisa : User Applies for Visa After Logging In
ApplyForVisa --> PaymentMade : Payment Made For Visa Application
PaymentMade --> ApplicationAccepted : Application Accepted
ApplicationAccepted --> ViewStatus : User Views Status After Application Accepted
ViewStatus --> CheckStatus : User Checks Status After Viewing It
CheckStatus --> CancelApplication : User Cancels Application After Checking Status
CancelApplication --> Logout : User Logs Out After Canceling Application
Login --> ModifyDetails : User Modifies Details After Logging In
ModifyDetails --> Logout : User Logs Out After Modifying Details
Login --> ViewDetails : User Views Details After Logging In
ViewDetails --> Logout : User Logs Out After Viewing Details
Login --> ViewPurpose : User Views Purpose of Application After Logging In
ViewPurpose --> UpdateStatus : Status Updated Based on Document Check
UpdateStatus --> GiveFeedback : User Gives Feedback After Checking Status
GiveFeedback --> Logout : User Logs Out After Giving Feedback

state "CreateAccount" {
  [*] -> CreateAccount : 
}

state "Login" {
  CreateAccount -> Login : 
}

state "ApplyForVisa" {
  Login -> ApplyForVisa : 
}

state "PaymentMade" {
  ApplyForVisa -> PaymentMade : 
}

state "ApplicationAccepted" {
  PaymentMade -> ApplicationAccepted : 
}

state "ViewStatus" {
  ApplicationAccepted -> ViewStatus : 
}

state "CheckStatus" {
  ViewStatus -> CheckStatus : 
}

state "CancelApplication" {
  CheckStatus -> CancelApplication : 
}

state "ModifyDetails" {
  Login -> ModifyDetails : 
}

state "ViewDetails" {
  Login -> ViewDetails : 
}

state "ViewPurpose" {
  Login -> ViewPurpose : 
}

state "UpdateStatus" {
  ViewPurpose -> UpdateStatus : 
}

state "GiveFeedback" {
  UpdateStatus -> GiveFeedback : 
}

state "Logout" {
  CancelApplication -> Logout : 
  ModifyDetails -> Logout : 
  ViewDetails -> Logout : 
  GiveFeedback -> Logout : 
}
@enduml
