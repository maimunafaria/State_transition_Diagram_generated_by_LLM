@startuml
state "Off" as off {
  [*] --> off : Initial State
}

state "Alarm Set" as alarm_set {
  off --> alarm_set : User sets alarm time
}

state "Alarm Activated" as alarm_activated {
  alarm_set --> alarm_activated : Alarm activated
}

state "Alarm Ringing" as alarm_ringing {
  alarm_activated --> alarm_ringing : Current time matches set alarm time
}

state "Alarm Stopped" as alarm_stopped {
  alarm_ringing --> alarm_stopped : User stops the alarm
}

alarm_set --> alarm_activated : Alarm activated
alarm_activated --> alarm_ringing : Current time matches set alarm time
alarm_ringing --> alarm_stopped : User stops the alarm
alarm_stopped --> alarm_set : Next scheduled alarm time

off --> alarm_set : User sets alarm time
alarm_stopped --> alarm_set : Next scheduled alarm time

state "Off" as off {
  alarm_stopped --> off : Alarm stopped and next scheduled alarm time not reached yet
}

@enduml
