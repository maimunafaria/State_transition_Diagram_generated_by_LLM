@startuml
state "Idle" as s1
state "Select Amount" as s2
state "Enter Custom Amount" as s3
state "Cancel Transaction" as s4
state "Return Card" as s5

s1 ->down> s2 : User selects predefined amount option
s2 ->up> s1 : User cancels selection of predefined amount
s2 ->right> s3 : User chooses to enter custom amount
s3 ->left> s2 : User cancels input of custom amount
s3 ->down> s4 : User confirms withdrawal amount
s4 ->up> s5 : User selects cancel transaction option
s4 ->left> s1 : Transaction is cancelled and card is returned

s5 ->up> s1 : Initial state after cancelling transaction

@enduml
