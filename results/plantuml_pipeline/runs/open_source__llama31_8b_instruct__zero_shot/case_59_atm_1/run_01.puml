@startuml
state "Idle" as s1
state "Select Amount" as s2
state "Enter Custom Amount" as s3
state "Cancel Transaction" as s4
state "Transaction Complete" as s5

s1 ->down> s2 : User selects predefined amount
s2 ->up> s3 : User chooses to enter custom amount
s3 ->up> s2 : User enters valid custom amount
s2 ->right> s4 : User cancels transaction
s3 ->right> s4 : User cancels transaction while entering custom amount
s4 ->left> s1 : Transaction cancelled, return card

s2 ->down> s5 : Predefined amount selected, proceed with transaction
s3 ->down> s5 : Custom amount entered, proceed with transaction

s5 ->up> s1 : Transaction complete, system returns to idle state

@enduml
