@startuml
state "Idle" as idle {
  [*] --> chooseAmount
}
state "Choose Amount" as chooseAmount {
  chooseAmount -->|enterCustom| customAmount
  chooseAmount -->|selectPredefined| predefinedAmount
  enterCustom -->|cancel| idle
  selectPredefined -->|cancel| idle
}

state "Custom Amount" as customAmount {
  customAmount -->|confirm| withdrawMoney
  customAmount -->|cancel| idle
}
state "Withdraw Money" as withdrawMoney {
  withdrawMoney -->|returnCard| idle
}

state "Predefined Amount" as predefinedAmount {
  predefinedAmount -->|confirm| withdrawMoney
  predefinedAmount -->|cancel| idle
}

idle : Initial state
withdrawMoney : Final state

@enduml
