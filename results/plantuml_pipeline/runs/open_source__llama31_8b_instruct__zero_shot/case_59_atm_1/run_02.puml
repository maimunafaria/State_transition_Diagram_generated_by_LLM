@startuml
[*] --> ChooseWithdrawalAmount : Initial State
state "Choose Withdrawal Amount" as A {
  [*] --> SelectPredefinedAmount : User selects predefined amount
  SelectPredefinedAmount --> InputCustomAmount : User wants to input custom amount
  InputCustomAmount --> CancelTransaction : User cancels transaction
}

state "Input Custom Amount" as B {
  InputCustomAmount --> ConfirmWithdrawal : User confirms withdrawal amount
  ConfirmWithdrawal --> CancelTransaction : User cancels transaction
}

state "Cancel Transaction" as C {
  CancelTransaction --> ReturnCard : System returns card to user
}

[*] --> SelectPredefinedAmount

A -->|Confirm Withdrawal|> B
B -->|Return Card|> [*]
C -->|Return Card|> [*]

@enduml
