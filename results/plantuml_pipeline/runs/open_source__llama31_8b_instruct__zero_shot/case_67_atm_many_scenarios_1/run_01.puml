@startuml
state "Card Inserted" as s1
state "PIN Prompted" as s2
state "PIN Verified" as s3
state "Options Provided" as s4
state "Withdrawal Request Processed" as s5
state "Cash Dispensed" as s6
state "Receipt Printed" as s7
state "Card Returned" as s8
state "System Reset" as s9

s1 ->down> s2 : Card inserted, prompt PIN
s2 ->down> s3 : User enters PIN, verify against stored information
alt PIN is correct
  s3 ->down> s4 : PIN verified successfully, provide options to user
else
  s3 ->up> s2 : Invalid PIN, re-prompt user for PIN
end

s4 ->down> s5 : User selects withdrawal request option
s5 ->down> s6 : System processes withdrawal request and dispenses cash
s6 ->down> s7 : Cash is dispensed, print receipt
s7 ->down> s8 : Receipt printed, return user's card
s8 ->up> s9 : Card returned, system resets

s9 ->left> s1 : System reset, ready for next user

@enduml
