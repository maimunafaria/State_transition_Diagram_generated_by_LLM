@startuml
state "Card Inserted" as s1
state "PIN Prompted" as s2
state "PIN Verified" as s3
state "Options Provided" as s4
state "Withdrawal Request Processed" as s5
state "Cash Dispensed" as s6
state "Receipt Printed" as s7
state "Card Returned" as s8
state "System Reset" as s9

s1 ->down> s2 : Card Inserted
s2 ->down> s3 : PIN Entered
s3 ->down> s4 : PIN Verified Successfully
s4 ->down> s5 : User Approves Withdrawal Request
s5 ->down> s6 : Cash Dispensed
s6 ->down> s7 : Receipt Printed
s7 ->down> s8 : Card Returned
s8 ->down> s9 : System Reset

s3 -up-> s9 : PIN Verification Failed or Invalid
s4 -up-> s9 : User Cancels Withdrawal Request
s5 -up-> s9 : Withdrawal Request Failed or Cancelled
s6 -up-> s9 : Cash Dispensing Failed or Cancelled
s7 -up-> s9 : Receipt Printing Failed or Cancelled
s8 -up-> s9 : Card Returning Failed or Cancelled

s9 ->down> s1 : System Reset Complete

@enduml
