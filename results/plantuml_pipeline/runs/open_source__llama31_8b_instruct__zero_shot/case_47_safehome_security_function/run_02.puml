@startuml
state Ready {
  [*] --> PowerOn
  PowerOn -->|Problem During Startup| Error
  PowerOn -->|Everything Fine| Ready
}

state Error {
  Error -->|Reset| Ready
  Error -->|Activate| Ready
  Error -->|Turn Off| Ready
  Ready -->|Password Entered| Normal
}

state Normal {
  Ready -->|Reset| Ready
  Ready -->|Activate| Monitoring
  Ready -->|Turn Off| Normal
  Error -->|Password Entered| Normal
  Monitoring -->|Sensor Triggered| Alarm
  Alarm -->|False Alarm or Time Ended| Normal
}

state Monitoring {
  Monitoring -->|Sensor Triggered| Alarm
  Alarm -->|False Alarm or Time Ended| Normal
}

state Alarm {
  Alarm -->|False Alarm or Time Ended| Normal
}

@enduml
