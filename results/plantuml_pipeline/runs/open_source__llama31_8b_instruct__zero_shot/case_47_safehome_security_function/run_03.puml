@startuml
state Ready {
  [*] --> PowerOn
  PowerOn -->|Power-On Successful| Ready
  Ready --> Reset
  Ready --> Activate
  Ready --> Deactivate
}

state PoweringOff {
  Ready -->|Deactivate| PoweringOff
  PoweringOff -->|Power-Down Successful| Off
}

state Monitoring {
  Ready -->|Activate| Monitoring
  Monitoring -->|Sensor Triggered| Alarm
  Alarm -->|False Alarm or Time Ended| Ready
}

state Alarm {
  Monitoring -->|Sensor Triggered| Alarm
  Alarm -->|Password Entered| Ready
}

Ready as InitialState
Alarm as FinalState

@enduml
