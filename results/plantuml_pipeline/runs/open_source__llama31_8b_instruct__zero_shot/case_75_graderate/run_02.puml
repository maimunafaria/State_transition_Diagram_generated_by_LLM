@startuml
state "Waiting" as waiting
state "Active" as active
state "Expired" as expired
state "Archived" as archived

waiting :> [Start Date Arrives] -> active
active :> [Finish Date Reached] -> expired
expired :> [One Year from Expiration] -> archived

[*] --> waiting : Initial State
waiting --> [*] : Final State (Archived)

@enduml
