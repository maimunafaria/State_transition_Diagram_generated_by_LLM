@startuml
state "Waiting for new sale" as WaitingForNewSale
state "Adding items" as AddingItems
state "Payment pending" as PaymentPending
state "Payment approved" as PaymentApproved
state "Sale completed" as SaleCompleted

[*] --> WaitingForNewSale : 
WaitingForNewSale -->|new sale|> AddingItems : 

AddingItems -->|all items added|> PaymentPending : 

alt Cash payment
  PaymentPending -->|cash payment|> SaleCompleted : 
else Card or check payment
  PaymentPending -->|payment verification|> PaymentApproved : 
  PaymentApproved -->|approved payment|> SaleCompleted : 
endif

SaleCompleted --> [*] : 

@enduml
