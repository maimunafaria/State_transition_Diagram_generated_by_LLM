@startuml
state SaleWaiting {
  [*] --> WaitingForSale : Wait for new sale
}
state AddingItems {
  WaitingForSale --> AddingItems : Enter items one by one
  AddingItems --> PaymentAfterAddingAllItems : Move to payment after all items added
}
state PaymentVerification {
  PaymentAfterAddingAllItems --> PaymentVerification : Verify payment if customer pays by card or check
}
state SaleCompleted {
  PaymentVerification --> SaleCompleted : Complete sale once payment is approved
  PaymentAfterAddingAllItems --> SaleCompleted : Complete sale immediately if customer pays with cash
}
state WaitingForNextCustomer {
  SaleCompleted --> WaitingForNextCustomer : Return to waiting for next customer after payment finished
}

[*] --> SaleWaiting

@enduml
