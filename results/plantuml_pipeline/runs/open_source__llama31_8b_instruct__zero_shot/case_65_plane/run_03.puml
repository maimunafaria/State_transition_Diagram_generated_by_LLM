@startuml
state "Order" as Order {
  [*] --> Arrival
}
state "Arrival" as Arrival {
  Arrival --> Preparation
}
state "Preparation" as Preparation {
  Preparation --> Operations
  Preparation --> Maintenance
}
state "Operations" as Operations {
  Operations --> Preparation
  Operations --> Withdrawn
}
state "Maintenance" as Maintenance {
  Maintenance --> Preparation
  Maintenance --> Withdrawn
}
state "Withdrawn" as Withdrawn

Order --> Order : No plane delivery
Arrival --> Arrival : Plane not yet prepared
Preparation --> Operations : Plane assigned to operations
Preparation --> Maintenance : Plane assigned to maintenance
Operations --> Operations : Scheduled flights remaining
Operations --> Withdrawn : No scheduled flights or permanent withdrawal
Maintenance --> Maintenance : Plane still in maintenance
Maintenance --> Preparation : Plane ready for operations

Withdrawn --> Withdrawn : Permanent removal from service

@enduml
