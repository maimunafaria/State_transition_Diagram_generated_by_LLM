@startuml
state "Order" as order
state "Arrival" as arrival
state "Preparation" as preparation
state "Operations" as operations
state "Maintenance" as maintenance
state "Withdrawn" as withdrawn

order ->[label="Delivery"]> arrival : Delivery of plane
arrival ->[label="Arrival"]> preparation : Plane arrives at destination
preparation ->[label="Assignment"]> (operations or maintenance) : Assignment based on condition and schedule
(operations or maintenance) ->[label="Scheduled Flights"]> operations : Scheduled flights available
(operations or maintenance) ->[label="No Scheduled Flights"]> maintenance : No scheduled flights or maintenance required
maintenance ->[label="Servicing Complete"]> preparation : Servicing complete, plane ready for operations
operations ->[label="Withdrawn from Service"]> withdrawn : Plane permanently withdrawn from service

history order
history arrival
history preparation
history operations
history maintenance
history withdrawn

@enduml
