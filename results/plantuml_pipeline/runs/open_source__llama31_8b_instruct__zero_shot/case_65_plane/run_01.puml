@startuml
state "Order" as order {
  [*] --> Order : New Plane Acquisition
}

state "Arrival" as arrival {
  Order --> Arrival : Plane Arrived
}

state "Preparation" as preparation {
  Arrival --> Preparation : Transition to Preparation
}

state "Operations" as operations {
  Preparation --> Operations : Assigned to Operations
  Operations --> Maintenance : No Scheduled Flights or Maintenance Required
}

state "Maintenance" as maintenance {
  Operations --> Maintenance : Transition to Maintenance
  Maintenance --> Preparation : Checked and Serviced
}

state "Withdrawn" as withdrawn {
  Operations --> Withdrawn : Permanently Withdrawn from Service
}

order --> arrival : Plane Arrived
arrival --> preparation : Transition to Preparation
preparation --> operations : Assigned to Operations
operations --> maintenance : No Scheduled Flights or Maintenance Required
maintenance --> preparation : Checked and Serviced
operations --> withdrawn : Permanently Withdrawn from Service

@enduml
