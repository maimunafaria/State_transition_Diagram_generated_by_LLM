@startuml
state "Registration" {
  [*] --> RegistrationFailed : Registration fails
  RegistrationFailed --> EndAccess : Access ends
  RegistrationFailed --> Registered : Registration succeeds
}

state "Registered" {
  Registered --> SignIn : User signs in
  SignIn --> AccessGranted : Access granted to facilities
  AccessGranted --> NewsAndExpertContent : Users read news and expert content
  NewsAndExpertContent --> HealthInfo : Users check symptoms or use fitness checking options
  HealthInfo --> ContinueOrFinish : Users continue using the system or finish session
}

state "ContinueOrFinish" {
  ContinueOrFinish --> PaymentProcess : Users process payment for finance-related services
  PaymentProcess --> InsuranceCheck : System checks insurance for doctor consultations
  InsuranceCheck --> CompletePayment : System completes payment process
  CompletePayment --> SelectPaymentMethod : Users select payment method (cash or insurance) for drug and supplement purchases
}

state "SelectPaymentMethod" {
  SelectPaymentMethod --> CashPaymentDetails : System informs users about cash payment details if chosen as the payment method
  CashPaymentDetails --> CompleteInsurancePayment : System completes payment process for insurance-based payments
}

state "CompleteInsurancePayment" {
  CompleteInsurancePayment --> CollectFeedback : System collects user feedback after service completion
  CollectFeedback --> Logout : Users log out at end of session
}

state EndAccess {
  EndAccess --> [*] : Session ends
}

state Logout {
  Logout --> [*] : User logs out
}

[*] --> Registration : New users start registration

@enduml
