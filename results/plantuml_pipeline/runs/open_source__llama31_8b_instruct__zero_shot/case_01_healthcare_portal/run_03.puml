@startuml
state "New User" as NewUser
state "Registered User" as RegisteredUser
state "Signed In" as SignedIn
state "Access Denied" as AccessDenied
state "Session Finished" as SessionFinished
state "Payment Processed" as PaymentProcessed
state "Feedback Collected" as FeedbackCollected

[*] --> NewUser: Initial State
NewUser -->|Registration Successful|> RegisteredUser
NewUser -->|Registration Failed|> AccessDenied

RegisteredUser -->|Sign In|> SignedIn
SignedIn -->|View Facilities|> SignedIn
SignedIn -->|Read News and Expert Content|> SignedIn
SignedIn -->|Check Symptoms or Fitness|> SignedIn
SignedIn -->|Continue Using System|> SessionFinished
SignedIn -->|Finish Session|> SessionFinished

AccessDenied -->|Sign In Again|> NewUser

SessionFinished -->|Logout|> [*]

RegisteredUser -->|Process Insurance|> PaymentProcessed
PaymentProcessed -->|Check Payment with Insurance|> PaymentProcessed
PaymentProcessed -->|Complete Payment Process|> PaymentProcessed

SignedIn -->|Select Payment Method|> PaymentProcessed
PaymentProcessed -->|Inform User about Cash Payment Details|> PaymentProcessed
PaymentProcessed -->|Complete Payment Process for Insurance-Based Payments|> PaymentProcessed

PaymentProcessed -->|Collect Feedback|> FeedbackCollected
FeedbackCollected -->|Logout|> [*]

@enduml
