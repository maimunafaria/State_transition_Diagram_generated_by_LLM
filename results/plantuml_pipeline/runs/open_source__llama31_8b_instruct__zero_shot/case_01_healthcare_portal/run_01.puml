@startuml
state "Registration" {
  [*] --> RegistrationFailed : registration fails
  RegistrationFailed --> EndAccess : access ends
  RegistrationFailed --> Registered : registration succeeds
}

state "Registered" {
  Registered --> SignedIn : user signs in
  SignedIn --> AccessFacilities : user accesses facilities
  AccessFacilities --> ReadNews : user reads news and expert content
  ReadNews --> CheckSymptoms : user checks symptoms or uses fitness checking options
  CheckSymptoms --> ContinueSession : user continues session
  ContinueSession --> FinishSession : user finishes session
}

state "SignedIn" {
  SignedIn --> AccessFacilities : user accesses facilities
  AccessFacilities --> ReadNews : user reads news and expert content
  AccessFacilities --> CheckSymptoms : user checks symptoms or uses fitness checking options
  AccessFacilities --> PaymentProcess : user completes payment process for doctor consultations
}

state "PaymentProcess" {
  PaymentProcess --> InsuranceValidation : system processes insurance validation
  InsuranceValidation --> CashPaymentDetails : user selects cash as payment method
  CashPaymentDetails --> CompletePayment : system completes payment process for insurance-based payments
  CompletePayment --> CollectFeedback : system collects user feedback after service completion
}

state "EndAccess" {
  EndAccess --> [*] : session ends
}

state "FinishSession" {
  FinishSession --> EndAccess : session ends
}

state "CollectFeedback" {
  CollectFeedback --> EndAccess : session ends
}

state "CashPaymentDetails" {
  CashPaymentDetails --> CompletePayment : system completes payment process for cash payments
}

@enduml
