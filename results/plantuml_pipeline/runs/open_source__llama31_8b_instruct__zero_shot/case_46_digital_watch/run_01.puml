@startuml
state "Idle" as s1
state "Adjusting Time" as s2
state "Setting Alarm Hour" as s3
state "Setting Alarm Minutes" as s4
state "Alarm On" as s5
state "Alarm Off" as s6
state "Light On" as s7
state "Light Off" as s8

s1 -.-> s2 : Press Time Button
s2 --> s3 : Press Hour Button
s3 --> s4 : Press Minutes Button
s4 --> s2 : Press Time Button
s2 --> s5 : Set Alarm On
s5 --> s6 : Set Alarm Off
s6 --> s7 : Press Light Button
s7 --> s8 : Release Light Button
s8 --> s1 : No Action

s3 --> s1 : No Action
s4 --> s1 : No Action
s5 --> s2 : Press Time Button
s6 --> s1 : No Action
s7 --> s8 : Release Light Button
s8 --> s1 : No Action

s1 as initial
s5 as final

@enduml
