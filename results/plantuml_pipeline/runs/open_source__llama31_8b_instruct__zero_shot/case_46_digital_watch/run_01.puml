@startuml
state "Idle" as idle {
  [*] --> idle
}

state "Adjusting Time" as adjusting_time {
  idle --> adjusting_time : Press time adjustment button
  adjusting_time --> idle : Press time adjustment button again
}

state "Increasing Value" as increasing_value {
  adjusting_time --> increasing_value : Press increase value button
  increasing_value --> adjusting_time : Press decrease value button or press time adjustment button again
}

state "Setting Alarm Hour" as setting_alarm_hour {
  adjusting_time --> setting_alarm_hour : Press alarm hour button
  setting_alarm_hour --> adjusting_time : Press time adjustment button again
}

state "Setting Alarm Minute" as setting_alarm_minute {
  setting_alarm_hour --> setting_alarm_minute : Press alarm minute button
  setting_alarm_minute --> setting_alarm_hour : Press alarm hour button or press time adjustment button again
}

state "Alarm On" as alarm_on {
  setting_alarm_minute --> alarm_on : Set alarm to current time and press alarm on button
  alarm_on --> setting_alarm_minute : Press alarm off button
}

state "Alarm Ringing" as alarm_ringing {
  alarm_on --> alarm_ringing : Alarm matches current time
  alarm_ringing --> alarm_on : Press stop alarm button
}

state "Light On" as light_on {
  idle --> light_on : Press light on button
  light_on --> idle : Release light on button
}

idle --> light_on : Press light on button

@enduml
