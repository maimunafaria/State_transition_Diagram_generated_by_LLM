@startuml
[*] --> "Idle" as Initial State
state Idle {
  [*] --> "Adjusting Time"
  "Adjusting Time" --> "Switching Between Options"
}
state Switching Between Options {
  "Switching Between Options" --> "Changing Hour" : Press Hour Button
  "Switching Between Options" --> "Changing Minutes" : Press Minute Button
  "Switching Between Options" --> "Alarm Hour" : Press Alarm Hour Button
  "Switching Between Options" --> "Alarm Minutes" : Press Alarm Minute Button
}
state Changing Hour {
  "Changing Hour" --> "Increasing Value" : Press Increase Button
  "Increasing Value" --> "Adjusting Time"
}
state Changing Minutes {
  "Changing Minutes" --> "Increasing Value" : Press Increase Button
  "Increasing Value" --> "Adjusting Time"
}
state Alarm Hour {
  "Alarm Hour" --> "Turning On/Off Alarm" : Press Alarm Enable Button
  "Turning On/Off Alarm" --> "Alarm Enabled"
}
state Alarm Minutes {
  "Alarm Minutes" --> "Turning On/Off Alarm" : Press Alarm Enable Button
  "Turning On/Off Alarm" --> "Alarm Enabled"
}
state Alarm Enabled {
  "Alarm Enabled" --> "Waiting for Alarm Time Match" : Set Alarm Time Matches Current Time
  "Waiting for Alarm Time Match" --> "Alarm Triggered"
}
state Waiting for Alarm Time Match {
  "Alarm Triggered" --> "Stop Alarm" : Press Stop Alarm Button
  "Stop Alarm" --> "Idle"
}
state Increasing Value {
  "Increasing Value" --> "Adjusting Time"
}
state Turning On/Off Light {
  "Turning On/Off Light" --> "Light On" : Press Light Button
  "Light On" --> "Light Off" : Release Light Button
  "Light Off" --> "Idle"
}

[*] --> "Alarm Triggered"

@enduml
