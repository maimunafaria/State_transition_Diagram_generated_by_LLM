@startuml
state "New User" as NewUser
state "Registered User" as RegisteredUser
state "Logged In" as LoggedIn
state "Ticket Booked" as TicketBooked
state "Account Managed" as AccountManaged
state "Logged Out" as LoggedOut

[*] --> NewUser : Initial State
NewUser -->|Create Account|> RegisteredUser
RegisteredUser -->|Validate Registration|> RegisteredUser
RegisteredUser -->|Login|> LoggedIn
LoggedIn -->|Check Ticket Status|> LoggedIn
LoggedIn -->|Book Ticket|> TicketBooked
TicketBooked -->|Confirm Payment|> TicketBooked
TicketBooked -->|Logout|> LoggedOut
LoggedIn -->|Manage Account|> AccountManaged
AccountManaged -->|Save Changes|> RegisteredUser
RegisteredUser -->|Logout|> LoggedOut

[*] --> TicketBooked : Final State
[*] --> AccountManaged : Final State
[*] --> LoggedOut : Final State

@enduml
