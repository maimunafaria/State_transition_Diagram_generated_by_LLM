@startuml
state "New User" as NewUser {
  [*] --> CreateAccount : Create Account
}
state "Registered User" as RegisteredUser {
  CreateAccount --> ValidateRegistration : Validate Registration
  ValidateRegistration --> Login : Successful Registration
  Login --> CheckTicketStatus : Logged In
  Login --> BookTicket : Logged In
  CheckTicketStatus --> Logout : Complete Action
  BookTicket --> PaymentConfirmation : Confirm Ticket and Pay
  PaymentConfirmation --> Logout : Complete Action
}
state "Logged Out" as LoggedOut {
  Logout --> [*] : Log Out
}

NewUser ->> RegisteredUser : Successful Registration
RegisteredUser ->> NewUser : Failed Registration
RegisteredUser ->> RegisteredUser : Login Success
RegisteredUser ->> LoggedOut : Logout

@enduml
