@startuml
state "New User" as NewUser
state "Registered User" as RegisteredUser
state "Logged In" as LoggedIn
state "Ticket Booked" as TicketBooked
state "Account Managed" as AccountManaged
state "Logged Out" as LoggedOut

NewUser ->> RegisteredUser : Successful Registration
note right of RegisteredUser: Validate registration (FR2)

RegisteredUser ->> LoggedIn : Successful Login
note right of LoggedIn: User logs in successfully (FR3)

LoggedIn ->> TicketBooked : Book Ticket
note right of TicketBooked: Confirm ticket and make payment (FR5)
LoggedIn ->> AccountManaged : Manage Account
note right of AccountManaged: Edit or delete account details (FR6)

TicketBooked ->> LoggedOut : Complete Action
note right of LoggedOut: Log out user after completing action (FR7)

AccountManaged ->> LoggedOut : Complete Action
note right of LoggedOut: Log out user after completing action (FR7)

LoggedIn ->> RegisteredUser : Logout and Return to Registration
note right of RegisteredUser: User can log back in if logged out

RegisteredUser ->> NewUser : Logout and Return to New User
note right of NewUser: User can create a new account if logged out

NewUser ->> LoggedOut : Cancel Account Creation
note right of LoggedOut: User cancels account creation

LoggedIn ->> TicketBooked : Check Ticket Status
note right of TicketBooked: Provide options for checking ticket status (FR4)

state NewUser {
  [*] --> NewUser : Initial State
}

state RegisteredUser {
  RegisteredUser --> LoggedIn : Successful Login
  RegisteredUser --> NewUser : Logout and Return to New User
  RegisteredUser --> LoggedOut : Complete Action
}

state LoggedIn {
  LoggedIn --> TicketBooked : Book Ticket
  LoggedIn --> AccountManaged : Manage Account
  LoggedIn --> LoggedOut : Complete Action
  LoggedIn --> RegisteredUser : Logout and Return to Registration
}

state TicketBooked {
  TicketBooked --> LoggedOut : Complete Action
  TicketBooked --> LoggedIn : Check Ticket Status
}

state AccountManaged {
  AccountManaged --> LoggedOut : Complete Action
}

state LoggedOut {
  [*] --> NewUser : Initial State
  NewUser --> RegisteredUser : Successful Registration
  RegisteredUser --> LoggedIn : Successful Login
  LoggedIn --> TicketBooked : Book Ticket
  LoggedIn --> AccountManaged : Manage Account
  TicketBooked --> LoggedOut : Complete Action
  AccountManaged --> LoggedOut : Complete Action
}

@enduml
