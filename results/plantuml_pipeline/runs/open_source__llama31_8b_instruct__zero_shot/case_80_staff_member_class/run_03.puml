@startuml
state "Unassigned" as unassigned
state "Assigned to Client" as assigned_to_client
state "Assigned to Campaign" as assigned_to_campaign
state "Archived" as archived
state "Employed" as employed

unassigned ->* assigned_to_client : Assign to client
unassigned ->* assigned_to_campaign : Add to campaign

assigned_to_client ->* unassigned : Remove from client
assigned_to_campaign ->* unassigned : Remove from campaign

assigned_to_client ->* assigned_to_campaign : Switch to campaign
assigned_to_campaign ->* assigned_to_client : Switch to client

employed -> archived : Leave job after some time has passed

unassigned -> employed : Hire new staff member
archived -> unassigned : Unarchive record

note right of unassigned: Initial state
note bottom of archived: Final state
@enduml
