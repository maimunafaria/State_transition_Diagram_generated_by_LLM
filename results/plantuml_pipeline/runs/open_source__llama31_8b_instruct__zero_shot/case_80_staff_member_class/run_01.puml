@startuml
state Unassigned {
  [*] --> Unassigned : Initial State
}
state Assigned {
  Unassigned -->* Assigned : Assign to client or campaign
  Assigned -->* Unassigned : Remove assignment
  Assigned -->* Assigned : Switch assignments
}
state Archived {
  Unassigned -->* Archived : Staff member leaves job (unemployed)
  Assigned -->* Archived : Staff member leaves job (unemployed)
}

note "After some time, archive record of former employee" as note1

Unassigned -->* Archived : Time passed (archive record)

@enduml
