@startuml
state Unassigned {
  [*] --> Unassigned
}
state Assigned {
  Unassigned -->^[]: Assign to Client or Campaign
  Unassigned -->^[]: Switch Assignment
  Assigned -->^[]: Remove Assignment
  Assigned -->^[]: Switch Assignment
}

state Archived {
  Assigned -->^[]: Archive Record after Time Passed
}

state Unemployed {
  Assigned -->^[]: Mark as Unemployed when Leave Job
  Unemployed -->^[]: Archive Record after Time Passed
}

Unassigned --> Assigned : Assign to Client or Campaign
Unassigned --> Assigned : Add to Campaign
Assigned --> Unassigned : Remove Assignment
Assigned --> Archived : Switch Assignment and then Archive Record
Archived --> Unemployed : Mark as Unemployed when Leave Job
Unemployed --> Archived : Archive Record after Time Passed

@enduml
