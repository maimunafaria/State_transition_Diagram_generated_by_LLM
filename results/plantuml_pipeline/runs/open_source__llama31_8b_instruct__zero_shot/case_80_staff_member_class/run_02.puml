@startuml
state Unassigned {
  [*] --> Unassigned
}
state Assigned {
  Unassigned -->^[*]: Assign
  Assigned -->^[*]: Reassign
  Assigned -->^[*]: Remove
}

state Archived {
  Assigned -->^[*]: LeaveJob
  Archived -->^[*]: Archive
}

Unassigned --> Assigned: Assign
Assigned --> Unassigned: Remove
Assigned --> Assigned: Reassign
Assigned --> Archived: LeaveJob

Archived --> Unassigned: Archive

@enduml
