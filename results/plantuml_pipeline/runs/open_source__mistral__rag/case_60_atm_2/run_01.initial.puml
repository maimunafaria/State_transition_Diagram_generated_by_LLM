@startuml
title ATM State Machine for Withdrawal

[*] --> SelectAmount

state "SelectAmount"
state "VerifyTransaction"
state "RejectedAmount"
state "ReturnCard"

SelectAmount --> VerifyTransaction : validAmount
SelectAmount --> RejectedAmount : invalidAmount

RejectedAmount --> SelectAmount : reEnterAmount

VerifyTransaction --> ReturnCard : approvedWithdrawal
VerifyTransaction --> RejectedAmount : rejectedWithdrawal

ReturnCard --> [*] : returnCard
@enduml
