@startuml
title UML State Chart Diagram for Process Sale

[*] --> WaitingForSale

state "Waiting for Customer" as WaitingCustomer
state "Recording Items" as RecordingItems
state "Waiting for Payment" as WaitingPayment
state "Payment Verification" as PaymentVerification
state "Payment Completed" as PaymentCompleted
state "Return to Waiting" as ReturnToWaiting

WaitingForSale --> WaitingCustomer

WaitingCustomer --> RecordingItems : item selected
RecordingItems --> RecordingItems : item added
RecordingItems --> WaitingPayment : all items added
WaitingPayment --> PaymentVerification : payment method chosen

PaymentVerification --> PaymentCompleted : approved
PaymentVerification --> ReturnToWaiting : denied

PaymentCompleted --> ReturnToWaiting
ReturnToWaiting --> [*]
@enduml
