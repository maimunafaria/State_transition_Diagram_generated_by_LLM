@startuml
[*] --> StaffMember

state StaffMember {
  [*] --> Assigned
  Assigned --> [*] : removed
  Assigned --> [*] : switchAssignment

  state Unassigned {
    [*] --> Unassigned
    Unemployed --> Unassigned : markUnemployed
  }

  state Employed {
    [*] --> Employed
    Employed --> Unemployed : markUnemployed
  }

  Employed --> Assigned : assignedToClient
  Employed --> Assigned : addedToCampaign

  Assigned --> Employed : switchAssignment
  Assigned --> Unemployed : markUnemployed
  Unemployed --> Unassigned : markUnemployed
  Unassigned --> Employed : hireStaffMember
  Unemployed --> Employed : rehireStaffMember
}

Unemployed --> [*] : archiveRecord
@enduml
