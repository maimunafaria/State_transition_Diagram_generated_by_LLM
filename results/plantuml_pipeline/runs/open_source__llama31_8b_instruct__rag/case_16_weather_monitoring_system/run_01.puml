@startuml
[*] --> CreateAccount
state CreateAccount {
  [*] --> Login
  Login --> Dashboard : login successful
  Dashboard --> Dashboard : logged in
}

state Dashboard {
  Dashboard --> ViewWeather : view weather
  ViewWeather --> Dashboard : view weather
}

state ViewWeather {
  ViewWeather --> SelectLocation : select location
  SelectLocation --> ViewWeather : select location
}

state SelectLocation {
  SelectLocation --> ViewWeather : select location
  ViewWeather --> SelectWeather : select weather
}

state SelectWeather {
  SelectWeather --> ViewWeather : select weather
  ViewWeather --> ViewDetails : view details
}

state ViewDetails {
  ViewDetails --> Dashboard : view details
  Dashboard --> Logout : logout
}

state Logout {
  Logout --> [*] : logout
}

CreateAccount --> Login : create account
Login --> Dashboard : login successful
Dashboard --> ViewWeather : view weather
ViewWeather --> SelectLocation : select location
SelectLocation --> ViewWeather : select location
ViewWeather --> SelectWeather : select weather
SelectWeather --> ViewWeather : select weather
ViewWeather --> ViewDetails : view details
ViewDetails --> Dashboard : view details
Dashboard --> Logout : logout
Logout --> [*] : logout

@enduml
