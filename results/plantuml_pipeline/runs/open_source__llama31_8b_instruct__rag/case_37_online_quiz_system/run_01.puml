@startuml
title Online Quiz System

state "Register" as Register
state "Login" as Login
state "Teacher" as Teacher
state "Student" as Student
state "Create Quiz" as CreateQuiz
state "Edit Quiz" as EditQuiz
state "Save Quiz" as SaveQuiz
state "Post Quiz" as PostQuiz
state "View Results" as ViewResults
state "Select Quiz" as SelectQuiz
state "Answer Quiz" as AnswerQuiz
state "Submit Quiz" as SubmitQuiz
state "View Result" as ViewResult

[*] --> Register

Register --> Login
Login --> [*] : [Invalid Credentials]
Login --> Teacher : [Valid]
Login --> Student : [Valid]

Teacher --> CreateQuiz
Teacher --> EditQuiz
Teacher --> SaveQuiz
Teacher --> PostQuiz
Teacher --> ViewResults

Student --> SelectQuiz
Student --> AnswerQuiz
Student --> SubmitQuiz
Student --> ViewResult

CreateQuiz --> EditQuiz
EditQuiz --> SaveQuiz
SaveQuiz --> PostQuiz
PostQuiz --> ViewResults

SelectQuiz --> AnswerQuiz
AnswerQuiz --> SubmitQuiz
SubmitQuiz --> ViewResult

@enduml
