@startuml
[*] --> Idle
Idle --> [*]

state Idle {
  [*] --> Restart
  Restart --> Running : restart
  Running --> [*]
}

state Running {
  [*] --> CollectData
  CollectData --> Running : collectData
  Running --> [*]
}

state Running {
  [*] --> PrepareSummary
  PrepareSummary --> Running : prepareSummary
  Running --> [*]
}

state Running {
  [*] --> CheckStatus
  CheckStatus --> Running : checkStatus
  Running --> [*]
}

state Running {
  [*] --> ControlledMode
  ControlledMode --> Running : controlledMode
  Running --> [*]
}

state Running {
  [*] --> Shutdown
  Shutdown --> Idle : shutdown
  Idle --> [*]
}

@enduml
