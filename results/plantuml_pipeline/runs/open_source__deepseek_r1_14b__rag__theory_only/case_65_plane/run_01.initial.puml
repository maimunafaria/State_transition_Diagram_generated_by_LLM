@startuml
state Order {
  [*] --> self : initial state
}
Order --> Arrival : delivered
Arrival --> Preparation : arrival processed
Preparation -> Operations : assigned to operations
Preparation -> Maintenance : assigned to maintenance
Operations: while has scheduled flights
Operations --> Maintenance : no more flights or maintenance required
Maintenance --> Preparation : serviced
Operations --> OutOfService : unavailable
Preparation --> OutOfService : unavailable
Arrival --> OutOfService : unavailable
Order --> OutOfService : unavailable
state Retired {
  Operations --> Retired : permanently withdrawn
}
@enduml
