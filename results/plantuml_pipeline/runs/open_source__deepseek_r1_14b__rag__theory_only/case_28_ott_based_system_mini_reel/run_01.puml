@startuml
state unauthenticated {
  [*] --> createAccount --> authenticated
}
state authenticated {
  --> watchVideo
  --> uploadVideo
}
state watchingVideo {
  state likeVideo {
    --> viewLikes
    --> enterDiscussion
    --> watchingVideo
  }
  state viewLikes {
    --> backToWatching
    --> enterDiscussion
  }
  when saveVideo --> likeVideo
  when viewSaved --> viewLikes
  when continueWatching --> itself
}
state uploadedVideo {
  --> watchVideo
}
state likedVideo {
  --> watchVideo
}
@enduml
