@startuml
state "Start" {
    [*] --> LoginScreen
}
state "LoginScreen" {
    login --> MainMenu
}
state "MainMenu" {
    on "select market condition" --> MarketReport
    on "select pest control help" --> PestControl
    on "select soil information" --> SoilSuggestions
    on "select weather insights" --> WeatherInsights
    on "select labour availability" --> LabourAvailability
}
state "MarketReport" {
    after viewing report, on "continue" --> MainMenu
    after viewing report, on "logout" --> EndSession
}
state "PestControl" {
    after viewing techniques, on "continue" --> MainMenu
    after viewing techniques, on "logout" --> EndSession
}
state "SoilSuggestions" {
    after receiving suggestions, on "continue" --> MainMenu
    after receiving suggestions, on "logout" --> EndSession
}
state "WeatherInsights" {
    after viewing insights, on "continue" --> MainMenu
    after viewing insights, on "logout" --> EndSession
}
state "LabourAvailability" {
    after viewing details, on "continue" --> MainMenu
    after viewing details, on "logout" --> EndSession
}
state "EndSession" {
    end
}
@enduml
