@startuml
[*] --> Start: start
Start:
    --> AddingGoods : add
    --> UpdatingPrices : update_price
    --> RemovingGoods : remove
    --> IdentifyingExpiredGoods : identify_expired
    --> PlacingOrder : place_order
    --> SearchingItems : search
    --> CalculatingDiscountsTaxes : calculate
    --> GeneratingReceipt : generate_receipt
    --> ReplacingCancelingReceipt : replace_cancel
    --> RecordingRequests : record_request
    --> ViewingSummaries : view_summary

AddingGoods:
    transition: add_goods; exit to Start

UpdatingPrices:
    transition: update_price; exit to Start

RemovingGoods:
    transition: remove; exit to Start

IdentifyingExpiredGoods:
    transition: identify_expired; exit to Start

PlacingOrder:
    --> GeneratingInvoice : generate_invoice
GeneratingInvoice:
    transition: invoice_generated; exit to Start

SearchingItems:
    transition: search_items; exit to CalculatingDiscountsTaxes

CalculatingDiscountsTaxes:
    transition: calculate_discount_tax; exit to GeneratingReceipt

GeneratingReceipt:
    --> ReplacingCancelingReceipt : replace_cancel_receipt
ReplacingCancelingReceipt:
    transition: replace_or_cancel; exit to Start

RecordingRequests:
    transition: record_request; exit to Start

ViewingSummaries:
    transition: view_summary; exit to Start

enduml
@enduml
