@startuml
state Normal {
  [*] --> Normal : start
}

state AdjustingTime {
  when button pressed: --> Normal
}

state AlarmOn {
  when alarm off pressed: --> AlarmOff
}

state AlarmOff {
  when alarm on pressed: --> AlarmOn
}

state LightOn {
  when button released: --> LightOff
}

state LightOff {
  when button pressed: --> LightOn
}

Normal --> AdjustingTime : adjust settings pressed
AdjustingTime --> Normal : exit adjustment
AlarmOn --> AlarmOff : disable alarm
LightOn --> LightOff : release button
LightOff --> LightOn : press button
@enduml
