@startuml
state Start {
  [*] --> CreateAccount : "Create Account"
}
state LoggedIn {
  --> ApplyForVisa : "Apply for Visa"
  --> ModifyDetails : "Modify Details"
  --> ViewDetails : "View Details"
  --> CancelApplication : "Cancel Application"
  --> CheckStatus : "Check Status"
}
state ApplicationProcessing {
  --> StatusChecked : "Payment Completed & Accepted"
}
state StatusChecked {
  --> GiveFeedback : "Give Feedback"
}
state GiveFeedback {
  --> Logout : "Logout after Feedback"
}
state Logout {
}

@enduml
