@startuml
state Homepage {
  [*] -->Homepage: start
}
state Projects {
  Homepage --> Projects: click Navigation Bar
  Projects --> ProjectInfo: select project
  ProjectInfo --> Photos: choose photos
  ProjectInfo --> Videos: choose videos
}
state Career {
  Homepage --> Career: click Navigation Bar
  Career --> CareerInfo: select career opportunity
  CareerInfo --> Updates: view updates
  CareerInfo --> ApplicationForm: open application form
}
state SubmittedApplication {
  ApplicationForm --> SubmittedApplication: submit application
}
@enduml
