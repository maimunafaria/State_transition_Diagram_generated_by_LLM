@startuml
hide empty description

skinparam packageStyle rectangle
skinparam arrowKeys true

package System {
    State Login as "User Logged Out" {
        [*] -> Login: User logs in
        Login: JourneyDetailsDisplayed(JourneyDetails)
        Login: DrivingModeActivated(DrivingMode) | ChooseOption(OtherOptions)
        Login: PlaceToEatSelected(PlaceToEat) -> EatingPlace
        PlaceToEat: MenuViewed(Menu)
        PlaceToEat: OrderPlaced(Order)
        EatingPlace: Satisfied(Feedback) | Dissatisfied(Feedback)
        Feedback: Sent(Notification)
    }

    State Accident as "Accident Occurred" {
        EatingPlace: AccidentOccurs(Accident) -> Accident
        Accident: NotificationSent(Notification)
        Accident: RelevantAuthoritiesInformed(RelevantAuthorities)
    }

    State DrivingMode as "Driving Mode Active" {
        Login: DrivingModeActivated(DrivingMode)
        DrivingMode: NotificationSent(Notification) | AccidentOccurs(Accident) -> Accident
        DrivingMode: JourneyCompleted(JourneyCompleted)
        JourneyCompleted: FeedbackProvided(Feedback)
    }
}

@enduml
