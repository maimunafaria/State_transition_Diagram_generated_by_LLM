@startuml
hide empty description

skinparam fontSize 14

state "Idle" {
    [Select Amount] -> Idle: Select Amount Option
    State "Select Amount Option" {
        Note over Idle, Select Amount Option: List of options provided
        State "Selected Amount Option" {
            Note over Selected Amount Option: Amount verified
            State "Amount Verified" {
                Note over Amount Verified: Transaction accepted
                "Transaction Accepted"
            }
            State "Amount Rejected" {
                Note over Amount Rejected: Re-enter amount
                "Re-Enter Amount" -> Amount Rejected: User re-enters amount
            }
        }
    }
}
@enduml
