@startuml
hide empty package

skinparam backgroundColor #f2f2f2
skinparam fontName Arial
skinparam lineWidth 3

package "Ott Based System" {
    State "Unregistered" as U
    State "Registered" as R
    State "WatchingVideo" as WV
    State "UploadingVideo" as UV
    State "SavingVideo" as SV
    State "ViewingLikes" as VL
    State "InDiscussion" as ID

    U -- Registered: Create Account: createAccount:r1
    R -- WatchingVideo: Watch Video: watchVideo:r2
    WV -- SavingVideo: Save Video: saveVideo:r3
    WV -- ViewingLikes: Go to Likes List: goToLikesList:r4
    SV -- Registered: Upload Successful: uploadSuccessful:r5
    ID -- * : Exit Discussion: exitDiscussion:r6
}
@enduml
