@startuml
hide empty package

skinparam packageStyle rectangular
skinparam packageColor #F8F

package "System States" {
    State Login
    State MainArea
    State MarketConditions
    State MarketReport
    State PestControlHelp
    State PestControlTechniques
    State SoilInfo
    State WeatherInsights
    State LabourAvailability
    State ServiceContinue
    State SessionEnded
}

Login --> MainArea: User signs in
MainArea --|> MarketConditions: User selects market conditions
MainArea --|> PestControlHelp: User selects pest control help
MainArea --|> SoilInfo: System receives soil information from user
MainArea --|> WeatherInsights: System provides location
LabourAvailability --|> ServiceContinue: User views labour availability details
SessionEnded --> SessionEnded: User logs out

MarketConditions --|> MarketReport: Customer selects market report
PestControlHelp --|> PestControlTechniques: System requires user to provide a photo
ServiceContinue --|> MainArea: Users continue using the service

@enduml
