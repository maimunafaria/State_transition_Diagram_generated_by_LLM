@startuml
hide empty package

package Campaign {
  state NotStarted {
    [Manager and Staff Assigned] --> NotStarted : Trigger 1
  }

  state PendingApproval {
    NotStarted --> PendingApproval : Trigger 2
    PendingApproval --> NotStarted : Contract Not Signed
    PendingApproval --> Activated : Contract Signed
  }

  state PreparingAdverts {
    Activated --> PreparingAdverts : Adverts Prepared
  }

  state ApprovingAndSchedulingAdverts {
    PreparingAdverts --> ApprovingAndSchedulingAdverts : Adverts Approved and Scheduled
  }

  state RunningAdverts {
    ApprovingAndSchedulingAdverts --> RunningAdverts : Adverts Running
    RunningAdverts --> AdjustingCampaign : Campaign Adjusted or Extended
  }

  state CompletingCampaign {
    RunningAdverts *-- CompletingCampaign : All Adverts Finished
    CompletingCampaign --> FinalStatementPreparation : Trigger 7
  }

  state PaymentHandling {
    CompletingCampaign --> PaymentHandling : Campaign Completed
    PaymentHandling *-- Refund : Amount Paid < Required Amount
    PaymentHandling *-- WaitingForSettlement : Amount Paid > Required Amount
    WaitingForSettlement --> MarkedAsPaid : Correct Balance Settled
  }

  state Archived {
    MarkedAsPaid --> Archived : Trigger 11
  }
}
@enduml
