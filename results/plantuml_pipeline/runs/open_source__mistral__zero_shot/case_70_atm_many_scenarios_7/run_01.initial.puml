@startuml
hide empty package

package ATM {
  state Arrived {
    [*] -> Arrived: Greet user
    Arrived: Insert card -> CardInserted
    CardInserted: Enter PIN -> CorrectPIN
    CardInserted: Enter PIN * IncorrectPIN -> IncorrectPIN
  }

  state CardInserted {
    CardInserted: IncorrectPIN n times -> CardRetained
  }

  state IncorrectPIN {
    IncorrectPIN: Try again -> CardInserted
    IncorrectPIN * Maximum attempts -> CardRetained
  }

  state CorrectPIN {
    CorrectPIN: Display options -> ChooseOption
  }

  state ChooseOption {
    ChooseOption: Select request -> ProcessRequest
    ChooseOption: Cancel operation -> ReturnCard
  }

  state CardRetained {
    [*] -> CardRetained
  }

  state ReturnCard {
    [*] -> ReturnCard
  }

  state ProcessRequest {
    [*] -> ProcessRequest
  }
}
@enduml
