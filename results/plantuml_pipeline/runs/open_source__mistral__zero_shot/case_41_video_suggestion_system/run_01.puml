@startuml
hide empty description

skinparam backgroundColor #F2F2F2
skinparam fontName Arial
skinparam fontSize 14

title Video Suggestion System

state "Idle" as idle
state "RequestReceived" as requestReceived
state "GatheringVideos" as gatheringVideos
state "ProcessingVideos" as processingVideos
state "SendingVideos" as sendingVideos
state "VideoSent" as videoSent

idle -> requestReceived: Receive Video Suggestion Request
requestReceived -> gatheringVideos: Identify User & Gather Videos
gatheringVideos -> processingVideos: Add Details to Videos
processingVideos -> sendingVideos: Processed Videos Ready
sendingVideos -> videoSent: Sent Video to User
videoSent -> idle: Wait for Next Request

@enduml
