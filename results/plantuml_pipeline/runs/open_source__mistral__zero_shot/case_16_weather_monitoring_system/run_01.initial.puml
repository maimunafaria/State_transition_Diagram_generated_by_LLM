@startuml
hide empty package

skinparam packageStyle rectangular
skinparam packagePadding 5mm

package "Weather Monitoring System" {
    state "NotRegistered"
    state "LoggedIn"
    state "InvalidLocation"
    state "ValidLocation"
    state "ChoosingParameter"
    state "ViewingDetails"
    state "LoggedOut"
}

"NotRegistered" -- "LoggedIn": register: User enters credentials and registers
"LoggedIn" -- "InvalidLocation": enterLocation: User enters an invalid location
"InvalidLocation" -- "LoggedIn": retry: User chooses to re-enter a valid location
"LoggedIn" -- "ValidLocation": validateLocation: System verifies the entered location is valid
"ValidLocation" -- "ChoosingParameter": chooseParameter: User selects what to check (temperature, humidity, rainfall, pressure, or dew point)
"ValidLocation" -- "ViewingDetails": showWeatherInfo: System shows the selected weather information
"ViewingDetails" -- "ViewingDetails": viewAdditionalDetails: User chooses to view additional details
"LoggedIn" -- "LoggedOut": logout: User logs out of their account

@enduml
