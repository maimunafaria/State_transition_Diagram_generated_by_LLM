@startuml
hide empty package

skinparam packageStyle rectangle
skinparam packageFillColor #f2f2f2

package "User Account" {
    State AccountCreated
    State LoggedIn
}

package "Visa Application" {
    State ApplicationSubmitted
    State PaymentMade
    State ApplicationAccepted
    State ApplicationRejected
    State ApplicationCancelled
    State FeedbackGiven
}

package "Status Check" {
    State StatusViewed
    State StatusChecked
}

package "User Details" {
    State DetailsModified
    State DetailsViewed
}

AccountCreated -- LoggedIn: Login
LoggedIn -- ApplicationSubmitted: ApplyForVisa
ApplicationSubmitted -- PaymentMade: MakePayment
PaymentMade -- ApplicationAccepted: AcceptApplication
ApplicationAccepted -- StatusViewed: ViewStatus
StatusViewed -- StatusChecked: CheckStatus
StatusChecked -- FeedbackGiven: GiveFeedback

LoggedIn -- ApplicationRejected: VisaRejected
ApplicationRejected -- StatusViewed: ViewStatus

LoggedIn -- ApplicationCancelled: CancelApplication

DetailsModified -- DetailsViewed: ViewDetails

@enduml
