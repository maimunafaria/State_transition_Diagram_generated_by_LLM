@startuml
hide empty description

skinparam diagramFontSize 14

state "Inserted" {
    [PIN Entered] -> "Inserted": Enter PIN
}

state "Verifying" {
    "Inserted" --> "Verifying": Verify PIN
}

state "Approved" {
    "Verifying" --> "Approved": Successful Verification
    "Approved" --> "Processing": Process Withdrawal Request
}

state "Processing" {
    "Approved" --> "Processing": Processing
    "Processing" --> "Dispensing Cash": Dispense Cash
    "Processing" --> "Printing Receipt": Print Receipt
}

state "Dispensing Cash" {
    "Processing" --> "Dispensing Cash": Dispensing Cash
    "Dispensing Cash" --> "Printing Receipt": Print Receipt
}

state "Printing Receipt" {
    "Dispensing Cash" --> "Printing Receipt": Printing Receipt
    "Printing Receipt" --> "Returning Card": Return User's Card
}

state "Returning Card" {
    "Printing Receipt" --> "Returning Card": Returning Card
    "Returning Card" --> "Resetting": Reset System
}

state "Resetting" {
    "Returning Card" --> "Resetting": Resetting
    "Resetting" --> "Ready": Become Ready for Next User
}

state "Ready" {
    "Resetting" --> "Ready": Ready
}

@enduml
