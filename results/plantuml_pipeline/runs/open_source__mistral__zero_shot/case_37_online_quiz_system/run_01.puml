@startuml
hide empty package

skinparam packageStyle rectangular
skinparam packageFillColor #f2f2f2

package "Online Quiz System" {
    state LoginScreen {
        [*] -login : User enters login details
        Teacher -teachLogin : Teacher logs in
        Student -studyLogin : Student logs in
    }

    state TeacherDashboard {
        TeacherLogin -createQuiz : Teacher creates a new quiz
        TeacherLogin -editQuiz : Teacher edits an existing quiz
        TeacherLogin -saveDraft : Teacher saves a quiz as a draft
        TeacherLogin -postQuiz : Teacher posts a quiz for students
    }

    state StudentDashboard {
        StudentLogin -getNotified : Student gets notified of available quizzes
        StudentLogin -selectQuiz : Student selects a quiz
        StudentLogin -answerQuiz : Student answers the selected quiz
        StudentLogin -submitQuiz : Student submits their quiz
        StudentLogin -viewResult : Student views their result after submitting the quiz
    }

    state TeacherResults {
        PostQuiz -viewResults : Teacher views quiz results once the quiz is over
    }
}

@enduml
