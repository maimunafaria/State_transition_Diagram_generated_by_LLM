@startuml
hide empty package

skinparam ascii

package System {
    State PowerOn {
        [Initial]
        State StartupChecking
        State ReadyToUse[Ready to Use]
        State Resetting
        State Activating
        State Deactivating
        State Monitoring
        State AlarmTriggered
        State FalseAlarmOrTimeEnd
        State Normal
    }

    State PowerOff {
        [Final]
    }
}

System.PowerOn::StartupChecking:PowerOn -> System.PowerOn::StartupChecking:ProblemDuringStartup
System.PowerOn::StartupChecking:NoProblem -> System.PowerOn::ReadyToUse

System.PowerOn::ReadyToUse:Reset -> System.PowerOn::Resetting
System.PowerOn::ReadyToUse:Activate -> System.PowerOn::Activating
System.PowerOn::ReadyToUse:Deactivate -> System.PowerOn::Deactivating
System.PowerOn::Deactivating:EnterPassword -> System.PowerOn::Normal

System.PowerOn::Activating:Monitor -> System.PowerOn::Monitoring

System.PowerOn::Monitoring:SensorTriggered -> System.PowerOn::AlarmTriggered
System.PowerOn::Monitoring:FalseAlarmOrTimeEnd -> System.PowerOn::FalseAlarmOrTimeEnd

System.PowerOn::AlarmTriggered:EnterPassword -> System.PowerOn::Normal

System.PowerOn::FalseAlarmOrTimeEnd:ContinueMonitoring -> System.PowerOn::Monitoring

System.PowerOn::Deactivating:EnterPassword -> System.PowerOn::Normal
System.PowerOn::Normal:PowerOff -> System.PowerOff:Final
@enduml
