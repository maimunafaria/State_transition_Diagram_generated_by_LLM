@startuml
hide empty package

skinparam packageStyle rectangular
skinparam packageFillColor #f2f2f2

package WeatherStation {
    state ShutDown {
        [Shut Down]
        _shutdown(black)
    }

    state Running {
        [Running]
        _running(black)
    }

    state ConfigMode {
        [Configuration Mode]
        _config(black)
    }

    state ControlledMode {
        [Controlled Mode]
        _controlled(black)
    }

    Running -- ShutDown: Triggered by shutdown command: shutdown
    ShutDown -- Running: Triggered by power on: powerOn

    Running -- ConfigMode: Triggered by configuration changes or power-saving settings: configChange
    ConfigMode -- Running: Triggered by completion of configuration: configComplete

    Running -- ControlledMode: Triggered by remote control command: remoteControl
    ControlledMode -- Running: Triggered by end of controlled mode operation

    Running -- Running: Triggered by clock tick: clockTick
    Running -- Running: Triggered by data collection, summary preparation, or status checking: activity
}
@enduml
