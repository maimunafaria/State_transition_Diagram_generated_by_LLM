@startuml
hide empty description

skinparam fontSize 14

state Waiting {
    [Waiting]
}

state Active {
    [Active]
}

state Expired {
    [Expired]
}

state Archived {
    [Archived]
}

state StartDateReached [Start Date Reached]
state EndOfValidityReached [End of Validity Reached]
state FinishDateReached [Finish Date Reached]
state OneYearPassed [One Year Passed]

Waiting -- StartDateReached: Trigger(Start Date Arrival)
StartDateReached -- Active: Transition(Activation)
Active -- EndOfValidityReached: Transition(End of Validity Reach)
Expired -- OneYearPassed: Transition(One Year Passed)
Archived -- uml:hidden

@enduml
