@startuml
hide empty package

skinparam packageStyle rectangular
skinparam packagePadding 5mm

package System {
    state Off {
        [*] -> Off: Initial State
        AlarmSet -> Active(Alarm Set)
    }

    state Active {
        Off -> Active(User Sets Alarm): User sets alarm time
        Active -> Ringing(Current Time matches Alarm Time): Current time equals alarm time
        Ringing -> Stopped(User stops the alarm): User stops the ringing alarm
        Stopped -> Off: Alarm turned off
    }
}
@enduml
