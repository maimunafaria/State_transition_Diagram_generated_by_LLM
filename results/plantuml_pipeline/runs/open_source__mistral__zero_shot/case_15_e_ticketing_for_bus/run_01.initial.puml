@startuml
hide empty package

skinparam packageStyle rectangle
skinparam packageFillColor #f2f2f2

package "User Account" {
    State Unregistered
    State Registering
    State Registered
    State LoggedIn
    State TicketStatusCheck
    State BookingTicket
    State PaymentConfirmation
    State ManagingAccount
    State LoggedOut
}

Unregistered -- Registering: Register
Registering --|> Registered: RegistrationSuccess
Registered -- LoggedIn: Login
LoggedIn -- TicketStatusCheck: CheckTicketStatus
LoggedIn -- BookingTicket: BookTicket
BookingTicket -- PaymentConfirmation: PaymentConfirmed
PaymentConfirmation -- ManagingAccount: PaymentCompleted
ManagingAccount --|> Registered: AccountModified
ManagingAccount -- LoggedOut: Logout

@enduml
