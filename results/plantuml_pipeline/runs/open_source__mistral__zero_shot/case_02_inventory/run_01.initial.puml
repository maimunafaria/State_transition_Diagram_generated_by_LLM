@startuml
hide empty package

package InventorySystem {
  state InitialState {
    [*] -> InitialState: Add Goods, Update Price, Remove Goods, Place Order, Search Items, View Report
    InitialState -- Update Price: Update Price
    InitialState -- Remove Goods: Remove Goods
    InitialState -- Place Order: Place Order
    InitialState -- Search Items: Search Items
    InitialState -- View Report: View Report

    InitialState -- Expired Goods: Identify Expired Goods
    ExpiredGoods -- InitialState: Notify User, Remove Expired Goods

    InitialState -- Order Placed: Order Placed
    OrderPlaced -- InvoiceGenerated: Generate Invoice

    InitialState -- Items Selected: Items Selected
    ItemsSelected -- Calculate DiscountTax: Calculate Discount and Tax
    ItemsSelected -- ReceiptGenerated: Generate Receipt
    ItemsSelected -- ReplaceItemOrCancelReceipt: Replace Item or Cancel Receipt

    InitialState -- CustomerRequest: Customer Request
    CustomerRequest -- RecordRequest: Record Customer Request

    OrderPlaced -- BillingProcess: Record Transaction
  }

  state BillingProcess {
    BillingProcess <-- InvoiceGenerated
    BillingProcess -- ReceiptGenerated: Generate Receipt
    BillingProcess -- ReplaceItemOrCancelReceipt: Replace Item or Cancel Receipt
  }
}
@enduml
