@startuml
hide empty description

skinparam fontSize 14

title Atm Scenario 1 - State Transition Diagram

state Idle {
    [Initial]
}

state WithdrawalAmountSelection
state PredefinedSelection
state CustomAmountInput
state CancellationOption
state TransactionCancelled
state TransactionCompleted

Idle --select:Select Amount-> WithdrawalAmountSelection
WithdrawalAmountSelection --predefined:Predefined Selection-> PredefinedSelection
PredefinedSelection --continue:Continue-> WithdrawalAmountSelection
PredefinedSelection --cancel:Cancel-> CancellationOption
CustomAmountInput --amount:Enter Custom Amount-> WithdrawalAmountSelection
CancellationOption --cancel:Cancel Transaction-> CancellationOption
CancellationOption --returnCard:Return Card-> TransactionCancelled
WithdrawalAmountSelection --continue:Continue-> CustomAmountInput
TransactionCancelled --end:End-> Idle
WithdrawalAmountSelection --complete:Complete Transaction-> TransactionCompleted
TransactionCompleted --end:End-> Idle

@enduml
