@startuml
hide empty package

package System {
    State Idle {
        [Initial]
        State SearchFilterSelection(filterCategory: String, priceRange: String)
        State SearchResultsDisplay(matchingUsers: List<User>)
    }

    User -> Idle: Start
    Idle -- SearchFilterSelection: Select Filter Category
    Idle -- SearchFilterSelection: Select Price Range
    SearchFilterSelection -- SearchResultsDisplay: Display Matching Users
}

@enduml
