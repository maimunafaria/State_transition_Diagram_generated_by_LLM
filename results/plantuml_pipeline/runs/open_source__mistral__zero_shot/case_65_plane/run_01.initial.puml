@startuml
hide empty package

skinparam packageStyle rectangular
skinparam packagePadding 5mm

package "Plane States" {
    state Order
    state Arrival
    state Preparation
    state Operations
    state Maintenance
    state OutOfService
}

Plane -- Order: placed
Order -- Arrival: upon arrival
Arrival -- Preparation: assigned for preparation
Preparation -- Operations: assigned to operations or maintenance
Operations -- Maintenance: when no more scheduled flights or maintenance required
Maintenance -- Preparation: after checking and servicing
Preparation -- OutOfService: taken out of service if not available for use
OutOfService -- : removed from operations when permanently withdrawn

@enduml
