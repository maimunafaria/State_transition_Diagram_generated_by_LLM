@startuml
hide empty package

skinparam ascii

package MicrowaveOven {
  State Idle {
    [Current Time]
    Operation(Open Door) -> Idle: Open Door
    Operation(Set Power) -> SetPower: Set Power
    Operation(Set Time) -> SetTime: Set Time
  }

  State SetPower {
    [Choose between Full and Half Power]
    Operation(Select Power Level) -> Idle: Select Power Level
  }

  State SetTime {
    [Enter Cooking Time]
    Operation(Input Time) -> Active: Input Time
  }

  State Active {
    [Cooking Process]
    Event(DoorOpen) -> Idle: Door Open During Operation
    Event(Cancel) -> Idle: Cancel Cooking Process
  }

  State Error {
    [Door Open During Cooking Process]
    Event(DoorOpen) -> Error: Door Open During Cooking Process
  }

  State Idle < Idle : Display Current Time
  SetPower < Idle : Set Power Level Selected
  SetTime < Active : Cooking Time Set
  Active < Idle : Cooking Completed or Cancelled
  Error < Idle : Door Closed and Waiting for Next Use
}
@enduml
