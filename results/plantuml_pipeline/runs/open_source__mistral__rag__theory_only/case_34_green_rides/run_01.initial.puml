@startuml
state Login
state JourneyDetails
state DrivingMode
state OtherOptions
state Hungry
state PlaceToEat
state OrderPlaced
state Accident
state NotificationSent
state Feedback

Login --> JourneyDetails: DestinationSelected
JourneyDetails --> DrivingMode: DriveClicked
JourneyDetails --> OtherOptions: OtherOptionClicked
Hungry --> PlaceToEat: SearchFoodClicked
PlaceToEat --> OrderPlaced: OrderPlaced
Accident --> NotificationSent: AccidentDetected
NotificationSent --> Accident: NotificationSent
Feedback --> : JourneyCompleted

@enduml
