@startuml

STATE_MACHINE User {
  [*] Initial
  Initial --> Authenticated : login submitted
  Authenticated --> Registered : registration successful
  Registered --> LoggedIn : correct credentials
  LoggedIn --> UploadingDocuments : document upload requested
  LoggedIn --> ViewProfile : view profile requested
  LoggedIn --> ApplyForCertificate : certificate application requested
  LoggedIn --> Reapplying : reapplication requested
  LoggedIn --> RequestingCertificates : registrar requests certificate
  LoggedIn --> RequestingMoreCertificates : registrar requests more certificates
  LoggedIn --> SessionEnded : user ends session
}

STATE_MACHINE Registrar {
  [*] Initial
  Initial --> RequestingCertificates : certificate request submitted
  RequestingCertificates --> CertificateVerified : verification successful
  RequestingCertificates --> CertificateNotVerified : verification failed
}

@enduml
