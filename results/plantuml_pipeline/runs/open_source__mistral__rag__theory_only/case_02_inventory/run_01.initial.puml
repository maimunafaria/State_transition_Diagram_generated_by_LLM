@startuml

InventorySystem - Inventory {
  state WaitingForInput
  state AddingGoods[Adding Goods]
  state UpdatingPrice[Updating Price]
  state RemovingGoods[Removing Goods]
  state IdentifyingExpired[Identifying Expired Goods]
  state OrderingSupplier[Ordering Supplier]
  state GeneratingInvoice[Generating Invoice]
  state SearchingItems[Searching Items]
  state CalculatingDiscountTax[Calculating Discount and Tax]
  state GeneratingReceipt[Generating Receipt]
  state BillingProcess[Billing Process]
  state RecordingRequest[Recording Request]
  state ViewingSummaryReport[Viewing Summary Report]

  [*] WaitingForInput --> AddingGoods: Add Good
  AddingGoods --> WaitingForInput: Done

  WaitingForInput --> UpdatingPrice: Update Price
  UpdatingPrice --> WaitingForInput: Done

  WaitingForInput --> RemovingGoods: Remove Good
  RemovingGoods --> WaitingForInput: Done

  IdentifyingExpired --> WaitingForInput: Notify Expiration
  WaitingForInput --> OrderingSupplier: Order Supplier
  OrderingSupplier --> GeneratingInvoice: Place Order
  GeneratingInvoice --> WaitingForInput: Done

  SearchingItems --> CalculatingDiscountTax: Select Items
  CalculatingDiscountTax --> GeneratingReceipt: Calculate Discount and Tax
  GeneratingReceipt --> BillingProcess: Generate Receipt

  BillingProcess --> RecordingRequest: Record Request (if needed)
  BillingProcess --> WaitingForInput: Done

  ViewingSummaryReport --> WaitingForInput: View Report
}

@enduml
