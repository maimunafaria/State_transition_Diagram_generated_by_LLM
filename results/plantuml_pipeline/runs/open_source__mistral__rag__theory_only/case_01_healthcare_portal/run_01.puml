@startuml

STATE_USER_NOT_REGISTERED
STATE_USER_REGISTRATION_FAILED
STATE_USER_REGISTERED
STATE_USER_LOGGED_OUT
STATE_USER_LOGGED_IN
STATE_SESSION_ACTIVE
STATE_PAYMENT_PENDING
STATE_PAYMENT_PROCESSING
STATE_INSURANCE_VERIFIED
STATE_NEWS_AND_CONTENT_VIEWED
STATE_HEALTH_INFO_VIEWED
STATE_DOCTOR_CONSULTATION_REQUESTED
STATE_DRUG_AND_SUPPLEMENT_PURCHASED
STATE_FEEDBACK_COLLECTED
STATE_SESSION_ENDED

USER_NOT_REGISTERED--*[|Register]->USER_REGISTERED
USER_REGISTERED--[|Failed]->USER_NOT_REGISTERED: Registration Failed
USER_REGISTERED--[|Success]->USER_LOGGED_OUT: Logout
USER_LOGGED_OUT--[|Login]->USER_LOGGED_IN
USER_LOGGED_IN--[|Logout]->USER_LOGGED_OUT
USER_LOGGED_IN--[|View News and Content]->NEWS_AND_CONTENT_VIEWED
USER_LOGGED_IN--[|View Health Info]->HEALTH_INFO_VIEWED
USER_LOGGED_IN--[|Request Doctor Consultation]->DOCTOR_CONSULTATION_REQUESTED
USER_LOGGED_IN--[|Purchase Drugs and Supplements]->DRUG_AND_SUPPLEMENT_PURCHASED
NEWS_AND_CONTENT_VIEWED--[|Continue Session]->SESSION_ACTIVE
HEALTH_INFO_VIEWED--[|Continue Session]->SESSION_ACTIVE
DOCTOR_CONSULTATION_REQUESTED--[|Verify Insurance]->INSURANCE_VERIFIED: Insurance Verification
INSURANCE_VERIFIED--[|Check Payment with Insurance]->PAYMENT_PENDING: Payment Pending
PAYMENT_PENDING--[|Process Payment]->PAYMENT_PROCESSING
PAYMENT_PROCESSING--[|Complete Payment]->SESSION_ACTIVE: Cash Payment
PAYMENT_PROCESSING--[|Complete Insurance Payment]->SESSION_ACTIVE
DRUG_AND_SUPPLEMENT_PURCHASED--[|Collect Cash Payment Details]->SESSION_ACTIVE: Cash Payment Details
DRUG_AND_SUPPLEMENT_PURCHASED--[|Complete Insurance Payment]->SESSION_ACTIVE
SESSION_ACTIVE--[|Collect Feedback]->FEEDBACK_COLLECTED
FEEDBACK_COLLECTED--[|End Session]->USER_LOGGED_OUT

@enduml
