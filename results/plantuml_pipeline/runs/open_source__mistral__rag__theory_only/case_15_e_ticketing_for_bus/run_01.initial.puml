@startuml
STATE UserIdle
STATE UserRegistering
STATE UserLoggedIn
STATE TicketBooking
STATE AccountManagement
STATE Logout

UserIdle:User Idle
UserRegistering:User Registering
UserLoggedIn:User Logged In
TicketBooking:Ticket Booking
AccountManagement:Account Management
Logout:Logged Out

UserIdle --> UserRegistering:register
UserRegistering --> UserIdle:cancelRegistration
UserRegistering --> UserLoggedIn:validateRegistration

UserLoggedIn --> AccountManagement:manageAccount
UserLoggedIn --> TicketBooking:checkTicketStatus

TicketBooking --> Booking:bookTicket
Booking --> Payment:confirmPayment
Payment --> TicketBooking:paySuccessful
Payment --> TicketBooking:paymentFailed

AccountManagement --> EditDetails:editDetails
AccountManagement --> DeleteAccount:deleteAccount

Logout --> UserIdle:logout
@enduml
