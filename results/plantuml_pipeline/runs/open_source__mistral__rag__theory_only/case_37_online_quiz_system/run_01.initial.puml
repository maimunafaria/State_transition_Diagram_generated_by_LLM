@startuml

State Teacher {
    State Login
    State Dashboard[Dashboard]
    State CreateQuiz
    State EditQuiz
    State SaveDraft
    State PostQuiz
    State ViewResults

    Login --> Dashboard: login successful
    Dashboard --> CreateQuiz: create new quiz
    Dashboard --> EditQuiz: edit existing quiz
    Dashboard --> SaveDraft: save as draft
    Dashboard --> PostQuiz: post for students
    Dashboard --> ViewResults: view results once quiz is over
}

State Student {
    State Login
    State Dashboard[Dashboard]
    State SelectQuiz
    State AnswerQuiz
    State SubmitQuiz
    State ViewResult

    Login --> Dashboard: login successful
    Dashboard --> SelectQuiz: get notified and select quiz
    SelectQuiz --> AnswerQuiz: start answering selected quiz
    AnswerQuiz --> SubmitQuiz: submit quiz after answering
    SubmitQuiz --> ViewResult: view result after submitting the quiz
}

@enduml
