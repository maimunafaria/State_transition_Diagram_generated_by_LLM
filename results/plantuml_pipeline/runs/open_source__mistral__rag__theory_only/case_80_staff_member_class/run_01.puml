@startuml

StaffMember - [*] Assigned
Assigned -- Unassigned: Remove Assignment
Assigned -- Switch: Switch Assignment
Assigned -- Unemployed: Leave Job
Unemployed -- Archived: After Time Passes

State StaffMember {
  Assigned {
    Operation assignToClient(client)
    Operation addToCampaign(campaign)
  }
  Unassigned {
    Operation removeFromAssignment()
  }
  Switch {
    Operation switchAssignment(newAssignment)
  }
  Unemployed {
    Operation markAsUnemployed()
  }
  Archived {
  }
}

@enduml
