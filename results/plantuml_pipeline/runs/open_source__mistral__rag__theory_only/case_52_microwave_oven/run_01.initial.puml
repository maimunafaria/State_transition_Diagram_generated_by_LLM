@startuml

STATE WaitingForInput {
    [*] -> WaitingForInput: User interacts with system
    WaitingForInput --> TimeDisplay: System displays current time
    WaitingForInput --> PowerSelection: User selects power level
    WaitingForInput --> CookingTimeEntry: User sets cooking time
}

STATE PowerSelection {
    PowerSelection --> HalfPower: User chooses half power
    PowerSelection --> FullPower: User chooses full power
    PowerSelection --> Cancel: User cancels operation
}

STATE CookingTimeEntry {
    CookingTimeEntry --> TimeInput: User enters cooking time
    CookingTimeEntry --> DoorOpenDuringOperation: Door opens during operation
    CookingTimeEntry --> OperationInProgress: System starts cooking process
}

STATE DoorOpenDuringOperation {
    DoorOpenDuringOperation --> StopImmediately: System stops immediately
    DoorOpenDuringOperation --> WaitForDoorClose: System waits for door to close
}

STATE OperationInProgress {
    OperationInProgress --> TimeDisplay: System displays current time during operation
    OperationInProgress --> DoorOpenDuringCooking: Door opens during cooking process
    OperationInProgress --> CookingComplete: Cooking process completes
}

STATE CookingComplete {
    CookingComplete --> TimeDisplay: System returns to displaying current time
    CookingComplete --> NextUse: User can interact with system again
}

@enduml
