@startuml
state Off
state AlarmActive

[*] -> Off: SetAlarmTime
Off -- SetAlarmTime: set_alarm_time
Off --> AlarmActive: ActivateAlarm
AlarmActive -- ActivateAlarm: activate_alarm
AlarmActive -- Ringing: current_time_matches_alarm_time
Ringing -- Ringing: user_turns_off_alarm
Ringing --> Off: stop_alarm
Off -- NextScheduledAlarm: remain_active_for_next_scheduled_alarm
@enduml
