@startuml

STATE_MACHINE User {
    STATE LoggedOut
    STATE LoggedIn
    STATE Applying
    STATE PendingPayment
    STATE PaymentAccepted
    STATE ViewingStatus
    STATE CheckingStatus
    STATE CancellingApplication
    STATE ModifyingDetails
    STATE GivingFeedback

    [*] LoggedOut --> LoggedIn: create account
    LoggedIn --> Applying: apply for visa
    Applying --> PendingPayment: make payment
    PendingPayment --> PaymentAccepted: accepted
    PaymentAccepted --> ViewingStatus: application approved
    PaymentAccepted --> CheckingStatus: application rejected
    LoggedIn --> CancellingApplication: cancel application
    LoggedIn --> ModifyingDetails: modify details
    ViewingStatus --> GivingFeedback: give feedback
    CheckingStatus --> LoggedOut: log out
    LoggedIn --> LoggedOut: log out
    ModifyingDetails --> ViewingDetails: save changes
    ViewingDetails --> LoggedOut: log out
}

@enduml
