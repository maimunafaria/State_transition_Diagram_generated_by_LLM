@startuml
state Idle {
  [*] --> DisplayTime
  DisplayTime --> Idle

  state Cooking {
    DisplayTime --> Cooking: user sets cooking time
    Cooking --> Inactive: door opens during operation
    Inactive --> Cooking: door closes
    Cooking --> Cancelled: user cancels cooking
    Cancelled --> Idle
    Cooking --> Stopped: system stops immediately when door is opened during cooking process
    Stopped --> Idle
  }

  state PowerLevel {
    DisplayTime --> HalfPower: user chooses half power level
    HalfPower --> Cooking
    DisplayTime --> FullPower: user chooses full power level
    FullPower --> Cooking
  }
@enduml
