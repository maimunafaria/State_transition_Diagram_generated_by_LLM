@startuml
state Running {
  [*] --> Running
  Running --> Configuring : changes or power-saving settings required
  state Configuring {
    [*] --> ConfigMode
    ConfigMode --> Running : configuration completed
  }
  Running --> DataCollection : triggered by clock
  state DataCollection {
    [*] --> CollectingData
    CollectingData --> Running
  }
  Running --> SummaryPreparation
  state SummaryPreparation {
    [*] --> PreparingSummary
    PreparingSummary --> Running
  }
  Running --> StatusChecking
  state StatusChecking {
    [*] --> CheckingStatus
    CheckingStatus --> Running
  }
  Running --> RemoteControl : remote control
  state ControlledMode {
    [*] --> Controlled
    Controlled --> Running : exit controlled mode
  }
  Running --> Shutdown : shutdown command given while running
@enduml
