@startuml
state StaffMember {
  state Assigned {
    [*] --> Assigned : login
    Assigned --> Unassigned : remove assignment
    Assigned --> SwitchAssignment : switch assignment
  }
  state Unemployed {
    [*] --> Unemployed : leave job
    Unemployed --> Archived : after some time has passed
  }
  state Archived
  Assigned --> Unemployed : quit job
  Unemployed --> Assigned : rehire
}
StaffMember --> Assigned[*] : assign to client or campaign
@enduml
