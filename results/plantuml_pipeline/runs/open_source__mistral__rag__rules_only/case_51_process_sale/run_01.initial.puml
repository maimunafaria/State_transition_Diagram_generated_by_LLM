@startuml
state WaitingForSale as "Waiting for New Sale"
state AddingItems as "Adding Items One by One"
state PaymentSelection as "Choosing Payment Method"
state VerifyingPayment as "Verifying Payment"
state CompletingSale as "Completing the Sale"
state OrderCompletedSuccessfully as "Order Completed Successfully"

WaitingForSale [*] --> AddingItems
AddingItems --> PaymentSelection
PaymentSelection --> VerifyingPayment: payment chosen
VerifyingPayment --> CompletingSale: payment approved
CompletingSale --> OrderCompletedSuccessfully: sale completed
OrderCompletedSuccessfully --> WaitingForSale: ready for next customer
@enduml
