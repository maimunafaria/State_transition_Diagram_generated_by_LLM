@startuml
[*] --> LoggedIn

state LoggedIn {
  state MarketConditions {
    [*] --> ShowMarketConditions
    ShowMarketConditions --> ShowMarketReport
  }

  state PestControlHelp {
    [*] --> RequirePhoto
    RequirePhoto --> ShowPestControlTechniques
  }

  state SoilSuggestions {
    [*] --> ReceiveSoilInfo
    ReceiveSoilInfo --> ProvideCropSuggestions
  }

  state WeatherInsights {
    [*] --> ReceiveLocation
    ReceiveLocation --> ShowWeatherInsights
  }

  state LabourAvailability {
    [*] --> ReceiveLocation
    ReceiveLocation --> ShowLabourAvailabilityDetails
  }

  state MainArea {
    --select--> MarketConditions : select market conditions
    --select--> PestControlHelp : select pest control help
    --select--> SoilSuggestions : select soil suggestions
    --select--> WeatherInsights : select weather insights
    --select--> LabourAvailability : select labour availability
    MainArea --> [*] : continue using service
  }

  MainArea --> Logout : log out
}
@enduml
