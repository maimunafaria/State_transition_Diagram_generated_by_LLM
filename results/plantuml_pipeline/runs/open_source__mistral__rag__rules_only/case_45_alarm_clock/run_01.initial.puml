@startuml
state Off {
  [*] --> Off
  Off --> AlarmRinging : alarm set and current time matches
  Off --> Active : next scheduled alarm time
}

Off:AlarmSet(alarmTime) --> AlarmActive(alarmTime)
AlarmActive(alarmTime) --> AlarmRinging

state AlarmRinging {
  [*] --> AlarmRinging
  AlarmRinging --> Off : alarm stopped
}

AlarmRinging:Stopped --> Active

Active:NextScheduledAlarm(nextAlarmTime) --> Off
@enduml
