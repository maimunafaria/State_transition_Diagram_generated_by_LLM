@startuml
state ViewTime {
  [*] --> ViewTime
  ViewTime --> AdjustHour
  ViewTime --> AdjustMinute
  ViewTime --> AlarmHour
  ViewTime --> AlarmMinute
}

state IncreaseValue {
  AdjustHour --> IncreaseValue
  AdjustMinute --> IncreaseValue
  AlarmHour --> IncreaseValue
  AlarmMinute --> IncreaseValue
}

state AlarmOnOff {
  ViewTime --> AlarmOn
  ViewTime --> AlarmOff
}

state AlarmRing {
  AlarmOn --> AlarmRing : alarm time matches current time
  AlarmRing --> StopAlarm
}

state StopAlarm {
  AlarmRing --> StopAlarm
  StopAlarm --> [*] : user presses specific button
}

state Light {
  [*] --> LightOn
  LightOn --> LightOff : user releases button
}

AlarmOn --> AlarmOnOff
AlarmOff --> AlarmOnOff
StopAlarm --> ViewTime
LightOn --> ViewTime
LightOff --> ViewTime
@enduml
