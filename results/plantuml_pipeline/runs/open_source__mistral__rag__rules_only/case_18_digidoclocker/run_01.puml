@startuml
[*] --> CitizenLogin

state CitizenLogin {
  state RegisteredCitizen {
    [*] --> LoggedIn
    LoggedIn --> UploadDocuments : upload documents
    LoggedIn --> ApplyForCertificate : apply for certificate
    LoggedIn --> RequestVerification : request verification (registrar)
    LoggedIn --> Logout : logout
  }

  state NotRegisteredCitizen {
    [*] --> RegistrationRequired
    RegistrationRequired --> RegisteredCitizen : registration completed
  }
}

CitizenLogin --> CitizenLogin_Error : incorrect login details
@enduml
