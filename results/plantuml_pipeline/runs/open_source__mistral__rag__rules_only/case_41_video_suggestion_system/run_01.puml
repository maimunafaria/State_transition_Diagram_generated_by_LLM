@startuml
state UserRequest {
  [*] --> Receiving
}

state IdentifiedUser {
  Receiving --> Identifying
}

state GatheringVideos {
  Identifying --> Gathering
  hide empty description
  note left of Gathering: Based on user's profile, preferences, trending videos, similar tags, genres, and promoted videos
}

state AddDetails {
  Gathering --> Adding
}

state SendingVideos {
  Adding --> Sending
  hide empty description
}

UserRequest --> IdentifiedUser
IdentifiedUser --> GatheringVideos
GatheringVideos --> AddDetails
AddDetails --> SendingVideos
SendingVideos --> [*]
@enduml
