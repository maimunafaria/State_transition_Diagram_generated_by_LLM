@startuml
state LoggedIn {
  state JourneyDetails {
    [*] --> ViewJourneyDetails
    ViewJourneyDetails --> ActivateDrivingMode : activate driving mode
    ActivateDrivingMode --> DrivingMode
    DrivingMode --> Accident : accident occurs
    Accident --> NotifyAuthorities
    NotifyAuthorities --> EndJourney
    ViewJourneyDetails --> ChooseEat : user is hungry
    ChooseEat --> PlaceToEatSelection
    PlaceToEatSelection --> MenuView : select place to eat
    MenuView --> OrderPlacement : view menu and place order
    OrderPlacement --> EndJourney
  }
  JourneyDetails --> LoggedIn : user navigates away
  [*] --> JourneyDetails : login and destination selection
  JourneyDetails --> Feedback : upon completion of journey
  Feedback --> EndJourney
}
LoggedIn --> [*] : logout
@enduml
