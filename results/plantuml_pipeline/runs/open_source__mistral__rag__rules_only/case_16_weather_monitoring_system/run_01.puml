@startuml
[*] --> LoggedIn

state LoggedIn {
  [*] --> CheckLocation
  CheckLocation --> ValidLocation : valid input
  ValidLocation --> ChooseInfo : select info
  ChooseInfo --> WeatherInfo : selected info
  WeatherInfo --> AdditionalDetails : view details
  AdditionalDetails --> WeatherInfo
  InvalidLocation --> EndProcess : invalid input
  EndSession --> [*] : logout
}
@enduml
