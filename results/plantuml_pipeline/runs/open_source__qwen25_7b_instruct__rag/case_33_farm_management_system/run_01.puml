@startuml
hide empty description
[*] --> LoggedIn

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> MarketConditions : select market condition
  MarketConditions --> MarketReport : view market report
  MarketConditions --> [*] : back
}

state LoggedIn {
  [*] --> PestControlHelp : select pest control help
  PestControlHelp --> PestControlTechniques : view pest control techniques
  PestControlHelp --> [*] : back
}

state LoggedIn {
  [*] --> SoilSuggestions : provide soil information
  SoilSuggestions --> SoilSuggestionsResult : receive soil-related suggestions
  SoilSuggestions --> [*] : back
}

state LoggedIn {
  [*] --> WeatherInsights : provide location
  WeatherInsights --> WeatherDetails : receive weather insights
  WeatherInsights --> [*] : back
}

state LoggedIn {
  [*] --> LabourAvailability : provide location
  LabourAvailability --> LabourDetails : receive labour availability details
  LabourAvailability --> [*] : back
}

LoggedIn --> [*] : logout
@enduml
