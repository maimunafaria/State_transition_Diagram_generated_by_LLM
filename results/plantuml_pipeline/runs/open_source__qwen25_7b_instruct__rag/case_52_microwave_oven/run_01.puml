@startuml
title Microwave Oven - State Diagram

[*] --> Idle

state Idle {
  [*] --> WaitingForInput : display time
  WaitingForInput --> Idle : input received
}

state WaitingForInput {
  [*] --> PowerSelection : power level selected
  PowerSelection --> TimeSelection : time entered
  TimeSelection --> Cooking : start cooking
  Cooking --> DoorOpen : door opened
  DoorOpen --> DoorClosed : door closed
  DoorClosed --> Idle : cooking completed or cancelled
}

state Cooking {
  [*] --> DoorOpen : door opened
  DoorOpen --> DoorClosed : door closed
  DoorClosed --> Idle : cooking completed or cancelled
  DoorClosed --> Cancel : cooking cancelled
  Cancel --> Idle : cooking cancelled
}

state DoorOpen {
  [*] --> DoorClosed : door closed
}

state DoorClosed {
  [*] --> Idle : cooking completed or cancelled
}

@enduml
