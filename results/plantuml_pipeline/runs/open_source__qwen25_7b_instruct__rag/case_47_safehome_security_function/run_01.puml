@startuml
[*] --> Idle

state Idle {
  [*] --> ReadyToUse
  ReadyToUse --> [*]
}

state ReadyToUse {
  ReadyToUse --> Reset : reset
  ReadyToUse --> Activate : activate
  ReadyToUse --> TurnOff : turnOff
  ReadyToUse --> Monitoring : monitor
}

state Monitoring {
  Monitoring --> Alarm : sensorTriggered
  Monitoring --> Monitoring : falseAlarm
  Monitoring --> Monitoring : timeEnds
  Monitoring --> [*] : passwordEntry
}

state Alarm {
  Alarm --> [*] : passwordEntry
}

@enduml
