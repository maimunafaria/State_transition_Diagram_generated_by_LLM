@startuml
title UML State Machine Diagram

[*] --> NavigationBar

state HomePage {
  [*] --> Projects
  [*] --> CareerOpportunities
}

state Projects {
  Projects --> ViewPhotos
  Projects --> ViewVideos
  ViewPhotos --> Projects
  ViewVideos --> Projects
}

state CareerOpportunities {
  CareerOpportunities --> ViewUpdates
  CareerOpportunities --> ApplicationForm
  ViewUpdates --> CareerOpportunities
  ApplicationForm --> CareerOpportunities
}

state ViewPhotos {
  ViewPhotos --> Projects
}

state ViewVideos {
  ViewVideos --> Projects
}

state ViewUpdates {
  ViewUpdates --> CareerOpportunities
}

state ApplicationForm {
  ApplicationForm --> CareerOpportunities
}

state CareerOpportunitiesReview {
  CareerOpportunities --> CareerOpportunitiesReview
  CareerOpportunitiesReview --> [*]
}

@enduml
