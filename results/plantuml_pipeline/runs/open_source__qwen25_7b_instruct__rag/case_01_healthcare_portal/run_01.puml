@startuml
title UML State Machine Diagram for Healthcare Portal

[*] --> Register

state Register {
  [*] --> Registered : registration successful
  Registered --> Login : user signs in
  Registered --> Register : registration fails
}

state Login {
  [*] --> Home : sign-in successful
  Home --> Home : continue using system
  Home --> Logout : finish session
}

state Home {
  Home --> Home : access available facilities
  Home --> Home : read news and expert content
  Home --> Home : check symptoms or use fitness checking options
  Home --> InsuranceValidation : process insurance for finance-related services
  Home --> PaymentSelection : select payment methods
  Home --> FeedbackCollection : collect user feedback after service completion
}

state InsuranceValidation {
  InsuranceValidation --> PaymentConfirmation : validate insurance
  PaymentConfirmation --> Home : complete payment process
}

state PaymentSelection {
  PaymentSelection --> CashPaymentDetails : inform about cash payment details
  PaymentSelection --> InsurancePaymentProcessing : process and complete insurance-based payments
}

state CashPaymentDetails {
  [*] --> Home : finish session
}

state InsurancePaymentProcessing {
  [*] --> Home : finish session
}

state FeedbackCollection {
  [*] --> Logout : log out user at the end of their session
}

Logout --> [*]
@enduml
