@startuml
title Farm Management System

state "Logged Out" as LoggedOut
state "Logged In" as LoggedIn
state "Main Area" as MainArea
state "Market Conditions" as MarketConditions
state "Market Report" as MarketReport
state "Pest Control Help" as PestControlHelp
state "Pest Control Techniques" as PestControlTechniques
state "Soil Suggestions" as SoilSuggestions
state "Weather Insights" as WeatherInsights
state "Labour Availability" as LabourAvailability
state "Session Ended" as SessionEnded

[*] --> LoggedOut

LoggedIn --> MainArea : User Signs In
MainArea --> MarketConditions : User Selects Market Conditions
MarketConditions --> MarketReport : User Selects Market Report
MarketReport --> LoggedIn : User Returns to Main Area

MainArea --> PestControlHelp : User Selects Pest Control Help
PestControlHelp --> PestControlTechniques : User Provides Photo
PestControlTechniques --> LoggedIn : User Returns to Main Area

MainArea --> SoilSuggestions : User Provides Soil Information
SoilSuggestions --> LoggedIn : User Returns to Main Area

MainArea --> WeatherInsights : User Provides Location
WeatherInsights --> LoggedIn : User Returns to Main Area

MainArea --> LabourAvailability : User Provides Location
LabourAvailability --> LoggedIn : User Returns to Main Area

LoggedIn --> SessionEnded : User Logs Out
SessionEnded --> [*] : User Ends Session

@enduml
