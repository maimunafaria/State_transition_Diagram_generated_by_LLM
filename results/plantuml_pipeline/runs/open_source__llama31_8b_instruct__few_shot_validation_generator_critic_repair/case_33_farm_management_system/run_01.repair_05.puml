@startuml
[*] --> Login : User Logs In
Login --> MainArea : Successful Login
MainArea --> MarketConditions : Select Market Conditions
MarketConditions --> MarketReport : Select Market Report
MainArea --> PestControlHelp : Select Pest Control Help
PestControlHelp --> PestControlTechniques : Provide Photo and Select Techniques
MainArea --> SoilSuggestions : Receive Soil Information
SoilSuggestions --> SoilSuggestions : Provide Suitable Crops
MainArea --> WeatherInsights : Provide Location
WeatherInsights --> LabourAvailability : Provide Location
LabourAvailability --> LabourDetails : Display Labour Details
Login --> Logout : User Logs Out

state MainArea {
  Login --> MarketConditions : Select Market Conditions
  Login --> PestControlHelp : Select Pest Control Help
  Login --> SoilSuggestions : Receive Soil Information
  Login --> WeatherInsights : Provide Location
}

state MarketReport {
  LabourAvailability --> LabourDetails : Display Labour Details
}

state PestControlTechniques {
  LabourAvailability --> LabourDetails : Display Labour Details
}

Logout --> [*] : User Logs Out

@enduml
