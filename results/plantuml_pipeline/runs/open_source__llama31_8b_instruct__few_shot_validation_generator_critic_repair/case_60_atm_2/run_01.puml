@startuml
state "Idle" as s1
[*] --> s1 : Start
s1[*] --> s2 : Select Amount
state "Select Amount" as s2
s2 --> s3 : Enter Custom Value
state "Enter Custom Value" as s3
s3 --> s4 : Verify Transaction
state "Verify Transaction" as s4
alt Transaction Valid
  s4 --> s5 : Display Withdrawal Confirmation
else
  s4 --> s6 : Re-enter Amount
end
state "Re-enter Amount" as s6
s6 --> s2 : Go Back to Select Amount
s5 --> [*] : End

@enduml
