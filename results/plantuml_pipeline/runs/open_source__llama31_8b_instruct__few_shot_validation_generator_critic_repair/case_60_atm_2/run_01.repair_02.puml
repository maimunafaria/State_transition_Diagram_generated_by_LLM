@startuml
state "Idle" as s1
[*] --> s2 : Start
s2 --> s3 : Select Amount
state "Select Amount" as s3
s3 --> s4 : Enter Custom Value
state "Enter Custom Value" as s4
s4 --> s5 : Verify Transaction
state "Verify Transaction" as s5
alt Transaction Valid
  s5 --> s6 : Display Withdrawal Confirmation
else
  s5 --> s7 : Re-enter Amount
end
state "Re-enter Amount" as s7
s7 --> s3 : Go Back to Select Amount
s6 --> [*] : End

@enduml
