@startuml
[*] --> s1 : Card Inserted
state "Card Inserted" as s1
s1[*] --> s2 : Prompt PIN
state "PIN Entered" as s2
s2 --> s3 : Verify PIN
state "PIN Verified" as s3
s3 --> s4 : Provide Options
state "Options Selected" as s4
s4 --> s5 : Process Withdrawal Request
state "Withdrawal Request Processed" as s5
s5 --> s6 : Dispense Cash
state "Cash Dispensed" as s6
s6 --> s7 : Print Receipt
state "Receipt Printed" as s7
s7 --> s8 : Return Card
state "Card Returned" as s8
s8 --> s9 : Reset System
state "System Reset" as s9
s9[*] --> [*] : Ready for Next User

@enduml
