@startuml
title Online Quiz System States

[*] --> UserType

state UserType <<choice>>
UserType --> Registration : [New user]
UserType --> Login : [Registered user]

state "Registration" as Registration {
    UserType --> GettingDetails : [New user]
    GettingDetails --> ChoiceReg : [Registration verification]
    ChoiceReg --> UpdateDB : [valid]
    ChoiceReg --> EndInvalid : [invalid]
    UpdateDB --> Login : [verified]
}

Registration : entry / New user
Registration : do / Registration
Registration : exit / After updation

state Login {
    Profile --> Login : [valid uname & pwd]
    Login : do / Enter username and password
    Login : exit / After verification
}

state "Profile" as Profile {
    ChoiceProfile --> TeacherProfile : [Teacher]
    ChoiceProfile --> StudentProfile : [Student]

    TeacherProfile --> CreateQuiz : [Create new quiz]
    TeacherProfile --> EditQuiz : [Edit existing quiz]
    TeacherProfile --> SaveDraft : [Save as draft]
    TeacherProfile --> PostQuiz : [Post for students]

    StudentProfile --> SelectQuiz : [Select quiz]
    StudentProfile --> AnswerQuiz : [Answer quiz]
    StudentProfile --> SubmitQuiz : [Submit quiz]
    StudentProfile --> ViewResult : [View result]

}

CreateQuiz --> SaveDraft : [Save as draft]
CreateQuiz --> PostQuiz : [Post for students]

EditQuiz --> SaveDraft : [Save as draft]
EditQuiz --> PostQuiz : [Post for students]

SaveDraft --> PostQuiz : [Post for students]

PostQuiz --> ViewResult : [View result]

SelectQuiz --> AnswerQuiz : [Answer quiz]
SelectQuiz --> SubmitQuiz : [Submit quiz]

AnswerQuiz --> SubmitQuiz : [Submit quiz]

SubmitQuiz --> ViewResult : [View result]

ViewResult --> [*]

Logout --> [*]

@enduml
