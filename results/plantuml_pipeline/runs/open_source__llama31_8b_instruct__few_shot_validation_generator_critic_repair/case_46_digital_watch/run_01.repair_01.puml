@startuml
title Digital Watch System States

[*] --> AdjustTime

state "Adjust Time" as AdjustTime
state "Switch Mode" as SwitchMode
state "Increase Value" as IncreaseValue
state "Alarm On/Off" as AlarmOnOff
state "Alarm Triggered" as AlarmTriggered
state "Alarm Stopped" as AlarmStopped
state "Light On/Off" as LightOnOff

AdjustTime : entry / View time
AdjustTime : do / Adjust time settings
AdjustTime : exit / Time adjusted

SwitchMode : entry / Switch mode
SwitchMode : do / Switch mode
SwitchMode : exit / Mode switched

IncreaseValue : entry / Increase value
IncreaseValue : do / Increase value
IncreaseValue : exit / Value increased

AlarmOnOff : entry / Turn alarm on/off
AlarmOnOff : do / Alarm on/off
AlarmOnOff : exit / Alarm status updated

AlarmTriggered : entry / Alarm triggered
AlarmTriggered : do / Alarm triggered
AlarmTriggered : exit / Alarm triggered

AlarmStopped : entry / Alarm stopped
AlarmStopped : do / Alarm stopped
AlarmStopped : exit / Alarm stopped

LightOnOff : entry / Turn light on/off
LightOnOff : do / Light on/off
LightOnOff : exit / Light status updated

AdjustTime --> SwitchMode : [press button]
SwitchMode --> IncreaseValue : [press button]
IncreaseValue --> AdjustTime : [press button]
AdjustTime --> AlarmOnOff : [press button]
AlarmOnOff --> AlarmTriggered : [alarm on]
AlarmTriggered --> AlarmStopped : [alarm off]
AlarmStopped --> AdjustTime : [press button]
AdjustTime --> LightOnOff : [press button]
LightOnOff --> AlarmOnOff : [press button]

SwitchMode --> AlarmOnOff : [press button]
IncreaseValue --> SwitchMode : [press button]
AlarmOnOff --> IncreaseValue : [press button]
AlarmStopped --> [*] : [press button]

@enduml
