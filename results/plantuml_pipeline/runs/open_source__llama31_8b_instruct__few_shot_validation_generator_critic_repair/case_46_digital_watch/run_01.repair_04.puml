@startuml
[*] --> ViewTime
ViewTime --> AdjustTime [*]
AdjustTime --> IncreaseHour [*]
IncreaseHour --> IncreaseMinutes [*]
IncreaseMinutes --> AlarmHour [*]
AlarmHour --> AlarmMinutes [*]
AlarmMinutes --> SetAlarm [*]
SetAlarm --> TriggerAlarm [when set alarm time matches current time]
TriggerAlarm --> StopAlarm [*]
StopAlarm --> TurnOffLight [*]
TurnOnLight --> TurnOffLight [*]  // moved this line to fix the issue
TurnOffLight --> [*]  // added final transition

@enduml
