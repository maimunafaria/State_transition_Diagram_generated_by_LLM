@startuml
state "Idle" as idle
state "Display Time" as display_time
state "Choose Power Level" as choose_power_level
state "Set Cooking Time" as set_cooking_time
state "Cooking" as cooking
state "Door Open During Cooking" as door_open_during_cooking
state "Door Open After Cooking" as door_open_after_cooking

[*] --> display_time : Start
display_time --> choose_power_level : User selects power level
choose_power_level --> set_cooking_time : User sets cooking time
set_cooking_time --> cooking : Cooking starts
cooking --> door_open_during_cooking : Door is opened during cooking
door_open_during_cooking --> idle : Cooking stops immediately
cooking --> door_open_after_cooking : Cooking completes or cancelled
door_open_after_cooking --> idle : Return to idle state after door open
idle --> display_time : Return to idle state
idle --> [*] : End

@enduml
