@startuml
state "Off" as off
state "Alarm Activated" as activated
state "Alarm Ringing" as ringing
state "Alarm Stopped" as stopped

[*] --> off : Initial State
off --> activated : Set Alarm Time
activated --> stopped : User turns off alarm
stopped --> activated : Next scheduled alarm time
activated --> ringing : Current time matches set alarm time
ringing --> stopped : User stops alarm
stopped --> [*] : Final State

@enduml
