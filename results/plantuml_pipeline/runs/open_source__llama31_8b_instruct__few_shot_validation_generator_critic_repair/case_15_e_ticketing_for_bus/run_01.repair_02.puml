@startuml
state "New Account" as NewAccount
state "Registration Validation" as RegistrationValidation
state "Login" as Login
state "Ticket Status Check" as TicketStatusCheck
state "Book Ticket" as BookTicket
state "Payment Confirmation" as PaymentConfirmation
state "Manage Account" as ManageAccount
state "Logout" as Logout

[*] --> NewAccount : Create New Account
NewAccount -->[*] RegistrationValidation : Create New Account
RegistrationValidation --> Login : Successful Registration
Login --> TicketStatusCheck : Logged In User
TicketStatusCheck --> BookTicket : Check Ticket Status
BookTicket --> PaymentConfirmation : Book Ticket
PaymentConfirmation --> Login : Payment Confirmation
Login --> ManageAccount : Logged In User
ManageAccount --> Logout : Complete Action

Logout --> [*] : Log Out
@enduml
