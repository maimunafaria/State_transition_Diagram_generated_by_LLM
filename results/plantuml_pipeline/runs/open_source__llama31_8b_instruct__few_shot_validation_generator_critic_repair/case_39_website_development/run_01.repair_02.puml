@startuml
[*] --> NavigateToProject: "The system shall allow users to navigate from the homepage using a navigation bar."
state NavigateToProject {
  NavigateToProject --> ViewProjectInfo: "The system shall display information about projects when selected by the user."
}
state ViewProjectInfo {
  ViewProjectInfo --> ChooseMedia: "The system shall allow users to choose between viewing photos or watching videos when viewing projects."
  ChooseMedia --> ViewPhotos
  ChooseMedia --> WatchVideos
  state ViewPhotos {}
  state WatchVideos {}
}

NavigateToCareerOpportunities --> ChooseAction: "The system shall display information about career opportunities when selected by the user."
state NavigateToCareerOpportunities {
  ChooseAction --> ViewUpdates: "The system shall allow users to choose between viewing updates or opening an application form for employment or internship when viewing career opportunities."
  ChooseAction --> OpenApplicationForm
  state ViewUpdates {}
  state OpenApplicationForm {}
}

state SubmitJobApplication {
  SubmitJobApplication --> CheckApplications: "The system shall check submitted job applications after they are submitted."
  CheckApplications --> [*]
}
@enduml
