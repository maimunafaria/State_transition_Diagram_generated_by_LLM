@startuml
[*] --> Login
Login --> SelectDestination
SelectDestination --> ViewJourneyDetails
ViewJourneyDetails --> ActivateDrivingMode|ChooseOtherOptions
ActivateDrivingMode --> SelectPlaceToEat
SelectPlaceToEat --> ViewMenu|PlaceOrder
ViewMenu --> PlaceOrder
PlaceOrder --> SendNotification|InformAuthorities
SendNotification --> ProvideFeedback
ProvideFeedback --> End

Login --> [*]
End --> [*]

state Login {
  [*] --> Checking
}

state ActivateDrivingMode {
  [*] --> Driving
}

state SelectPlaceToEat {
  [*] --> Eating
}

state ViewMenu {
  [*] --> Viewing
}

state SendNotification {
  [*] --> Notifying
}

state InformAuthorities {
  [*] --> Informing
}
@enduml
