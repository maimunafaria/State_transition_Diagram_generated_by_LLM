@startuml
title Video Suggestion System State Machine

[*] --> Idle

state Idle {
  Idle --> ReceiveRequest : receive request
}

state ReceiveRequest {
  ReceiveRequest --> IdentifyUser : identify user
  IdentifyUser --> GatherVideos : gather videos
  GatherVideos --> AddDetails : add details
  AddDetails --> SendSuggestions : send suggestions
  SendSuggestions --> Idle : idle
}

state GatherVideos {
  GatherVideos --> UserProfile : user profile
  GatherVideos --> UserPreferences : user preferences
  GatherVideos --> TrendingVideos : trending videos
  GatherVideos --> SimilarVideos : similar videos
  GatherVideos --> PromotedVideos : promoted videos
}

state AddDetails {
  AddDetails --> SendingSuggestions : add thumbnails and view counts
}

state SendingSuggestions {
  SendingSuggestions --> Idle : send suggestions to user
}

[*] --> Idle

@enduml
