@startuml
title Microwave Oven - State Diagram

[*] --> DisplayTime

state "Display Time" as DisplayTime {
  DisplayTime --> ChoosePowerLevel : Power Selected
  DisplayTime --> Idle : Door Open
}

state "Choose Power Level" as ChoosePowerLevel {
  ChoosePowerLevel --> SetCookingTime : Cooking Time Entered
  ChoosePowerLevel --> DisplayTime : Cancel
}

state "Set Cooking Time" as SetCookingTime {
  SetCookingTime --> Cooking : Start Cooking
  SetCookingTime --> DisplayTime : Cancel
}

state "Cooking" as Cooking {
  Cooking --> DoorOpen : Door Opened
  Cooking --> Stopped : User Cancels or Timer Expired
}

state "Door Open" as DoorOpen {
  DoorOpen --> Stopped : Door Closed
}

state "Stopped" as Stopped {
  Stopped --> DisplayTime : Next Use
}

DisplayTime --> [*]

@enduml
