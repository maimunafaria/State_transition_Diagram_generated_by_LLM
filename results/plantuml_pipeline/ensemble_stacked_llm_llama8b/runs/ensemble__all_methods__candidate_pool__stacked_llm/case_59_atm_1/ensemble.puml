@startuml
title ATM Withdrawal State Machine

state "Initial" as Initial
state "SelectAmount" as SelectAmount
state "CustomAmount" as CustomAmount
state "CancelTransaction" as CancelTransaction
state "TransactionComplete" as TransactionComplete
state "CardReturned" as CardReturned

[*] --> Initial

Initial --> SelectAmount : Choose predefined amount
Initial --> CustomAmount : Enter custom amount

SelectAmount --> TransactionComplete : Confirm
SelectAmount --> CancelTransaction : Cancel

CustomAmount --> TransactionComplete : Confirm
CustomAmount --> CancelTransaction : Cancel

TransactionComplete --> CardReturned : End transaction

CancelTransaction --> CardReturned : Stop transaction
@enduml
