@startuml
title UML State Machine Diagram - Website Development

[*] --> Homepage

state "Homepage" as Homepage
state "Project Details" as ProjectDetails
state "View Photos" as ViewPhotos
state "Watch Videos" as WatchVideos
state "Career Opportunities" as CareerOpportunities
state "View Updates" as ViewUpdates
state "Open Application Form" as OpenApplicationForm
state "Job Application Status" as JobApplicationStatus

Homepage --> ProjectDetails : select project
ProjectDetails --> ViewPhotos : view photos
ProjectDetails --> WatchVideos : watch videos
ProjectDetails --> CareerOpportunities : select career opportunities
CareerOpportunities --> ViewUpdates : view updates
CareerOpportunities --> OpenApplicationForm : open application form
OpenApplicationForm --> JobApplicationStatus : submit application
JobApplicationStatus --> [*] : application checked

ViewPhotos --> ProjectDetails : back to project details
WatchVideos --> ProjectDetails : back to project details
ViewUpdates --> CareerOpportunities : back to career opportunities

[*] --> CheckSubmittedApplications : check submitted job applications

@enduml
