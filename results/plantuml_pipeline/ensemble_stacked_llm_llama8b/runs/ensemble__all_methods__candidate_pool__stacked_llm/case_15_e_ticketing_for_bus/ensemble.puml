@startuml
title E-Ticketing System State Transition Diagram

[*] --> Start

state "Start" as Start
state "Create Account" as CreateAccount
state "Validate Registration" as ValidateRegistration
state "Login" as Login
state "Logged In" as LoggedIn
state "Check Ticket Status" as CheckTicketStatus
state "Book Ticket" as BookTicket
state "Confirm Booking" as ConfirmBooking
state "Make Payment" as MakePayment
state "Manage Account" as ManageAccount
state "Logout" as Logout
state "End" as End

Start --> CreateAccount : Create Account

CreateAccount --> ValidateRegistration : Submit Registration

ValidateRegistration --> Login : Successful Registration

Login --> LoggedIn : Log In

LoggedIn --> CheckTicketStatus : Check Status
LoggedIn --> BookTicket : Book Ticket
LoggedIn --> ManageAccount : Manage Account
LoggedIn --> Logout : Log Out

CheckTicketStatus --> LoggedIn : Back to Menu
BookTicket --> ConfirmBooking : Book Now
ConfirmBooking --> MakePayment : Confirm and Pay
MakePayment --> LoggedIn : Payment Complete
ManageAccount --> LoggedIn : Account Updated

Logout --> End : Log Out

@enduml
