@startuml
title Staff Member Class State Machine

[*] --> Unassigned

state Unassigned {
  Unassigned --> AssignedToClient : Assign to Client
  Unassigned --> AssignedToCampaign : Add to Campaign
}

state AssignedToClient {
  AssignedToClient --> AssignedToCampaign : Switch to Campaign
  AssignedToClient --> Unassigned : Remove Assignment
}

state AssignedToCampaign {
  AssignedToCampaign --> AssignedToClient : Switch to Client
  AssignedToCampaign --> Unassigned : End Campaign or Remove Assignment
}

Unassigned --> Unemployed : Mark as Unemployed

state Unemployed {
  Unemployed --> Archived : Archive Record after some time
}

Archived --> [*]

@enduml
