@startuml
title Weather Monitoring System State Diagram

[*] --> CreateUser

state CreateUser
CreateUser : entry / start registration
CreateUser : do / validate registration
CreateUser : exit / registration complete or failed

state CreateUserDecision <<choice>>
CreateUser --> CreateUserDecision

state "Successful Registration" as SuccessReg
SuccessReg : entry / registration completed
SuccessReg : do / proceed to login
SuccessReg : exit / move to login

state "Failed Registration" as FailReg
FailReg : entry / registration failed
FailReg : do / end process
FailReg : exit / return

CreateUserDecision --> SuccessReg
CreateUserDecision --> FailReg

state Login
Login : entry / start login
Login : do / validate credentials
Login : exit / login successful or failed

state LoginDecision <<choice>>
SuccessReg --> Login
Login --> LoginDecision

state "Successful Login" as SuccessLogin
SuccessLogin : entry / login completed
SuccessLogin : do / proceed to weather check
SuccessLogin : exit / move to weather check

state "Failed Login" as FailLogin
FailLogin : entry / login failed
FailLogin : do / end process
FailLogin : exit / return

LoginDecision --> SuccessLogin
LoginDecision --> FailLogin

state WeatherCheck
WeatherCheck : entry / check location
WeatherCheck : do / validate location
WeatherCheck : exit / location valid or invalid

state LocationInvalid
LocationInvalid : entry / invalid location entered
LocationInvalid : do / end process
LocationInvalid : exit / return

WeatherCheck --> LocationInvalid

state WeatherSelection <<choice>>
WeatherCheck --> WeatherSelection

state WeatherInfo
WeatherInfo : entry / display selected info
WeatherInfo : do / update and show info
WeatherInfo : exit / proceed to additional details

state AdditionalDetails
AdditionalDetails : entry / view additional details
AdditionalDetails : do / choose action
AdditionalDetails : exit / proceed accordingly

state Logout
Logout : entry / start logout
Logout : do / end session
Logout : exit / return

WeatherSelection --> WeatherInfo
WeatherInfo --> AdditionalDetails

AdditionalDetails --> WeatherInfo
AdditionalDetails --> Logout

Logout --> [*]

SuccessLogin --> WeatherCheck
WeatherInfo --> AdditionalDetails
AdditionalDetails --> [*]

@enduml
