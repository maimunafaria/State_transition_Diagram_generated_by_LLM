@startuml
[*] --> Register

state Register {
  Register --> Login : registration successful
  Login --> [*] : registration unsuccessful
}

state Login {
  Login --> CheckLocation : login successful
  CheckLocation --> [*] : invalid location
}

state CheckLocation {
  CheckLocation --> CheckInfo : location valid
  CheckInfo --> [*] : location invalid
}

state CheckInfo {
  CheckInfo --> ChooseInfo : valid selection
  ChooseInfo --> [*] : invalid selection
}

state ChooseInfo {
  ChooseInfo --> ShowInfo : valid selection
  ShowInfo --> [*] : logout
}

state ShowInfo {
  ShowInfo --> ViewDetails : view additional details
}

state ViewDetails {
  ViewDetails --> [*] : additional details viewed
  ShowInfo --> [*] : session ended
}

@enduml
