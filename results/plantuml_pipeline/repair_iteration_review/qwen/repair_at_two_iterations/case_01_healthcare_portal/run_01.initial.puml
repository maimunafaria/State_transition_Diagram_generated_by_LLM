@startuml
title UML State Machine Diagram for Healthcare Portal

[*] --> Register

state Register {
  [*] --> Login : [registration successful]
  Login : [registration failed]
}

state Login {
  [*] --> Dashboard : [login successful]
  Dashboard : [logout]
}

state Dashboard {
  [*] --> News : [read news]
  News : [back to dashboard]
  [*] --> Facilities : [access facilities]
  Facilities : [back to dashboard]
  [*] --> SymptomCheck : [check symptoms]
  SymptomCheck : [back to dashboard]
  [*] --> FitnessCheck : [use fitness checking options]
  FitnessCheck : [back to dashboard]
  [*] --> Payment : [select payment method]
  Payment : [finish session]
}

state Payment {
  [*] --> InsurancePayment : [insurance payment]
  InsurancePayment : [complete payment]
  InsurancePayment : [cash payment]
  InsurancePayment --> CashPayment : [choose cash payment]
  CashPayment : [display cash payment details]
  CashPayment : [finish session]
}

state InsurancePayment {
  [*] --> DoctorConsultation : [doctor consultation]
  DoctorConsultation : [complete payment]
}

state DoctorConsultation {
  [*] --> PaymentComplete : [payment completed]
  PaymentComplete : [finish session]
}

state CashPayment {
  [*] --> FinishSession : [finish session]
}

state FinishSession {
  [*] --> Feedback : [provide feedback]
  Feedback : [finish session]
}

state Feedback {
  [*] --> Logout : [logout]
  Logout : [logout successfully]
}

@enduml
