@startuml
title Statechart diagram of the plane lifecycle

[*] --> Order
state Order
state "Arrival" as Arrival
state Preparation
state Operations
state Maintenance
state "Out of Service" as OutOfService
state Historic

Order --> Arrival : plane acquired
Arrival --> Preparation : plane arrived
Preparation --> Operations : plane prepared
Operations --> Maintenance : no more scheduled flights
Maintenance --> Preparation : plane serviced
Operations --> OutOfService : plane withdrawn
Preparation --> Historic : plane withdrawn
Maintenance --> Historic : plane withdrawn
OutOfService --> [*] : plane restored
Historic --> [*] : plane irrelevant
@enduml
