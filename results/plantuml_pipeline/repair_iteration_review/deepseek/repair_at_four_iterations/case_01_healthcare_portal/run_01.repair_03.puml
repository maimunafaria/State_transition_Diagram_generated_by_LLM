@startuml
state Unauthenticated {
  [*] --> Unauthenticated
}
state Authenticated {
  Authenticated --> AccessEnded : Fail
  Authenticated --> AccessEnded : Logout
  Authenticated --> ContinueUsing : Continue
}
state AccessEnded {
  AccessEnded --> [*]
}
state ContinueUsing {
  ContinueUsing --> ViewResult : View Result
}
state ViewResult {
  ViewResult --> ContinueUsing : Continue
  ViewResult --> FinishSession : Finish
}
state FinishSession {
  FinishSession --> LoggedOut
}
state LoggedOut {
  LoggedOut --> [*]
}
@enduml
