@startuml
title UML State Transition Diagram - Healthcare Portal

state "Idle" as Idle
Idle : entry/Welcome
Idle : do/Waiting for user action
Idle : exit/Register/Login

state "Register" as Register
Register : entry/Register
Register : do/Register after validating
Register : exit/MainMenu/InvalidRegister

state "InvalidRegister" as InvalidRegister
InvalidRegister : entry/Invalid registration
InvalidRegister : do/Cannot register
InvalidRegister : exit/Abnormal termination

state "Login" as Login
Login : entry/Login
Login : do/Login using valid credentials
Login : exit/MainMenu/InvalidLogin

state "InvalidLogin" as InvalidLogin
InvalidLogin : entry/Invalid login
InvalidLogin : do/Cannot login
InvalidLogin : exit/Abnormal termination

state "MainMenu" as MainMenu
MainMenu : entry/MainMenu
MainMenu : do/Access facilities
MainMenu : exit/Waiting for user choice

state "ReadContent" as ReadContent
ReadContent : entry/ReadContent
ReadContent : do/View news/expert content
ReadContent : exit/MainMenu

state "HealthInfo" as HealthInfo
HealthInfo : entry/HealthInfo
HealthInfo : do/Check symptoms or fitness
HealthInfo : exit/MainMenu

state "ViewResult" as ViewResult
ViewResult : entry/ViewResult
ViewResult : do/View results
ViewResult : exit/Continue/Logout

state "ProcessInsurance" as ProcessInsurance
ProcessInsurance : entry/ProcessInsurance
ProcessInsurance : do/Validate insurance
ProcessInsurance : exit/InsuranceApproved/InsuranceRejected

state "PaymentSelection" as PaymentSelection
PaymentSelection : entry/PaymentSelection
PaymentSelection : do/Choose payment method
PaymentSelection : exit/CashPayment/InsurancePayment

state "CashPayment" as CashPayment
CashPayment : entry/CashPayment
CashPayment : do/Inform cash details
CashPayment : exit/CompletePayment

state "InsurancePayment" as InsurancePayment
@enduml
