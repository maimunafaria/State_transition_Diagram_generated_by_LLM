@startuml
title Digidoclocker State Diagram

[*] --> Start

state Start
state IdentifyUserType
state CitizenRegistration
state Login
state PostLoginOptions
state UploadDocuments
state ApplyforCertificate
state RegistrarOptions
state RequestCertificate
state EndSession

Start --> IdentifyUserType

IdentifyUserType --> CitizenRegistration : [Citizen]
IdentifyUserType --> Login : [Registered Citizen]

Login --> PostLoginOptions

PostLoginOptions --> UploadDocuments : upload documents
PostLoginOptions --> ApplyforCertificate : apply for certificate
PostLoginOptions --> RegistrarOptions : [Registrar]

UploadDocuments --> PostLoginOptions

ApplyforCertificate --> PostLoginOptions

RegistrarOptions --> RequestCertificate

RequestCertificate --> RegistrarOptions

PostLoginOptions --> EndSession : done
RegistrarOptions --> EndSession : done

EndSession --> [*]

@enduml
