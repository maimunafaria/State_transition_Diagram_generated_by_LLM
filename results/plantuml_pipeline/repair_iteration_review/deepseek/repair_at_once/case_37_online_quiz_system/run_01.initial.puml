@startuml
title Online Quiz System State Diagram

[*] --> Start

state Start
state "LoggedIn" as LoggedIn
state "TeacherMenu" as TeacherMenu
state "StudentMenu" as StudentMenu
state "CreatingQuiz" as CreatingQuiz
state "EditingQuiz" as EditingQuiz
state "ViewingQuizResults" as ViewingResults
state "SelectingQuiz" as SelectingQuiz
state "AnsweringQuiz" as AnsweringQuiz
state "SubmittingQuiz" as SubmittingQuiz
state "ViewingResult" as ViewingResult

Start --> LoggedIn : login/register

LoggedIn --> TeacherMenu : choose teacher role
LoggedIn --> StudentMenu : choose student role

TeacherMenu --> CreatingQuiz : create new quiz
TeacherMenu --> EditingQuiz : edit existing quiz
TeacherMenu --> ViewingResults : view results
TeacherMenu --> LoggedIn : logout

CreatingQuiz --> TeacherMenu : save as draft
CreatingQuiz --> TeacherMenu : post quiz

EditingQuiz --> TeacherMenu : save changes
EditingQuiz --> TeacherMenu : discard changes

ViewingResults --> TeacherMenu : back to menu

StudentMenu --> SelectingQuiz : select quiz

SelectingQuiz --> AnsweringQuiz : select a quiz

AnsweringQuiz --> SubmittingQuiz : submit quiz

SubmittingQuiz --> StudentMenu : cancel submission
SubmittingQuiz --> ViewingResult : submit completed

ViewingResult --> StudentMenu : back to menu

[*] <-- LoggedIn : logout
[*] <-- ViewingResult : system ends
[*] <-- SubmittingQuiz : system ends
[*] <-- AnsweringQuiz : system ends
[*] <-- SelectingQuiz : system ends
[*] <-- ViewingResults : system ends
[*] <-- EditingQuiz : system ends
[*] <-- CreatingQuiz : system ends
[*] <-- TeacherMenu : system ends
[*] <-- StudentMenu : system ends

@enduml
