@startuml
title Inventory Management State Transition Diagram

[*] --> Start

state Start
state AddGoods
state UpdatePrice
state RemoveGoods
state CheckExpiry
state PlaceOrder
state GenerateInvoice
state SearchItems
state CalculateDiscountTax
state GenerateReceipt
state ReplaceCancelReceipt
state RecordRequest
state GenerateReport

Start --> AddGoods : Add new goods
AddGoods --> Start

Start --> UpdatePrice : Update price
UpdatePrice --> Start

Start --> RemoveGoods : Remove goods
RemoveGoods --> Start

Start --> CheckExpiry : Check expiry
CheckExpiry --> Start

Start --> PlaceOrder : Place order
PlaceOrder --> GenerateInvoice
GenerateInvoice --> Start

Start --> SearchItems : Search items
SearchItems --> CalculateDiscountTax
CalculateDiscountTax --> GenerateReceipt
GenerateReceipt --> Start

GenerateReceipt --> ReplaceCancelReceipt : Replace/cancel
ReplaceCancelReceipt --> Start

Start --> RecordRequest : Record request
RecordRequest --> Start

Start --> GenerateReport : Generate report
GenerateReport --> Start

@enduml
