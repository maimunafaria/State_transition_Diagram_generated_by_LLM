@startuml
title UML State Chart Diagram

state "Homepage" as Homepage
state "Projects" as Projects
state "View Photos" as ViewPhotos
state "View Videos" as ViewVideos
state "Career Info" as CareerInfo
state "View Updates" as ViewUpdates
state "Apply" as Apply
state "Job Application" as JobApplication
state "Application Checked" as ApplicationChecked

Homepage --> Projects : Navigation
Homepage --> CareerInfo : Navigation
Homepage --> Contact : Navigation

Projects --> ViewPhotos : Select Photos
Projects --> ViewVideos : Select Videos
ViewPhotos --> Projects : Back
ViewVideos --> Projects : Back

CareerInfo --> ViewUpdates : Select Updates
CareerInfo --> Apply : Submit Application
Apply --> JobApplication : Submit
JobApplication --> ApplicationChecked : Check

ApplicationChecked --> [*]

Contact --> [*]

@enduml
