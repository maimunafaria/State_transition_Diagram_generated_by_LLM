@startuml
[*] --> LoggedIn
LoggedIn --> Dashboard

state LoggedIn {
  Dashboard --> MarketConditions : check market conditions
  MarketConditions --> MarketReport : show market report

  Dashboard --> PestControlHelp : choose pest control help
  PestControlHelp --> PhotoRequired : require photo
  PhotoRequired --> PestControlTechniques : show techniques

  Dashboard --> SoilInfo : receive soil information
  SoilInfo --> Suggestions : provide suggestions

  Dashboard --> WeatherInsights : offer weather insights
  Dashboard --> LabourAvailability : display labour availability details

  Dashboard --> Results : show any of the results
  Results --> Continue : allow to continue using service

  LoggedIn --> [*] : logout
}
@enduml
