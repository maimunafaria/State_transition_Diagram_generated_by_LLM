@startuml
title Digidoclocker System States

[*] --> Registration

state "Registration" as Registration
state "Login" as Login
state "Document Upload" as DocumentUpload
state "Profile View" as ProfileView
state "Certificate Application" as CertificateApplication
state "Reapply for Certificate" as ReapplyCertificate
state "Request Certificate" as RequestCertificate
state "End Session" as EndSession

Registration : entry / citizen registration
Registration : do / validate citizen details
Registration : exit / citizen registered

Registration --> Login : [registration successful]

Login : entry / citizen login
Login : do / validate login details
Login : exit / login successful

Login --> DocumentUpload : [login successful]
Login --> ProfileView : [login successful]
Login --> CertificateApplication : [login successful]

DocumentUpload : entry / citizen upload documents
DocumentUpload : do / upload documents
DocumentUpload : exit / documents uploaded

DocumentUpload --> CertificateApplication : [documents uploaded]

CertificateApplication : entry / citizen apply for certificate
CertificateApplication : do / apply for certificate
CertificateApplication : exit / certificate applied

CertificateApplication --> ReapplyCertificate : [certificate applied]

ReapplyCertificate : entry / citizen reapply for certificate
ReapplyCertificate : do / reapply for certificate
ReapplyCertificate : exit / certificate reapplied

ReapplyCertificate --> CertificateApplication : [reapply successful]

RequestCertificate : entry / registrar request certificate
RequestCertificate : do / request certificate
RequestCertificate : exit / certificate requested

RequestCertificate --> CertificateApplication : [certificate requested]

CertificateApplication --> EndSession : [certificate applied]

EndSession --> [*]

@enduml
