@startuml
title Process Sale State Machine

[*] --> WaitingForSale

state WaitingForSale
state AddingItems
state Payment
state Completed
state VerifyingPayment

WaitingForSale --> AddingItems : new sale
AddingItems --> Payment : all items added
Payment --> Completed : cash payment
Payment --> VerifyingPayment : card or check payment

VerifyingPayment --> Completed : payment approved
Completed --> WaitingForSale : payment finished
Completed --> [*] : payment finished

@enduml
