@startuml
title ATM State Machine

state "Idle" as Idle
state "Select Amount" as SelectAmount
state "Custom Amount" as CustomAmount
state "Cancel Transaction" as CancelTransaction
state "Transaction Completed" as TransactionCompleted

[*] --> Idle : entry/To action

Idle --> SelectAmount : selectAmountButtonClicked()

SelectAmount --> SelectAmount : predefinedAmountSelected()
SelectAmount --> CustomAmount : customAmountSelected()

CustomAmount --> SelectAmount : cancelButtonClicked()
CustomAmount --> TransactionCompleted : confirmButtonClicked()

SelectAmount --> TransactionCompleted : confirmButtonClicked()

CancelTransaction --> Idle : cancelButtonClicked()

TransactionCompleted --> CancelTransaction : cancelButtonClicked()  // added transition
TransactionCompleted --> [*] : exit/To action

@enduml
