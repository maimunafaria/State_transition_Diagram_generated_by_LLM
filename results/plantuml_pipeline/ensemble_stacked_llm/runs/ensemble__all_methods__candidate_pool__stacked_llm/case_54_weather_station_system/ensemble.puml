@startuml
title Weather Station System State Diagram

[*] --> Shutdown : Power Failure / Shutdown Command

state Shutdown {
  Shutdown --> Running : Restart / Start
}

state Running {
  Running --> ConfigurationMode : Changes or Power-Saving Settings Required
  Running --> ControlledMode : Remote Control Command
  Running --> Shutdown : Shutdown Command
  Running --> DataCollection : Clock Triggered (Data Collection)
  Running --> SummaryPreparation : Request for Weather Summary
  Running --> StatusChecking : Request for Status Check
}

state ConfigurationMode {
  ConfigurationMode --> Running : Configuration Completed
}

state ControlledMode {
  ControlledMode --> Running : Exit Controlled Mode
}

state DataCollection {
  DataCollection --> Running : Activity Completed
}

state SummaryPreparation {
  SummaryPreparation --> Running : Summary Prepared and Sent
}

state StatusChecking {
  StatusChecking --> Running : Status Checked and Transmitted
}

Shutdown --> [*] : System Shut Down

@enduml
