@startuml
[*] --> ShutDown

state ShutDown {
  ShutDown --> Running : Restart / Start
}

state ConfigurationMode {
  Running --> ConfigurationMode : Changes or Power-Saving Settings Required
  ConfigurationMode --> Running : Configuration Completed
}

state ControlledMode {
  Running --> ControlledMode : Remote Control / Move to Controlled Mode
  ControlledMode --> Running : Return to Running State
}

state Running {
  Running --> DataCollection : Clock Triggered / Data Collection
  Running --> SummaryPreparation : Request for Weather Summary / Prepare and Send
  Running --> StatusChecking : Request for Status / Check and Transmit
  Running --> Shutdown : Shutdown Command / Shut Down
  DataCollection --> Running : Activity Completed
  SummaryPreparation --> Running : Summary Prepared
  StatusChecking --> Running : Status Checked
}

Shutdown --> [*] : System shut down

@enduml
