@startuml
title UML State Machine Diagram - BPO Management System Search

[*] --> ChoiceSearch

state ChoiceSearch <<choice>>
ChoiceSearch --> FilterCategory : [select filter category]
ChoiceSearch --> PriceRange : [select price range]

FilterCategory --> ProcessCriteria : [search based on category]
PriceRange --> ProcessCriteria : [search based on price range]

state "Process Criteria" as ProcessCriteria
ProcessCriteria --> DisplayResults

state "Display Results" as DisplayResults
DisplayResults --> End : [satisfied]
DisplayResults --> ChoiceSearch : [not satisfied]

state End <<choice>>
End --> [*] : [satisfied]
End --> ChoiceSearch : [not satisfied]

@enduml
