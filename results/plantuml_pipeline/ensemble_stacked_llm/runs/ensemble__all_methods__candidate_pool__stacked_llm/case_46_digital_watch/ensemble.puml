@startuml
[*] --> Idle

state "Idle" as Idle {
  Idle --> HourMode : press hour button
  Idle --> MinuteMode : press minute button
  Idle --> AlarmHourMode : press alarm hour button
  Idle --> AlarmMinuteMode : press alarm minute button
  Idle --> AlarmOn : press alarm on button
  Idle --> LightOn : press light on button
}

state "Hour Mode" as HourMode {
  HourMode --> MinuteMode : press minute button
  HourMode --> IncreaseValue : press increase button
  HourMode --> Idle : press hour button
}

state "Minute Mode" as MinuteMode {
  MinuteMode --> AlarmHourMode : press alarm hour button
  MinuteMode --> IncreaseValue : press increase button
  MinuteMode --> HourMode : press hour button
}

state "Alarm Hour Mode" as AlarmHourMode {
  AlarmHourMode --> AlarmMinuteMode : press alarm minute button
  AlarmHourMode --> IncreaseValue : press increase button
  AlarmHourMode --> HourMode : press hour button
}

state "Alarm Minute Mode" as AlarmMinuteMode {
  AlarmMinuteMode --> Idle : press hour button
  AlarmMinuteMode --> HourMode : press minute button
  AlarmMinuteMode --> AlarmHourMode : press alarm hour button
  AlarmMinuteMode --> AlarmMinuteMode : press increase button
}

state "Increase Value" as IncreaseValue {
  IncreaseValue --> HourMode : increase value
  IncreaseValue --> MinuteMode : increase value
  IncreaseValue --> AlarmHourMode : increase value
  IncreaseValue --> AlarmMinuteMode : increase value
}

state "Alarm On" as AlarmOn {
  AlarmOn --> AlarmOff : press alarm off button
  AlarmOn --> AlarmRinging : current time matches alarm time
}

state "Alarm Off" as AlarmOff {
  AlarmOff --> Idle : press alarm on button
}

state "Alarm Ringing" as AlarmRinging {
  AlarmRinging --> AlarmOff : press stop alarm button
}

state "Light On" as LightOn {
  LightOn --> LightOff : light button released
}

state "Light Off" as LightOff {
  LightOff --> Idle : light button pressed
}

Idle --> [*]
AlarmRinging --> [*]

@enduml
