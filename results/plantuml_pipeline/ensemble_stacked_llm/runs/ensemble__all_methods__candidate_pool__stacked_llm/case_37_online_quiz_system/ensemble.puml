@startuml
title Online Quiz System State Diagram

state "Register/Login" as RegisterLogin
state "Choose Role" as ChooseRole
state "Teacher Mode" as TeacherMode
state "Create/Edit Quiz" as CreateEditQuiz
state "Save/Post Quiz" as SavePostQuiz
state "View Results" as ViewResults
state "Student Mode" as StudentMode
state "Select Quiz" as SelectQuiz
state "Answer Quiz" as AnswerQuiz
state "Submit Quiz" as SubmitQuiz
state "View Result" as ViewResult

[*] --> RegisterLogin

RegisterLogin --> ChooseRole : [Valid Credentials]

ChooseRole --> TeacherMode : [Teacher]
ChooseRole --> StudentMode : [Student]

TeacherMode --> CreateEditQuiz : [Create/Edit Quiz]
TeacherMode --> SavePostQuiz : [Save/Post Quiz]
TeacherMode --> ViewResults : [View Results]
TeacherMode --> RegisterLogin : [Logout]

CreateEditQuiz --> SavePostQuiz
SavePostQuiz --> ViewResults

StudentMode --> SelectQuiz : [Select Quiz]
SelectQuiz --> AnswerQuiz : [Answer Quiz]
AnswerQuiz --> SubmitQuiz : [Submit Quiz]
SubmitQuiz --> ViewResult : [View Result]
ViewResult --> StudentMode : [Return to Home]

[*] <-- RegisterLogin : [Logout]
@enduml
