@startuml
title UML State Chart Diagram for Campaign Version 2

[*] --> Initial

state Initial {
    Initial --> AssignStaffManager : Start Campaign
}

state AssignStaffManager {
    AssignStaffManager --> ApproveSignContract : Manager and Staff Assigned
}

state ApproveSignContract {
    ApproveSignContract --> PrepareAdverts : Everything Approved and Contract Signed
}

state PrepareAdverts {
    PrepareAdverts --> ApproveScheduleAdverts : Adverts Prepared
}

state ApproveScheduleAdverts {
    ApproveScheduleAdverts --> RunAdverts : Adverts Approved and Scheduled
}

state RunAdverts {
    RunAdverts --> ExtendAdjustCampaign : Campaign Extension or Adjustment Requested
    RunAdverts --> CompleteCampaign : All Adverts Finished
}

state ExtendAdjustCampaign {
    ExtendAdjustCampaign --> RunAdverts : [Extension or Adjustment Needed]
}

state CompleteCampaign {
    CompleteCampaign --> FinalStatement : Campaign Completed
}

state FinalStatement {
    FinalStatement --> PaymentHandling : Prepare Final Statement
}

state PaymentHandling {
    PaymentHandling --> RefundGenerated : Amount Paid Less Than Required
    PaymentHandling --> AwaitingBalance : Amount Paid More Than Required
    PaymentHandling --> PaymentCompleted : Full Amount Paid
}

state RefundGenerated {
    RefundGenerated --> CampaignArchiving : Archive Campaign
}

state AwaitingBalance {
    AwaitingBalance --> PaymentCompleted : Correct Balance Settled
}

state PaymentCompleted {
    PaymentCompleted --> CampaignArchiving : Mark Campaign as Paid
}

state CampaignArchiving {
    CampaignArchiving --> Final : Staff and Managers Released
}

state Final {
    Final --> [*]
}

@enduml
