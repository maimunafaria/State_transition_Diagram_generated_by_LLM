@startuml
title UML State Chart Diagram for Campaign Version 2

state "Initial" as Initial
state "Assign Staff and Manager" as AssignStaffManager
state "Approve and Sign Contract" as ApproveSignContract
state "Prepare Adverts" as PrepareAdverts
state "Approve and Schedule Adverts" as ApproveScheduleAdverts
state "Run Adverts" as RunAdverts
state "Extend or Adjust Campaign" as ExtendAdjustCampaign
state "Complete Campaign" as CompleteCampaign
state "Final Statement" as FinalStatement
state "Payment Handling" as PaymentHandling
state "Payment Completed" as PaymentCompleted
state "Campaign Archiving" as CampaignArchiving
state "Final" as Final

[*] --> Initial

Initial --> AssignStaffManager

AssignStaffManager --> ApproveSignContract

ApproveSignContract --> PrepareAdverts

PrepareAdverts --> ApproveScheduleAdverts

ApproveScheduleAdverts --> RunAdverts

RunAdverts --> ExtendAdjustCampaign : [Extension or Adjustment Needed]

ExtendAdjustCampaign --> RunAdverts : [Continue Running]

RunAdverts --> CompleteCampaign : [All Adverts Finished]

CompleteCampaign --> FinalStatement

FinalStatement --> PaymentHandling

PaymentHandling --> PaymentCompleted : [Full Amount Paid]
PaymentHandling --> CampaignArchiving : [Amount Paid Exceeds Required]

PaymentCompleted --> Final
CampaignArchiving --> Final

Final --> [*]

@enduml
