@startuml
title Process Sale State Machine

[*] --> WaitingForSale

state "Waiting for sale" as WaitingForSale
state "Enter items one by one" as EnterItems
state "Move to payment" as Payment
state "Complete sale with cash" as CompleteCash
state "Verify payment with card or check" as VerifyPayment
state "Complete sale" as CompleteSale
state "Return to waiting" as ReturnWait

WaitingForSale --> EnterItems : new sale
EnterItems --> EnterItems : add item
EnterItems --> Payment : end of sale
Payment --> CompleteCash : cash
Payment --> VerifyPayment : card or check
VerifyPayment --> CompleteSale : payment approved
CompleteSale --> ReturnWait : payment finished
CompleteCash --> ReturnWait : payment finished
ReturnWait --> WaitingForSale : next customer

@enduml
