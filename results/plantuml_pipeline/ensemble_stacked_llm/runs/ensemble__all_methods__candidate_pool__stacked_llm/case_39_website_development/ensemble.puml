@startuml
title UML State Machine Diagram - Website Development

state "Homepage" as Homepage
state "Projects" as Projects
state "View Photos" as ViewPhotos
state "Watch Videos" as WatchVideos
state "Career Opportunities" as CareerOpportunities
state "View Updates" as ViewUpdates
state "Open Application Form" as OpenApplicationForm
state "Job Application Status" as JobApplicationStatus

Homepage --> Projects : Navigation Bar Click
Projects --> ViewPhotos : Select Photos
Projects --> WatchVideos : Select Videos
ViewPhotos --> Projects : Back to Project Details
WatchVideos --> Projects : Back to Project Details

Homepage --> CareerOpportunities : Navigation Bar Click
CareerOpportunities --> ViewUpdates : View Updates
CareerOpportunities --> OpenApplicationForm : Submit Application
OpenApplicationForm --> JobApplicationStatus : Submit
JobApplicationStatus --> [*] : Check Submitted Applications

@enduml
