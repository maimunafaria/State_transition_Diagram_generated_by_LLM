@startuml
[*] --> CreateUser

state CreateUser {
  CreateUser --> Login : login
}

state Login {
  Login --> LoggedIn : valid
  Login --> CreateUser : invalid
}

state LoggedIn {
  [*] --> Dashboard
  Dashboard --> ApplyForVisa : apply for visa
  ApplyForVisa --> PaymentConfirmed : payment confirmed
  PaymentConfirmed --> ApplicationAccepted : application accepted
  ApplicationAccepted --> ViewStatus : view status
  ViewStatus --> CheckStatus : check status
  CheckStatus --> CancelApplication : cancel application
  CheckStatus --> ModifyDetails : modify details
  CheckStatus --> ViewPurpose : view purpose
  CancelApplication --> LoggedOut : log out
  ModifyDetails --> ViewDetails : view details
  ViewDetails --> GiveFeedback : give feedback
  ViewPurpose --> GiveFeedback : give feedback
  ViewPurpose --> ViewStatus : view status
  GiveFeedback --> LoggedOut : log out
}

state LoggedOut {
  LoggedOut --> [*]
}
@enduml
