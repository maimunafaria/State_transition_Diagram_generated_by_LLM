@startuml
[*] --> CreateUser

state "Create User" as CreateUser {
  CreateUser --> Login : Create Account
}

state "Login" as Login {
  Login --> CreateUser : Invalid Credentials
  Login --> LoggedIn : Valid Credentials
}

state "Logged In" as LoggedIn {
  LoggedIn --> Dashboard : Open Dashboard
  Dashboard --> ApplyForVisa : Apply For Visa
  Dashboard --> ViewStatus : View Status
  Dashboard --> ModifyDetails : Modify Details
  Dashboard --> ViewDetails : View Details
  Dashboard --> GiveFeedback : Give Feedback
}

state "Apply for Visa" as ApplyForVisa {
  ApplyForVisa --> PaymentConfirmed : Make Payment
  PaymentConfirmed --> ApplicationAccepted : Payment Successful
  PaymentConfirmed --> LoggedIn : Payment Failed
}

state "Application Accepted" as ApplicationAccepted {
  ApplicationAccepted --> ViewStatus : View Status
}

state "View Status" as ViewStatus {
  ViewStatus --> CheckStatus : Check Status
  ViewStatus --> CancelApplication : Cancel Application
  ViewStatus --> ModifyDetails : Modify Details
  ViewStatus --> ViewDetails : View Details
}

state "Check Status" as CheckStatus {
  CheckStatus --> ViewStatus : Back to View Status
  CheckStatus --> GiveFeedback : Give Feedback
}

state "Cancel Application" as CancelApplication {
  CancelApplication --> LoggedIn : Log Out
}

state "Modify Details" as ModifyDetails {
  ModifyDetails --> ViewDetails : View Details
  ModifyDetails --> ViewStatus : View Status
}

state "View Details" as ViewDetails {
  ViewDetails --> ViewPurpose : View Purpose of Application
  ViewDetails --> GiveFeedback : Give Feedback
  ViewDetails --> ViewStatus : View Status
}

state "View Purpose" as ViewPurpose {
  ViewPurpose --> GiveFeedback : Give Feedback
  ViewPurpose --> ViewStatus : View Status
}

state "Give Feedback" as GiveFeedback {
  GiveFeedback --> LoggedIn : Log Out
}

LoggedIn --> Logout : Log Out

state "Logout" as Logout {
  Logout --> [*] : End
}

@enduml
