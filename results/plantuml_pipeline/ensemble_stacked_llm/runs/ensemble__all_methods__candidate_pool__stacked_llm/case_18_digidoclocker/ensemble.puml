@startuml
[*] --> Registration

state Registration
Registration : entry / Get User Details
Registration : do / Validate Details
Registration : exit / Valid or Invalid

Registration --> Login : [Valid Registration]
Registration --> [*] : [Invalid Registration]

state Login
Login : entry / Get Login Details
Login : do / Validate Login Details
Login : exit / Valid or Invalid

Login --> Choice1 : [Valid Login]

state Choice1 <<choice>>
Choice1 --> UploadDocuments : [Upload Documents]
Choice1 --> ViewProfile : [View Profile]
Choice1 --> ApplyCert : [Apply for Certificate]
Choice1 --> ContinueUpload : [Continue Uploading]
Choice1 --> ChoiceRegistrar : [Registrar]

state UploadDocuments
UploadDocuments : entry / Upload Document
UploadDocuments : do / Process Upload
UploadDocuments : exit / Proceed or Continue

UploadDocuments --> Choice1 : [Proceed]
UploadDocuments --> ContinueUpload : [Continue]

state ContinueUpload
ContinueUpload : entry / Continue Upload
ContinueUpload : do / Process Upload
ContinueUpload : exit / Proceed

ContinueUpload --> Choice1 : [Done]

state ViewProfile
ViewProfile : entry / View Profile
ViewProfile : do / Display Profile
ViewProfile : exit / Exit from Profile Viewing

ViewProfile --> EndMerge : [End]

state ApplyCert
ApplyCert : entry / Apply for Certificate
ApplyCert : do / Process Application
ApplyCert : exit / Issue or Reapply

ApplyCert --> IssueCertificate : [Certificate Issued]
ApplyCert --> Choice1 : [Reapply]

state IssueCertificate
IssueCertificate : entry / Issue Certificate
IssueCertificate : do / Process Issue
IssueCertificate : exit / Done

IssueCertificate --> Choice1 : [Done]

state ChoiceRegistrar <<choice>>
ChoiceRegistrar --> RequestCertificate : [Request Certificate]

state RequestCertificate
@enduml
