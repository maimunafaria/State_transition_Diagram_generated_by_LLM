@startuml
title ATM Withdrawal State Machine

state "Initial" as Initial
state "Select Amount" as SelectAmount
state "Predefined Amount Selected" as PredefinedSelected
state "Custom Amount Entered" as CustomEntered
state "Confirm Withdrawal" as ConfirmWithdrawal
state "Cancel Transaction" as CancelTransaction
state "Dispense Cash" as DispenseCash
state "Return Card" as ReturnCard

Initial --> SelectAmount : Start transaction

SelectAmount --> PredefinedSelected : Select predefined amount
SelectAmount --> CustomEntered : Enter custom amount
SelectAmount --> CancelTransaction : Cancel

PredefinedSelected --> ConfirmWithdrawal : Confirm
CustomEntered --> ConfirmWithdrawal : Confirm
ConfirmWithdrawal --> DispenseCash : Approved
ConfirmWithdrawal --> ReturnCard : Rejected

DispenseCash --> ReturnCard : Cash dispensed

CancelTransaction --> ReturnCard : Stop transaction

ReturnCard --> Initial : End transaction

@enduml
