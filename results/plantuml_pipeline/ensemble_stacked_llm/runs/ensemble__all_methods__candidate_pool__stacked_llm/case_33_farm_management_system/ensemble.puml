@startuml
title Farm Management System

[*] --> Login

state Login {
  Login : entry / user provide Login Details
  Login : do / verify Login Details
  Login : exit / login Successful
}

Login --> LoggedIn : [valid]
Login --> InvalidLogin : [invalid]

state "Invalid Login" as InvalidLogin
InvalidLogin : entry / wrong Info
InvalidLogin : do / display Error message
InvalidLogin : exit / return To Start

InvalidLogin --> Login

state LoggedIn <<choice>> {
  LoggedIn --> MainArea : User Signs In
}

state MainArea <<choice>> {
  MainArea --> MarketConditions : Select Market Conditions
  MainArea --> PestControlHelp : Select Pest Control Help
  MainArea --> SoilSuggestions : Provide Soil Information
  MainArea --> WeatherInsights : Provide Location
  MainArea --> LabourAvailability : Provide Location
  MainArea --> ContinueService : Continue Using Service
  MainArea --> Logout : User Logs Out
}

state MarketConditions <<choice>> {
  MarketConditions --> MarketReport : View Market Report
  MarketConditions --> MainArea : Back to MainMenu
}

state MarketReport {
  MarketReport --> MainArea
}

state PestControlHelp <<choice>> {
  PestControlHelp --> PestControlTechniques : Provide Photo
  PestControlHelp --> MainArea : Back to MainMenu
}

state PestControlTechniques {
  PestControlTechniques --> MainArea
}

state SoilSuggestions <<choice>> {
  SoilSuggestions --> SoilSuggestionsResult : Receive Soil-Related Suggestions
  SoilSuggestions --> MainArea : Back to MainMenu
}

state WeatherInsights <<choice>> {
  WeatherInsights --> WeatherDetails : Receive Weather Insights
  WeatherInsights --> MainArea : Back to MainMenu
}

state LabourAvailability <<choice>> {
  LabourAvailability --> LabourDetails : Receive Labour Availability Details
  LabourAvailability --> MainArea : Back to MainMenu
}

state ContinueService <<choice>> {
  ContinueService --> MainArea : User Can Choose Options Again
}

state Logout {
  Logout --> [*]
}

@enduml
