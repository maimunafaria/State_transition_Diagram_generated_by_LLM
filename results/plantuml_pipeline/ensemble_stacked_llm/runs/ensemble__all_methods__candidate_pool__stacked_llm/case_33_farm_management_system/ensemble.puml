@startuml
title Farm Management System

[*] --> Login

state Login {
  Login --> LoggedIn : User Signs In
}

state LoggedIn <<choice>> {
  LoggedIn --> MarketConditions : Select Market Conditions
  LoggedIn --> PestControlHelp : Select Pest Control Help
  LoggedIn --> SoilSuggestions : Provide Soil Information
  LoggedIn --> WeatherInsights : Provide Location
  LoggedIn --> LabourAvailability : Provide Location
  LoggedIn --> Logout : Logout
}

state MarketConditions {
  MarketConditions --> MarketReport : View Market Report
  MarketReport --> LoggedIn : Back to Main Area
}

state PestControlHelp {
  PestControlHelp --> PestControlTechniques : User Provides Photo
  PestControlTechniques --> LoggedIn : Back to Main Area
}

state SoilSuggestions {
  SoilSuggestions --> LoggedIn : Back to Main Area
}

state WeatherInsights {
  WeatherInsights --> LoggedIn : Back to Main Area
}

state LabourAvailability {
  LabourAvailability --> LoggedIn : Back to Main Area
}

LoggedIn --> [*] : Logout

@enduml
