@startuml
title UML State Chart Diagram for Weather Monitoring System

[*] --> CreateUser

state CreateUser {
  CreateUser --> SuccessReg : registration successful
  CreateUser --> FailReg : registration unsuccessful
}

state "Successful Registration" as SuccessReg
SuccessReg : entry / registration completed
SuccessReg : do / proceed to login
SuccessReg : exit / move to login

state "Failed Registration" as FailReg
FailReg : entry / registration failed
FailReg : do / end process
FailReg : exit / return

SuccessReg --> Login

state Login {
  Login --> SuccessLogin : login successful
  Login --> FailLogin : login failed
}

state "Successful Login" as SuccessLogin
SuccessLogin : entry / login completed
SuccessLogin : do / proceed to weather check
SuccessLogin : exit / move to weather check

state "Failed Login" as FailLogin
FailLogin : entry / login failed
FailLogin : do / end process
FailLogin : exit / return

Login --> SuccessLogin
Login --> FailLogin

SuccessLogin --> WeatherCheck

state WeatherCheck {
  WeatherCheck --> LocationValid : location valid
  WeatherCheck --> LocationInvalid : location invalid
}

state "Location Valid" as LocationValid
LocationValid : entry / location validated
LocationValid : do / proceed to weather selection
LocationValid : exit / move to weather selection

state LocationInvalid {
  LocationInvalid --> [*] : end process
}

WeatherCheck --> LocationValid
WeatherCheck --> LocationInvalid

state WeatherSelection <<choice>>
LocationValid --> WeatherSelection

state SelectTemperature as Temperature
state SelectHumidity as Humidity
state SelectRainfall as Rainfall
state SelectPressure as Pressure
state SelectDewPoint as DewPoint

WeatherSelection --> Temperature : select temperature
WeatherSelection --> Humidity : select humidity
WeatherSelection --> Rainfall : select rainfall
WeatherSelection --> Pressure : select pressure
WeatherSelection --> DewPoint : select dew point

Temperature --> ShowInfo : show selected info
Humidity --> ShowInfo : show selected info
Rainfall --> ShowInfo : show selected info
Pressure --> ShowInfo : show selected info
DewPoint --> ShowInfo : show selected info

state "Show Weather Info" as ShowInfo {
  ShowInfo --> ViewDetails : view additional details
}

Temperature --> ShowInfo
Humidity --> ShowInfo
Rainfall --> ShowInfo
Pressure --> ShowInfo
DewPoint --> ShowInfo

ViewDetails --> [*] : end session
ViewDetails --> ShowInfo : no view details

ShowInfo --> ViewDetails : view additional details
ShowInfo --> [*] : no view details

Logout {
  Logout --> [*] : logout
}

@enduml
