@startuml
title Staff Member Class State Machine

[*] --> Unassigned

state Unassigned {
  Unassigned --> Assigned : Assign Staff Member
  Unassigned --> InCampaign : Add to Campaign
}

state Assigned {
  Assigned --> Unassigned : Remove Assignment
  Assigned --> InCampaign : Switch to Campaign
}

state "In Campaign" as InCampaign {
  InCampaign --> Unassigned : End Campaign
  InCampaign --> Unassigned : Remove Assignment
}

Unassigned --> Unemployed : Mark as Unemployed

state Unemployed {
  Unemployed --> Archived : Archive Record after some time
}

Archived --> [*]

@enduml
