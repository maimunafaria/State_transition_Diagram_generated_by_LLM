@startuml
title Inventory Management System State Transition Diagram

[*] --> Start : Initialization

state "Start" as Start {
    [*] --> AddNewGoods : [Add new goods]
    [*] --> UpdatePrice : [Update price]
    [*] --> RemoveGoods : [Remove goods]
    [*] --> CheckExpiry : [Check expiry]
    [*] --> PlaceOrder : [Place order]
    [*] --> GenerateInvoice : [Generate invoice]
    [*] --> SearchItems : [Search items]
    [*] --> CalculateDiscountTax : [Calculate discount and tax]
    [*] --> GenerateReceipt : [Generate receipt]
    [*] --> ReplaceCancelReceipt : [Replace/cancel receipt]
    [*] --> RecordRequest : [Record request]
    [*] --> ViewTransactions : [View transactions]
}

state "Add new goods" as AddNewGoods
state "Update price" as UpdatePrice
state "Remove goods" as RemoveGoods
state "Check expiry" as CheckExpiry
state "Place order" as PlaceOrder
state "Generate invoice" as GenerateInvoice
state "Search items" as SearchItems
state "Calculate discount and tax" as CalculateDiscountTax
state "Generate receipt" as GenerateReceipt
state "Replace/cancel receipt" as ReplaceCancelReceipt
state "Record request" as RecordRequest
state "View transactions" as ViewTransactions

AddNewGoods --> Start : [Return to start]
UpdatePrice --> Start : [Return to start]
RemoveGoods --> Start : [Return to start]
CheckExpiry --> Start : [Return to start]
PlaceOrder --> GenerateInvoice : [Generate invoice]
GenerateInvoice --> Start : [Return to start]
SearchItems --> CalculateDiscountTax : [Calculate discount and tax]
CalculateDiscountTax --> GenerateReceipt : [Generate receipt]
GenerateReceipt --> ReplaceCancelReceipt : [Replace/cancel receipt]
ReplaceCancelReceipt --> RecordRequest : [Record request]
RecordRequest --> ViewTransactions : [View transactions]
ViewTransactions --> Start : [Return to start]

@enduml
