@startuml
[*] --> PowerOnCheck

state PowerOnCheck {
  PowerOnCheck --> Ready : everything fine
  PowerOnCheck --> Problem : problem during startup
}

state Problem {
  Problem --> [*] : Stop
}

state Ready {
  Ready --> Reset : Reset
  Ready --> Activate : Activate
  Ready --> TurnOff : Turn off
  Ready --> Monitoring : Activate monitoring
}

state Monitoring {
  Monitoring --> Alarm : Sensor triggered
  Monitoring --> Monitoring : False alarm or time ends
  Monitoring --> Ready : Password entered
}

state Alarm {
  Alarm --> Monitoring : False alarm or time ends
  Alarm --> Ready : Password entered
}

state TurnOff {
  TurnOff --> Ready : Turn off
}

state Reset {
  Reset --> Ready : Reset
}

state Activate {
  Activate --> Monitoring : Activate
}

@enduml
