@startuml
title E-Ticketing For Bus State Transition Diagram

[*] --> CreateUser : Start

state CreateUser
state ValidateRegistration
state Login
state MainMenu
state CheckTicketStatus
state BookTicket
state ConfirmPayment
state ManageAccount
state Logout
state End

CreateUser --> ValidateRegistration : Submit Registration
ValidateRegistration --> Login : Successful Registration
Login --> MainMenu : Log In

MainMenu --> CheckTicketStatus : Check Status
CheckTicketStatus --> MainMenu : Back to Menu
MainMenu --> BookTicket : Book Ticket
BookTicket --> ConfirmPayment : Book Now
ConfirmPayment --> MainMenu : Payment Complete
MainMenu --> ManageAccount : Manage Account
ManageAccount --> MainMenu : Account Updated
MainMenu --> Logout : Log Out

Logout --> End : Log Out
End --> [*] : Exit System

@enduml
