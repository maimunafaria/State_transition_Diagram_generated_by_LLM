@startuml
title Plane State Transition Diagram

[*] --> Order : Acquire

state Order
state "Arrival" as Arrival
state Preparation
state Operations
state Maintenance
state "Out of Service" as OutOfService
state Historic

Order --> Arrival : plane delivered
Arrival --> Preparation : plane arrived
Preparation --> Operations : plane prepared and ready for operations
Operations --> Maintenance : no more scheduled flights or maintenance required
Maintenance --> Preparation : plane serviced and ready
Operations --> OutOfService : plane withdrawn from service
Maintenance --> OutOfService : plane withdrawn from service
OutOfService --> Historic : plane permanently withdrawn
Order --> Historic : plane permanently withdrawn

@enduml
