@startuml
title UML State Machine Diagram - Healthcare Portal

[*] --> InitialState : Start

state InitialState {
  InitialState --> Registration : Register
}

state Registration {
  Registration --> LoginSuccess : Successful Registration
  Registration --> RegistrationFailed : Failed Registration
}

state RegistrationFailed {
  RegistrationFailed --> [*] : End Access
}

state LoginSuccess {
  LoginSuccess --> SignedIn : Sign In Success
}

state SignedIn {
  SignedIn --> FacilitiesAccess : Access Facilities
  SignedIn --> ReadNewsContent : Read News/Expert Content
  SignedIn --> CheckSymptomsFitness : Check Symptoms/Fitness
  SignedIn --> PaymentProcess : Process Insurance
  SignedIn --> FeedbackCollection : Provide Feedback
  SignedIn --> Logout : Log Out
}

state FacilitiesAccess {
  FacilitiesAccess --> ContinueSession : Continue Session
  FacilitiesAccess --> FinishSession : Finish Session
}

state ReadNewsContent {
  ReadNewsContent --> ContinueSession : Continue Session
  ReadNewsContent --> FinishSession : Finish Session
}

state CheckSymptomsFitness {
  CheckSymptomsFitness --> ContinueSession : Continue Session
  CheckSymptomsFitness --> FinishSession : Finish Session
}

state PaymentProcess {
  PaymentProcess --> SelectPaymentMethod : Choose Payment Method
}

state SelectPaymentMethod {
  SelectPaymentMethod --> CashPaymentDetails : Cash Payment Selected
  SelectPaymentMethod --> InsurancePaymentProcess : Insurance Payment Selected
}

state CashPaymentDetails {
  CashPaymentDetails --> PaymentProcess : Process Payment
}

state InsurancePaymentProcess {
  InsurancePaymentProcess --> FinishSession : Complete Payment
}

state ContinueSession {
  ContinueSession --> SignedIn : Continue Session
}

state FinishSession {
  FinishSession --> FeedbackCollection : Collect Feedback
  FinishSession --> Logout : Log Out
}

state FeedbackCollection {
  FeedbackCollection --> Logout : Provide Feedback
}

state Logout {
  Logout --> [*] : End of Session
}

@enduml
