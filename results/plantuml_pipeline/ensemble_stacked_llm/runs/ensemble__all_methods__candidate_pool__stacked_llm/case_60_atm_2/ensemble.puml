@startuml
title ATM State Diagram

[*] --> Start

state Start {
    Start --> SelectAmount : select amount
    Start --> EnterAmount : enter custom amount
}

state SelectAmount
state EnterAmount
state VerifyTransaction
state ReEnterAmount
state End

SelectAmount --> VerifyTransaction : verify
EnterAmount --> VerifyTransaction : verify

VerifyTransaction --> End : accepted
VerifyTransaction --> ReEnterAmount : rejected

ReEnterAmount --> SelectAmount : re-enter amount
ReEnterAmount --> EnterAmount : re-enter amount

End --> [*]

@enduml
