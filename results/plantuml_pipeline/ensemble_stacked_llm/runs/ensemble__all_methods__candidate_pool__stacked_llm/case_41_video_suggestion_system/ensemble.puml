@startuml
title Video Suggestion System State Machine

[*] --> Idle

state Idle {
  Idle --> ReceiveRequest : receive request
}

state "Receive Request" as ReceiveRequest {
  ReceiveRequest --> IdentifyUser : identify user
}

state "Identify User" as IdentifyUser {
  IdentifyUser --> GatherVideos : gather videos
}

state "Gather Videos" as GatherVideos {
  GatherVideos --> UserProfile : get profile
  GatherVideos --> UserPreferences : get preferences
  GatherVideos --> TrendingVideos : get trending
  GatherVideos --> SimilarVideos : get similar
  GatherVideos --> PromotedVideos : get promoted
  GatherVideos --> AddingDetails : add details
}

state "Add Details" as AddingDetails {
  AddingDetails --> SendingSuggestions : send suggestions
}

state "Sending Suggestions" as SendingSuggestions {
  SendingSuggestions --> Idle : idle
}

state UserProfile {}
state UserPreferences {}
state TrendingVideos {}
state SimilarVideos {}
state PromotedVideos {}

ReceiveRequest --> IdentifyUser
IdentifyUser --> GatherVideos
GatherVideos --> AddingDetails
AddingDetails --> SendingSuggestions

SendSuggestions --> [*]

@enduml
